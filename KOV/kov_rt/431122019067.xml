						<tavatekst id="539eab4d-53f7-4348-95de-ab73035094ff">Teenuse saajalt võib võtta temale osutatava teenuse eest tasu.</tavatekst>
					</sisuTekst>
				</loige>
				<loige id="para15lg2">
