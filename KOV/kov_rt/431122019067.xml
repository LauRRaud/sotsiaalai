	<aktinimi id="5eb016ba-5358-4e0e-821c-3a20af1d8aba">
		<nimi id="2761fa54-8fd5-48a4-9b47-0c0304ebfecf">
			<pealkiri id="5517b6b7-a12b-4e78-89a7-509bebcf8105">Võlanõustamisteenuse ja teiste toetavate sotsiaalteenuste korraldamise ja osutamise kord</pealkiri>
		</nimi>
	</aktinimi>
	<sisu id="3909d1e7-e207-4a67-be7a-db3956cb7b5b">
		<preambul id="00f884c1-726f-4623-bb7e-362d16653184">
			<tavatekst id="7ab1646c-cab3-4d80-a9d0-6c4814465083">Määrus kehtestatakse kohaliku omavalitsuse korralduse seaduse § 6 lõike 1 ja § 22 lõike 1 punkti 5 ning sotsiaalhoolekande seaduse § 14 lõike 1 ja §-de 44–45 alusel.</tavatekst>
		</preambul>
		<peatykk id="1eb4e51a-09eb-42ac-af8e-f74e4e5b9abc">
			<peatykkNr id="ca95473c-a5d0-4a6e-930e-594a1fc44865">1</peatykkNr>
			<kuvatavNr id="1a1c409f-6a96-4c23-a8cb-981d3474d32e"><![CDATA[1. peatükk]]></kuvatavNr>
			<peatykkPealkiri id="5716a59e-3a83-478b-ac77-62d6a3d2cde5">Üldsätted</peatykkPealkiri>
			<paragrahv id="para1">
				<paragrahvNr id="639f16f4-da90-423e-b701-3fab2248c1d8">1</paragrahvNr>
				<kuvatavNr id="c0fbdcd3-7d9f-437b-81d2-7bf907b4257e"><![CDATA[§ 1. ]]></kuvatavNr>
				<paragrahvPealkiri id="c0fa4b82-c68f-424d-b553-fcd49d84b113">Reguleerimisala</paragrahvPealkiri>
				<loige id="para1lg1">
					<loigeNr id="5b5602f3-701d-447a-8936-d09be9bab304">1</loigeNr>
					<kuvatavNr id="83a8460e-e893-4a0d-b8d8-f9808993c1cd"><![CDATA[(1)]]></kuvatavNr>
					<sisuTekst id="4988d7a5-8cf2-4bce-9ebd-1668c59713ba">
						<tavatekst id="5a834f33-bf56-4778-bf55-fa1e3f78367e">Käesolev kord reguleerib võlanõustamisteenuse (edaspidi <i>teenus</i>) ning teiste toetavate sotsiaalteenuste (edaspidi <i>toetavad sotsiaalteenused</i>) korraldamise ja osutamise tingimused.</tavatekst>
					</sisuTekst>
				</loige>
				<loige id="para1lg2">
					<loigeNr id="7ae11ea5-97e0-4489-94ce-0faefee9a167">2</loigeNr>
					<kuvatavNr id="75037ae3-10b7-4db4-bcf6-992d1f6aaf4d"><![CDATA[(2)]]></kuvatavNr>
					<sisuTekst id="f014cb3e-6c65-48bb-aa97-d698ff266598">
						<tavatekst id="13c56a17-2820-41de-a097-4cddd2d2ac97">Teenuse ja toetavate sotsiaalteenuste osutamist korraldab Viljandi Vallavalitsuse ametiasutus (edaspidi <i>ametiasutus</i>).</tavatekst>
					</sisuTekst>
				</loige>
			</paragrahv>
			<paragrahv id="para2">
				<paragrahvNr id="ed660ac2-d3fb-4759-b5d8-664f32a3f9ae">2</paragrahvNr>
				<kuvatavNr id="9a8cc942-45f4-4864-80c0-25aafc479337"><![CDATA[§ 2. ]]></kuvatavNr>
				<paragrahvPealkiri id="22cc8997-cd83-44d0-b06c-017be573c694">Mõisted</paragrahvPealkiri>
				<loige id="para2lg1">
				<loigeNr/>
				<kuvatavNr/>
				<sisuTekst id="5f1a0006-bfc2-495a-8005-06f2286a4246">
					<tavatekst id="119ebca4-d856-487b-8413-70f9cd7999cd">Käesolevas korras kasutatakse mõisteid järgmises tähenduses:</tavatekst>
				</sisuTekst>
				<alampunkt id="para2lg1p1">
					<alampunktNr>1</alampunktNr>
					<kuvatavNr><![CDATA[1) ]]></kuvatavNr>
				<sisuTekst id="4a03f60d-3781-4611-a9da-1fb34c7ff2f2">
					<tavatekst id="b60485ee-77ad-4f02-81d7-ea4dcd46275e">teenuse ja toetavate sotsiaalteenuste taotleja – isik, kes soovib teenust saada;</tavatekst>
				</sisuTekst>
				</alampunkt>
				<alampunkt id="para2lg1p2">
					<alampunktNr>2</alampunktNr>
					<kuvatavNr><![CDATA[2) ]]></kuvatavNr>
				<sisuTekst id="ec850f60-2dfc-464c-a4fd-d7d45d5365c9">
					<tavatekst id="35f02656-c819-44a2-b0b7-0cdeced3279d">teenuse ja toetavate sotsiaalteenuste saaja – isik, kes on õigustatud teenust saama;</tavatekst>
				</sisuTekst>
				</alampunkt>
				<alampunkt id="para2lg1p3">
					<alampunktNr>3</alampunktNr>
					<kuvatavNr><![CDATA[3) ]]></kuvatavNr>
				<sisuTekst id="0d3d1275-291c-4123-a8b8-b6a6c4b8b59a">
					<tavatekst id="ec513449-4c94-4051-a298-157474c73a12">teenuse ja toetavate sotsiaalteenuste osutaja – võib olla füüsiline- või juriidiline isik, ametiasutus või tema hallatav asutus;</tavatekst>
				</sisuTekst>
				</alampunkt>
				<alampunkt id="para2lg1p4">
					<alampunktNr>4</alampunktNr>
					<kuvatavNr><![CDATA[4) ]]></kuvatavNr>
				<sisuTekst id="986bca89-986b-483d-bc5f-7f2729980c17">
					<tavatekst id="12d548f8-b623-45b9-bf57-83bd85042590">teenuse ja toetavate sotsiaalteenuste vahetu osutaja – vastava ettevalmistusega täisealine isik, kes osutab teenust vahetult;</tavatekst>
				</sisuTekst>
				</alampunkt>
				<alampunkt id="para2lg1p5">
					<alampunktNr>5</alampunktNr>
					<kuvatavNr><![CDATA[5) ]]></kuvatavNr>
				<sisuTekst id="58ee3429-efd3-4af9-a40c-d2d5903654ef">
					<tavatekst id="393e1b08-7327-4cf7-8213-dd92ee7c4a96"> seadusjärgne ülalpidaja – perekonnaseaduse § 96 mõistes abivajava isiku täisealised esimese ja teise astme ülenejad (vanemad ja vanavanemad) ja alanejad sugulased (lapsed ja lapselapsed);</tavatekst>
				</sisuTekst>
			</alampunkt>
				<alampunkt id="para2lg1p6">
					<alampunktNr>6</alampunktNr>
					<kuvatavNr><![CDATA[6) ]]></kuvatavNr>
				<sisuTekst id="c724581c-533c-4508-8f45-4010ffd6f712">
					<tavatekst id="c2a94c30-8398-49bd-8660-b675d3cd54dc">spetsialist – ametiasutuse sotsiaalvaldkonna ametnik.</tavatekst>
				</sisuTekst>
				</alampunkt>
			</loige>
			</paragrahv>
		</peatykk>
		<peatykk id="8c53aae7-c844-4864-b3e6-3610f45672fb">
			<peatykkNr id="e607bc26-e0c2-4da6-8809-83b01df46eb2">2</peatykkNr>
			<kuvatavNr id="792f1d51-508f-4a2d-b1ea-63d3100ec8b3"><![CDATA[2. peatükk]]></kuvatavNr>
			<peatykkPealkiri id="78912e71-5650-4df7-8776-85a66b3cb3d3">Võlanõustamisteenuse korraldamine ja osutamine</peatykkPealkiri>
			<paragrahv id="para3">
				<paragrahvNr id="77040f84-f10a-4a57-8914-9e413c33cf56">3</paragrahvNr>
				<kuvatavNr id="e0990a90-0cbf-4240-a055-974dbcb41b6e"><![CDATA[§ 3. ]]></kuvatavNr>
				<paragrahvPealkiri id="ac6bfde9-e88d-4e90-a442-5fdd6190d576">Teenuse eesmärk ja kirjeldus</paragrahvPealkiri>
				<loige id="para3lg1">
					<loigeNr id="0004bc17-d4cc-415f-91cc-96dbe1237d71">1</loigeNr>
					<kuvatavNr id="1c4c8978-b30f-47e5-99d9-6df77a35ca5a"><![CDATA[(1)]]></kuvatavNr>
					<sisuTekst id="17b12172-6711-40ff-a3ba-6836d97da0b2">
						<tavatekst id="4323af56-dd38-4bf4-b568-6e6abb32c0e6"> Teenuse eesmärk on abistada isikut tema varalise olukorra kindlakstegemisel, võlausaldajaga läbirääkimiste pidamisel ja nõuete rahuldamisel, vältida uute võlgnevuste tekkimist toimetulekuvõime parandamise kaudu ning lahendada muid võlgnevusega seotud probleeme.</tavatekst>
					</sisuTekst>
				</loige>
				<loige id="para3lg2">
					<loigeNr id="643e0008-7618-485c-926b-ba482dc96d2e">2</loigeNr>
					<kuvatavNr id="52cc2e12-736c-4e24-a6d7-c595c852a80b"><![CDATA[(2)]]></kuvatavNr>
					<sisuTekst id="c040416b-1a97-4c00-a285-b9e736178949">
						<tavatekst id="32f938b9-5378-463c-80e3-d54231c09fd5"> Teenuse raames loetakse võlgnevuseks olukorda, kus isikule on esitatud nõue täita võlaõiguslikust suhtest või seadusest tulenev sissenõutavaks muutunud rahaline kohustus, mida isik ei ole võimeline iseseisvalt täitma.</tavatekst>
					</sisuTekst>
				</loige>
				<loige id="para3lg3">
					<loigeNr id="27e1c590-7797-4709-a60c-f711bd3077d7">3</loigeNr>
					<kuvatavNr id="1661be8d-7597-44ec-8234-e82923380650"><![CDATA[(3)]]></kuvatavNr>
					<sisuTekst id="539b6db3-d52e-4d72-9930-9eceadf72927">
						<tavatekst id="c53a0933-3d01-4d2f-9a2f-ce48385b8337"> Teenus hõlmab isiku nõustamist, juhendamist ja edasiste võlgade tekkimise ennetamist.</tavatekst>
					</sisuTekst>
				</loige>
			</paragrahv>
			<paragrahv id="para4">
				<paragrahvNr id="4a592d16-a201-42a1-8efa-7b57d4e45d74">4</paragrahvNr>
				<kuvatavNr id="a31eb1f6-51d3-4dbf-8478-712b9bcd02ef"><![CDATA[§ 4. ]]></kuvatavNr>
				<paragrahvPealkiri id="d70ba719-1090-407d-98c8-1042d06e0efd">Teenuse sihtgrupp</paragrahvPealkiri>
				<loige id="para4lg1">
				<loigeNr/>
				<kuvatavNr/>
				<sisuTekst id="479af435-e02d-4fec-bfe1-a6b19042799b">
					<tavatekst id="a19387e1-dc19-483c-ac5b-48d6561348a7">Teenuse sihtgrupiks on Eesti rahvastikuregistri andmetel Viljandi vallas alaliselt elavad täisealised isikud, kellel on tekkinud võlgnevused ja kes vajavad nõustamist võlgadega seotud probleemide lahendamiseks ning kelle finantsmajanduslik käitumine võib edaspidi tekitada majanduslikku toimetulematust või võlgadesse sattumist.</tavatekst>
				</sisuTekst>
			</loige>
			</paragrahv>
			<paragrahv id="para5">
				<paragrahvNr id="4fbb8eb0-c58d-4a58-a81d-8a830e4cbe00">5</paragrahvNr>
				<kuvatavNr id="67ebad40-bc1e-4ad0-98a4-3128b75416e9"><![CDATA[§ 5. ]]></kuvatavNr>
				<paragrahvPealkiri id="592327bb-2301-4919-86bb-8af41ac08702">Teenuse vahetu osutaja</paragrahvPealkiri>
				<loige id="para5lg1">
				<loigeNr/>
				<kuvatavNr/>
				<sisuTekst id="bb4354f8-0eb5-4992-9218-a19c985d7306">
					<tavatekst id="337bdd83-bcdc-4b60-83e5-a9c1e3373fc4">Teenuse vahetu osutaja peab vastama sotsiaalhoolekande seaduse § 45 lõikes 1 sätestatud tingimustele.</tavatekst>
				</sisuTekst>
			</loige>
			</paragrahv>
			<paragrahv id="para6">
				<paragrahvNr id="a9e15bec-ad77-42de-8594-373e047b9007">6</paragrahvNr>
				<kuvatavNr id="2107c535-3ef1-49d2-842d-5165530ad038"><![CDATA[§ 6. ]]></kuvatavNr>
				<paragrahvPealkiri id="926a6bf8-b020-407b-a2b4-b4648542cbc3">Teenuse osutamise maht ja koht</paragrahvPealkiri>
				<loige id="para6lg1">
					<loigeNr id="9ac281cd-97eb-4193-ac37-3ec07d370ca0">1</loigeNr>
					<kuvatavNr id="72ed923d-e58e-4334-a2e2-88b7bb1b4ffc"><![CDATA[(1)]]></kuvatavNr>
					<sisuTekst id="b9845e79-19ae-4086-954c-9737ba547d85">
						<tavatekst id="234fec4e-a41b-455e-93d7-723d6149849c">Teenuse osutamise sisu, maht ja kestus sõltuvad teenuse taotleja vajadusest.</tavatekst>
					</sisuTekst>
				</loige>
				<loige id="para6lg2">
					<loigeNr id="c1309977-97ab-4339-9acb-b84101db80fa">2</loigeNr>
					<kuvatavNr id="7d491165-df40-4d9b-8638-efe289d1155d"><![CDATA[(2)]]></kuvatavNr>
					<sisuTekst id="a8c2fad8-7990-40d9-a995-7bfb80c50bf4">
						<tavatekst id="293c61d7-98c7-4b2f-b587-d4e6c5ecf60b">Teenuse osutamise koht on üldjuhul Viljandi linn ja Viljandi vald.</tavatekst>
					</sisuTekst>
				</loige>
			</paragrahv>
			<paragrahv id="para7">
				<paragrahvNr id="41564834-3a4f-4ed1-aad0-f961edc53164">7</paragrahvNr>
				<kuvatavNr id="723e0348-b920-4ffb-ad24-f69442ad51d4"><![CDATA[§ 7. ]]></kuvatavNr>
				<paragrahvPealkiri id="e72f97f1-1ee3-4f15-a488-7cf40015da36">Teenuse taotlemine</paragrahvPealkiri>
				<loige id="para7lg1">
					<loigeNr id="83ce4828-01c5-4895-b162-89c951fc6643">1</loigeNr>
					<kuvatavNr id="3a3fbcc2-15ff-4c53-8c8e-1bcce5ec136b"><![CDATA[(1)]]></kuvatavNr>
					<sisuTekst id="1c89c3dc-a339-4b58-8292-c464c80acd12">
						<tavatekst id="7683da5c-e281-470b-8791-876f3626efed">Teenuse taotleja esitab ametiasutusele taotluse teenuse saamiseks, milles märgitakse teenust vajava isiku:</tavatekst>
					</sisuTekst>
					<alampunkt id="para7lg1p1">
						<alampunktNr id="f989a377-c0cb-4270-8437-c6bf13811471">1</alampunktNr>
						<kuvatavNr id="a1b757c4-5c02-4279-b00c-86e7e3b19689"><![CDATA[1) ]]></kuvatavNr>
						<sisuTekst id="7cb05785-39bc-4c3d-aeec-30bd6929071a">
							<tavatekst id="0089237e-dd23-409f-9763-adbdb782c25d">ees- ja perekonnanimi;</tavatekst>
						</sisuTekst>
					</alampunkt>
					<alampunkt id="para7lg1p2">
						<alampunktNr id="81b5faae-c047-46d5-98eb-676f0ce857f3">2</alampunktNr>
						<kuvatavNr id="69500dab-9a4e-4523-a3fe-f279321cb953"><![CDATA[2) ]]></kuvatavNr>
						<sisuTekst id="97afcd4e-bd92-437e-b9c4-eef8c49d6820">
							<tavatekst id="084c3690-0b91-4535-8508-65d742fedb5a">elukoha aadress ja muud kontaktandmed;</tavatekst>
						</sisuTekst>
					</alampunkt>
					<alampunkt id="para7lg1p3">
						<alampunktNr id="aa1e5d5e-fa45-4e5e-b252-dc0ee2ceb4fd">3</alampunktNr>
						<kuvatavNr id="e97f31c8-9aba-46c4-8a3a-fdd621b32cb1"><![CDATA[3) ]]></kuvatavNr>
						<sisuTekst id="aae98691-bdf5-4bfe-887d-1600abc212a4">
							<tavatekst id="8005d25c-de37-4e36-b41a-db8884dabeb3">asjaolude kirjeldus;</tavatekst>
						</sisuTekst>
					</alampunkt>
					<alampunkt id="para7lg1p4">
						<alampunktNr id="a4acb1d6-5806-4440-989a-dc91d55c734c">4</alampunktNr>
						<kuvatavNr id="9ae2f570-d442-4159-950b-4d1316c122aa"><![CDATA[4) ]]></kuvatavNr>
						<sisuTekst id="6dbab3c0-32f5-4d44-ae83-419dec57e02e">
							<tavatekst id="ac64bd95-4181-41a3-a412-d6467029fb0c">sissetulek ja varaline seis, sh võlgnevused;</tavatekst>
						</sisuTekst>
					</alampunkt>
					<alampunkt id="para7lg1p5">
						<alampunktNr id="6e739bc9-f365-4297-b4a1-52def018b549">5</alampunktNr>
						<kuvatavNr id="34f2cf8a-7135-45ba-8afd-5bb805756191"><![CDATA[5) ]]></kuvatavNr>
						<sisuTekst id="b78ba314-a193-4488-936f-5551e196a9cd">
							<tavatekst id="dcb0fdd2-5f3f-4719-9fea-dedae6d41626">kinnitus andmete õigsuse kohta ning nõusolek andmete kontrollimiseks ja töötlemiseks.</tavatekst>
						</sisuTekst>
					</alampunkt>
				</loige>
				<loige id="para7lg2">
					<loigeNr id="b87e8dbd-e777-45a0-8e4b-fb5cd6228459">2</loigeNr>
					<kuvatavNr id="94c21a44-07c8-4a83-83a7-d584382c6bbe"><![CDATA[(2)]]></kuvatavNr>
					<sisuTekst id="7803ae3d-c899-4937-8a38-b28874f11ebd">
						<tavatekst id="848b63d4-3239-4361-8ed4-23f1b7824177">Teenuse vajaduse kindlakstegemiseks viib spetsialist koostöös teenuse taotlejaga ja vajadusel koostöös tema seadusjärgsete ülalpidajatega läbi teenuse taotleja abivajaduse hindamise.</tavatekst>
					</sisuTekst>
				</loige>
				<loige id="para7lg3">
					<loigeNr id="ac137869-b097-4800-b68b-835679d3441d">3</loigeNr>
					<kuvatavNr id="e969c881-043d-4d7d-a823-80e0a809ac0e"><![CDATA[(3)]]></kuvatavNr>
					<sisuTekst id="5cdf79c3-93af-4989-af4e-5a04c8816404">
						<tavatekst id="33d60063-a5bd-441d-90cf-fb1190717f5e">Spetsialist võib teenuse taotleja olukorra hindamiseks teha päringuid perekondliku, tervisliku ja majandusliku seisundi välja selgitamiseks ning vajadusel nõuda täiendavaid dokumente.</tavatekst>
					</sisuTekst>
				</loige>
				<loige id="para7lg4">
					<loigeNr id="92003ee9-eb11-421d-9a26-b5c7484b5a68">4</loigeNr>
					<kuvatavNr id="b3198e58-6d54-4262-88fa-f10ba83f1e61"><![CDATA[(4)]]></kuvatavNr>
					<sisuTekst id="6e242a0d-5e43-417f-8482-9f62d56fae74">
						<tavatekst id="3efdd8ad-817f-42c6-8e8c-4d3288718e5a">Teenuse taotlejale, kes iseseisva toimetuleku parandamiseks vajab pikaajalist ja mitmekülgset abi, rakendatakse juhtumikorralduse põhimõtet.</tavatekst>
					</sisuTekst>
				</loige>
			</paragrahv>
			<paragrahv id="para8">
				<paragrahvNr id="40a27f6a-f843-49ae-9859-2e72d59d1dd5">8</paragrahvNr>
				<kuvatavNr id="fd40045f-7334-4ae4-adf0-00613b30f4a2"><![CDATA[§ 8. ]]></kuvatavNr>
				<paragrahvPealkiri id="ff65c9e7-f1f5-4fff-9340-51fb43706675">Teenuse korraldamine, osutamine ja osutamisest keeldumine</paragrahvPealkiri>
				<loige id="para8lg1">
					<loigeNr id="e0b3cd5b-83de-4012-a531-59d036e2202f">1</loigeNr>
					<kuvatavNr id="6f3be0a5-70dd-4d22-a8df-1e4b47864187"><![CDATA[(1)]]></kuvatavNr>
					<sisuTekst id="57f92fa1-0409-4410-8f58-ee78055c62a8">
						<tavatekst id="62611f7b-7a4e-4e7a-8543-ee3841173ad6">Teenuse korraldamiseks selgitab spetsialist välja sobiva teenuse osutaja ja suunab teenuse saaja vastavale teenusele.</tavatekst>
					</sisuTekst>
				</loige>
				<loige id="para8lg2">
					<loigeNr id="4aa65586-c99f-4b41-b287-d8c5b58ef570">2</loigeNr>
					<kuvatavNr id="06f494ae-ecbe-473f-96a2-6bebdd5f2ba7"><![CDATA[(2)]]></kuvatavNr>
					<sisuTekst id="2833f05b-6e0c-4aaa-8746-3d3c83d248a7">
						<tavatekst id="ad976492-e6af-468f-b547-70bf3146c841">Teenuse osutamise, osutamisest keeldumise, muutmise ja lõpetamise otsustab spetsialist, kes hindab kaalutlusõiguse alusel taotluse põhjendatust ja taotlusele lisatud dokumente ning teeb otsuse 10 tööpäeva jooksul alates viimase nõuetekohase dokumendi saamisest.</tavatekst>
					</sisuTekst>
				</loige>
				<loige id="para8lg3">
					<loigeNr id="eb70a4e0-10b8-44c8-a582-95b235ac8730">3</loigeNr>
					<kuvatavNr id="2b4ea92b-04e6-4890-8937-c7e5544d426b"><![CDATA[(3)]]></kuvatavNr>
					<sisuTekst id="3134e882-9820-48fc-944d-b9b5bca7e9c1">
						<tavatekst id="2cc1a30f-7bf9-42ca-b2aa-ae3e1f8f9f11">Spetsialistil on vajadusel õigus suunata taotlus otsustamiseks Viljandi Vallavalitsuse alatisele sotsiaalkomisjonile (edaspidi sotsiaalkomisjon).</tavatekst>
					</sisuTekst>
				</loige>
				<loige id="para8lg4">
					<loigeNr id="2793a64c-5bfb-47e7-b117-3174e8708b8a">4</loigeNr>
					<kuvatavNr id="ba07b2fb-096e-4a33-98ef-bf6d7b5a4008"><![CDATA[(4)]]></kuvatavNr>
					<sisuTekst id="067244ef-685c-4891-8929-d402ed352160">
						<tavatekst id="30134133-54a2-437b-abd4-55d7d2c0bd78">Teenuse osutamisel võetakse arvesse teenuse saaja tervislikku seisundit, iseseisva toimetuleku võimet ning muid isiku ja tema juhtumiga seotud asjaolusid.</tavatekst>
					</sisuTekst>
				</loige>
				<loige id="para8lg5">
					<loigeNr id="f2c98084-0707-425f-b2c5-3323d3de9590">5</loigeNr>
					<kuvatavNr id="80930058-82fa-4ba0-a573-3f85b75806e9"><![CDATA[(5)]]></kuvatavNr>
					<sisuTekst id="0c5d2b85-4de4-4a0b-898b-57a426fa4df0">
						<tavatekst id="ac66658f-47f8-4ae3-81c6-0b6fb8a5b829">Teenuse osutamisest võib keelduda juhul, kui esineb vähemalt üks järgmistest asjaoludest: </tavatekst>
					</sisuTekst>
					<alampunkt id="para8lg5p1">
						<alampunktNr id="a02a9ce9-0fc0-480b-9700-cc48b9b3c3f5">1</alampunktNr>
						<kuvatavNr id="9cb4955a-5cbd-4a6b-bf5e-6d9f7e8baa98"><![CDATA[1) ]]></kuvatavNr>
						<sisuTekst id="a2b8946d-83b6-407a-b13b-c95a2e6658ca">
							<tavatekst id="4110983d-e140-4d19-81f1-71c44c6c9859">teenuse taotleja ei esita nõutud täiendavaid dokumente või ei võimalda taotluse asjaolusid kontrollida või ei paranda avalduses esinevaid puudusi määratud tähtajaks;</tavatekst>
						</sisuTekst>
					</alampunkt>
					<alampunkt id="para8lg5p2">
						<alampunktNr id="809268b2-e0d5-4d01-8f3a-049a91c0a058">2</alampunktNr>
						<kuvatavNr id="8a35012c-631a-4ca3-bb1c-8970c9bb85ac"><![CDATA[2) ]]></kuvatavNr>
						<sisuTekst id="2c31c2a9-8b5d-459d-af6a-6b93a013a84c">
							<tavatekst id="7ac23f63-35af-4948-ab40-8307ca19cbf1">teenuse taotleja ei ole ametiasutust viivitamata teavitanud teenuse saamise õigust ja teenuse osutamist mõjutavatest asjaoludest ja asjaolude muutumisest; </tavatekst>
						</sisuTekst>
					</alampunkt>
					<alampunkt id="para8lg5p3">
						<alampunktNr id="efca07d9-6e42-4b6c-994b-cf164bfa9cdf">3</alampunktNr>
						<kuvatavNr id="8e69e2e6-8d54-4149-b01e-3703ab708284"><![CDATA[3) ]]></kuvatavNr>
						<sisuTekst id="4693643e-5e75-4232-9981-79197df84c3b">
							<tavatekst id="b78961d1-26f4-48e0-9ae1-adb8aa265511">teenuse vajadust on võimalik või otstarbekas katta muude teenuste, toetavate sotsiaalteenuste või muu sotsiaalhoolekandelise abiga;</tavatekst>
						</sisuTekst>
					</alampunkt>
					<alampunkt id="para8lg5p4">
						<alampunktNr id="82c8e570-f3a3-40bd-a499-9ec482476008">4</alampunktNr>
						<kuvatavNr id="2a74e129-7bc4-4275-861c-9b6f9e3a3721"><![CDATA[4) ]]></kuvatavNr>
						<sisuTekst id="c3bdbe2a-20ec-4e19-9eed-032ae7760bed">
							<tavatekst id="81712212-799c-481e-802e-4bcb5f785748">teenuse taotleja on teadvalt andmeid varjanud või esitanud valeandmeid;</tavatekst>
						</sisuTekst>
					</alampunkt>
					<alampunkt id="para8lg5p5">
						<alampunktNr id="8dc75d21-8007-4ef5-8d6c-df8d8fbed74f">5</alampunktNr>
						<kuvatavNr id="ab84bfde-1c73-4037-8ea2-9cc3c2a56c67"><![CDATA[5) ]]></kuvatavNr>
						<sisuTekst id="eafb6b03-5fed-46f0-9529-01798d88b6de">
							<tavatekst id="13ff81e9-6694-4a70-99f8-62560df3fe23">esineb muid põhjendatud asjaolusid, mis ei anna alust teenuse osutamiseks.</tavatekst>
						</sisuTekst>
					</alampunkt>
				</loige>
			</paragrahv>
			<paragrahv id="para9">
				<paragrahvNr id="048a3896-dd57-4c21-8df8-6ab31a8f43c3">9</paragrahvNr>
				<kuvatavNr id="ddf805f7-6fd4-4721-b40e-0d1fb3dc7a71"><![CDATA[§ 9. ]]></kuvatavNr>
				<paragrahvPealkiri id="80b66575-c63a-406d-8a4a-a9f008e7a0a4">Teenuse eest tasumine</paragrahvPealkiri>
				<loige id="para9lg1">
					<loigeNr id="92261546-d1d7-44e5-a9b0-51f9cf0bde8b">1</loigeNr>
					<kuvatavNr id="ef81a805-ae3e-4e3a-9653-c3e56771b46f"><![CDATA[(1)]]></kuvatavNr>
					<sisuTekst id="2e9a15c4-32d9-4b99-bcfe-4a932b0da41f">
						<tavatekst id="60cecdf5-c33b-425c-97ff-65e08cff3ec1">Teenuse saajale on esmane nõustamine ametiasutuses üldjuhul tasuta.</tavatekst>
					</sisuTekst>
				</loige>
				<loige id="para9lg2">
					<loigeNr id="2fd2e6d3-f9ec-43b0-8246-ba849f54bbf8">2</loigeNr>
					<kuvatavNr id="1210cd93-ee4c-445a-9172-f5084c27a38d"><![CDATA[(2)]]></kuvatavNr>
					<sisuTekst id="0018f0af-42e4-4cba-97e8-878194f96d16">
						<tavatekst id="ab05df67-beef-48b5-8e11-2091cb55b357">Teenuse osutaja võib teenuse saajalt võtta osutatava teenuse eest tasu. Võetava tasu suurus oleneb teenuse mahust ja maksumusest ning teenuse saaja ja tema perekonna majanduslikust olukorrast.</tavatekst>
					</sisuTekst>
				</loige>
				<loige id="para9lg3">
					<loigeNr id="87ff0f27-5002-4239-a249-4adb17ff7c44">3</loigeNr>
					<kuvatavNr id="248e4472-982c-4368-a48e-52e08fce9cd8"><![CDATA[(3)]]></kuvatavNr>
					<sisuTekst id="51ae4747-777f-4c73-92ff-0b60a71e3ca2">
						<tavatekst id="87c69b7d-9237-468f-87bd-29d1ca84047d">Teenuse hinnakirja kehtestab teenuse osutaja.</tavatekst>
					</sisuTekst>
				</loige>
				<loige id="para9lg4">
					<loigeNr id="621271d6-1b01-4e91-a4a7-b3f5c5a575f9">4</loigeNr>
					<kuvatavNr id="af7a30cc-b350-474f-98fe-4dab6ef60415"><![CDATA[(4)]]></kuvatavNr>
					<sisuTekst id="1a04a16e-60a3-446c-91ad-ba33bfd0c5a2">
						<tavatekst id="2c30ebfb-6c0c-429a-b75f-e96219b3dbcb">Juhul, kui teenuse saaja ei ole võimeline teenuse eest täies ulatuses tasuma, on teenuse saajal õigus teha sotsiaalkomisjonile taotlus teenuse eest tasumise toetuse saamiseks.</tavatekst>
					</sisuTekst>
				</loige>
				<loige id="para9lg5">
					<loigeNr id="1908ba09-7852-4ee7-b921-d9557dabd990">5</loigeNr>
					<kuvatavNr id="abeab227-bfec-48dd-899e-c0cdc75f830c"><![CDATA[(5)]]></kuvatavNr>
					<sisuTekst id="2cc86894-74ce-4a0d-81e9-d90ee98b3eee">
						<tavatekst id="75c279ae-a85a-4666-9147-7451c79d6670">Sotsiaalkomisjon otsustab toetuse määramise ja maksmise vastavalt Viljandi Vallavolikogu 27.06.2018 määrusele nr 36 „Sotsiaaltoetuste taotlemise, määramise ja maksmise kord" 10 tööpäeva jooksul alates viimase nõuetekohase dokumendi saamisest.</tavatekst>
					</sisuTekst>
				</loige>
				<loige id="para9lg6">
					<loigeNr id="eb475b1c-e043-41ce-a2b1-09776c57c4db">6</loigeNr>
					<kuvatavNr id="aa6b7d85-3444-46e0-80c5-7c100e6f2735"><![CDATA[(6)]]></kuvatavNr>
					<sisuTekst id="9264803b-7f76-4215-ac01-7bf35cfc3749">
						<tavatekst id="e4b8fed4-80d0-47a8-a551-964cd0e779ba">Teenuse rahastamise otsusesse märgitakse vähemalt teenuse saaja nimi, teenuse maht ja maksumus.</tavatekst>
					</sisuTekst>
				</loige>
				<loige id="para9lg7">
					<loigeNr id="f05098e2-2b19-43b7-931b-59004402bb56">7</loigeNr>
					<kuvatavNr id="1307abd3-f410-4c25-8d86-13d134436376"><![CDATA[(7)]]></kuvatavNr>
					<sisuTekst id="1a855896-6adb-4e68-b189-156c67dee064">
						<tavatekst id="45ce47ff-8862-4c61-a4d1-c49504a9b817">Teenuse eest tasumise või osalise tasumise korral ametiasutuse poolt, teavitab spetsialist teenuse osutajat kirjalikku taasesitamist võimaldavas vormis teenuse mahust ja maksumusest. </tavatekst>
					</sisuTekst>
				</loige>
				<loige id="para9lg8">
					<loigeNr id="945a0d12-db96-4e13-a8be-24a2ffa23675">8</loigeNr>
					<kuvatavNr id="060fe151-07bf-424b-a772-bd7983f103fd"><![CDATA[(8)]]></kuvatavNr>
					<sisuTekst id="8fd0e795-c675-41a7-9dcb-d8f7e97b5782">
						<tavatekst id="9595a2f8-98ba-4ff9-8f88-de85d7415c77">Kui teenuse saaja või tema seadusjärgsed ülalpidajad tasuvad teenuse eest kogu ulatuses ise, võib isik teenuse ostmiseks pöörduda otse teenuse osutaja poole.</tavatekst>
					</sisuTekst>
				</loige>
			</paragrahv>
			<paragrahv id="para10">
				<paragrahvNr id="a2ad719d-4263-4b2f-ae72-ffdf00beccc2">10</paragrahvNr>
				<kuvatavNr id="23cfb833-069e-4bd9-b7c0-d5d086accad6"><![CDATA[§ 10. ]]></kuvatavNr>
				<paragrahvPealkiri id="46fe3115-a5ce-48a2-89d1-aea671035165">Teenuse osutamise lõppemine ja lõpetamine</paragrahvPealkiri>
				<loige id="para10lg1">
					<loigeNr id="2e78ceac-adac-458d-86ae-1e4ac9be8674">1</loigeNr>
					<kuvatavNr id="d132c0b8-f6da-4062-a22b-47bdec1eabc7"><![CDATA[(1)]]></kuvatavNr>
					<sisuTekst id="5457be95-0efd-47c9-b92c-27bc170744c7">
						<tavatekst id="c258c147-d552-4f6a-9242-5e0f75ebee77">Teenuse osutamise lõpetamise otsustab spetsialist või sotsiaalkomisjon:</tavatekst>
					</sisuTekst>
					<alampunkt id="para10lg1p1">
						<alampunktNr id="0edfd74c-9e25-4ce1-855a-a5d79e8e3918">1</alampunktNr>
						<kuvatavNr id="8098ed15-3237-4af2-a266-e877186a5742"><![CDATA[1) ]]></kuvatavNr>
						<sisuTekst id="345880b1-e503-4190-987b-97015dcf250a">
							<tavatekst id="097aada2-853f-4984-97b6-a2fd0784f981">teenuse vajaduse äralangemisel;</tavatekst>
						</sisuTekst>
					</alampunkt>
					<alampunkt id="para10lg1p2">
						<alampunktNr id="0d0022b2-21c9-4509-a4a2-8d8ea879be53">2</alampunktNr>
						<kuvatavNr id="f0bcd404-5b4b-4587-9684-e2b8ef1e422a"><![CDATA[2) ]]></kuvatavNr>
						<sisuTekst id="06aa7373-dc47-4f86-a167-82d5a45e1e1d">
							<tavatekst id="ea4a6564-bbc9-40c4-bf5c-0c436028fd54">teenuse saaja (sh teenuse saaja seadusliku esindaja) või teenuse osutaja taotluse alusel; </tavatekst>
						</sisuTekst>
					</alampunkt>
					<alampunkt id="para10lg1p3">
						<alampunktNr id="f0b96596-ce6d-4bf1-adb3-55b69c50ab57">3</alampunktNr>
						<kuvatavNr id="d3f05928-7596-4a35-a52b-394d6418bd69"><![CDATA[3) ]]></kuvatavNr>
						<sisuTekst id="1aafaabb-67d9-44d4-ba78-9a58e0678037">
							<tavatekst id="c736ed1b-5928-4105-86de-7206cdb9ce8f">teenuse saaja või teenuse osutaja elama asumisel teise omavalitsusüksuse haldusterritooriumile;</tavatekst>
						</sisuTekst>
					</alampunkt>
					<alampunkt id="para10lg1p4">
						<alampunktNr id="90462c8e-b15b-45e9-9162-ce2933f4ceff">4</alampunktNr>
						<kuvatavNr id="34c9ec49-ac43-4837-a4e5-48213b0d485a"><![CDATA[4) ]]></kuvatavNr>
						<sisuTekst id="69ba3bc3-9a8a-4930-a77a-4de55357d187">
							<tavatekst id="b0595bb3-b52f-404a-a7ff-d015c16b117e">kui teenuse saaja või tema seaduslik esindaja on esitanud teenuse saamiseks teadlikult valeandmeid;</tavatekst>
						</sisuTekst>
					</alampunkt>
					<alampunkt id="para10lg1p5">
						<alampunktNr id="85121079-5e98-49a3-a165-3476c737267d">5</alampunktNr>
						<kuvatavNr id="40424e44-0786-4fa1-b3fd-010b08ff2388"><![CDATA[5) ]]></kuvatavNr>
						<sisuTekst id="5d629bdd-94fe-4246-b7dc-fde70edba014">
							<tavatekst id="97c2848d-5207-4021-af96-0864ffc8a05e">muudel põhjendatud asjaoludel.</tavatekst>
						</sisuTekst>
					</alampunkt>
				</loige>
				<loige id="para10lg2">
					<loigeNr id="11947ad5-7bf5-44c4-b553-7e20f0a9d696">2</loigeNr>
					<kuvatavNr id="23deb893-6e4d-4bbc-93d9-27519a967aad"><![CDATA[(2)]]></kuvatavNr>
					<sisuTekst id="0b08e0b6-b815-4292-a364-8a5c7d313098">
						<tavatekst id="5a272c40-c86b-427e-8614-995e22bb545a">Teenuse osutamine lõpeb teenuse saaja surma korral, millest spetsialist informeerib ametiasutuse finantsvaldkonda.</tavatekst>
					</sisuTekst>
				</loige>
			</paragrahv>
		</peatykk>
		<peatykk id="41620d75-bdc8-49b1-87bd-264978a2d76f">
			<peatykkNr id="8dba3c23-cddc-4c2b-b783-74a22a78eba7">3</peatykkNr>
			<kuvatavNr id="698e1dd0-7d50-4ac8-bfd5-db28caabf304"><![CDATA[3. peatükk]]></kuvatavNr>
			<peatykkPealkiri id="a2cc81bd-586f-4c13-8724-041cfe934617">Teiste toetavate sotsiaalteenuse korraldamine ja osutamine </peatykkPealkiri>
			<paragrahv id="para11">
				<paragrahvNr id="40b18b0b-e6d2-41ae-98ca-18958f64b9dd">11</paragrahvNr>
