	<aktinimi id="a5dfc4e6-a087-4e0c-8bab-b3b9478e5674">
		<nimi id="ff0c36bf-24ed-4543-b94b-97d615c7f8d1">
			<pealkiri id="dda956f4-3ac5-4743-a897-411098d2c273">Narva linna Sotsiaalabiameti põhimäärus</pealkiri>
		</nimi>
	</aktinimi>
	<muutmismarge id="6577ebda-8e0a-4e0e-93eb-62c3fe090b87">
		<aktikuupaev id="7372538a-933d-420f-8d27-6ddba4b4daa5">2019-12-19</aktikuupaev>
		<avaldamismarge id="3b8e41d9-3da2-470d-aaaf-8b8363101a35">
			<RTosa id="bfa1731e-0a8a-4846-86cd-ffb7ef71104b">RT IV</RTosa>
			<avaldamineKuupaev id="8e0fa106-949a-45f9-ab31-6960dada7e5e">2019-12-31</avaldamineKuupaev>
