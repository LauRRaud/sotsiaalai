				<paragrahvPealkiri id="b9cb6415-594e-4933-b183-66f3bf3ec1bf">Toetavate sotsiaalteenuste sihtgrupp</paragrahvPealkiri>
				<loige id="para13lg1">
				<loigeNr/>
				<kuvatavNr/>
				<sisuTekst id="f0fdc6e0-48d6-4ec3-a136-3e0fd0dbef1e">
					<tavatekst id="b86bb191-570e-4782-a723-a71d57be087a">Toetavaid sotsiaalteenuseid on õigustatud saama isikud, kelle elukoht on Eesti rahvastikuregistri andmetel Viljandi vallas ning kes vajavad abi oma tervislikust seisundist või toimetulekust lähtuvalt igapäevaeluga hakkamasaamiseks.</tavatekst>
				</sisuTekst>
			</loige>
			</paragrahv>
			<paragrahv id="para14">
