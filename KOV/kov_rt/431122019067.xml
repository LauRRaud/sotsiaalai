				<kuvatavNr id="c191265e-1b98-4dec-9b78-aabe77a9b98a"><![CDATA[§ 14. ]]></kuvatavNr>
				<paragrahvPealkiri id="8b72a395-82aa-4fc8-b8c8-58aeaed6d66d">Toetavate sotsiaalteenuste osutamine ja korraldamine</paragrahvPealkiri>
				<loige id="para14lg1">
				<loigeNr/>
				<kuvatavNr/>
				<sisuTekst id="dcb82e52-dba2-45de-86e6-026ebc7716eb">
					<tavatekst id="67686e2d-0f40-49be-aa53-983a650525cd">Toetavale sotsiaalteenusele suunatakse üldjuhul kas spetsialisti ettepanekul või pöördub teenuse saaja ise otse teenuse osutaja poole, kui teenuse osutamine on ametiasutuse või teenuse osutaja poolt selliselt korraldatud (nt päevakeskuses pakutav pesupesemise vm teenus).</tavatekst>
				</sisuTekst>
			</loige>
			</paragrahv>
			<paragrahv id="para15">
