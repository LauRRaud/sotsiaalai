			<pealkiri id="6e4c35e2-e5ae-4912-9a36-c15eafe6fbfc">Sotsiaalteenuste osutamise kord</pealkiri>
		</nimi>
	</aktinimi>
	<sisu id="a1c6ac1a-15c7-4b9e-b376-aeeb28430df4">
		<preambul id="008346c1-60fa-47bd-85fd-31e649c912c2">
			<tavatekst id="d49ddddd-ff89-4483-a682-331a5b0ad81a">Määrus kehtestatakse kohaliku omavalitsuse korralduse seaduse § 22 lõike 1 punkti 5 ja sotsiaalhoolekande seaduse § 14 lõike 2 alusel.</tavatekst>
		</preambul>
		<paragrahv id="para1">
			<paragrahvNr id="96630eda-801f-407a-acd1-50e4e73b766c">1</paragrahvNr>
			<kuvatavNr id="725daf1d-dbd9-4d0e-80f1-dddc81423889"><![CDATA[§ 1. ]]></kuvatavNr>
			<paragrahvPealkiri id="a6caf5d8-4e10-49db-a35d-65bd3c7fbc30">Üldsätted</paragrahvPealkiri>
			<loige id="para1lg1">
				<loigeNr id="b44e0f23-b183-48c1-ac53-b4a092eca215">1</loigeNr>
				<kuvatavNr id="b3a50d20-4fca-44ef-b32f-1b65165e141f"><![CDATA[(1)]]></kuvatavNr>
				<sisuTekst id="39669c85-1d86-4f90-af37-80e41fad15e6">
					<tavatekst id="b99a5fef-1091-4f32-b902-2fd71ceea50a"> Määrusega sätestatakse Maardu linna poolt korraldatavate sotsiaalteenuste osutamise ning vältimatu sotsiaalabi andmise tingimused ja kord, kui see ei ole reguleeritud Maardu Linnavolikogu muu õigusaktiga.</tavatekst>
				</sisuTekst>
			</loige>
			<loige id="para1lg2">
				<loigeNr id="ac9eef49-5108-41cf-8bad-eed479f3008d">2</loigeNr>
				<kuvatavNr id="0498b258-f2f4-4915-b564-35b43dcf3306"><![CDATA[(2)]]></kuvatavNr>
				<sisuTekst id="967615e1-3feb-4500-bc93-3d80323395a8">
					<tavatekst id="994653d0-b027-4e9e-9a4e-8edb2cd576ce"> Sotsiaalteenuseid on õigus taotleda abivajaval isikul, kelle rahvastikuregistrisse kantud ja tegelik elukoht on Maardu linnas. Vältimatu sotsiaalabi antakse abivajavale isikule sõltumata rahvastikuregistrisse kantud elukohast.</tavatekst>
				</sisuTekst>
			</loige>
			<loige id="para1lg3">
				<loigeNr id="6317c484-ba97-49b7-b860-238b97e43e54">3</loigeNr>
				<kuvatavNr id="7ab91925-1d2b-4ae0-a776-8cdc62d975e9"><![CDATA[(3)]]></kuvatavNr>
				<sisuTekst id="15df7e0f-5814-42b1-b74f-4f992cdec0bd">
					<tavatekst id="1fa8b470-eb88-4e5e-bdf5-3dc3a8765d5b"> Määrust kohaldatakse koos sotsiaalseadustiku üldosa seaduse ja sotsiaalhoolekande seadusega ning vajadusel teiste sotsiaalkaitse korraldust ja sotsiaalkaitse tagamist reguleerivate õigusaktidega.</tavatekst>
				</sisuTekst>
			</loige>
			<loige id="para1lg4">
				<loigeNr id="27433311-1654-4bff-ba31-f8934319af2e">4</loigeNr>
				<kuvatavNr id="7c59ac09-6d61-4ef3-89c9-99a590c8693b"><![CDATA[(4)]]></kuvatavNr>
				<sisuTekst id="0d07e901-e9f6-4010-807c-e04844c54e50">
					<tavatekst id="5a7e5791-b04b-4782-b855-9577e24ccfed"> Sotsiaalseadustiku üldosa seaduse, sotsiaalhoolekande seaduse ja lastekaitseseaduse alusel kohalikule omavalitsusele pandud ning käesoleva määrusega nimetatud linna ülesandeid täidab Maardu Linnavalitsus (edaspidi linnavalitsus), kes võib otsustamise delegeerida struktuuriüksusele või ametnikule, kelle õigused ja pädevus sätestatakse linnavalitsuse sisepädevust reguleerivate aktidega. </tavatekst>
				</sisuTekst>
			</loige>
			<loige id="para1lg5">
				<loigeNr id="fc03fc51-b77c-4b12-89c9-4d2cded244ce">5</loigeNr>
				<kuvatavNr id="c090526a-3319-4c3e-b852-68af5ea522f7"><![CDATA[(5)]]></kuvatavNr>
				<sisuTekst id="772e52e4-cf37-4ee2-8492-63129a38effc">
					<tavatekst id="f86f6d09-c515-4d96-9d3e-0ffbe083adcc"> Linnavalitsus võib osutada sotsiaalteenust enda hallatava asutuse kaudu või volitada sotsiaalteenuse osutamise halduslepinguga eraõiguslikule juriidilisele või füüsilisele isikule või teise kohaliku omavalitsuse üksuse ametiasutusele.</tavatekst>
				</sisuTekst>
			</loige>
			<loige id="para1lg6">
				<loigeNr id="713c1172-05e5-42ef-8f62-3b29866d4777">6</loigeNr>
				<kuvatavNr id="b4b279e4-2e2e-4762-b579-230f8922f595"><![CDATA[(6)]]></kuvatavNr>
				<sisuTekst id="3bbf058a-4961-4730-b56f-8085f00ab9aa">
					<tavatekst id="eca20189-3f8b-418f-9e85-d46324f62a17"> Käesolevas korras kirjeldatud sotsiaalteenuste loetelu ei ole ammendav ning taotluste menetlemise kord laieneb üldiselt kõigile sotsiaalhoolekande seaduses või käesolevas määruses kirjeldatud sotsiaalteenustele ning teistele linnavalitsuse ja linnavalitsuse hallatavate asutuste osutatavatele sotsiaalteenustele, mille taotlemise ja osutamisega seonduv ei ole reguleeritud eraldi õigusaktiga. </tavatekst>
				</sisuTekst>
			</loige>
			<loige id="para1lg7">
				<loigeNr id="2f21421a-5b32-438d-b8d3-e1ae3954a678">7</loigeNr>
				<kuvatavNr id="081d47fc-2590-4983-bc20-33d8002c1b78"><![CDATA[(7)]]></kuvatavNr>
				<sisuTekst id="154a9546-db14-46e1-95ff-7bb0ebe10bf6">
					<tavatekst id="856c7dcb-2b44-4e95-a196-d70d204aecf9"> Linnavalitsus võib kehtestada sotsiaalteenuste osutamise täiendavad tingimused.</tavatekst>
				</sisuTekst>
			</loige>
		</paragrahv>
		<paragrahv id="para2">
