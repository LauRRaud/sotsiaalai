							</avaldamismarge>
							<joustumine>2023-07-01</joustumine>
						</muutmismarge>
						<paragrahv id="para136b7">
							<paragrahvNr ylaIndeks="7">136</paragrahvNr>
							<kuvatavNr><![CDATA[§ 136<sup>7</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri>Tegevusloa kehtivusaasta eest tasumine</paragrahvPealkiri>
							<loige id="para136b7lg1">
								<loigeNr/>
								<kuvatavNr/>
								<sisuTekst>
									<tavatekst>Käesoleva seaduse § 136<sup>3</sup> lõike 1 punktides 2–12, § 136<sup>4</sup> lõike 1 punktides 1–4 ja § 136<sup>5</sup> lõikes 1 nimetatud tegevusloa esimese kehtivusaasta eest tasutakse riigilõiv enne tegevusloa taotluse esitamist ning iga järgmise kehtivusaasta eest vähemalt 10 päeva enne vastava kehtivusaasta algust.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130062023001</aktViide>
									</avaldamismarge>
									<joustumine>2023-07-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
					</jaotis>
				</jagu>
