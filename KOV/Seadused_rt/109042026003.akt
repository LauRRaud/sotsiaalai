						<loige id="para333lg1">
							<sisuTekst id="9ad29348-bf82-4030-8984-21cea4a09891">
								<tavatekst id="697dfaba-12d1-4874-b2c8-8b52f94b2b3d">Sõidukikaardi taotluse läbivaatamise eest tasutakse riigilõivu 20 eurot.</tavatekst>
							</sisuTekst>
							<muutmismarge id="80d6e499-36eb-4919-a71f-7787b0cdfa19">
