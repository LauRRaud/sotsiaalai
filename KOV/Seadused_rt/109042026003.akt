								<kuvatavNr><![CDATA[§ 142<sup>33</sup>. ]]></kuvatavNr>
								<paragrahvPealkiri>Nõuete täitmise alternatiivsete meetodite kohaldamise loa taotluse läbivaatamine ja loa hoidmine</paragrahvPealkiri>
								<loige id="para142b33lg1">
									<loigeNr>1</loigeNr>
									<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Nõuete täitmise alternatiivsete meetodite kohaldamise loa taotluse läbivaatamise eest tasutakse riigilõivu 1000 eurot.</tavatekst>
									</sisuTekst>
								</loige>
								<loige id="para142b33lg2">
									<loigeNr>2</loigeNr>
									<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Nõuete täitmise alternatiivsete meetodite kohaldamise loa hoidmise eest tasutakse iga aasta kohta riigilõivu 100 eurot.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130062023001</aktViide>
										</avaldamismarge>
										<joustumine>2023-07-01</joustumine>
									</muutmismarge>
								</loige>
							</paragrahv>
							<paragrahv id="para142b34">
								<paragrahvNr ylaIndeks="34">142</paragrahvNr>
								<kuvatavNr><![CDATA[§ 142<sup>34</sup>. ]]></kuvatavNr>
								<paragrahvPealkiri>Lennundusmeditsiinikeskuse sertifikaadi väljaandmise ja muutmise taotluse läbivaatamine ning sertifikaadi hoidmine</paragrahvPealkiri>
								<loige id="para142b34lg1">
									<loigeNr>1</loigeNr>
									<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Lennundusmeditsiinikeskuse sertifikaadi taotluse läbivaatamise eest tasutakse riigilõivu 400 eurot.</tavatekst>
									</sisuTekst>
								</loige>
								<loige id="para142b34lg2">
									<loigeNr>2</loigeNr>
									<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Lennundusmeditsiinikeskuse sertifikaadi muutmise taotluse läbivaatamise eest tasutakse riigilõivu 150 eurot.</tavatekst>
									</sisuTekst>
								</loige>
								<loige id="para142b34lg3">
									<loigeNr>3</loigeNr>
									<kuvatavNr><![CDATA[(3)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Lennundusmeditsiinikeskuse sertifikaadi hoidmise eest tasutakse iga aasta kohta riigilõivu 100 eurot.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130062023001</aktViide>
										</avaldamismarge>
										<joustumine>2023-07-01</joustumine>
									</muutmismarge>
								</loige>
							</paragrahv>
							<paragrahv id="para142b35">
								<paragrahvNr ylaIndeks="35">142</paragrahvNr>
								<kuvatavNr><![CDATA[§ 142<sup>35</sup>. ]]></kuvatavNr>
								<paragrahvPealkiri>Lennundusarsti tunnistuse väljaandmise, kehtivusaja pikendamise ja muutmise ning lennundusarsti pädevuse laiendamise taotluse läbivaatamine</paragrahvPealkiri>
								<loige id="para142b35lg1">
									<loigeNr>1</loigeNr>
									<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Lennundusarsti tunnistuse taotluse läbivaatamise eest tasutakse riigilõivu 100 eurot.</tavatekst>
									</sisuTekst>
								</loige>
								<loige id="para142b35lg2">
									<loigeNr>2</loigeNr>
									<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Lennundusarsti tunnistuse kehtivusaja pikendamise ja muutmise taotluse läbivaatamise eest tasutakse riigilõivu 50 eurot.</tavatekst>
									</sisuTekst>
								</loige>
								<loige id="para142b35lg3">
									<loigeNr>3</loigeNr>
									<kuvatavNr><![CDATA[(3)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Komisjoni määruse (EL) nr 1178/2011 kohase lennundusarsti tunnistust omava lennundusarsti pädevuse laiendamise taotluse läbivaatamise eest tasutakse riigilõivu 50 eurot.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130062023001</aktViide>
										</avaldamismarge>
										<joustumine>2023-07-01</joustumine>
									</muutmismarge>
								</loige>
							</paragrahv>
