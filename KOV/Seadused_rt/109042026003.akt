								<sisuTekst id="719ca083-a1fd-48ce-9c3f-bd1f5febc20c">
									<tavatekst id="e9ff7e57-6f93-484b-bcbd-fd232977e6ca">Füüsilise isiku siduva eelotsuse taotluse läbivaatamise eest tasutakse riigilõivu 300 eurot.</tavatekst>
								</sisuTekst>
							</loige>
