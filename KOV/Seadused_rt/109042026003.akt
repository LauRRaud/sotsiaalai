						<paragrahv id="para215b1">
							<paragrahvNr ylaIndeks="1">215</paragrahvNr>
							<kuvatavNr><![CDATA[§ 215<sup>1</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri>Riigi eriplaneeringu alusel ehitatava ehitise ehitusloa taotluse läbivaatamine</paragrahvPealkiri>
							<loige id="para215b1lg1">
								<loigeNr>1</loigeNr>
								<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Riigi eriplaneeringu alusel ehitatava ehitise ehitusloa taotluse läbivaatamise eest tasutakse riigilõivu 250 eurot. Ehitise lammutamiseks vajaliku ehitusloa taotluse läbivaatamise eest tasutakse riigilõivu 60 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130122023001</aktViide>
									</avaldamismarge>
									<joustumine>2024-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para215b1lg2">
								<loigeNr>2</loigeNr>
								<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Kui ehitusloa taotlus sisaldab mitut ehitist, siis tasutakse riigilõiv iga taotluses sisalduva ehitusloakohustusliku ehitise eest eraldi.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2015-03-23</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>123032015003</aktViide>
									</avaldamismarge>
									<joustumine>2015-07-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
						<paragrahv id="para215b2">
							<paragrahvNr ylaIndeks="2">215</paragrahvNr>
							<kuvatavNr><![CDATA[§ 215<sup>2</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri>Riigi eriplaneeringu alusel ehitatava ehitise kasutusloa taotluse läbivaatamine</paragrahvPealkiri>
