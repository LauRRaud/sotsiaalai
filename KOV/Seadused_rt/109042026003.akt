									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-02-03</avaldamineKuupaev>
										<RTartikkel>2</RTartikkel>
										<aktViide>103022023002</aktViide>
									</avaldamismarge>
									<joustumine>2023-06-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
						<paragrahv id="para297b2">
							<paragrahvNr id="e4fdef18-174f-42fb-934e-da1b97e5a847" ylaIndeks="2">297</paragrahvNr>
							<kuvatavNr id="b9361fd3-0f87-4ab2-9da7-08f7c3399ac5"><![CDATA[§ 297<sup>2</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri id="3389b69a-13ee-421a-afa8-b9b2b4745a6b">Biotsiidile loa andmine</paragrahvPealkiri>
							<loige id="para297b2lg1">
								<loigeNr id="88f0bcef-db89-4288-a367-47107e6bcc24">1</loigeNr>
								<kuvatavNr id="4c1e0efe-c10f-4764-88d2-2be66eb0c595"><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst id="561f2b05-43b4-4217-85b1-d114d8a19482">
									<tavatekst id="76ab214b-9f57-42f0-922a-0b6c387b2dba">Biotsiidi või biotsiidipere loa taotluse menetlemise eest hindava liikmesriigina tasutakse riigilõivu 3300 eurot.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para297b2lg2">
								<loigeNr id="f44d62e7-d7d7-41a8-b9da-ed018f583b32">2</loigeNr>
								<kuvatavNr id="210875eb-2994-4408-9b73-ff04af4cb42a"><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst id="7006baa9-b10d-4ae2-b368-d865acee0382">
									<tavatekst id="8e01856e-a21c-4a4e-a4f5-3ca74615b145">Biotsiidi või biotsiidipere loa taotluse menetlemise eest asjaomase liikmesriigina tasutakse riigilõivu 1400 eurot.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para297b2lg3">
								<loigeNr id="6ea96535-35de-44b7-9efb-9d2beb3ab062">3</loigeNr>
								<kuvatavNr id="aa70f189-ec30-4e41-95e9-7a84416dddb2"><![CDATA[(3)]]></kuvatavNr>
								<sisuTekst id="a3debfc2-08fb-41e8-af4e-2bc6bb3f1afc">
									<tavatekst id="8d747584-45f4-48dd-b971-3989cef655ae">Biotsiidi või biotsiidipere loaga seotud teate menetlemise eest tasutakse riigilõivu 300 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-02-03</avaldamineKuupaev>
										<RTartikkel>2</RTartikkel>
										<aktViide>103022023002</aktViide>
									</avaldamismarge>
									<joustumine>2023-06-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
						<paragrahv id="para297b3">
							<paragrahvNr id="5d2e1f1d-e74f-42d3-9b72-d6ee6b3f0520" ylaIndeks="3">297</paragrahvNr>
							<kuvatavNr id="dd5e34b5-172c-4b73-827a-e13c96f71a53"><![CDATA[§ 297<sup>3</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri id="7fdff1b4-8b14-4d76-80d1-4d4068272250">Biotsiidi registreerimine üleminekuperioodil</paragrahvPealkiri>
							<loige id="para297b3lg1">
								<loigeNr id="f2623f60-002e-4a26-89e5-e7ef9cb4744d">1</loigeNr>
								<kuvatavNr id="8d0980f5-4efb-4356-a175-f211d7279405"><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst id="ec032b71-2624-4487-936a-befd18e28877">
									<tavatekst id="9e78d9b8-79c8-496c-83a9-89457bc5022f">Üleminekuperioodil biotsiidi registreerimistunnistuse taotluse menetlemise eest tasutakse riigilõivu 400 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-02-03</avaldamineKuupaev>
										<RTartikkel>2</RTartikkel>
										<aktViide>103022023002</aktViide>
									</avaldamismarge>
									<joustumine>2023-06-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para297b3lg2">
								<loigeNr id="137e2249-a796-4ddb-b6e4-838d9be4ea57">2</loigeNr>
								<kuvatavNr id="20a029ff-e06a-4680-9388-2084bd24a9b5"><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst id="7f58f20e-3eb2-465c-9a8e-d1bc7091ab85">
									<tavatekst id="47b88afd-58bf-4ceb-862b-b3bd469c24df">Üleminekuperioodil biotsiidi registreerimistunnistuse muudatuse taotluse menetlemise eest tasutakse riigilõivu 150 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge id="ca18686f-16a0-4e0f-a717-4c739321da49">
									<avaldamismarge id="dbee7004-e3a9-4537-a270-44c89c67e862">
										<RTosa id="1967d2b8-6ef6-4caf-b524-4e98848680cc">RT I</RTosa>
										<avaldamineKuupaev id="871891c9-ae80-42bc-9feb-ff1912e6763f">2015-03-10</avaldamineKuupaev>
										<RTartikkel id="fbb9a198-2445-4855-8666-068c1f6f4468">1</RTartikkel>
										<aktViide id="c170a8b8-2b68-4604-9de4-4aeee36f420d">110032015001</aktViide>
									</avaldamismarge>
									<joustumine id="cd9a5883-b92b-4595-a5be-f161c2117cc3">2015-03-20</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para297b3lg3">
								<loigeNr>3</loigeNr>
								<kuvatavNr><![CDATA[(3)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Üleminekuperioodil biotsiidi registreerimistunnistuse halduslike muudatuste taotlusega seotud toimingute eest tasutakse riigilõivu 50 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-02-03</avaldamineKuupaev>
										<RTartikkel>2</RTartikkel>
										<aktViide>103022023002</aktViide>
									</avaldamismarge>
									<joustumine>2023-06-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
					</jaotis>
					<jaotis id="jaotis121">
						<jaotisNr>6</jaotisNr>
						<kuvatavNr><![CDATA[6. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Kemikaaliseaduse alusel tehtavad toimingud</jaotisPealkiri>
						<paragrahv id="para298">
							<paragrahvNr>298</paragrahvNr>
							<kuvatavNr><![CDATA[§ 298. ]]></kuvatavNr>
							<paragrahvPealkiri>Detergentide turustamiseks erandi taotluse läbivaatamine</paragrahvPealkiri>
							<loige id="para298lg1">
								<sisuTekst>
									<tavatekst>Euroopa Parlamendi ja nõukogu määruse (EÜ) nr 648/2004 detergentide kohta (ELT L 104, 08.04.2004, lk 1–35) alusel detergendi turustamiseks erandi taotluse läbivaatamise eest tasutakse riigilõivu 710 eurot.</tavatekst>
								</sisuTekst>
							</loige>
						</paragrahv>
					</jaotis>
					<jaotis id="jaotis122">
