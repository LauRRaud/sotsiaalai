									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130062023001</aktViide>
									</avaldamismarge>
									<joustumine>2023-07-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
						<paragrahv id="para261b13">
							<paragrahvNr ylaIndeks="13">261</paragrahvNr>
							<kuvatavNr><![CDATA[§ 261<sup>13</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri>Sundlitsentsi andmine</paragrahvPealkiri>
							<loige id="para261b13lg1">
								<loigeNr/>
								<kuvatavNr/>
								<sisuTekst>
									<tavatekst>Sundlitsentsi andmise eest tasutakse riigilõivu 64 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130062023001</aktViide>
									</avaldamismarge>
									<joustumine>2023-07-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
						<paragrahv id="para261b14">
							<paragrahvNr ylaIndeks="14">261</paragrahvNr>
							<kuvatavNr><![CDATA[§ 261<sup>14</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri>Sordi registreerimine ja sordilehte võtmine</paragrahvPealkiri>
							<loige id="para261b14lg1">
								<loigeNr>1</loigeNr>
								<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Sordi registreerimise taotluse läbivaatamise eest tasutakse riigilõivu 20 eurot.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para261b14lg2">
								<loigeNr>2</loigeNr>
								<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Sordi ja geneetiliste ressursside säilitamiseks ette nähtud sordi sordilehte võtmise taotluse läbivaatamise eest tasutakse riigilõivu 25 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130062023001</aktViide>
									</avaldamismarge>
									<joustumine>2023-07-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
						<paragrahv id="para261b15">
							<paragrahvNr ylaIndeks="15">261</paragrahvNr>
							<kuvatavNr><![CDATA[§ 261<sup>15</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri>Sordi sordilehes hoidmine</paragrahvPealkiri>
							<loige id="para261b15lg1">
								<loigeNr>1</loigeNr>
								<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Teraviljakultuuri, suvirapsi ja kartuli sordi sordilehes hoidmise iga aasta eest tasutakse riigilõivu:</tavatekst>
								</sisuTekst>
								<alampunkt id="para261b15lg1p1">
									<alampunktNr>1</alampunktNr>
									<kuvatavNr><![CDATA[1)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>1.–10. aastal 30 eurot;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para261b15lg1p2">
									<alampunktNr>2</alampunktNr>
									<kuvatavNr><![CDATA[2)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>alates 11. aastast 50 eurot.</tavatekst>
									</sisuTekst>
								</alampunkt>
							</loige>
							<loige id="para261b15lg2">
								<loigeNr>2</loigeNr>
								<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Muu taimeliigi sordi sordilehes hoidmise iga aasta eest tasutakse riigilõivu 25 eurot.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para261b15lg3">
								<loigeNr>3</loigeNr>
								<kuvatavNr><![CDATA[(3)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Sordi sordilehes hoidmise riigilõiv tasutakse hiljemalt kaks kuud enne järgmise sordilehes hoidmise aasta algust.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130062023001</aktViide>
									</avaldamismarge>
									<joustumine>2023-07-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
						<paragrahv id="para261b16">
							<paragrahvNr ylaIndeks="16">261</paragrahvNr>
							<kuvatavNr><![CDATA[§ 261<sup>16</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri>Seemne ja seemnekartuli sertifitseerimine</paragrahvPealkiri>
							<loige id="para261b16lg1">
								<loigeNr>1</loigeNr>
								<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Põldtunnustamise eest tasutakse riigilõivu:</tavatekst>
								</sisuTekst>
								<alampunkt id="para261b16lg1p1">
									<alampunktNr>1</alampunktNr>
									<kuvatavNr><![CDATA[1)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>teraviljakultuuri liigi, õli- ja kiukultuuri liigi, põldoa ja -herne, peedi ning köögiviljakultuuri liigi puhul 14 eurot hektari kohta;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para261b16lg1p2">
									<alampunktNr>2</alampunktNr>
									<kuvatavNr><![CDATA[2)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>söödakultuuri liigi, välja arvatud põldoa ja -herne puhul 7 eurot hektari kohta.</tavatekst>
									</sisuTekst>
								</alampunkt>
							</loige>
							<loige id="para261b16lg2">
								<loigeNr>2</loigeNr>
								<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Seemneproovi võtmise eest tasutakse riigilõivu:</tavatekst>
								</sisuTekst>
								<alampunkt id="para261b16lg2p1">
									<alampunktNr>1</alampunktNr>
									<kuvatavNr><![CDATA[1)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>teraviljakultuuri liigi, õli- ja kiukultuuri liigi, põldoa ja -herne, peedi ning köögiviljakultuuri liigi puhul 100 eurot ühe proovi kohta ja lisaks 75 eurot iga järgmise seemneproovi võtmise eest samas ettevõttes sama proovivõtmise korra ajal;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para261b16lg2p2">
									<alampunktNr>2</alampunktNr>
									<kuvatavNr><![CDATA[2)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>söödakultuuri liigi, välja arvatud põldoa ja -herne puhul 50 eurot ühe proovi kohta ja lisaks 35 eurot iga järgmise seemneproovi võtmise eest samas ettevõttes sama proovivõtmise korra ajal.</tavatekst>
									</sisuTekst>
								</alampunkt>
							</loige>
							<loige id="para261b16lg3">
								<loigeNr>3</loigeNr>
								<kuvatavNr><![CDATA[(3)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Põldtunnustamise või proovivõtmise eest käesoleva paragrahvi lõigetes 1 ja 2 nimetamata liigi puhul või muul eesmärgil kui seemnete sertifitseerimiseks tasutakse riigilõivu lõigetes 1 ja 2 nimetatud köögiviljakultuuri liigi kohta sätestatud määra kohaselt.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para261b16lg4">
								<loigeNr>4</loigeNr>
								<kuvatavNr><![CDATA[(4)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Seemnekartuli kvaliteedi määramiseks mugulaproovi võtmise ja visuaalse analüüsimise eest tasutakse riigilõivu 55 eurot kuni viie mugulaproovi eest samas ettevõttes sama proovivõtmise ja analüüsimise korra ajal ning lisaks 10 eurot iga järgmise mugulaproovi eest samas ettevõttes sama proovivõtmise ja analüüsimise korra ajal.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130062023001</aktViide>
									</avaldamismarge>
									<joustumine>2023-07-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
					</jaotis>
					<jaotis id="jaotis95">
						<jaotisNr>2</jaotisNr>
						<kuvatavNr><![CDATA[2. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Taimekaitseseaduse alusel tehtavad toimingud</jaotisPealkiri>
						<muutmismarge>
							<avaldamismarge>
								<RTosa>RT I</RTosa>
								<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
								<RTartikkel>1</RTartikkel>
								<aktViide>130062023001</aktViide>
							</avaldamismarge>
							<joustumine>2023-07-01</joustumine>
						</muutmismarge>
						<paragrahv id="para261b17">
							<paragrahvNr ylaIndeks="17">261</paragrahvNr>
							<kuvatavNr><![CDATA[§ 261<sup>17</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri>Taimekaitsevahendi turulelaskmine</paragrahvPealkiri>
							<loige id="para261b17lg1">
								<loigeNr>1</loigeNr>
								<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Euroopa Parlamendi ja nõukogu määruse (EÜ) nr 1107/2009 taimekaitsevahendite turulelaskmise ja nõukogu direktiivide 79/117/EMÜ ja 91/414/EMÜ kehtetuks tunnistamise kohta (ELT L 309, 24.11.2009, lk 1–50) artiklis 33 nimetatud loa taotluse läbivaatamise eest tasutakse riigilõivu:</tavatekst>
								</sisuTekst>
								<alampunkt id="para261b17lg1p1">
									<alampunktNr>1</alampunktNr>
									<kuvatavNr><![CDATA[1)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>taimekaitsevahendi Eestis turulelaskmise puhul 1560 eurot;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para261b17lg1p2">
									<alampunktNr>2</alampunktNr>
									<kuvatavNr><![CDATA[2)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>taimekaitsevahendi Eestis ja teises Euroopa Liidu liikmesriigis turulelaskmise puhul 8240 eurot.</tavatekst>
									</sisuTekst>
								</alampunkt>
							</loige>
							<loige id="para261b17lg2">
								<loigeNr>2</loigeNr>
								<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Euroopa Parlamendi ja nõukogu määruse (EÜ) nr 1107/2009 artiklis 40 nimetatud loa taotluse läbivaatamise eest tasutakse riigilõivu 915 eurot.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para261b17lg3">
								<loigeNr>3</loigeNr>
								<kuvatavNr><![CDATA[(3)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Euroopa Parlamendi ja nõukogu määruse (EÜ) nr 1107/2009 artiklis 43 nimetatud loa muutmise taotluse läbivaatamise eest tasutakse riigilõivu 1650 eurot.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para261b17lg4">
								<loigeNr>4</loigeNr>
								<kuvatavNr><![CDATA[(4)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Euroopa Parlamendi ja nõukogu määruse (EÜ) nr 1107/2009 artiklis 30 nimetatud loa taotluse läbivaatamise eest tasutakse riigilõivu 1560 eurot.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para261b17lg5">
								<loigeNr>5</loigeNr>
								<kuvatavNr><![CDATA[(5)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Euroopa Parlamendi ja nõukogu määruse (EÜ) nr 1107/2009 artiklis 47 nimetatud loa taotluse läbivaatamise eest tasutakse riigilõivu 1560 eurot.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para261b17lg6">
								<loigeNr>6</loigeNr>
								<kuvatavNr><![CDATA[(6)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Euroopa Parlamendi ja nõukogu määruse (EÜ) nr 1107/2009 artiklis 52 nimetatud loa taotluse läbivaatamise eest tasutakse riigilõivu 185 eurot.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para261b17lg7">
								<loigeNr>7</loigeNr>
								<kuvatavNr><![CDATA[(7)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Euroopa Parlamendi ja nõukogu määruse (EÜ) nr 1107/2009 artiklites 30, 33, 40, 45, 47 ja 52 nimetatud loa muutmise taotluse läbivaatamise eest tasutakse riigilõivu 150 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130062023001</aktViide>
									</avaldamismarge>
									<joustumine>2023-07-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
						<paragrahv id="para261b18">
							<paragrahvNr ylaIndeks="18">261</paragrahvNr>
							<kuvatavNr><![CDATA[§ 261<sup>18</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri>Taimekaitsevahendite registri toimingud</paragrahvPealkiri>
							<loige id="para261b18lg1">
								<loigeNr/>
								<kuvatavNr/>
								<sisuTekst>
									<tavatekst>Taimekaitsevahendite turustaja, väga mürgiste taimekaitsevahendite Eestisse toimetaja ja kasutaja ning nende hoiu- ja turustamiskohtade registrisse kandmise või registrikande muutmise eest tasutakse riigilõivu 7 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130062023001</aktViide>
									</avaldamismarge>
									<joustumine>2023-07-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
						<paragrahv id="para261b19">
							<paragrahvNr ylaIndeks="19">261</paragrahvNr>
							<kuvatavNr><![CDATA[§ 261<sup>19</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri>Taimetervise registri toimingud</paragrahvPealkiri>
							<loige id="para261b19lg1">
								<loigeNr/>
								<kuvatavNr/>
								<sisuTekst>
									<tavatekst>Taimekaitseseaduse § 31 lõike 1 alusel majandustegevusteate esitamise eest tasutakse riigilõivu 32 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130062023001</aktViide>
									</avaldamismarge>
									<joustumine>2023-07-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
						<paragrahv id="para261b20">
							<paragrahvNr ylaIndeks="20">261</paragrahvNr>
							<kuvatavNr><![CDATA[§ 261<sup>20</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri>Taimepassi väljaandmine ja taimepassi väljaandmise tegevusloa taotluse läbivaatamine</paragrahvPealkiri>
							<loige id="para261b20lg1">
								<loigeNr>1</loigeNr>
								<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Euroopa Parlamendi ja nõukogu määruse (EL) 2016/2031, mis käsitleb taimekahjustajatevastaseid kaitsemeetmeid, millega muudetakse Euroopa Parlamendi ja nõukogu määruseid (EL) nr 228/2013, (EL) nr 652/2014 ja (EL) nr 1143/2014 ning millega tunnistatakse kehtetuks nõukogu direktiivid 69/464/EMÜ, 74/647/EMÜ, 93/85/EMÜ, 98/57/EÜ, 2000/29/EÜ, 2006/91/EÜ ja 2007/33/EÜ (ELT L 317, 23.11.2016, lk 4–104), artikli 79 lõike 1 punktis c ja artikli 94 lõikes 1 nimetatud taime, taimse saaduse ja muu objekti, välja arvatud sertifitseeritud seemne ja seemnekartuli kohta taimepassi väljaandmise eest tasutakse riigilõivu 5 eurot iga 100 taimepassi kohta.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para261b20lg2">
								<loigeNr>2</loigeNr>
								<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Taimepassi väljaandmise tegevusloa taotluse läbivaatamise eest tasutakse riigilõivu 270 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130062023001</aktViide>
									</avaldamismarge>
									<joustumine>2023-07-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
						<paragrahv id="para261b21">
							<paragrahvNr ylaIndeks="21">261</paragrahvNr>
							<kuvatavNr><![CDATA[§ 261<sup>21</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri>Ekspordi fütosanitaarsertifikaadiga, reekspordi fütosanitaarsertifikaadiga ja ekspordieelse fütosanitaarsertifikaadiga seotud toimingute tegemine</paragrahvPealkiri>
							<loige id="para261b21lg1">
								<loigeNr/>
								<kuvatavNr/>
								<sisuTekst>
									<tavatekst>Ekspordi fütosanitaarsertifikaadi, reekspordi fütosanitaarsertifikaadi ja ekspordieelse fütosanitaarsertifikaadi taotluse läbivaatamise eest tasutakse riigilõivu 13 eurot ning lisaks:</tavatekst>
								</sisuTekst>
								<alampunkt id="para261b21lg1p1">
									<alampunktNr>1</alampunktNr>
									<kuvatavNr><![CDATA[1)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>kuni 50 elustaime kohta 4 eurot ja iga järgmise 100 taime kohta 2 eurot;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para261b21lg1p2">
									<alampunktNr>2</alampunktNr>
									<kuvatavNr><![CDATA[2)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>kuni 1000 lõikelille ja lõikerohelise kohta 20 eurot ning iga järgmise 1000 ühiku kohta 10 eurot;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para261b21lg1p3">
									<alampunktNr>3</alampunktNr>
									<kuvatavNr><![CDATA[3)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>iga 1000 kilogrammi teravilja ja kaunvilja kohta 0,1 eurot;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para261b21lg1p4">
									<alampunktNr>4</alampunktNr>
									<kuvatavNr><![CDATA[4)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>kuni 100 kuupmeetri ümarpuidu, saematerjali, laastude, tükkide, saepuru, puidujäätmete ja puidust pakkematerjali kohta 20 eurot ning iga järgmise 100 kuupmeetri kohta 10 eurot;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para261b21lg1p5">
									<alampunktNr>5</alampunktNr>
									<kuvatavNr><![CDATA[5)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>kuni 25 000 kilogrammi kakao- ja kohviubade kohta 25 eurot ning iga järgmise 1000 kilogrammi kohta 1 euro;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para261b21lg1p6">
									<alampunktNr>6</alampunktNr>
									<kuvatavNr><![CDATA[6)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>kuni 100 kuupmeetri turba kohta 10 eurot ja üle 100 kuupmeetri turba kohta 17 eurot;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para261b21lg1p7">
									<alampunktNr>7</alampunktNr>
									<kuvatavNr><![CDATA[7)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>muude taimede, taimsete saaduste ja muude objektide kohta 40 eurot iga kaubasaadetise kohta.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130062023001</aktViide>
										</avaldamismarge>
										<joustumine>2023-07-01</joustumine>
									</muutmismarge>
								</alampunkt>
							</loige>
						</paragrahv>
						<paragrahv id="para261b22">
							<paragrahvNr ylaIndeks="22">261</paragrahvNr>
							<kuvatavNr><![CDATA[§ 261<sup>22</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri>Puidust pakkematerjali, puidu ja muu objekti vastavusmärgiga märgistamise tegevusloa taotluse läbivaatamine</paragrahvPealkiri>
							<loige id="para261b22lg1">
								<loigeNr/>
								<kuvatavNr/>
								<sisuTekst>
									<tavatekst>Puidust pakkematerjali, puidu ja muu objekti vastavusmärgiga märgistamise tegevusloa taotluse läbivaatamise eest tasutakse riigilõivu 320 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130062023001</aktViide>
									</avaldamismarge>
									<joustumine>2023-07-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
						<paragrahv id="para261b23">
							<paragrahvNr ylaIndeks="23">261</paragrahvNr>
							<kuvatavNr><![CDATA[§ 261<sup>23</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri>Puidust pakkematerjali, puidu ja muu objekti töötlemise, parandamise ning märgistamise nõuete täitmise üle järelevalve teostamine</paragrahvPealkiri>
							<loige id="para261b23lg1">
								<loigeNr/>
								<kuvatavNr/>
								<sisuTekst>
									<tavatekst>Puidust pakkematerjali, puidu ja muu objekti töötlemise ja vastavusmärgiga märgistamise ning puidust pakkematerjali parandamise nõuete täitmise üle järelevalve teostamise eest tasutakse riigilõivu 170 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130062023001</aktViide>
									</avaldamismarge>
									<joustumine>2023-07-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
						<paragrahv id="para261b24">
							<paragrahvNr ylaIndeks="24">261</paragrahvNr>
							<kuvatavNr><![CDATA[§ 261<sup>24</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri>Piiripunkti ja ametliku kontrollimise koha määramise taotluse läbivaatamine</paragrahvPealkiri>
							<loige id="para261b24lg1">
								<loigeNr/>
								<kuvatavNr/>
								<sisuTekst>
									<tavatekst>Piiripunkti ja ametliku kontrollimise koha määramise taotluse läbivaatamise eest tasutakse riigilõivu 437 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130062023001</aktViide>
									</avaldamismarge>
									<joustumine>2023-07-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
					</jaotis>
					<jaotis id="jaotis96">
						<jaotisNr>3</jaotisNr>
						<kuvatavNr><![CDATA[3. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Väetiseseaduse alusel tehtavad toimingud</jaotisPealkiri>
						<muutmismarge>
							<avaldamismarge>
								<RTosa>RT I</RTosa>
								<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
								<RTartikkel>1</RTartikkel>
								<aktViide>130062023001</aktViide>
							</avaldamismarge>
							<joustumine>2023-07-01</joustumine>
						</muutmismarge>
						<paragrahv id="para261b25">
							<paragrahvNr ylaIndeks="25">261</paragrahvNr>
							<kuvatavNr><![CDATA[§ 261<sup>25</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri>Väetise nõuetekohasuse järelevalvetoimingud</paragrahvPealkiri>
							<loige id="para261b25lg1">
								<loigeNr/>
								<kuvatavNr/>
								<sisuTekst>
									<tavatekst>Majandustegevusteate alusel väetiseregistrisse kantud väetise nõuetekohasuse järelevalvetoimingute eest tasutakse riigilõivu 10 eurot kuni 25-kilogrammisesse või 25-liitrisesse pakendisse pakendatud ning 160 eurot üle 25-kilogrammisesse või 25-liitrisesse pakendisse pakendatud ja pakendamata väetise käitlemisega alustamise aastal majandustegevusteate esitamisel ning igal sellele järgneval kalendriaastal kuni sama väetise käitlemise lõpetamiseni. Kui väetist turustatakse erineva suurusega pakendites, tasutakse riigilõiv suurimast pakendist lähtudes.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130062023001</aktViide>
									</avaldamismarge>
									<joustumine>2023-07-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
					</jaotis>
					<jaotis id="jaotis97">
						<jaotisNr>4</jaotisNr>
						<kuvatavNr><![CDATA[4. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Maaparandusseaduse alusel tehtavad toimingud</jaotisPealkiri>
						<muutmismarge>
							<tavatekst>Kehtetu - </tavatekst>
							<avaldamismarge>
								<RTosa>RT I</RTosa>
								<avaldamineKuupaev>2024-12-30</avaldamineKuupaev>
								<RTartikkel>1</RTartikkel>
								<aktViide>130122024001</aktViide>
							</avaldamismarge>
							<joustumine>2025-01-01</joustumine>
						</muutmismarge>
						<paragrahv id="para261b26">
							<paragrahvNr ylaIndeks="26">261</paragrahvNr>
							<kuvatavNr><![CDATA[§ 261<sup>26</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri>Maaparandussüsteemi ehitusloa andmine</paragrahvPealkiri>
							<muutmismarge>
								<tavatekst>Kehtetu - </tavatekst>
								<avaldamismarge>
									<RTosa>RT I</RTosa>
									<avaldamineKuupaev>2024-12-30</avaldamineKuupaev>
									<RTartikkel>1</RTartikkel>
									<aktViide>130122024001</aktViide>
								</avaldamismarge>
								<joustumine>2025-01-01</joustumine>
							</muutmismarge>
						</paragrahv>
					</jaotis>
					<jaotis id="jaotis98">
						<jaotisNr>5</jaotisNr>
						<kuvatavNr><![CDATA[5. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Söödaseaduse alusel tehtavad toimingud</jaotisPealkiri>
						<muutmismarge>
							<avaldamismarge>
								<RTosa>RT I</RTosa>
								<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
								<RTartikkel>1</RTartikkel>
								<aktViide>130062023001</aktViide>
							</avaldamismarge>
							<joustumine>2023-07-01</joustumine>
						</muutmismarge>
						<paragrahv id="para261b27">
							<paragrahvNr ylaIndeks="27">261</paragrahvNr>
							<kuvatavNr><![CDATA[§ 261<sup>27</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri>Riigi toidu ja sööda käitlejate registri toimingud</paragrahvPealkiri>
							<loige id="para261b27lg1">
								<loigeNr/>
								<kuvatavNr/>
								<sisuTekst>
									<tavatekst>Riigi toidu ja sööda käitlejate registri andmete kinnitatud väljavõtte eest tasutakse riigilõivu 1 euro iga formaadis A4 lehekülje eest.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130062023001</aktViide>
									</avaldamismarge>
									<joustumine>2023-07-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
					</jaotis>
					<jaotis id="jaotis99">
						<jaotisNr>6</jaotisNr>
						<kuvatavNr><![CDATA[6. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Mahepõllumajanduse seaduse alusel tehtavad toimingud</jaotisPealkiri>
						<muutmismarge>
							<avaldamismarge>
								<RTosa>RT I</RTosa>
								<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
								<RTartikkel>1</RTartikkel>
								<aktViide>130062023001</aktViide>
							</avaldamismarge>
							<joustumine>2023-07-01</joustumine>
						</muutmismarge>
						<paragrahv id="para261b28">
							<paragrahvNr ylaIndeks="28">261</paragrahvNr>
							<kuvatavNr><![CDATA[§ 261<sup>28</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri>Mahepõllumajanduse seaduse alusel toimingute tegemine</paragrahvPealkiri>
							<loige id="para261b28lg1">
								<loigeNr>1</loigeNr>
								<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Mahepõllumajandusliku taime- ja loomakasvatusega, sealhulgas mesindusega, ning vesiviljelusloomade ja merevetikate tootmisega ning sööda esmatootmisega tegelev isik tasub ettevõtte või selle osa tunnustamise eest ning tunnustamisele järgnevast aastast alates igal aastal korralise järelevalvetoimingu eest riigilõivu 62 eurot ning lisaks iga hektari kontrollitava maa või vesiviljelusloomade ja merevetikate tootmisala kohta 1,5 eurot ning taimede ja seente korjamiseks kasutatava mitteharitava ala hektari kohta 0,24 eurot, kuid kokku mitte üle 5000 euro.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para261b28lg2">
								<loigeNr>2</loigeNr>
								<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Mahepõllumajanduslikku toodet ettevalmistav või üksnes turule viiv isik või sööta tootev ja turule viiv isik tasub ettevõtte või selle osa tunnustamise eest ning tunnustamisele järgnevast aastast alates igal aastal korralise järelevalvetoimingu eest riigilõivu 120 eurot.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para261b28lg3">
								<loigeNr>3</loigeNr>
								<kuvatavNr><![CDATA[(3)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Mahepõllumajanduslikku toodet importiv isik tasub ettevõtte andmete mahepõllumajanduse registrisse kandmise eest ning registrisse kandmisele järgnevast aastast alates igal aastal ettevõttes või selle osas tehtud korralise järelevalvetoimingu eest riigilõivu 300 eurot.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para261b28lg4">
								<loigeNr>4</loigeNr>
								<kuvatavNr><![CDATA[(4)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Riigilõiv tasutakse ettevõtte tunnustamise taotluse esitamise kuupäevaks ja igal mahepõllumajandusega tegelemise jätkamise aastal Põllumajandus- ja Toiduametile mahepõllumajandusliku tegevusega jätkamiseks esitatava teabe esitamise tähtpäevaks.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130062023001</aktViide>
									</avaldamismarge>
									<joustumine>2023-07-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
					</jaotis>
					<jaotis id="jaotis100">
						<jaotisNr>7</jaotisNr>
						<kuvatavNr><![CDATA[7. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Toiduseaduse ja veterinaarseaduse alusel tehtavad toimingud</jaotisPealkiri>
						<muutmismarge>
							<avaldamismarge>
								<RTosa>RT I</RTosa>
								<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
								<RTartikkel>1</RTartikkel>
								<aktViide>130062023001</aktViide>
							</avaldamismarge>
							<joustumine>2023-07-01</joustumine>
						</muutmismarge>
						<paragrahv id="para261b29">
							<paragrahvNr ylaIndeks="29">261</paragrahvNr>
							<kuvatavNr><![CDATA[§ 261<sup>29</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri>Veterinaararsti kutsetegevuse loa taotluse ja kutsetegevust kinnitava tõendi taotluse läbivaatamine</paragrahvPealkiri>
							<loige id="para261b29lg1">
								<loigeNr>1</loigeNr>
								<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Veterinaararsti kutsetegevuse loa taotluse läbivaatamise eest tasutakse riigilõivu 70 eurot.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para261b29lg2">
								<loigeNr>2</loigeNr>
								<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Veterinaararsti kutsetegevust kinnitava tõendi taotluse läbivaatamise eest tasutakse riigilõivu 35 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130062023001</aktViide>
									</avaldamismarge>
									<joustumine>2023-07-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
						<paragrahv id="para261b30">
							<paragrahvNr ylaIndeks="30">261</paragrahvNr>
							<kuvatavNr><![CDATA[§ 261<sup>30</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri>Laboratooriumile volituse andmise taotluse läbivaatamine</paragrahvPealkiri>
							<loige id="para261b30lg1">
								<loigeNr/>
								<kuvatavNr/>
								<sisuTekst>
									<tavatekst>Laboratooriumile ametliku kontrolli tegemiseks, sealhulgas järelevalve ja muu menetluse käigus võetud proovide analüüsimiseks, esmakordse volituse andmise taotluse läbivaatamise eest tasutakse riigilõivu 96 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130062023001</aktViide>
									</avaldamismarge>
									<joustumine>2023-07-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
					</jaotis>
					<jaotis id="jaotis101">
						<jaotisNr>8</jaotisNr>
						<kuvatavNr><![CDATA[8. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Loomakaitseseaduse alusel tehtavad toimingud</jaotisPealkiri>
						<muutmismarge>
							<avaldamismarge>
								<RTosa>RT I</RTosa>
								<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
								<RTartikkel>1</RTartikkel>
								<aktViide>130062023001</aktViide>
							</avaldamismarge>
							<joustumine>2023-07-01</joustumine>
						</muutmismarge>
						<paragrahv id="para261b31">
							<paragrahvNr ylaIndeks="31">261</paragrahvNr>
							<kuvatavNr><![CDATA[§ 261<sup>31</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri>Katseloomade kasvatamise, katseloomadega varustamise ja katseloomade kasutamise tegevusloa taotluse lahendamine</paragrahvPealkiri>
							<loige id="para261b31lg1">
								<loigeNr/>
								<kuvatavNr/>
								<sisuTekst>
									<tavatekst>Katseloomade kasvatamise, katseloomadega varustamise ja katseloomade kasutamise tegevusloa taotluse lahendamise eest tasutakse riigilõivu 64 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130062023001</aktViide>
									</avaldamismarge>
									<joustumine>2023-07-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
					</jaotis>
					<jaotis id="jaotis102">
						<jaotisNr>9</jaotisNr>
						<kuvatavNr><![CDATA[9. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Alkoholiseaduse alusel tehtavad toimingud</jaotisPealkiri>
						<muutmismarge>
							<avaldamismarge>
								<RTosa>RT I</RTosa>
								<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
								<RTartikkel>1</RTartikkel>
								<aktViide>130062023001</aktViide>
							</avaldamismarge>
							<joustumine>2023-07-01</joustumine>
						</muutmismarge>
						<paragrahv id="para261b32">
							<paragrahvNr ylaIndeks="32">261</paragrahvNr>
							<kuvatavNr><![CDATA[§ 261<sup>32</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri>Riikliku alkoholiregistri toimingud</paragrahvPealkiri>
							<loige id="para261b32lg1">
								<loigeNr>1</loigeNr>
								<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Alkoholi registrisse kandmise taotluse läbivaatamise eest tasutakse riigilõivu 10 eurot.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para261b32lg2">
								<loigeNr>2</loigeNr>
								<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Registrikande kehtivusaja pikendamise taotluse läbivaatamise eest tasutakse riigilõivu 4 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130062023001</aktViide>
									</avaldamismarge>
									<joustumine>2023-07-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
					</jaotis>
				</jagu>
			</peatykk>
			<peatykk id="ptk11">
				<peatykkNr>11</peatykkNr>
				<kuvatavNr><![CDATA[11. peatükk]]></kuvatavNr>
				<peatykkPealkiri>Siseministeeriumi valitsemisala toimingud</peatykkPealkiri>
				<jagu id="jg39">
					<jaguNr>1</jaguNr>
					<kuvatavNr><![CDATA[1. jagu]]></kuvatavNr>
					<jaguPealkiri>Valdkonna eest vastutava ministri toimingud</jaguPealkiri>
					<jaotis id="jaotis103">
						<jaotisNr>1</jaotisNr>
						<kuvatavNr><![CDATA[1. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Nimeseaduse alusel tehtavad toimingud</jaotisPealkiri>
						<paragrahv id="para262">
							<paragrahvNr>262</paragrahvNr>
							<kuvatavNr><![CDATA[§ 262. ]]></kuvatavNr>
							<paragrahvPealkiri>Uue isikunime taotluse läbivaatamine</paragrahvPealkiri>
							<loige id="para262lg1">
								<loigeNr>1</loigeNr>
								<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Uue eesnime andmise, uue perekonnanime andmise, eesnime taastamise või perekonnanime taastamise taotluse läbivaatamise eest tasutakse riigilõivu 150 eurot.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para262lg2">
								<loigeNr>2</loigeNr>
								<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Uue isikunime andmise või isikunime taastamise taotluse läbivaatamise eest tasutakse riigilõivu 300 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
					</jaotis>
					<jaotis id="jaotis104">
						<jaotisNr>2</jaotisNr>
						<kuvatavNr><![CDATA[2. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Relvaseaduse alusel tehtavad toimingud</jaotisPealkiri>
						<paragrahv id="para263">
							<paragrahvNr>263</paragrahvNr>
							<kuvatavNr><![CDATA[§ 263. ]]></kuvatavNr>
							<paragrahvPealkiri>Relvaseaduse alusel loataotluse läbivaatamine, loa kehtivusaja pikendamine ning andmete muutmine teenistus- ja tsiviilrelvade registris</paragrahvPealkiri>
							<muutmismarge>
								<avaldamismarge>
									<RTosa>RT I</RTosa>
									<avaldamineKuupaev>2023-03-14</avaldamineKuupaev>
									<RTartikkel>22</RTartikkel>
									<aktViide>114032023022</aktViide>
								</avaldamismarge>
								<joustumine>2023-03-30</joustumine>
							</muutmismarge>
							<loige id="para263lg1">
								<loigeNr id="48740e03-7e03-4d8e-af05-96bbd7caf891">1</loigeNr>
								<kuvatavNr id="8b1776c0-fa56-4d14-bd70-f94eadbb952e"><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst id="ce1eeb31-9b5e-4199-a689-1fa4b1fd087a">
									<tavatekst id="8e766657-e990-4ba3-9a2e-e9743d0ae6de">Relvasoetamisloa, relvaloa, paralleelrelvaloa, relvakandmisloa ja kollektsioneerimisloa taotluse läbivaatamise eest tasutakse riigilõivu 60 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para263lg2">
								<loigeNr id="10a3204b-5e78-4f58-ac6d-ed15e6e072e3">2</loigeNr>
								<kuvatavNr id="1ed8908e-ef5b-4260-8853-45947b06bb51"><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst id="c19aec08-ed75-4bbf-94d1-855e0afca2b0">
									<tavatekst id="349604b7-0675-44f6-8c4d-0c6844fccb5c">Relva lammutamise, ümbertegemise, laskekõlbmatuks muutmise ja relva laskekõlbmatusnõuetele vastavuse tuvastamise loa taotluse läbivaatamise eest tasutakse riigilõivu 60 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para263lg3">
								<loigeNr id="6e54808f-e7af-4eac-80cb-44cb7ae69708">3</loigeNr>
								<kuvatavNr id="09091c7f-c85d-4ee5-b1d3-4e31eb4399f1"><![CDATA[(3)]]></kuvatavNr>
								<sisuTekst id="f22ad784-3e39-4969-b399-e3d458b06b5f">
									<tavatekst id="3d79824e-fcf2-477c-ab6f-878b47b1d6be">Relvaloa, paralleelrelvaloa, relvakandmisloa ja kollektsioneerimisloa kehtivuse pikendamise taotluse läbivaatamise eest tasutakse riigilõivu 30 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para263lg3b1">
								<loigeNr ylaIndeks="1">3</loigeNr>
								<kuvatavNr><![CDATA[(3<sup>1</sup>)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Relvasoetamisloa kehtivuse pikendamise taotluse läbivaatamise eest tasutakse riigilõivu 30 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para263lg4">
								<loigeNr id="250d1322-4eb6-4f13-ba58-e4120927d2f9">4</loigeNr>
								<kuvatavNr id="7659f5ee-753c-492e-b142-a8f8e82ddcae"><![CDATA[(4)]]></kuvatavNr>
								<sisuTekst id="5d5dc771-61fb-4e0f-a2a4-5b2e71634f81">
									<tavatekst id="f8637920-5159-4007-929b-e6609ffef45f">Paralleelrelvaloa ja relvakandmisloa relvaloa vastu vahetamise taotluse läbivaatamise eest tasutakse riigilõivu 30 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para263lg5">
								<loigeNr>5</loigeNr>
								<kuvatavNr><![CDATA[(5)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Relva otstarbe või hoiukoha andmete muutmise ning teenistus- ja tsiviilrelvade registrisse kandmise taotluse läbivaatamise eest tasutakse riigilõivu 30 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
						<paragrahv id="para263b1">
							<paragrahvNr id="b33ccc3b-c6f8-438e-adf0-9565afcf84ce" ylaIndeks="1">263</paragrahvNr>
							<kuvatavNr id="1d3a47e3-6939-4824-92ab-96525367a5f5"><![CDATA[§ 263<sup>1</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri id="fce6fb20-e042-4a58-b04e-44b846bb46c4">Laskekõlbmatu relva andmete muutmine</paragrahvPealkiri>
							<loige id="para263b1lg1">
								<loigeNr id="037670a0-e8fd-48ba-a61a-3c430f3ff175">1</loigeNr>
								<kuvatavNr id="254b89ab-66fe-40c8-bc5b-999bcc9adac9"><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst id="f165b267-55ad-452f-b46c-059f0b2e4ad9">
									<tavatekst id="adc379ae-8d1a-4109-9401-cca80b120c34">Laskekõlbmatu relva omaniku muutmiseks ning relvaseaduse § 78<sup>3</sup> lõikes 3 nimetatud kande teenistus- ja tsiviilrelvade registrisse tegemiseks tasutakse riigilõivu 30 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para263b1lg2">
								<loigeNr id="80ad1737-1b7e-4f7b-bdc1-f91ac1ff073c">2</loigeNr>
								<kuvatavNr id="7ca164dc-34ef-4857-825a-7264fd435cac"><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst id="63e5c012-899a-4d54-a7c7-87d3fbd1deb1">
									<tavatekst id="ce5325a4-c4b5-4b07-844d-932e83805240">Relvaseaduse § 78<sup>2</sup> lõikes 4 nimetatud laskekõlbmatu relva kohta teenistus- ja tsiviilrelvade registrisse kande tegemiseks tasutakse riigilõivu 30 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
						<paragrahv id="para264">
							<paragrahvNr id="45c64e59-bde5-4a1e-ad7c-4973ecfb292b">264</paragrahvNr>
							<kuvatavNr id="888a6dd9-280a-4c10-bb0a-bfb30fa0fac2"><![CDATA[§ 264. ]]></kuvatavNr>
							<paragrahvPealkiri id="fb945eab-61b8-44ce-8f30-025c3e90a5d6">Relvaeksami vastuvõtmine</paragrahvPealkiri>
							<muutmismarge id="19c0e350-c0b1-4a23-bea1-b4c0ae04c58f">
								<avaldamismarge id="52d59b19-4c14-4c63-bf2d-22f3ed195a23">
									<RTosa id="29a607fd-e979-45d2-85fe-1ad160a61fd7">RT I</RTosa>
									<avaldamineKuupaev id="e8991deb-e824-4ed0-b006-09cdc0c18917">2018-12-12</avaldamineKuupaev>
									<RTartikkel id="cce0c615-f65a-4215-a321-6a6b22855190">1</RTartikkel>
									<aktViide id="8e332159-3726-416f-9e3b-415cfc1366f8">112122018001</aktViide>
								</avaldamismarge>
								<joustumine id="03bdb0bf-9017-45e2-8684-5f3160ccef1a">2019-01-01</joustumine>
							</muutmismarge>
							<loige id="para264lg1">
								<loigeNr id="67b11404-34db-49b4-acdb-328ba1ee9705">1</loigeNr>
								<kuvatavNr id="d153909f-0eee-46f4-afdc-96ecbbf3cbf5"><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst id="552b6a38-9726-4194-b87a-9f8b5044bcf0">
									<tavatekst id="60f82406-434e-4cda-a900-4626395dbc21">Relvaseaduse § 35 lõikes 6 sätestatud relvaeksami vastuvõtmise eest tasutakse riigilõivu 90 eurot. Kui isik ei soorita nimetatud eksamit või sooritab üksnes osa eksamist, tasutakse uue eksami sooritamise eest riigilõivu samas määras.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para264lg2">
								<loigeNr id="18fa6335-b98d-418a-9a61-1baa5cc08caa">2</loigeNr>
								<kuvatavNr id="e61dffdd-44ba-437a-878e-46c515ed2d10"><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst id="227dd413-6cdb-435f-92eb-2c56ed1cf52a">
									<tavatekst id="b732b2e2-5ecd-4d4a-bdd3-a91f57ccd88d">Kui relvaeksami käigus sooritatakse relvaseaduse § 26 lõikest 2, § 35 lõikest 6 või 12 või § 41 lõikest 7 tulenevalt üksnes teooriaeksam või relva käsitsemise katse, tasutakse riigilõivu 75 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para264lg3">
								<loigeNr id="a81d3325-a9f5-498f-83ad-593f0c1b08d0">3</loigeNr>
								<kuvatavNr id="205a6cc3-8f8e-4bea-a2c9-2ba4f5c34d9b"><![CDATA[(3)]]></kuvatavNr>
								<muutmismarge id="984ca888-9797-4bd7-a51b-91c09f9a32ee">
									<tavatekst id="2122fe53-bae8-4cdb-b42f-94d5f8b55988">Kehtetu - </tavatekst>
									<avaldamismarge id="cd99db9d-3d4b-4151-9a0d-1e1ebb95c1c7">
										<RTosa id="cbdd8a8b-8e1d-44fb-9f10-4f2aa3f64847">RT I</RTosa>
										<avaldamineKuupaev id="5f9c9517-1e92-4331-bb08-818ea81920fe">2018-03-09</avaldamineKuupaev>
										<RTartikkel id="95b47113-d0ae-4412-83a1-0f34c2401838">1</RTartikkel>
										<aktViide id="95d8f8b0-1720-4411-a02c-34ba408bb8c5">109032018001</aktViide>
									</avaldamismarge>
									<joustumine id="d05ffe95-84bd-4a9e-a3f7-e6be38e06429">2018-07-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
						<paragrahv id="para265">
							<paragrahvNr id="53861841-fa5e-424a-80d4-1f7d37462a3b">265</paragrahvNr>
							<kuvatavNr id="e8b445c7-a14b-432c-ac2d-2079739ca5c0"><![CDATA[§ 265. ]]></kuvatavNr>
							<paragrahvPealkiri id="b0685bfe-1911-4af2-81b0-cee3f257b849">Relvade, tulirelva oluliste osade ja laskemoona Eestisse sisseveo ja Eestist väljaveo eriloa väljastamine</paragrahvPealkiri>
							<muutmismarge id="5e52b017-a771-448f-bae6-412ec059a7b1">
								<avaldamismarge id="7fa4aac8-1365-438b-89fa-2d93bd35eccb">
									<RTosa id="a8e09149-0a77-4abf-af51-72838afb301c">RT I</RTosa>
									<avaldamineKuupaev id="12eb93eb-716c-4d43-9fb5-6889c62875b9">2018-03-09</avaldamineKuupaev>
									<RTartikkel id="322a16e3-0289-4251-9005-cb58bd89d50b">1</RTartikkel>
									<aktViide id="b12be845-8463-4799-9b32-00ec9c053c2e">109032018001</aktViide>
								</avaldamismarge>
								<joustumine id="528af024-658d-4f17-b8c4-96dee3d988bc">2018-07-01</joustumine>
							</muutmismarge>
							<loige id="para265lg1">
								<loigeNr id="2bfbd977-a8c9-4f03-bb19-0d7e45e80565">1</loigeNr>
								<kuvatavNr id="35ef2b9d-32d0-4e32-978a-ed91ea930e30"><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst id="1af1ecf1-952b-4840-b8aa-ba299e51ac1c">
									<tavatekst id="3af40924-4475-49f4-a42a-6e2d808c38c7">Eriloa väljastamise eest tulirelva või gaasirelva Eestisse sisseveoks või Eestist väljaveoks tasutakse riigilõivu 120 eurot iga relva kohta. Eriloa muutmisel või pikendamisel tasutakse riigilõivu 120 eurot. Kui eriloa muutmisel sisse- või väljaveetavate relvade arv suureneb, tasutakse lisaks riigilõivu 120 eurot iga lisandunud relva kohta.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para265lg1b1">
								<loigeNr ylaIndeks="1">1</loigeNr>
								<kuvatavNr><![CDATA[(1<sup>1</sup>)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Eriloa väljastamise eest tulirelva või gaasirelva kaubana Eestisse sisseveoks või Eestist väljaveoks tasutakse riigilõivu 120 eurot. Eriloa muutmise või pikendamise eest tasutakse riigilõivu 120 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para265lg2">
								<loigeNr id="b7e414b6-2884-461c-adca-ffd588476a92">2</loigeNr>
								<kuvatavNr id="8e7facb1-e727-4d33-9d28-2cecb7174dc7"><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst id="67884527-5582-4697-81bf-a7ae97349eb8">
									<tavatekst id="be7a3755-37be-46a3-a21c-4e789535126f">Eriloa väljastamise, muutmise ja pikendamise eest tulirelva oluliste osade ja laskemoona Eestisse sisseveoks tasutakse riigilõivu 120 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
						<paragrahv id="para266">
							<paragrahvNr id="5fc4e4f9-6a0b-42f0-9265-2c8c2d20f65d">266</paragrahvNr>
							<kuvatavNr id="b71b4505-ceb7-4931-892b-3e40ca5cfa7c"><![CDATA[§ 266. ]]></kuvatavNr>
							<paragrahvPealkiri id="89ae897a-7409-47e5-bbf5-82b655c87220">Relva edasitoimetamine Euroopa Liidus</paragrahvPealkiri>
							<muutmismarge id="61b471c5-7cf3-4d7c-b79c-d07a232ee462">
								<avaldamismarge id="8d6efa9c-e152-4c02-a4a5-e81a9f92c471">
									<RTosa id="ee227cd0-7417-4abf-bcb3-e18cf74617d0">RT I</RTosa>
									<avaldamineKuupaev id="280357a6-9884-4dda-83d0-674012ea9278">2020-02-12</avaldamineKuupaev>
									<RTartikkel id="3c449891-3161-43f5-8396-a3acb11f833d">1</RTartikkel>
									<aktViide id="f1e80760-c62c-47c6-b565-dca0d84359dd">112022020001</aktViide>
								</avaldamismarge>
								<joustumine id="7de29aab-5fb5-4be4-8125-83bb1e6d742e">2020-03-01</joustumine>
							</muutmismarge>
							<loige id="para266lg1">
								<loigeNr id="1e7f5c58-cd18-4ab3-9cc0-bd294a2db510">1</loigeNr>
								<kuvatavNr id="67bf96aa-ba90-4ba3-9b87-c99aaae1f47a"><![CDATA[(1)]]></kuvatavNr>
								<muutmismarge>
									<tavatekst>Kehtetu - </tavatekst>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para266lg2">
								<loigeNr id="a8fdf794-4e23-4e82-abcb-7baaaefc7476">2</loigeNr>
								<kuvatavNr id="0d9ab041-b04f-4291-b506-d67d9f5ba3c6"><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst id="1cee66b5-4ad6-44eb-b4ac-6f315e53d42b">
									<tavatekst id="a1aedfb7-ba9e-4594-b569-dfa4d8abfd86">Tulirelvade Euroopa Liidus ajutise või alalise edasitoimetamise eelloa või loa väljastamise eest tasutakse riigilõivu 120 eurot iga tulirelva kohta.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para266lg3">
								<loigeNr id="2f5ff9ef-66ca-49c5-9343-b8eb638bd0f4">3</loigeNr>
								<kuvatavNr id="fe0c586d-1364-4490-92b6-b3f9ffc581f8"><![CDATA[(3)]]></kuvatavNr>
								<sisuTekst id="73e7b0a2-dfdf-4516-ba59-b81ae598a177">
									<tavatekst id="bad89715-a17c-4500-b9c6-90af38e58c38">Akustilise relva Euroopa Liidus ajutise või alalise edasitoimetamise eelloa või loa väljastamise eest tasutakse riigilõivu 120 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para266lg4">
								<loigeNr id="b8d1b082-5950-4043-a151-5e3958d962cd">4</loigeNr>
								<kuvatavNr id="7be933be-6743-4a3a-ba1b-8ff50f069b75"><![CDATA[(4)]]></kuvatavNr>
								<sisuTekst id="5d1d6425-7f6a-4d9a-b530-acdf7832837b">
									<tavatekst id="03d0144e-06e5-4445-92a4-9de51a7510f6">Tulirelva kaubana teisest Euroopa Liidu liikmesriigist alalise Eestisse edasitoimetamise eelloa väljastamise eest tasutakse riigilõivu 120 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para266lg5">
								<loigeNr id="ea5ea59f-1eb6-40b7-9cb3-5f9104001d47">5</loigeNr>
								<kuvatavNr id="6a734706-9a25-42f6-a8f5-6d1318cc1d2d"><![CDATA[(5)]]></kuvatavNr>
								<sisuTekst id="1832e518-d9f3-4f17-863d-5583b987cdfb">
									<tavatekst id="ea947be2-d085-45ab-a854-fcffe62c19c1">Tulirelva kaubana Euroopa Liidus ajutise edasitoimetamise eelloa või loa väljastamise eest tasutakse riigilõivu 120 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para266lg6">
								<loigeNr id="57cbb2d3-6875-40a9-8159-7a564173996d">6</loigeNr>
								<kuvatavNr id="ece1452c-d5ec-4285-87db-5c9ac8ff50fb"><![CDATA[(6)]]></kuvatavNr>
								<sisuTekst id="107c9dac-159a-4ea2-90a5-44a189bbc6ae">
									<tavatekst id="2dee7f48-409c-48c7-91d7-856f90f21a15">Akustilise relva või laskekõlbmatu relva kaubana Euroopa Liidus edasitoimetamise eelloa või loa väljastamise eest tasutakse riigilõivu 120 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para266lg7">
								<loigeNr id="21c30608-ae5f-4f6c-94bb-3a1cfb948630">7</loigeNr>
								<kuvatavNr id="44ad3359-1fbe-499e-a4ce-cbc93460a361"><![CDATA[(7)]]></kuvatavNr>
								<sisuTekst id="bbf2bf10-757e-4a83-a507-f475f2b8b262">
									<tavatekst id="10e56297-e1e4-4e81-81c9-493e621dcdc5">Laskekõlbmatu relva Euroopa Liidus edasitoimetamise eelloa või loa väljastamise eest tasutakse riigilõivu 120 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para266lg8">
								<loigeNr id="fce57fd1-bac4-4e90-b769-d33d64bff966">8</loigeNr>
								<kuvatavNr id="c9096ee3-9d93-4d67-925d-8c293002c4b9"><![CDATA[(8)]]></kuvatavNr>
								<sisuTekst id="4e99479b-d8e1-4f4a-9b60-9208315865a4">
									<tavatekst id="5ec6302c-bd89-4a3f-8b3f-5c352cc6d0ff">Relva- ja padrunikollektsiooni kuuluva relva või laskemoona Euroopa Liidus ajutise edasitoimetamise eelloa või loa väljastamise eest tasutakse riigilõivu 120 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
						<paragrahv id="para267">
							<paragrahvNr id="c2be0010-3edd-44ed-a0e3-d1a6edd54e5b">267</paragrahvNr>
							<kuvatavNr id="af7150d8-0480-4ff4-8462-600d8889a826"><![CDATA[§ 267. ]]></kuvatavNr>
							<paragrahvPealkiri id="dfa0eb65-76e5-4f11-9f82-d1aae9d32a59">Relvade ja laskemoonaga seotud tegevusalal tegevusloa taotluse läbivaatamine</paragrahvPealkiri>
							<muutmismarge>
								<avaldamismarge>
									<RTosa>RT I</RTosa>
									<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
									<RTartikkel>3</RTartikkel>
									<aktViide>129062024003</aktViide>
								</avaldamismarge>
								<joustumine>2025-01-01</joustumine>
							</muutmismarge>
							<loige id="para267lg1">
								<sisuTekst id="74c22827-60bc-4bd1-a346-6d0df62108b7">
									<tavatekst id="16be7e2e-b62a-48d4-b00c-1444f88b4319">Relvade ja laskemoonaga seotud tegevusalal tegevusloa taotluse läbivaatamise eest tasutakse riigilõivu 365 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
						<paragrahv id="para267b1">
							<paragrahvNr id="501f09ed-9310-4f26-945d-5c8970aa0a57" ylaIndeks="1">267</paragrahvNr>
							<kuvatavNr id="f93a8862-fd39-4a5f-897a-3c45fb88f10d"><![CDATA[§ 267<sup>1</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri id="e29a46b3-394f-4bb6-a207-97c8553c8d2f">Sõjarelvaga, sõjalise otstarbega laskemoonaga ja lahingumoonaga seotud tegevusalal tegevusloa või käitamisloa andmine</paragrahvPealkiri>
							<loige id="para267b1lg1">
								<loigeNr id="ea1b78b3-0d5d-4ecc-938c-2f72cfac0ff0">1</loigeNr>
								<kuvatavNr id="eb562c8f-12a8-4d8d-b129-c288c0fc8ef0"><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst id="cf4170e6-8c2f-4f2e-8b15-1aa77daee4b4">
									<tavatekst>Sõjarelva, selle olulise osa, sõjalise otstarbega laskemoona või lahingumoona käitlemiseks tegevusloa taotluse läbivaatamise eest tasutakse riigilõivu 1570 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para267b1lg2">
								<loigeNr id="44128241-9ce3-473f-a826-e493c89a9051">2</loigeNr>
								<kuvatavNr id="aaa6fb63-23a7-442c-a62d-209c0231b4a0"><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst id="961e5c64-2552-4837-a623-f281a10d7543">
									<tavatekst>Sõjarelva, selle olulise osa, sõjalise otstarbega laskemoona või lahingumoona käitlemiskoha käitamisloa taotluse läbivaatamise eest tasutakse riigilõivu 1570 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
						<paragrahv id="para267b2">
							<paragrahvNr ylaIndeks="2">267</paragrahvNr>
							<kuvatavNr><![CDATA[§ 267<sup>2</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri>Sõjarelva ja relvasüsteemi käitleva ettevõtja vastutava isiku eksami vastuvõtmine</paragrahvPealkiri>
							<loige id="para267b2lg1">
								<loigeNr/>
								<kuvatavNr/>
								<sisuTekst>
									<tavatekst>Relvaseaduse § 83<sup>25</sup> lõikes 4 nimetatud sõjarelva või relvasüsteemi käitlemise eest vastutava isiku eksami vastuvõtmise eest tasutakse riigilõivu 130 eurot. Kui isik ei soorita nimetatud eksamit, tasutakse uue eksami vastuvõtmise eest riigilõivu samas määras.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-12-12</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>112122024001</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
					</jaotis>
					<jaotis id="jaotis105">
						<jaotisNr>3</jaotisNr>
						<kuvatavNr><![CDATA[3. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Turvaseaduse alusel tehtavad toimingud</jaotisPealkiri>
						<muutmismarge>
							<tavatekst>Kehtetu - </tavatekst>
							<avaldamismarge>
								<RTosa>RT I</RTosa>
								<avaldamineKuupaev>2023-03-01</avaldamineKuupaev>
								<RTartikkel>2</RTartikkel>
								<aktViide>101032023002</aktViide>
							</avaldamismarge>
							<joustumine>2024-07-01</joustumine>
						</muutmismarge>
						<paragrahv id="para268">
							<paragrahvNr>268</paragrahvNr>
							<kuvatavNr><![CDATA[§ 268. ]]></kuvatavNr>
							<paragrahvPealkiri>Turvateenuse osutamise tegevusloa andmise ja kehtivusaja pikendamise taotluse läbivaatamine</paragrahvPealkiri>
							<muutmismarge>
								<tavatekst>Kehtetu - </tavatekst>
								<avaldamismarge>
									<RTosa>RT I</RTosa>
									<avaldamineKuupaev>2023-03-01</avaldamineKuupaev>
									<RTartikkel>2</RTartikkel>
									<aktViide>101032023002</aktViide>
								</avaldamismarge>
								<joustumine>2024-07-01</joustumine>
							</muutmismarge>
						</paragrahv>
					</jaotis>
					<jaotis id="jaotis106">
						<jaotisNr>4</jaotisNr>
						<kuvatavNr><![CDATA[4. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Rahapesu ja terrorismi rahastamise tõkestamise seaduse alusel tehtavad toimingud</jaotisPealkiri>
						<paragrahv id="para269">
							<paragrahvNr>269</paragrahvNr>
							<kuvatavNr><![CDATA[§ 269. ]]></kuvatavNr>
							<paragrahvPealkiri>Rahapesu ja terrorismi rahastamise tõkestamise seaduse alusel väljastatava tegevusloa taotluse läbivaatamine</paragrahvPealkiri>
							<loige id="para269lg1">
								<loigeNr>1</loigeNr>
								<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Rahapesu ja terrorismi rahastamise tõkestamise seaduse alusel väljastatava tegevusloa taotluse läbivaatamise eest tasutakse riigilõivu järgmiselt:</tavatekst>
								</sisuTekst>
								<alampunkt id="para269lg1p1">
									<alampunktNr>1</alampunktNr>
									<kuvatavNr><![CDATA[1) ]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>usaldusfondide ja äriühingute teenuse osutamiseks, pandimajateenuse osutamiseks ning väärismetalli ja väärismetalltoodete, välja arvatud tootmise, teaduse ning meditsiini vajaduseks kasutatavad väärismetallid ja väärismetalltooted, või vääriskivide kokkuostuks või hulgimüügiks 345 eurot;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para269lg1p2">
									<alampunktNr>2</alampunktNr>
									<kuvatavNr><![CDATA[2) ]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>finantseerimisasutusena tegutsemiseks 3300 eurot.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2022-03-12</avaldamineKuupaev>
											<RTartikkel>2</RTartikkel>
											<aktViide>112032022002</aktViide>
										</avaldamismarge>
										<joustumine>2022-03-15</joustumine>
									</muutmismarge>
								</alampunkt>
								<alampunkt id="para269lg1p3">
									<alampunktNr>3</alampunktNr>
									<kuvatavNr><![CDATA[3) ]]></kuvatavNr>
									<muutmismarge id="db1ecf61-0480-4bb8-87f8-8854da37c1f5">
										<tavatekst>Kehtetu - </tavatekst>
										<avaldamismarge id="50e80ab9-6c24-44b6-8101-101e847e4d98">
											<RTosa id="c8f49f2f-e370-4ecb-9014-22d11c59d75a">RT I</RTosa>
											<avaldamineKuupaev id="61057543-c330-4d23-965b-251f0531cac4">2024-06-21</avaldamineKuupaev>
											<RTartikkel id="5924e549-0a99-4e36-9d82-6f0278e0260e">3</RTartikkel>
											<aktViide id="dcd7c803-3049-4f1c-b2a7-3ea00aedbace">121062024003</aktViide>
										</avaldamismarge>
										<joustumine id="389f43d8-820c-446b-9637-813ba2d14ff9">2024-12-30</joustumine>
									</muutmismarge>
								</alampunkt>
							</loige>
							<loige id="para269lg2">
								<loigeNr>2</loigeNr>
								<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
								<muutmismarge id="db1ecf61-0480-4bb8-87f8-8854da37c1f5">
									<tavatekst>Kehtetu - </tavatekst>
									<avaldamismarge id="50e80ab9-6c24-44b6-8101-101e847e4d98">
										<RTosa id="c8f49f2f-e370-4ecb-9014-22d11c59d75a">RT I</RTosa>
										<avaldamineKuupaev id="61057543-c330-4d23-965b-251f0531cac4">2024-06-21</avaldamineKuupaev>
										<RTartikkel id="5924e549-0a99-4e36-9d82-6f0278e0260e">3</RTartikkel>
										<aktViide id="dcd7c803-3049-4f1c-b2a7-3ea00aedbace">121062024003</aktViide>
									</avaldamismarge>
									<joustumine id="389f43d8-820c-446b-9637-813ba2d14ff9">2024-12-30</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
					</jaotis>
					<jaotis id="jaotis 106b1">
						<jaotisNr>5</jaotisNr>
						<kuvatavNr><![CDATA[5. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Riigisaladuse ja salastatud välisteabe seaduse alusel tehtavad toimingud</jaotisPealkiri>
						<muutmismarge>
							<avaldamismarge>
								<RTosa>RT I</RTosa>
								<avaldamineKuupaev>2025-07-08</avaldamineKuupaev>
								<RTartikkel>7</RTartikkel>
								<aktViide>108072025007</aktViide>
							</avaldamismarge>
							<joustumine>2025-09-01</joustumine>
						</muutmismarge>
						<paragrahv id="para269b1">
							<paragrahvNr ylaIndeks="1">269</paragrahvNr>
							<kuvatavNr><![CDATA[§ 269<sup>1</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri>Riigisaladuse ja salastatud välisteabe seaduse alusel väljastatava töötlemisloa taotluse läbivaatamine</paragrahvPealkiri>
							<loige id="para269b1lg1">
								<loigeNr/>
								<kuvatavNr/>
								<sisuTekst>
									<tavatekst>Riigisaladuse ja salastatud välisteabe seaduse alusel väljastatava töötlemisloa taotluse läbivaatamise eest tasutakse riigilõivu järgmiselt:</tavatekst>
								</sisuTekst>
								<alampunkt id="para269b1lg1p1">
									<alampunktNr>1</alampunktNr>
									<kuvatavNr><![CDATA[1) ]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>töötlemisloa esmakordsel taotlemisel 6000 eurot;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para269b1lg1p2">
									<alampunktNr>2</alampunktNr>
									<kuvatavNr><![CDATA[2) ]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>töötlemisloa kehtivuse pikendamisel 3000 eurot.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2025-07-08</avaldamineKuupaev>
											<RTartikkel>7</RTartikkel>
											<aktViide>108072025007</aktViide>
										</avaldamismarge>
										<joustumine>2025-09-01</joustumine>
									</muutmismarge>
								</alampunkt>
							</loige>
						</paragrahv>
					</jaotis>
				</jagu>
				<jagu id="jg40">
					<jaguNr>2</jaguNr>
					<kuvatavNr><![CDATA[2. jagu]]></kuvatavNr>
					<jaguPealkiri>Politsei- ja Piirivalveameti ning Eesti välisesinduse toimingud</jaguPealkiri>
					<jaotis id="jaotis107">
						<jaotisNr>1</jaotisNr>
						<kuvatavNr><![CDATA[1. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Kodakondsuse seaduse alusel tehtavad toimingud</jaotisPealkiri>
						<paragrahv id="para270">
							<paragrahvNr id="af4c3da4-c163-41d0-9794-a4e05f450c87">270</paragrahvNr>
							<kuvatavNr id="3ee217f3-e41d-4ac3-bd8c-efa5c3f1073e"><![CDATA[§ 270. ]]></kuvatavNr>
							<paragrahvPealkiri id="ecc7d238-63e6-48cd-b8ab-59a5170284c4">Kodakondsuse saamise, taastamise ja kodakondsusest vabastamise taotluse läbivaatamine</paragrahvPealkiri>
							<muutmismarge id="c992ec10-454d-4afb-abb2-4d44eead5684">
								<avaldamismarge id="4afe4d35-d194-47b4-88e1-512068a829e3">
									<RTosa id="b876815e-dfec-4be7-b066-ab92a1657f20">RT I</RTosa>
									<avaldamineKuupaev id="18404a48-71ac-48e0-828a-ce439bf777d7">2015-02-03</avaldamineKuupaev>
									<RTartikkel id="3d2966c7-bfcd-43f5-aa20-a59c07fe31b0">1</RTartikkel>
									<aktViide id="5f730417-cac6-4761-94fa-66269e1350f2">103022015001</aktViide>
								</avaldamismarge>
								<joustumine id="5f31308e-ebaa-4f62-8ba0-6ea8a6c74ef7">2016-01-01</joustumine>
							</muutmismarge>
							<loige id="para270lg1">
								<loigeNr id="195d7a18-1ff9-4a6f-a9b6-9caf34f61ee8">1</loigeNr>
								<kuvatavNr id="bbbdfecf-26d1-4d36-a3d4-211cd581bf1f"><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst id="525161ff-715e-424c-a3e0-f566480aae01">
									<tavatekst id="5207a87d-b4b9-4887-8e23-ba9bc9c7b4aa">Eesti kodakondsuse saamise või taastamise taotluse läbivaatamise eest tasutakse riigilõivu 150 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para270lg2">
								<loigeNr id="642a40c9-d5d7-49d7-97cf-f33002d84c5a">2</loigeNr>
								<kuvatavNr id="46baeaa7-0d2a-43df-a96b-3fddb00938dc"><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst id="065c2bb7-f902-4777-b358-7b3692bbf20b">
									<tavatekst id="697165d9-756c-431a-820f-0e0d961e8969">Eesti kodakondsusest vabastamise taotluse läbivaatamise eest tasutakse riigilõivu 150 eurot ja välisesinduses 180 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
					</jaotis>
					<jaotis id="jaotis108">
						<jaotisNr>2</jaotisNr>
						<kuvatavNr><![CDATA[2. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Euroopa Liidu kodaniku seaduse alusel tehtavad toimingud</jaotisPealkiri>
						<paragrahv id="para271">
							<paragrahvNr id="705b900c-a269-4229-810f-e5fc16b3b6c8">271</paragrahvNr>
							<kuvatavNr id="8340b6c2-fda2-408e-8c2a-4b66e897b3dc"><![CDATA[§ 271. ]]></kuvatavNr>
							<paragrahvPealkiri>Tähtajalise elamisõiguse taotluse, tähtajalise elamisõiguse pikendamise taotluse ja alalise elamisõiguse registreerimise taotluse läbivaatamine</paragrahvPealkiri>
							<loige id="para271lg1">
								<loigeNr id="ae80232a-f71e-41f3-8bce-1cd89e85eb6a">1</loigeNr>
								<kuvatavNr id="1983a252-7458-4f2e-98b7-df731495a88c"><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst id="178f5e53-ab7f-4444-bb54-8a980944a2b2">
									<tavatekst id="ab125cab-8edf-4ae9-b706-d655c0fcba85">Euroopa Liidu kodaniku alalise elamisõiguse registreerimise taotluse läbivaatamise eest tasutakse riigilõivu 45 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para271lg2">
								<loigeNr id="95edd527-66d8-49b9-a197-56ac77f548a8">2</loigeNr>
								<kuvatavNr id="778630ec-ae96-4648-bcf8-dfea940d612e"><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst id="aab33b89-9372-42d7-a5b6-0098b4cc2f64">
									<tavatekst>Euroopa Liidu kodaniku perekonnaliikme tähtajalise elamisõiguse taotluse läbivaatamise eest tasutakse riigilõivu 115 eurot ja välisesinduses 145 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para271lg3">
								<loigeNr id="4a0168b8-9026-4e9a-b349-4ab08c4b623c">3</loigeNr>
								<kuvatavNr id="b785125f-1c1d-4317-bba3-074434509ff6"><![CDATA[(3)]]></kuvatavNr>
								<sisuTekst id="5b04d932-ced8-4b59-b13d-5f4f3add7a66">
									<tavatekst>Euroopa Liidu kodaniku perekonnaliikme tähtajalise elamisõiguse pikendamise taotluse või alalise elamisõiguse registreerimise taotluse läbivaatamise eest tasutakse riigilõivu 115 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para271lg4">
								<loigeNr>4</loigeNr>
								<kuvatavNr><![CDATA[(4)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Käesoleva paragrahvi lõikes 2 nimetatud elamisõigust tõendava dokumendi väljastamise eest välisesinduses tasutakse riigilõivu 20 eurot, mis tasutakse dokumendi taotlemisel.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2025-06-26</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>126062025001</aktViide>
									</avaldamismarge>
									<joustumine>2025-07-06</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
					</jaotis>
					<jaotis id="jaotis109">
						<jaotisNr>3</jaotisNr>
						<kuvatavNr><![CDATA[3. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Isikut tõendavate dokumentide seaduse alusel tehtavad toimingud</jaotisPealkiri>
						<paragrahv id="para272">
							<paragrahvNr>272</paragrahvNr>
							<kuvatavNr><![CDATA[§ 272. ]]></kuvatavNr>
							<paragrahvPealkiri>Isikut tõendava dokumendi väljaandmise taotluse läbivaatamine</paragrahvPealkiri>
							<loige id="para272lg1">
								<loigeNr>1</loigeNr>
								<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Isikutunnistuse, välja arvatud diplomaatilise isikutunnistuse, väljaandmise taotluse läbivaatamise eest tasutakse riigilõivu 45 eurot ja välisesinduses 75 eurot. Kui nimetatud toimingut taotletakse Politsei- ja Piirivalveameti iseteeninduskeskkonna kaudu, tasutakse riigilõivu 35 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para272lg2">
								<loigeNr>2</loigeNr>
								<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Elamisloakaardi väljaandmise taotluse läbivaatamise eest tasutakse riigilõivu 70 eurot ja välisesinduses 100 eurot. Kui nimetatud toimingut taotletakse Politsei- ja Piirivalveameti iseteeninduskeskkonna kaudu, tasutakse riigilõivu 60 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para272lg3">
								<loigeNr>3</loigeNr>
								<kuvatavNr><![CDATA[(3)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Euroopa Liidu kodaniku ja elamisõigusega Ühendkuningriigi kodaniku perekonnaliikme elamisloakaardi väljaandmise taotluse läbivaatamise eest tasutakse riigilõivu 45 eurot ja välisesinduses 75 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para272lg3b1">
								<loigeNr ylaIndeks="1">3</loigeNr>
								<kuvatavNr><![CDATA[(3<sup>1</sup>)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Ühendkuningriigi kodaniku, kellel on elamisõigus, elamisloakaardi väljaandmise taotluse läbivaatamise eest tasutakse riigilõivu 45 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
