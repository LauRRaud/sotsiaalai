					<paragrahv id="para333">
						<paragrahvNr id="0527c8c7-608a-43af-af33-7a51f1ebccc1">333</paragrahvNr>
						<kuvatavNr id="ee7a537d-bee0-465b-8548-cdcb22a43cb5"><![CDATA[§ 333. ]]></kuvatavNr>
						<paragrahvPealkiri id="bb3e2b13-1e3d-4e71-9080-dca43585fa83">Sõidukikaardi taotluse läbivaatamine</paragrahvPealkiri>
						<muutmismarge id="4c158c9f-dfd2-4516-b859-a6cd28c7df5d">
							<avaldamismarge id="59a8ab55-ec81-488d-ab8d-bc85731b474d">
								<RTosa id="0a906241-39f5-44fb-b1e6-af215c08a3e6">RT I</RTosa>
