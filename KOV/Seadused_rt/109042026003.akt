										<RTartikkel id="a3331614-bd47-4d59-ab25-a8417b40214f">13</RTartikkel>
										<aktViide id="c6e7132e-4b58-4599-9c35-8623914dead0">119032019013</aktViide>
									</avaldamismarge>
									<joustumine id="c0af2d20-93e8-4f09-9036-ee5446a2992f">2019-05-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
					</jaotis>
				</jagu>
			</peatykk>
