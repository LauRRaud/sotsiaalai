						<paragrahv id="para209">
							<paragrahvNr>209</paragrahvNr>
							<kuvatavNr><![CDATA[§ 209. ]]></kuvatavNr>
							<paragrahvPealkiri>Riikliku raudteeliiklusregistri kanded</paragrahvPealkiri>
							<loige id="para209lg1">
								<loigeNr>1</loigeNr>
								<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Raudteerajatise raudteeliiklusregistrisse kandmise eest e-teenuste infosüsteemi kaudu tasutakse riigilõivu 68 eurot.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para209lg2">
								<loigeNr>2</loigeNr>
								<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Raudteerajatise registrikande muutmise eest e-teenuste infosüsteemi kaudu tasutakse riigilõivu 40 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2026-02-19</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>119022026001</aktViide>
									</avaldamismarge>
									<joustumine>2026-03-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
