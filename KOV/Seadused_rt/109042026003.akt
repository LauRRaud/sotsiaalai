									</alampunkt>
								</loige>
								<loige id="para142b60lg3">
									<loigeNr>3</loigeNr>
									<kuvatavNr><![CDATA[(3)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Laevapere liikme meresõidudiplomi või kutsetunnistuse kinnituslehe ja siseveelaeva laevajuhi diplomi kinnituslehe väljastamise eest tasutakse riigilõivu 30 eurot.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130122023001</aktViide>
										</avaldamismarge>
										<joustumine>2024-07-01</joustumine>
									</muutmismarge>
								</loige>
								<loige id="para142b60lg3b1">
									<loigeNr ylaIndeks="1">3</loigeNr>
									<kuvatavNr><![CDATA[(3<sup>1</sup>)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Välisriigi laevapere liikme meresõidudiplomi või kutsetunnistuse kinnituslehe ja välisriigi siseveelaeva laevajuhi diplomi kinnituslehe väljastamise eest tasutakse riigilõivu 60 eurot.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130122023001</aktViide>
										</avaldamismarge>
										<joustumine>2024-07-01</joustumine>
									</muutmismarge>
								</loige>
								<loige id="para142b60lg4">
									<loigeNr>4</loigeNr>
									<kuvatavNr><![CDATA[(4)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Laevapere liikme täiendusõppekursuse läbimist tõendava tunnistuse väljastamise eest tasutakse riigilõivu 30 eurot.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130122023001</aktViide>
										</avaldamismarge>
										<joustumine>2024-07-01</joustumine>
									</muutmismarge>
								</loige>
								<loige id="para142b60lg5">
									<loigeNr>5</loigeNr>
									<kuvatavNr><![CDATA[(5)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Laevapere liikme soodustusloa väljastamise eest tasutakse riigilõivu 60 eurot.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130122023001</aktViide>
										</avaldamismarge>
										<joustumine>2024-07-01</joustumine>
									</muutmismarge>
								</loige>
								<loige id="para142b60lg6">
									<loigeNr>6</loigeNr>
									<kuvatavNr><![CDATA[(6)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Käesoleva paragrahvi lõigetes 1–5 nimetamata tunnistuste väljastamise eest tasutakse riigilõivu 100 eurot.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130122023001</aktViide>
										</avaldamismarge>
										<joustumine>2024-07-01</joustumine>
									</muutmismarge>
								</loige>
								<loige id="para142b60lg7">
									<loigeNr>7</loigeNr>
									<kuvatavNr><![CDATA[(7)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Käesolevas paragrahvis nimetatud tunnistuse või dokumendi duplikaadi väljastamise eest tasutakse sama suurusega riigilõivu kui originaaltunnistuse või -dokumendi väljastamise eest.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130062023001</aktViide>
										</avaldamismarge>
										<joustumine>2023-07-01</joustumine>
									</muutmismarge>
								</loige>
							</paragrahv>
							<paragrahv id="para142b61">
								<paragrahvNr ylaIndeks="61">142</paragrahvNr>
								<kuvatavNr><![CDATA[§ 142<sup>61</sup>. ]]></kuvatavNr>
								<paragrahvPealkiri>Väikelaeva raadiosideoperaatori tunnistuse väljastamine</paragrahvPealkiri>
								<loige id="para142b61lg1">
									<loigeNr/>
									<kuvatavNr/>
									<sisuTekst>
										<tavatekst>Väikelaeva raadiosideoperaatori tunnistuse väljastamise taotluse läbivaatamise eest tasutakse riigilõivu 30 eurot.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130122023001</aktViide>
										</avaldamismarge>
										<joustumine>2024-07-01</joustumine>
									</muutmismarge>
								</loige>
							</paragrahv>
							<paragrahv id="para142b62">
								<paragrahvNr ylaIndeks="62">142</paragrahvNr>
								<kuvatavNr><![CDATA[§ 142<sup>62</sup>. ]]></kuvatavNr>
								<paragrahvPealkiri>Väikelaeva ja jeti juhtimise õigust tõendava dokumendi väljastamine</paragrahvPealkiri>
								<loige id="para142b62lg1">
									<loigeNr>1</loigeNr>
									<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Väikelaeva või jeti juhtimise õigust tõendava dokumendi väljastamise taotluse läbivaatamise eest tasutakse riigilõivu 35 eurot. Kui nimetatud toimingut taotletakse elektrooniliselt e-teenuste infosüsteemi kaudu, tasutakse riigilõivu 25 eurot.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130122023001</aktViide>
										</avaldamismarge>
										<joustumine>2024-07-01</joustumine>
									</muutmismarge>
								</loige>
								<loige id="para142b62lg2">
									<loigeNr>2</loigeNr>
									<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
									<muutmismarge>
										<tavatekst>Kehtetu - </tavatekst>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130122023001</aktViide>
										</avaldamismarge>
										<joustumine>2024-07-01</joustumine>
									</muutmismarge>
								</loige>
							</paragrahv>
						</alljaotis>
						<alljaotis id="alljaotis4">
							<alljaotisNr>3</alljaotisNr>
							<kuvatavNr><![CDATA[3. alljaotis]]></kuvatavNr>
							<alljaotisPealkiri>Sadamaseaduse alusel tehtavad toimingud</alljaotisPealkiri>
							<muutmismarge>
