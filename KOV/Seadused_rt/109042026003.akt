									<tavatekst id="e05f51e3-bead-40b3-ba07-7e68a99e2cf7">ühe klassi kohta 195 eurot;</tavatekst>
								</sisuTekst>
							</alampunkt>
							<alampunkt id="para94lg2p2">
								<alampunktNr id="8559710d-10da-4f74-b1f3-a7bad93a221f">2</alampunktNr>
								<kuvatavNr id="64893aba-ef92-4ce0-95cd-2fc773bf48f0"><![CDATA[2) ]]></kuvatavNr>
								<sisuTekst id="274f3042-9609-454e-b641-61c9a5d08797">
									<tavatekst id="ea55b995-b005-4da8-8e0a-248530da3395">iga täiendava klassi kohta 45 eurot.</tavatekst>
								</sisuTekst>
