							</loige>
							<loige id="para142b85lg7">
								<loigeNr>7</loigeNr>
								<kuvatavNr><![CDATA[(7)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Tehnilise teenistuse pädevuse ulatuse laiendamise eest tasutakse riigilõivu 80 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
