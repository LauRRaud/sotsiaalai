								<tavatekst id="4e231296-e1d7-4d53-a2f9-ca3377b1e887">Rahvusvahelise patenditaotluse siseriiklikku menetlusse võtmise eest tasutakse riigilõivu 225 eurot.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para100lg2">
							<loigeNr id="d9f7babf-17aa-4147-91a2-b250b58293ce">2</loigeNr>
							<kuvatavNr id="d7ea6136-bae0-49fe-aed3-118e465ec1d5"><![CDATA[(2)]]></kuvatavNr>
							<sisuTekst id="2c9c6b68-87da-49d7-b277-72d053c16f3f">
								<tavatekst id="61859559-6039-49a6-9735-606cabd5b1ba">Kasuliku mudeli rahvusvahelise registreerimise taotluse siseriiklikku menetlusse võtmise eest tasutakse riigilõivu 105 eurot.</tavatekst>
							</sisuTekst>
						</loige>
					</paragrahv>
					<paragrahv id="para101">
						<paragrahvNr id="fc5b1805-ea96-4b59-a965-2a2df98e927c">101</paragrahvNr>
						<kuvatavNr id="688c3a15-e1da-4a35-b416-bce9ba793235"><![CDATA[§ 101. ]]></kuvatavNr>
						<paragrahvPealkiri id="b7b60915-64eb-4ff3-b80b-4de02f573c6e">Menetluse jätkamine ja taastamine</paragrahvPealkiri>
						<loige id="para101lg1">
							<loigeNr id="a8207aae-500d-41ce-9cc7-bcda504b25e8">1</loigeNr>
							<kuvatavNr id="aff662db-7de3-4f96-9d3a-7efe6aeaa1ab"><![CDATA[(1)]]></kuvatavNr>
							<sisuTekst id="2b501279-592a-4d10-b708-ae852e6d3161">
								<tavatekst id="e6b79c0e-8a66-40b6-a63a-946256715a5d">Kaubamärgi registreerimise taotluse menetluse taastamise nõude esitamise eest tasutakse riigilõivu 32 eurot.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para101lg2">
							<loigeNr id="1ecb03a6-4e17-44e3-ab5d-2b8bef8f27d7">2</loigeNr>
							<kuvatavNr id="a458052e-1a34-4f5d-b203-623f069a68e2"><![CDATA[(2)]]></kuvatavNr>
							<sisuTekst id="e45250fc-cc1c-455c-b4c6-f3b7475f54bf">
								<tavatekst id="4eb6edc8-9d28-4545-9766-3b9859872b08">Patenditaotluse menetluse jätkamise nõude esitamise eest pärast menetluse peatamist tasutakse riigilõivu 32 eurot.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para101lg3">
							<loigeNr id="d35d3a59-fb08-468c-972f-9c8ec249aa58">3</loigeNr>
							<kuvatavNr id="21008402-e69a-4689-b5db-036b19bc9186"><![CDATA[(3)]]></kuvatavNr>
							<sisuTekst id="b6e54554-9d51-47a7-ada3-c163cdbf5e81">
								<tavatekst id="f39591b5-e8b7-4172-b73f-2101b3617a40">Patenditaotluse menetluse, patendi kehtivuse ja täiendava kaitse kehtivuse taastamise nõude esitamise eest tasutakse riigilõivu 32 eurot.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para101lg4">
							<loigeNr id="7cb35d67-f8d8-473d-aaa2-300a2d878277">4</loigeNr>
							<kuvatavNr id="b1162247-8d11-490d-af0e-5fa8641f42b1"><![CDATA[(4)]]></kuvatavNr>
							<sisuTekst id="b292af7b-fe76-40a3-8342-9d95f384e071">
								<tavatekst id="13668efb-cf2f-4071-b0bb-2081873eb07c">Kasuliku mudeli registreerimise taotluse menetluse jätkamise eest pärast menetluse peatamist tasutakse riigilõivu 32 eurot.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para101lg5">
							<loigeNr id="9ec1a353-0b13-44d2-bb4c-c513188a1168">5</loigeNr>
							<kuvatavNr id="dc681bb4-881f-4f14-80b1-bef8ec2b104e"><![CDATA[(5)]]></kuvatavNr>
							<sisuTekst id="4b874db4-c107-44b7-85e0-827429d9e5df">
								<tavatekst id="3f370f22-a6f6-483f-a9d1-f02e06d53073">Kasuliku mudeli registreerimise taotluse menetluse taastamise nõude esitamise eest tasutakse riigilõivu 32 eurot.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para101lg6">
							<loigeNr id="ae17de2c-8e54-4b13-b9db-448b35e2b03e">6</loigeNr>
							<kuvatavNr id="f1a05018-b883-4adb-9a2f-a1d74a5feac9"><![CDATA[(6)]]></kuvatavNr>
							<sisuTekst id="ff6a8933-481d-4eff-96d3-b7bf3fde060c">
								<tavatekst id="9bfabfc1-54ad-404e-94ea-ecc623399482">Tööstusdisainilahenduse registreerimise taotluse menetluse taastamise nõude esitamise eest tasutakse riigilõivu 32 eurot.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para101lg7">
							<loigeNr id="863892d6-297c-4aeb-8296-724bd19f6842">7</loigeNr>
							<kuvatavNr id="ae460d6b-1ef3-412a-ad2f-be6f039f3112"><![CDATA[(7)]]></kuvatavNr>
							<sisuTekst id="de0af522-d8e7-42b2-aa6d-38a4c039fc08">
								<tavatekst id="96b49ac1-7b40-41f7-9857-da4ad6605941">Mikrolülituse topoloogia registreerimise taotluse menetluse taastamise nõude esitamise eest tasutakse riigilõivu 32 eurot.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para101lg8">
							<loigeNr id="d0e89f5c-765a-4d63-98ec-1a13a73338fe">8</loigeNr>
							<kuvatavNr id="1aa3b836-d725-4161-8962-7ca336407fe7"><![CDATA[(8)]]></kuvatavNr>
							<sisuTekst id="5856f09d-dc6b-41c3-809d-d278b1053097">
								<tavatekst id="8a93a92c-f53e-4f80-a89f-a25b5738ce39">Rahvusvahelise patenditaotluse ja kasuliku mudeli rahvusvahelise registreerimise taotluse siseriikliku menetluse taastamise eest tasutakse riigilõivu 32 eurot.</tavatekst>
							</sisuTekst>
						</loige>
					</paragrahv>
					<paragrahv id="para102">
						<paragrahvNr id="98de2d39-3be1-4520-a528-c0ae373a32d0">102</paragrahvNr>
						<kuvatavNr id="72097f28-48ef-4fe5-a8fa-33e3c1dd62ad"><![CDATA[§ 102. ]]></kuvatavNr>
						<paragrahvPealkiri id="2fa917ca-76b3-443a-948b-6c1b66ff1095">Registreeringu tegemine</paragrahvPealkiri>
						<loige id="para102lg1">
							<loigeNr id="accecf03-94fd-4702-ae7c-169c807ec14c">1</loigeNr>
							<kuvatavNr id="a427fdd5-00cf-4541-96bf-af8031e4a320"><![CDATA[(1)]]></kuvatavNr>
							<muutmismarge id="1955fef7-42f4-4a36-a7f4-99c27d799121">
								<tavatekst id="4930350a-b872-4cee-973f-1ce1f8b0cd2f">Kehtetu - </tavatekst>
								<avaldamismarge id="5d6febe0-d97c-45d8-bd54-9c91fa123903">
									<RTosa id="1d6eb914-eaa0-4f0f-95cf-6ba20929e224">RT I</RTosa>
									<avaldamineKuupaev id="c93fda60-dd0e-4b0b-a046-192066f918eb">2019-03-19</avaldamineKuupaev>
									<RTartikkel id="65384b61-2aa8-4529-8de1-a9d4dc24ecf6">5</RTartikkel>
									<aktViide id="73dbc2ce-3d2c-4e9e-8f3f-b77071b09bdd">119032019005</aktViide>
								</avaldamismarge>
								<joustumine id="d6ffd2d1-b05a-42c1-bf82-cd89d4a5e0f3">2019-04-01</joustumine>
							</muutmismarge>
						</loige>
						<loige id="para102lg2">
							<loigeNr id="d377a5b1-5d65-4948-af58-5369ab027404">2</loigeNr>
							<kuvatavNr id="d903d562-46f2-493c-bbdf-16e5bed272b8"><![CDATA[(2)]]></kuvatavNr>
							<sisuTekst id="50fa1a07-08a8-4f1f-8ed9-c624e1658a33">
								<tavatekst id="9b14e013-ec2c-4b11-88bb-210f477ca335">Leiutise registreerimise eest patendiregistris tasutakse riigilõivu 96 eurot.</tavatekst>
							</sisuTekst>
						</loige>
					</paragrahv>
					<paragrahv id="para103">
						<paragrahvNr id="03383d05-9c03-4df0-865c-8a15caf45937">103</paragrahvNr>
						<kuvatavNr id="1df7dc3e-8be0-48c7-bf0c-b6f157915bf2"><![CDATA[§ 103. ]]></kuvatavNr>
						<paragrahvPealkiri id="250aa743-021a-40e5-b74b-dd31b38446fd">Patendis ja kasulikus mudelis tehtud muudatuste teate avaldamine</paragrahvPealkiri>
						<loige id="para103lg1">
							<loigeNr id="0248e08a-48c9-4e9a-95af-30631e922011">1</loigeNr>
							<kuvatavNr id="59b3be2f-22b4-4453-b14f-7fc928ed75b4"><![CDATA[(1)]]></kuvatavNr>
							<sisuTekst id="fca31733-351f-4f3b-93be-eb0834f34f13">
								<tavatekst id="c4cb5671-39eb-4b0a-a681-2d999fb8b212">Patendikirjelduse paranduste teate avaldamise eest tasutakse riigilõivu 32 eurot.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para103lg2">
							<loigeNr id="9414268f-9a1c-4a6f-9c68-cffc881e43d8">2</loigeNr>
							<kuvatavNr id="c6433408-7887-414a-a448-f44cb8a1793e"><![CDATA[(2)]]></kuvatavNr>
							<sisuTekst id="efb52b51-9f93-4a20-91e3-bc024b04c652">
								<tavatekst id="18d0ba4b-3ea3-4a8b-a055-e86285fce9e7">Patendinõudluse muutmise teate ja uue patendikirjelduse avaldamise eest tasutakse riigilõivu 45 eurot.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para103lg3">
							<loigeNr id="c6e8deb8-8ce7-4ced-afc3-df72057e2b58">3</loigeNr>
							<kuvatavNr id="8730f9b5-414f-42d9-ac95-05b89f4c33f6"><![CDATA[(3)]]></kuvatavNr>
							<sisuTekst id="eca7006d-f10b-4772-888e-ef078ffb7b49">
								<tavatekst id="4acacb06-eb5a-4fe2-8e61-0dab621e86e3">Kasuliku mudeli kirjelduse paranduste teate avaldamise eest tasutakse riigilõivu 32 eurot.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para103lg4">
							<loigeNr id="73848892-00e1-4bef-bb43-e59c58bdea7e">4</loigeNr>
							<kuvatavNr id="b4ea50cd-4686-4d13-a4bf-e19824b7ad24"><![CDATA[(4)]]></kuvatavNr>
							<sisuTekst id="382f4b37-7a5b-4360-aeb6-b76c87cb28b5">
								<tavatekst id="67214b54-34c8-466a-a7a6-d3e5eb803422">Kasuliku mudeli nõudluse muutmise teate ja uue kasuliku mudeli kirjelduse avaldamise eest tasutakse riigilõivu 45 eurot.</tavatekst>
							</sisuTekst>
						</loige>
					</paragrahv>
					<paragrahv id="para104">
						<paragrahvNr id="8907a221-f4a4-4c1d-bab0-a6bbbf816c44">104</paragrahvNr>
						<kuvatavNr id="bd4d5b85-39f6-4338-95f2-954c33f4c517"><![CDATA[§ 104. ]]></kuvatavNr>
						<paragrahvPealkiri id="1713dacc-99f2-4da3-b303-eae23bbc114e">Kehtivuse pikendamine ja jõushoidmine</paragrahvPealkiri>
						<loige id="para104lg1">
							<loigeNr id="aa8b04cc-6439-47c7-b3df-3ea05ab805c5">1</loigeNr>
							<kuvatavNr id="88923b81-9ca0-4e62-bbfa-0bc9c8058351"><![CDATA[(1)]]></kuvatavNr>
							<sisuTekst id="b2994bee-3604-47c5-b5d0-d5bf100f70d2">
								<tavatekst id="261cfc28-25df-4bab-845f-addc9ceaef55">Kaubamärgi õiguskaitse kehtivusaja pikendamise avalduse esitamise eest tasutakse riigilõivu 195 eurot.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para104lg2">
							<loigeNr id="903a2410-ccd7-49c0-b578-d1a95f0e906e">2</loigeNr>
							<kuvatavNr id="16231475-5502-4b67-b3ec-f68956ea9e27"><![CDATA[(2)]]></kuvatavNr>
							<sisuTekst id="82b299cb-d260-483f-9fda-00c6ff5e906a">
								<tavatekst id="9c5a83b8-a7ee-4e33-823f-a7c161b277c0">Kollektiivkaubamärgi, sertifitseerimismärgi ja garantiimärgi õiguskaitse kehtivusaja pikendamise avalduse esitamise eest tasutakse riigilõivu 245 eurot.</tavatekst>
							</sisuTekst>
							<muutmismarge id="8809cebf-305e-4f2b-a55a-a99f35940391">
								<avaldamismarge id="3a2bf210-7bed-4ec3-bea8-c71795f64fa4">
									<RTosa id="1f10fe0b-a16a-455c-a70d-7ddc81a53469">RT I</RTosa>
									<avaldamineKuupaev id="78c87035-f484-4c14-bd15-1bc8a666837c">2019-03-19</avaldamineKuupaev>
									<RTartikkel id="e3d0409c-8acb-498a-89b6-019abb879dab">5</RTartikkel>
									<aktViide id="893f59d7-6b86-435b-8557-5916d650ec02">119032019005</aktViide>
								</avaldamismarge>
								<joustumine id="a74fab87-5178-4822-9fed-05f01cd40c25">2019-04-01</joustumine>
							</muutmismarge>
						</loige>
						<loige id="para104lg3">
							<loigeNr id="7f2b1fd1-e681-4a55-a096-f08c9a30f8c2">3</loigeNr>
							<kuvatavNr id="871c5260-c411-4b26-b6b4-ee58be53e71b"><![CDATA[(3)]]></kuvatavNr>
							<sisuTekst id="1a85d020-2bb0-40d7-8e0e-b6c321c3784c">
								<tavatekst id="2206a51c-eb1d-44d0-b1a9-f4f45138d77f">Patenditaotluse, patendi ja Euroopa patendi jõushoidmise eest tasutakse riigilõivu:</tavatekst>
							</sisuTekst>
							<alampunkt id="para104lg3p1">
								<alampunktNr id="aac19e2c-30df-4eab-9875-32629a18710a">1</alampunktNr>
								<kuvatavNr id="40ef827b-8f7d-4c8a-8f62-056c14f8aec8"><![CDATA[1) ]]></kuvatavNr>
								<sisuTekst id="90d4a5a2-cfc8-481c-94a1-6f112b382a98">
									<tavatekst id="9a804dbb-823f-43a4-8311-04f8dec77c3b">esimese kehtivusaasta eest 26 eurot;</tavatekst>
								</sisuTekst>
							</alampunkt>
							<alampunkt id="para104lg3p2">
								<alampunktNr id="da5df6a5-686f-443b-a2ba-68eebd0d9af0">2</alampunktNr>
								<kuvatavNr id="dea58827-4d65-492a-97ec-14a3465dd7e4"><![CDATA[2) ]]></kuvatavNr>
								<sisuTekst id="d153493a-0f2b-4e41-8c08-ce58996c1199">
									<tavatekst id="8606f300-aea2-460a-ac1e-d570e694e678">teise kehtivusaasta eest 26 eurot;</tavatekst>
								</sisuTekst>
							</alampunkt>
							<alampunkt id="para104lg3p3">
								<alampunktNr id="b3fce2a2-d65c-4ee6-af36-54e658c39202">3</alampunktNr>
								<kuvatavNr id="a02a67a1-be18-43d8-bc1e-f2d2a18ef95f"><![CDATA[3) ]]></kuvatavNr>
								<sisuTekst id="a09ef495-364c-45c4-b267-5685bb7675db">
									<tavatekst id="91aeef52-4d03-4e1f-83f7-2834947adaba">kolmanda kehtivusaasta eest 64 eurot;</tavatekst>
								</sisuTekst>
							</alampunkt>
							<alampunkt id="para104lg3p4">
								<alampunktNr id="f915991b-b6aa-44fc-9e40-6b67ba00eef2">4</alampunktNr>
								<kuvatavNr id="593404c5-b70a-40a9-9e40-738e4815cfeb"><![CDATA[4) ]]></kuvatavNr>
								<sisuTekst id="b2086ebf-2461-45e4-b307-6f29f0c44423">
									<tavatekst id="a0a501b2-39e1-4444-85a1-327b613dcc75">neljanda kehtivusaasta eest 77 eurot;</tavatekst>
								</sisuTekst>
							</alampunkt>
							<alampunkt id="para104lg3p5">
								<alampunktNr id="6ad14d61-2c06-4d6e-a6af-92fa135ffa14">5</alampunktNr>
								<kuvatavNr id="b5f06ae5-82af-4c25-8b10-66ad66fdd00f"><![CDATA[5) ]]></kuvatavNr>
								<sisuTekst id="342376a9-c7fe-4683-8c30-bb6cc8183c84">
									<tavatekst id="c617c117-a664-44f4-81f9-3eef999205c5">viienda kehtivusaasta eest 96 eurot;</tavatekst>
								</sisuTekst>
							</alampunkt>
							<alampunkt id="para104lg3p6">
								<alampunktNr id="128ddbfa-998d-4658-85b0-2bbb3ec6d924">6</alampunktNr>
								<kuvatavNr id="1a7c5d3b-f9a6-4383-aed6-c9f640b8821d"><![CDATA[6) ]]></kuvatavNr>
								<sisuTekst id="404d4f12-dc3d-4ceb-aee1-8df2fd640411">
									<tavatekst id="c2702300-70a5-4d55-844a-a46f6d89402a">kuuenda kehtivusaasta eest 120 eurot;</tavatekst>
								</sisuTekst>
							</alampunkt>
							<alampunkt id="para104lg3p7">
								<alampunktNr id="27561fa9-8a89-437b-a218-9c0e46ccfe33">7</alampunktNr>
								<kuvatavNr id="a30ad730-7651-4497-b397-1b50161d58b8"><![CDATA[7) ]]></kuvatavNr>
								<sisuTekst id="8fac985e-d083-4563-9bf3-105d50523fad">
									<tavatekst id="e7c02c76-27b7-49cd-b323-d1eaf32c9a18">seitsmenda kehtivusaasta eest 135 eurot;</tavatekst>
								</sisuTekst>
							</alampunkt>
							<alampunkt id="para104lg3p8">
								<alampunktNr id="c9ab1f6c-e484-440f-989a-d0c6e34a09db">8</alampunktNr>
								<kuvatavNr id="d7ce7ed1-f919-403b-84cb-f995f01609f1"><![CDATA[8) ]]></kuvatavNr>
								<sisuTekst id="bdbca514-82e5-44bc-a9b8-142bd20de7b7">
									<tavatekst id="6aeaed5e-bf17-42af-b65f-352678652026">kaheksanda kehtivusaasta eest 155 eurot;</tavatekst>
								</sisuTekst>
							</alampunkt>
							<alampunkt id="para104lg3p9">
								<alampunktNr id="3f74d8ad-ef23-4b8b-9472-4101d8d06f0a">9</alampunktNr>
								<kuvatavNr id="507b1fc0-d20c-482b-981a-6f1f488bf076"><![CDATA[9) ]]></kuvatavNr>
								<sisuTekst id="d804e324-9f67-445f-8332-b663bb10e0fa">
									<tavatekst id="0d6f6be0-1b84-439d-93e8-e6d0cb2dba89">üheksanda kehtivusaasta eest 180 eurot;</tavatekst>
								</sisuTekst>
							</alampunkt>
							<alampunkt id="para104lg3p10">
								<alampunktNr id="b77e8211-35e4-401c-b701-4e3c9c93d28f">10</alampunktNr>
								<kuvatavNr id="d1bf325b-3cf2-4b35-b59e-c76a04e4e852"><![CDATA[10) ]]></kuvatavNr>
								<sisuTekst id="ecf66dbf-029a-440b-8c56-d5f2ac435aa9">
									<tavatekst id="56291fdd-6c63-4671-9ea9-7f064457a649">kümnenda kehtivusaasta eest 205 eurot;</tavatekst>
								</sisuTekst>
							</alampunkt>
							<alampunkt id="para104lg3p11">
								<alampunktNr id="6aaed9e0-d13a-4242-81a6-15155e01245a">11</alampunktNr>
								<kuvatavNr id="55c806c8-f9b7-425a-b10c-38a51e6e15b5"><![CDATA[11) ]]></kuvatavNr>
								<sisuTekst id="d59a7d06-aa9b-4f77-a071-95310a328c27">
									<tavatekst id="77fa96c4-e7ac-4808-9e82-13973e43eb48">üheteistkümnenda kehtivusaasta eest 245 eurot;</tavatekst>
								</sisuTekst>
							</alampunkt>
							<alampunkt id="para104lg3p12">
								<alampunktNr id="e5e5d5be-7911-4df0-95bf-2a7714ab98a5">12</alampunktNr>
								<kuvatavNr id="49d54e8e-fbcf-4bb2-aa1b-21ea30959e2d"><![CDATA[12) ]]></kuvatavNr>
								<sisuTekst id="498b5318-7c08-4e5f-bb40-da37a857c55b">
									<tavatekst id="01833e5c-a8fb-436d-ab46-5b0836002b50">kaheteistkümnenda kehtivusaasta eest 285 eurot;</tavatekst>
								</sisuTekst>
							</alampunkt>
							<alampunkt id="para104lg3p13">
								<alampunktNr id="acd3b0ce-1964-4e65-a6e4-e15ec4863bd7">13</alampunktNr>
								<kuvatavNr id="6e0814fd-f1c5-4a8e-9f77-80143a74617b"><![CDATA[13) ]]></kuvatavNr>
								<sisuTekst id="405a02c3-74f8-46f5-84e8-ea7ec563e956">
									<tavatekst id="02a88a21-7cec-4449-b2f0-1343a20ed11a">kolmeteistkümnenda kehtivusaasta eest 320 eurot;</tavatekst>
								</sisuTekst>
							</alampunkt>
							<alampunkt id="para104lg3p14">
								<alampunktNr id="dc5d98fe-1c16-4f34-9b09-2f509c03fe3a">14</alampunktNr>
								<kuvatavNr id="3e424f4b-9076-448c-9393-9d0211aa4920"><![CDATA[14) ]]></kuvatavNr>
								<sisuTekst id="5748eed3-e28e-4a8e-9654-9f031d76e15d">
									<tavatekst id="a5593c9b-1a63-4f75-bd8f-16304a27d61b">neljateistkümnenda kehtivusaasta eest 360 eurot;</tavatekst>
								</sisuTekst>
							</alampunkt>
							<alampunkt id="para104lg3p15">
								<alampunktNr id="b811c0c4-e8ee-40e9-a4dd-3d8ca982dfee">15</alampunktNr>
								<kuvatavNr id="ffe3fa90-aecd-44ef-8a8a-4387dd573e3b"><![CDATA[15) ]]></kuvatavNr>
								<sisuTekst id="c1812ffb-7c9b-4e50-9587-05882fbd6505">
									<tavatekst id="ab91aa68-f576-49fc-8609-11faf0c549b4">viieteistkümnenda kehtivusaasta eest 405 eurot;</tavatekst>
								</sisuTekst>
							</alampunkt>
							<alampunkt id="para104lg3p16">
								<alampunktNr id="7a47553e-66c3-4779-8e2e-c75b12268878">16</alampunktNr>
								<kuvatavNr id="ba759917-5e94-4941-ac7d-7ac7dae110d7"><![CDATA[16) ]]></kuvatavNr>
								<sisuTekst id="147899ab-ed2f-44d7-8e1d-8e321141a822">
									<tavatekst id="3bfaeb33-cf45-46fe-9283-13c90bb49385">kuueteistkümnenda kehtivusaasta eest 450 eurot;</tavatekst>
								</sisuTekst>
							</alampunkt>
							<alampunkt id="para104lg3p17">
								<alampunktNr id="cac6218b-0691-443e-a514-eeaa6caad857">17</alampunktNr>
								<kuvatavNr id="eca94ea8-1e6d-4589-8213-ea93e66611b0"><![CDATA[17) ]]></kuvatavNr>
								<sisuTekst id="b7bfb97c-3154-4e3d-99ee-03bfe5d743aa">
									<tavatekst id="3afcfe4b-b6ff-4d28-90ee-d4ba306d00f3">seitsmeteistkümnenda kehtivusaasta eest 495 eurot;</tavatekst>
								</sisuTekst>
							</alampunkt>
							<alampunkt id="para104lg3p18">
								<alampunktNr id="f1bc4239-b699-4f7e-bbf1-1394a91c05f5">18</alampunktNr>
								<kuvatavNr id="5184b0d2-3542-414a-bf63-b5057fd0222b"><![CDATA[18) ]]></kuvatavNr>
								<sisuTekst id="edd5ff4d-ec0c-4a64-94f7-9b10f62815f4">
									<tavatekst id="0d2e6ec9-6e6d-4407-ab35-6aadeec04cb0">kaheksateistkümnenda kehtivusaasta eest 540 eurot;</tavatekst>
								</sisuTekst>
							</alampunkt>
							<alampunkt id="para104lg3p19">
								<alampunktNr id="bea43a56-113a-45a4-afeb-c68480c19f6c">19</alampunktNr>
								<kuvatavNr id="8e324147-ed99-46ba-8325-0dbfddfd8c35"><![CDATA[19) ]]></kuvatavNr>
								<sisuTekst id="8a319912-6308-41e4-a7ad-ca178b074d2c">
									<tavatekst id="41ae3538-e4c7-4929-88d8-5a3f50f3c196">üheksateistkümnenda kehtivusaasta eest 585 eurot;</tavatekst>
								</sisuTekst>
							</alampunkt>
							<alampunkt id="para104lg3p20">
								<alampunktNr id="d628e542-1df4-4ae0-9fda-58c57e9ad25b">20</alampunktNr>
								<kuvatavNr id="21b42704-1590-4c5a-a553-7848e07320c3"><![CDATA[20) ]]></kuvatavNr>
								<sisuTekst id="3b2aec69-472f-4916-8862-e1f772369fe4">
									<tavatekst id="ef1a837c-7273-47e6-9030-67f3c74afa9b">kahekümnenda kehtivusaasta eest 630 eurot.</tavatekst>
								</sisuTekst>
							</alampunkt>
						</loige>
						<loige id="para104lg4">
							<loigeNr id="ed570ae1-934a-4be7-b16a-b8ac8794c97f">4</loigeNr>
							<kuvatavNr id="89f0c617-3dba-4b06-8fd7-49d28285f444"><![CDATA[(4)]]></kuvatavNr>
							<sisuTekst id="04900b6d-b6fc-4159-9f8c-c0a51d6acaeb">
								<tavatekst id="60a1774c-cd56-456b-92a7-385126d71370">Meditsiinitoote või taimekaitsetoote täiendava kaitse jõushoidmiseks tasutakse esimese ja iga järgmise täiendava õiguskaitse kehtivusaasta eest riigilõivu 630 eurot.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para104lg5">
							<loigeNr id="829ec987-3839-4344-9fe4-ab1416df6dad">5</loigeNr>
							<kuvatavNr id="94da1af1-16bd-4765-9606-fd826206951f"><![CDATA[(5)]]></kuvatavNr>
							<sisuTekst id="73d05eab-ed1a-4714-b032-a8655e92f2c6">
								<tavatekst id="59236006-191c-4df3-972d-ca38afe1b4c9">Kasuliku mudeli registreeringu kehtivuse pikendamisel tasutakse riigilõivu:</tavatekst>
							</sisuTekst>
							<alampunkt id="para104lg5p1">
								<alampunktNr id="802f1144-53c4-4259-8562-cfd015fba50e">1</alampunktNr>
								<kuvatavNr id="e6f1f4e2-520f-420e-b0bc-05504e27c94a"><![CDATA[1) ]]></kuvatavNr>
								<sisuTekst id="a1da6f7f-38b2-4bdd-8723-1e7ebc0c377e">
									<tavatekst id="b47fa356-dcdf-46a7-9888-4801749ce28a">esimese pikendamise eest 195 eurot;</tavatekst>
								</sisuTekst>
							</alampunkt>
							<alampunkt id="para104lg5p2">
								<alampunktNr id="b066a05c-8017-4a85-a796-01b1caba9008">2</alampunktNr>
								<kuvatavNr id="d3f90220-dd7b-44fa-a8b4-16a3b6bb5bce"><![CDATA[2) ]]></kuvatavNr>
								<sisuTekst id="f7fc6c9b-2586-496f-816b-a01f199d0ad1">
									<tavatekst id="2975b304-3f06-4b89-904c-3acfef7ca783">teise pikendamise eest 260 eurot.</tavatekst>
								</sisuTekst>
							</alampunkt>
						</loige>
						<loige id="para104lg6">
							<loigeNr id="53c639ed-42b4-4c7c-a6e0-90bfebdcea58">6</loigeNr>
							<kuvatavNr id="71ceed2d-4f9e-4906-871a-709109109271"><![CDATA[(6)]]></kuvatavNr>
							<sisuTekst id="c0fa7848-6978-478d-910e-dcac4f821a3a">
								<tavatekst id="598e27cf-8814-4c2f-bc40-1cd43b7ce14a">Tööstusdisainilahenduse registreeringu kehtivuse pikendamisel tasutakse riigilõivu:</tavatekst>
							</sisuTekst>
							<alampunkt id="para104lg6p1">
								<alampunktNr id="41aa0c74-54fb-4d6d-b22e-04858cbd2379">1</alampunktNr>
								<kuvatavNr id="e24bee07-fbe4-48d9-bea4-4856ee8237ae"><![CDATA[1) ]]></kuvatavNr>
								<sisuTekst id="c44aaa8f-f519-438c-88d7-f6942f285774">
									<tavatekst id="1a92796e-699a-49bf-b432-97dbbac06978">esimese pikendamise eest 130 eurot;</tavatekst>
								</sisuTekst>
							</alampunkt>
							<alampunkt id="para104lg6p2">
								<alampunktNr id="1a09cd26-a642-4ba9-8a46-1d10cb0fd348">2</alampunktNr>
								<kuvatavNr id="efdeff92-d3da-4a76-bc37-b76aa151ed6f"><![CDATA[2) ]]></kuvatavNr>
								<sisuTekst id="49c31fb0-1418-4a55-b05c-4230e8bde94c">
									<tavatekst id="75e8cc32-d87c-457d-b11c-35b9d5e4a8f2">teise ja iga järgmise pikendamise eest 260 eurot.</tavatekst>
								</sisuTekst>
							</alampunkt>
						</loige>
						<loige id="para104lg7">
							<loigeNr id="8fda5eb9-3360-4084-a772-c441a63bf5cd">7</loigeNr>
							<kuvatavNr id="8314be55-c424-45a7-ac82-f36d806e2080"><![CDATA[(7)]]></kuvatavNr>
							<sisuTekst id="62aab643-6588-4faf-b9ac-b5973c84379f">
								<tavatekst id="339e396d-deac-43aa-8277-f1c2856351df">Pediaatrias kasutatavate ravimite täiendava kaitse pikendamise eest tasutakse riigilõivu 260 eurot.</tavatekst>
							</sisuTekst>
						</loige>
					</paragrahv>
					<paragrahv id="para105">
						<paragrahvNr id="01d6b0f5-9298-4e76-bc64-eb44ca5f18ab">105</paragrahvNr>
						<kuvatavNr id="298a2529-bb25-4576-a684-571d9ed7386f"><![CDATA[§ 105. ]]></kuvatavNr>
						<paragrahvPealkiri id="6f7b755d-d5f3-40f4-a16d-90c0c1d45628">Kaubamärgi rahvusvahelise registreeringu kehtivusaja pikendamine</paragrahvPealkiri>
						<loige id="para105lg1">
							<loigeNr id="0aab7f20-0a8c-434b-a1a3-dee04d5b54bd">1</loigeNr>
							<kuvatavNr id="f089f24f-682a-4142-ae70-a9957934a28e"><![CDATA[(1)]]></kuvatavNr>
							<sisuTekst id="1837c12f-f6a0-4aa3-b3c3-432441969d18">
								<tavatekst id="a8442214-d388-439c-9463-2de5298cae4d">Kaubamärgi rahvusvahelise registreeringu kehtivusaja pikendamise eest tasutakse riigilõivu 180 eurot.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para105lg2">
							<loigeNr id="60adfcf1-5003-4570-a526-778338ca2acd">2</loigeNr>
							<kuvatavNr id="2e1c864b-9691-422a-a72f-1718cbdfb8ee"><![CDATA[(2)]]></kuvatavNr>
							<sisuTekst id="b175e9ae-c4bc-403a-9905-958b03906409">
								<tavatekst id="64375570-6801-46cf-acdd-426ae9970983">Kollektiivkaubamärgi ja sertifitseerimismärgi rahvusvahelise registreeringu kehtivusaja pikendamise eest tasutakse riigilõivu 225 eurot.</tavatekst>
							</sisuTekst>
							<muutmismarge>
								<avaldamismarge>
									<RTosa>RT I</RTosa>
									<avaldamineKuupaev>2023-01-06</avaldamineKuupaev>
									<RTartikkel>2</RTartikkel>
									<aktViide>106012023002</aktViide>
								</avaldamismarge>
								<joustumine>2023-01-16</joustumine>
							</muutmismarge>
						</loige>
					</paragrahv>
					<paragrahv id="para106">
						<paragrahvNr id="aef88fd8-50bb-4ddf-8394-66e3a1071c9e">106</paragrahvNr>
						<kuvatavNr id="29cd416e-605c-4624-8397-3b75058ad38c"><![CDATA[§ 106. ]]></kuvatavNr>
						<paragrahvPealkiri id="4be21444-c8b5-434f-aacb-379550bf092d">Kehtivuse pikendamise ja jõushoidmise tähtaja ennistamine</paragrahvPealkiri>
						<loige id="para106lg1">
							<loigeNr id="30041ce6-7b4b-4655-b2cb-addaf503239d">1</loigeNr>
							<kuvatavNr id="cb79facf-7158-4770-8b50-f95763778c5e"><![CDATA[(1)]]></kuvatavNr>
							<sisuTekst id="8ab5bbe0-860b-4dad-8d07-61f9379daa79">
								<tavatekst id="fc5d4aec-d7fd-4fc4-810f-0012235a0ff5">Kaubamärgi õiguskaitse kehtivusaja pikendamise tähtaja ennistamise eest tasutakse riigilõivu 45 eurot.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para106lg2">
							<loigeNr id="dd324cb7-456a-4a1d-90a7-eab45bcc1e77">2</loigeNr>
							<kuvatavNr id="996d8a57-eb3b-42d5-8fe7-397de4aaef66"><![CDATA[(2)]]></kuvatavNr>
							<sisuTekst id="9fba9689-72c6-4b3b-90a0-3fe869906cf4">
								<tavatekst id="f72f8e04-bbc1-413e-ba50-e8b23055a7ef">Kollektiivkaubamärgi, sertifitseerimismärgi ja garantiimärgi õiguskaitse kehtivusaja pikendamise tähtaja ennistamise eest tasutakse riigilõivu 45 eurot.</tavatekst>
							</sisuTekst>
							<muutmismarge id="e02f83ba-3db4-4c23-9778-84c68b0d09e5">
								<avaldamismarge id="5f2f4a1b-ce22-41c8-a776-bacce0eaaaa1">
									<RTosa id="c44816d3-7cff-463c-9530-d66caf984e4c">RT I</RTosa>
									<avaldamineKuupaev id="d0c15de7-ced9-49ee-838e-401c24d6ee5c">2019-03-19</avaldamineKuupaev>
									<RTartikkel id="6381ee53-4cea-47f2-8473-af20c6b372e9">5</RTartikkel>
									<aktViide id="f57e9633-79b2-4d98-94a5-afda278e54fc">119032019005</aktViide>
								</avaldamismarge>
								<joustumine id="88e1684a-cb62-458c-9a2a-69eb14dd7d34">2019-04-01</joustumine>
							</muutmismarge>
						</loige>
						<loige id="para106lg3">
							<loigeNr id="9f3586ae-f749-4f3e-8e57-9e765109aa1d">3</loigeNr>
							<kuvatavNr id="20b62669-6f3c-4e9a-8772-248e9e8a85a4"><![CDATA[(3)]]></kuvatavNr>
							<sisuTekst id="b726547b-2ec2-4860-a80b-8e1fd970b41e">
								<tavatekst id="44990b6d-f2f8-41ff-82b3-8d09033d813b">Patenditaotluse, patendi ja Euroopa patendi jõushoidmise eest kehtivusaasta riigilõivu tasumisel pärast tasumistähtpäeva möödumist tasutakse käesoleva seaduse § 104 lõikes 3 sätestatud kehtivusaasta riigilõivumäär ja lisaks 10 protsenti sellest riigilõivumäärast.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para106lg4">
							<loigeNr id="5c942b9d-e870-469e-a430-55fa8f4bb3b3">4</loigeNr>
							<kuvatavNr id="bda2baf7-831b-4504-ae9e-30d831ce9168"><![CDATA[(4)]]></kuvatavNr>
							<sisuTekst id="f4c6572c-1750-4c06-9f0d-0a8906ad4f04">
								<tavatekst id="34cc4bd1-e18e-4a31-b5c8-3b71cdc22f35">Meditsiinitoote või taimekaitsetoote täiendava kaitse jõushoidmise eest tasutakse kehtivusaasta riigilõivu tasumisel pärast tasumistähtpäeva möödumist käesoleva seaduse § 104 lõikes 4 sätestatud kehtivusaasta riigilõivumäär ja lisaks 10 protsenti sellest riigilõivumäärast.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para106lg5">
							<loigeNr id="4af9b951-e280-4849-adba-bd3a20097b4c">5</loigeNr>
							<kuvatavNr id="c7be48a7-c3f8-4301-84ca-e759beec6cdb"><![CDATA[(5)]]></kuvatavNr>
							<sisuTekst id="a6e9221c-d004-4b1f-a01d-3d4f7c2bf700">
								<tavatekst id="62dd0dfd-e4d0-4640-8343-889b8c0f27f8">Kasuliku mudeli registreeringu kehtivuse pikendamise eest pärast tasumistähtpäeva möödumist tasutakse käesoleva seaduse § 104 lõike 5 punktis 1 või 2 toodud riigilõivumäär ja lisaks 10 protsenti vastavast riigilõivumäärast.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para106lg6">
							<loigeNr id="a17fc87e-f2d5-4fab-b672-6628c7a340f7">6</loigeNr>
							<kuvatavNr id="9d903817-657d-4604-85c5-1d2591c21460"><![CDATA[(6)]]></kuvatavNr>
							<sisuTekst id="fd9bddea-c3f9-422c-9871-b3a53b8ba4ac">
								<tavatekst id="a9564bfc-7266-405d-a3cd-63398dd37939">Tööstusdisainilahenduse kaitse kehtivuse pikendamise tähtaja ennistamise eest tasutakse riigilõivu 45 eurot.</tavatekst>
							</sisuTekst>
						</loige>
					</paragrahv>
					<paragrahv id="para107">
						<paragrahvNr id="8a0d3ff0-b333-4b62-97a5-a8e4466eaa30">107</paragrahvNr>
						<kuvatavNr id="92bda615-e45c-46a0-86ce-cabf53e9ae7f"><![CDATA[§ 107. ]]></kuvatavNr>
						<paragrahvPealkiri id="9374243f-6fa6-4103-8607-a91b7bf70da9">Registreeringu jagamine</paragrahvPealkiri>
						<loige id="para107lg1">
							<loigeNr id="38cf05ad-2ab9-460c-99eb-163ef836104e">1</loigeNr>
							<kuvatavNr id="35910aac-d52c-4827-bf32-a5727e269a2a"><![CDATA[(1)]]></kuvatavNr>
							<sisuTekst id="48bf0a99-77b9-4058-8677-dc441d16af54">
								<tavatekst id="226a39cb-b4b6-4fa2-938c-0565bbf56c57">Kaubamärgi registreeringu jagamise eest tasutakse riigilõivu 45 eurot.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para107lg2">
							<loigeNr id="eb22fd38-43d1-4d5c-9c35-ed400800be43">2</loigeNr>
							<kuvatavNr id="be8bf9e8-b7ed-4e46-a8ed-b6085ceae631"><![CDATA[(2)]]></kuvatavNr>
							<sisuTekst id="9e10c249-e283-4f88-b8fa-945b85db0333">
								<tavatekst id="d6e27448-4c37-45f9-91c4-e7c4ec4f393d">Tööstusdisainilahenduse registreeringu jagamise eest tasutakse riigilõivu 45 eurot.</tavatekst>
							</sisuTekst>
						</loige>
					</paragrahv>
					<paragrahv id="para108">
						<paragrahvNr id="5260f0ab-2ce7-4831-9cbf-f57a8f59b581">108</paragrahvNr>
						<kuvatavNr id="27f46706-0a50-4373-bfd7-925de3413de9"><![CDATA[§ 108. ]]></kuvatavNr>
						<paragrahvPealkiri id="1b9aa1eb-f12d-4f83-86aa-ae3bb2f16179">Registreeringu võõrandamine, üleminek ja litsentsimine</paragrahvPealkiri>
						<loige id="para108lg1">
							<loigeNr id="0ec14a32-d8f7-4fe5-b3da-44d3b42b8586">1</loigeNr>
							<kuvatavNr id="90faf3e4-f5a4-4d2d-8166-aae05637947e"><![CDATA[(1)]]></kuvatavNr>
							<sisuTekst id="97ea02e7-4879-440e-827b-7bf33984f02e">
								<tavatekst id="6ca458d8-6039-4aa6-ac66-ba4efda841a3">Kaubamärgi võõrandamise, ülemineku või litsentsi registreerimise kohta kande tegemise avalduse esitamise eest tasutakse riigilõivu 32 eurot.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para108lg2">
							<loigeNr id="4a568f34-8a3e-4fc4-a940-021ab088c7c9">2</loigeNr>
							<kuvatavNr id="df53d057-a5cc-4ca9-af1d-25fef83cf62b"><![CDATA[(2)]]></kuvatavNr>
							<sisuTekst id="45850e3d-c274-40ce-af10-92beb056b468">
								<tavatekst id="12dabd0e-c68c-480c-a250-18e21da7e7a3">Patendi ja Eestis kehtiva Euroopa patendi ülemineku, litsentsi või sundlitsentsi registreerimise kohta kande tegemise avalduse esitamise eest tasutakse riigilõivu 32 eurot.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para108lg3">
							<loigeNr id="7695ebb2-e278-4bc6-a481-fdcd04fb3ebc">3</loigeNr>
							<kuvatavNr id="ecbc6f9a-23c0-46be-beb4-a4120b308aed"><![CDATA[(3)]]></kuvatavNr>
							<sisuTekst id="95044033-3d94-477d-b19d-004fbfa36116">
								<tavatekst id="9e0ee1b5-9dff-4c36-82c8-c1913b4b27bc">Kasuliku mudeli ülemineku, litsentsi registreerimise, avaliku lihtlitsentsi andmise registreerimise või avaliku lihtlitsentsi saamise kohta kande tegemise eest registris tasutakse riigilõivu 32 eurot.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para108lg4">
							<loigeNr id="ee9a33f8-d1a9-44a8-a880-8569883912f3">4</loigeNr>
							<kuvatavNr id="86a4c257-098b-42cc-8e9b-119453ca4001"><![CDATA[(4)]]></kuvatavNr>
							<sisuTekst id="3e17add4-496e-46da-9e19-68924be2b134">
								<tavatekst id="939ee6df-00c0-4a79-a365-b21eb4b758b3">Tööstusdisainilahenduse ülemineku või litsentsi registreerimise kohta kande tegemise avalduse esitamise eest tasutakse riigilõivu 32 eurot.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para108lg5">
							<loigeNr id="20e561be-b699-4a7b-b17f-bb8dc17a8166">5</loigeNr>
							<kuvatavNr id="76f0479e-6d9f-4124-bc60-180c8febf5e1"><![CDATA[(5)]]></kuvatavNr>
							<sisuTekst id="a7363056-df5a-44f4-b009-fa1842db2c8c">
								<tavatekst id="876cf9d5-0f66-4fc9-a0b1-5231d67800a4">Mikrolülituse topoloogia ülemineku või litsentsi registreerimise kohta kande tegemise avalduse esitamise eest tasutakse riigilõivu 32 eurot.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para108lg6">
							<loigeNr id="42baea47-fdc4-42c4-9dc0-bf128b2ddd99">6</loigeNr>
							<kuvatavNr id="e22b4ae3-1f83-4f68-b5aa-a96cfe52700e"><![CDATA[(6)]]></kuvatavNr>
							<sisuTekst id="6c1d9614-231e-498c-86fc-266b206ec586">
								<tavatekst id="f4a8f9f7-f306-4572-8b71-5a1d02a1c2df">Geograafilise tähise registreeringu andmete muutmise kande tegemise avalduse esitamise eest tasutakse riigilõivu 32 eurot.</tavatekst>
							</sisuTekst>
						</loige>
					</paragrahv>
					<paragrahv id="para109">
						<paragrahvNr id="e160daa8-a5e4-4e24-93bd-64db9d29901a">109</paragrahvNr>
						<kuvatavNr id="6501c790-6cdb-4555-9efe-67dd092de2aa"><![CDATA[§ 109. ]]></kuvatavNr>
						<paragrahvPealkiri id="7abb5c96-4ee4-4bbd-a1e3-1dcaa4b44402">Euroopa patenditaotluse patendinõudluse ja Euroopa patendikirjelduse tõlke avalikustamine</paragrahvPealkiri>
						<loige id="para109lg1">
							<loigeNr id="a01be3e3-cd6a-4b2c-ab8b-13336318ca88">1</loigeNr>
							<kuvatavNr id="faf69e30-bb0d-4387-8173-5237e1315025"><![CDATA[(1)]]></kuvatavNr>
							<sisuTekst id="18a917cc-e2c9-4292-8c7f-33cbfb92eef6">
								<tavatekst id="a85a110b-cbd4-495c-8e83-70f200f28e2f">Euroopa patenditaotluse patendinõudluse tõlke avalikustamise eest tasutakse riigilõivu 32 eurot.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para109lg2">
							<loigeNr id="1e78d7eb-fe3c-41dd-92f0-f8a2c98393f1">2</loigeNr>
							<kuvatavNr id="3b12e7e5-de2d-402a-9d9c-1a1a3935be4b"><![CDATA[(2)]]></kuvatavNr>
							<sisuTekst id="135efdff-c14c-4a6e-9026-14706a593468">
								<tavatekst id="191490c7-33cf-47f9-b801-5555f1f9ec7e">Euroopa patendikirjelduse tõlke või muudetud Euroopa patendikirjelduse tõlke avalikustamise eest tasutakse riigilõivu 45 eurot.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para109lg3">
							<loigeNr id="9196f13a-65f7-4f8d-b4c9-89b2a4213ad6">3</loigeNr>
							<kuvatavNr id="83a44288-0e86-40dd-a736-6557c4e15b87"><![CDATA[(3)]]></kuvatavNr>
							<sisuTekst id="2b3ab6e3-9602-4f0f-9d8d-a9671a538376">
								<tavatekst id="7a9d6063-614e-45fd-b43f-a2c557675353">Euroopa patendikirjelduse tõlke või muudetud Euroopa patendikirjelduse tõlke esitamise tähtaja pikendamise eest tasutakse riigilõivu 32 eurot.</tavatekst>
							</sisuTekst>
						</loige>
					</paragrahv>
					<paragrahv id="para110">
						<paragrahvNr id="1c8783fd-f5f6-4d74-88b2-81751b576d00">110</paragrahvNr>
						<kuvatavNr id="b31b06aa-b888-4a1f-b6b4-34fa658c7abd"><![CDATA[§ 110. ]]></kuvatavNr>
						<paragrahvPealkiri id="4c417d34-bff7-49db-b9fb-57c56d3cd108">Rahvusvahelise patenditaotluse patendinõudluse eestikeelse tõlke avalikustamine</paragrahvPealkiri>
						<loige id="para110lg1">
							<sisuTekst id="5ead28af-ae04-426f-b7b7-49cccd77c614">
								<tavatekst id="b941be69-cd85-45fb-a904-73e628393733">Rahvusvahelise patenditaotluse patendinõudluse eestikeelse tõlke avalikustamise eest tasutakse riigilõivu 32 eurot.</tavatekst>
							</sisuTekst>
						</loige>
					</paragrahv>
					<paragrahv id="para111">
						<paragrahvNr id="605fa28e-75b3-45a2-9bbb-c72b5aead99f">111</paragrahvNr>
						<kuvatavNr id="12c05cc9-207f-4707-99c9-0630ec73012d"><![CDATA[§ 111. ]]></kuvatavNr>
						<paragrahvPealkiri id="2d32cd6f-1552-4cd8-a113-42657b5d7bee">Rahvusvahelise patenditaotluse ja kasuliku mudeli rahvusvahelise registreerimise taotluse eestikeelse tõlke esitamise tähtaja pikendamine</paragrahvPealkiri>
						<loige id="para111lg1">
							<sisuTekst id="dc184b6a-0ad0-4cb6-9c8b-6ba62b908816">
								<tavatekst id="2ae8c759-67fc-4bf1-b508-cefbd4073aee">Rahvusvahelise patenditaotluse või kasuliku mudeli rahvusvahelise registreerimise taotluse eestikeelse tõlke esitamise tähtaja pikendamise eest tasutakse riigilõivu 32 eurot.</tavatekst>
							</sisuTekst>
						</loige>
					</paragrahv>
					<paragrahv id="para111b1">
						<paragrahvNr ylaIndeks="1">111</paragrahvNr>
						<kuvatavNr><![CDATA[§ 111<sup>1</sup>. ]]></kuvatavNr>
						<paragrahvPealkiri>Meditsiinitoote täiendava kaitsega seotud teate esitamine ja avaldamine</paragrahvPealkiri>
						<loige id="para111b1lg1">
							<loigeNr/>
							<kuvatavNr/>
							<sisuTekst>
								<tavatekst>Euroopa Parlamendi ja nõukogu määruse (EÜ) nr 469/2009 ravimite täiendava kaitse tunnistuse kohta (ELT L 152, 16.06.2009, lk 1–10) artikli 5 lõike 2 punktides b ja c osutatud teate esitamise ja avaldamise eest tasutakse riigilõivu 32 eurot.</tavatekst>
							</sisuTekst>
							<muutmismarge>
								<avaldamismarge>
									<RTosa>RT I</RTosa>
									<avaldamineKuupaev>2023-01-06</avaldamineKuupaev>
									<RTartikkel>2</RTartikkel>
									<aktViide>106012023002</aktViide>
								</avaldamismarge>
								<joustumine>2023-01-16</joustumine>
							</muutmismarge>
						</loige>
					</paragrahv>
					<paragrahv id="para112">
						<paragrahvNr id="a6eb5dbc-7f5d-4893-bad8-1ddf6de2b856">112</paragrahvNr>
						<kuvatavNr id="b224719e-3d23-4414-a8b5-881718d8aa90"><![CDATA[§ 112. ]]></kuvatavNr>
						<paragrahvPealkiri id="c02c321d-94ce-43e4-bf33-53a712c4ea6c">Registritoimikuga tutvumine</paragrahvPealkiri>
						<loige id="para112lg1">
							<sisuTekst id="fe8f9a67-7a4f-4e99-a9cf-aea0ad3fff40">
								<tavatekst id="7412b2ea-e972-4064-adc2-d85bf4475d39">Registritoimikuga tutvumise eest tasutakse riigilõivu 8 eurot.</tavatekst>
							</sisuTekst>
						</loige>
					</paragrahv>
					<paragrahv id="para113">
						<paragrahvNr id="0cc91aea-0910-4542-9cb2-ff90f8102182">113</paragrahvNr>
						<kuvatavNr id="5c10ef43-62e1-4ed2-9fff-e80296de82a1"><![CDATA[§ 113. ]]></kuvatavNr>
						<paragrahvPealkiri id="0da309a9-d6f5-4e87-977a-78a5dbf671ba">Dokumentide väljastamine</paragrahvPealkiri>
						<loige id="para113lg1">
							<loigeNr id="eb4c3ad4-a010-4a50-91d6-bbbf9e19ad5d">1</loigeNr>
							<kuvatavNr id="f4d23a25-5207-4fab-ae32-ddba666a1c31"><![CDATA[(1)]]></kuvatavNr>
							<sisuTekst id="c2722692-204b-4443-9174-79b4a89119de">
								<tavatekst id="adc5eac3-3419-44cf-b3c7-464c79fa70a2">Prioriteeti või prioriteedinõuet tõendava dokumendi väljastamise eest tasutakse riigilõivu 16 eurot.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para113lg2">
							<loigeNr id="2ae949bb-0302-442b-8fb0-52ea0d0dfbfc">2</loigeNr>
							<kuvatavNr id="928b4d1e-6ff3-4816-826d-8e4371f42dc5"><![CDATA[(2)]]></kuvatavNr>
							<sisuTekst id="062a23f9-3985-41b7-8e09-9ec75760a684">
								<tavatekst id="31151df6-59e5-48cb-ae7c-825664078ace">Tööstusomandi kaitse tunnistuse ärakirja või duplikaadi või patendikirja duplikaadi väljastamise eest tasutakse riigilõivu 16 eurot.</tavatekst>
							</sisuTekst>
							<muutmismarge id="4a35c2a1-823d-46b8-a5bc-0c6a6e4ca5e4">
								<avaldamismarge id="4bb96c9e-63fe-4c32-b614-920696c97c97">
									<RTosa id="81f31488-d7e1-46c8-80d8-ae68dc1a586b">RT I</RTosa>
									<avaldamineKuupaev id="5b8b04e6-0485-4018-8643-df1d393648da">2019-03-19</avaldamineKuupaev>
									<RTartikkel id="488236cd-f9c8-4b89-9777-d794a7c589f8">4</RTartikkel>
									<aktViide id="7c34f025-d11f-46d5-9320-28e445519440">119032019004</aktViide>
								</avaldamismarge>
								<joustumine id="1db22c02-c113-460a-800b-b2498d1439a6">2019-03-29</joustumine>
							</muutmismarge>
						</loige>
						<loige id="para113lg3">
							<loigeNr id="29b01619-2dbf-4f2f-b420-e8511bd78679">3</loigeNr>
							<kuvatavNr id="ec92cbeb-5cc2-45bc-b20a-7fa0658b6a14"><![CDATA[(3)]]></kuvatavNr>
							<sisuTekst id="9c2d053f-2616-4fe1-bc39-cad1a4ad477e">
								<tavatekst id="1d209bfc-09aa-4aa0-8de0-726a1a79be21">Registritoimiku dokumendi kinnitatud ärakirja või kirje väljatrüki väljastamise eest tasutakse riigilõivu 1 euro iga formaadis A4 lehekülje eest.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para113lg3b1">
							<loigeNr id="c4652f03-872c-4f65-8f64-89138ec05fb8" ylaIndeks="1">3</loigeNr>
							<kuvatavNr id="06901873-5d5c-4e16-a90b-c5ff73d2ada8"><![CDATA[(3<sup>1</sup>)]]></kuvatavNr>
							<sisuTekst id="610f0cdc-f7e8-4a8d-9879-36458ef27e86">
								<tavatekst id="16c043dd-a35b-4c43-bc52-d6419f068afa">Käesoleva paragrahvi lõikes 3 nimetatud dokumendi elektrooniliselt väljastamise eest ühe tööstusomandi objekti kohta tasutakse riigilõivu 8 eurot.</tavatekst>
							</sisuTekst>
							<muutmismarge id="2472b6c1-67d2-4adc-aae6-eb77241cae40">
								<avaldamismarge id="756c0870-54d5-4ff8-b267-ce143a056d21">
									<RTosa id="08e224a0-88ab-413a-8378-11c99bab4733">RT I</RTosa>
									<avaldamineKuupaev id="44bef4e6-3ec5-402d-b042-a47b1df36860">2019-03-19</avaldamineKuupaev>
									<RTartikkel id="0ae46229-fd7b-4d3a-88b2-b4d17689894c">4</RTartikkel>
									<aktViide id="f525bc9c-f0bd-429a-ab4a-024e68c147a2">119032019004</aktViide>
								</avaldamismarge>
								<joustumine id="1aab9813-f8a9-41f6-aeeb-bb2eb5d99709">2019-03-29</joustumine>
							</muutmismarge>
						</loige>
						<loige id="para113lg4">
							<loigeNr id="b0b022b9-9040-442f-9079-7481bb415071">4</loigeNr>
							<kuvatavNr id="52b8819a-c7e0-4cb7-8541-724fc64d5e47"><![CDATA[(4)]]></kuvatavNr>
							<sisuTekst id="baa74903-a260-4deb-a0f5-deb9f8952689">
								<tavatekst id="4c6a2eef-bde4-43c9-9d3c-4189d84196ea">Patendikirjelduse, kasuliku mudeli kirjelduse, leiutiskirjelduse, patendinõudluse, kasuliku mudeli nõudluse, jooniste ja muu illustreeriva materjali, Euroopa patenditaotluse patendinõudluse tõlke või rahvusvahelise patenditaotluse patendinõudluse tõlke kinnitatud ärakirja väljastamise eest tasutakse riigilõivu 2 eurot esimese formaadis A4 lehekülje eest ja 0,20 eurot iga järgmise formaadis A4 lehekülje eest.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para113lg4b1">
							<loigeNr id="02af38b1-c675-4025-87f0-7c33e5a72b8e" ylaIndeks="1">4</loigeNr>
							<kuvatavNr id="f3a1f35f-a7b1-4be6-91be-bb471532b340"><![CDATA[(4<sup>1</sup>)]]></kuvatavNr>
							<sisuTekst id="214e6c61-65e6-46fe-94b1-d70986607560">
								<tavatekst id="7cebb4e8-216a-4e56-8c57-0d86f6e40237">Käesoleva paragrahvi lõikes 4 nimetatud dokumendi elektrooniliselt väljastamise eest ühe tööstusomandi objekti kohta tasutakse riigilõivu 8 eurot.</tavatekst>
							</sisuTekst>
							<muutmismarge id="c5d1a6d6-33bc-4396-b542-548befc2cc67">
								<avaldamismarge id="42456934-3e9e-427b-a38f-570ded605aa1">
									<RTosa id="6b0509c5-1167-419d-9653-3d550d64a5b7">RT I</RTosa>
									<avaldamineKuupaev id="f3b83587-4380-4268-9d37-75567c162b2b">2019-03-19</avaldamineKuupaev>
									<RTartikkel id="57c1f5f5-f7c7-470a-813c-356a758cd63f">4</RTartikkel>
									<aktViide id="eeffbd59-6add-4648-8acf-74e05f5b9aa1">119032019004</aktViide>
								</avaldamismarge>
								<joustumine id="3b6361d2-947f-45f4-85b6-e45f0aa4d80c">2019-03-29</joustumine>
							</muutmismarge>
						</loige>
						<loige id="para113lg5">
							<loigeNr id="3c5c51f7-82db-4e88-a025-d456d8943816">5</loigeNr>
							<kuvatavNr id="93e790c3-5c90-4bba-971c-6b310f4a5010"><![CDATA[(5)]]></kuvatavNr>
							<sisuTekst id="c2134826-af05-4a66-ad99-e255e14d8043">
								<tavatekst id="f799e518-ae11-4b16-b1b1-3faf297d7af6">Patenditaotluse ekspertiisi käigus viidatud patendidokumentide või muude trükiste koopiate väljastamise eest tasutakse riigilõivu 10 eurot.</tavatekst>
							</sisuTekst>
						</loige>
					</paragrahv>
					<paragrahv id="para114">
						<paragrahvNr id="97f5337e-cc91-42c8-bb6a-1b3edc0768bc">114</paragrahvNr>
						<kuvatavNr id="df2acf3a-0a55-407c-aada-3f7ecc41423a"><![CDATA[§ 114. ]]></kuvatavNr>
						<paragrahvPealkiri id="15d823fb-a30a-461e-89ff-9788a3df5322">Teabe väljastamine</paragrahvPealkiri>
						<loige id="para114lg1">
							<loigeNr id="86296d63-f5ec-4df6-9470-d850f2b11246">1</loigeNr>
							<kuvatavNr id="c2578ecc-0d7f-4a09-82a4-24529704afa0"><![CDATA[(1)]]></kuvatavNr>
							<sisuTekst id="ee654dc7-a609-40da-acb5-6976eb11d313">
								<tavatekst id="23c0cdb8-df5e-4807-9763-676cbc833c15">Tööstusomandi registritest ja menetluse andmekogudest kirjaliku kinnitatud teabe väljastamise eest ühe tööstusomandi objekti kohta tasutakse riigilõivu 8 eurot.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para114lg2">
							<loigeNr id="3e7ca155-b927-488c-af96-ad0b3f173c10">2</loigeNr>
							<kuvatavNr id="a0115e14-59f2-4842-9116-94eadad1a59c"><![CDATA[(2)]]></kuvatavNr>
							<sisuTekst id="24725e36-48b7-4697-bbe3-c732a3bff2a5">
								<tavatekst id="7fbe4b45-8bfc-4dfb-adb4-85eb933630ff">Riiklikust patendivolinike registrist kirjaliku kinnitatud teabe väljastamise eest tasutakse riigilõivu 8 eurot iga dokumendi eest.</tavatekst>
							</sisuTekst>
						</loige>
					</paragrahv>
					<paragrahv id="para115">
						<paragrahvNr id="7c1a6230-7aef-4dc8-852b-0861c4c79a5f">115</paragrahvNr>
						<kuvatavNr id="90c5ce45-73cd-4e01-bd92-a2f898435069"><![CDATA[§ 115. ]]></kuvatavNr>
						<paragrahvPealkiri id="1bd11b6d-d1ff-49ee-bb1e-95413eec561d">Patendivoliniku kutse taotlemise avalduse esitamine</paragrahvPealkiri>
						<muutmismarge id="bd3f4845-85a6-4cc3-9128-18675ad90bdc">
							<tavatekst id="5957d05f-647f-40ad-9f7f-28dae3676d15">Kehtetu - </tavatekst>
							<avaldamismarge id="8a1e54b0-9bfc-44a8-8b96-5781e30b5d0f">
								<RTosa id="558111c5-5b30-472f-805e-22accac5ac95">RT I</RTosa>
								<avaldamineKuupaev id="2a84bb09-b306-4dfb-b2ef-de15ed123eb3">2018-05-31</avaldamineKuupaev>
