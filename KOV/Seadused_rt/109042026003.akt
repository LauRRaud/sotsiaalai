									<RTartikkel id="b5a2c92d-e0e0-47d5-9268-d9d15f9aac31">1</RTartikkel>
									<aktViide id="b6495047-c803-4cd1-a342-76e2fa23f050">121122019001</aktViide>
								</avaldamismarge>
								<joustumine id="1c5339de-486d-49a1-acbc-2f0b5fbeef3b">2020-07-01</joustumine>
							</muutmismarge>
						</paragrahv>
					</jaotis>
					<jaotis id="jaotis22">
						<jaotisNr>2</jaotisNr>
						<kuvatavNr><![CDATA[2. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Jäätmeseaduse alusel tehtavad toimingud</jaotisPealkiri>
						<paragrahv id="para126">
