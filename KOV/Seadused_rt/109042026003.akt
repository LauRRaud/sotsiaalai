						<jaotisPealkiri>Meditsiiniseadme seaduse alusel tehtavad toimingud</jaotisPealkiri>
						<muutmismarge>
							<avaldamismarge>
								<RTosa>RT I</RTosa>
								<avaldamineKuupaev>2024-11-20</avaldamineKuupaev>
								<RTartikkel>1</RTartikkel>
								<aktViide>120112024001</aktViide>
