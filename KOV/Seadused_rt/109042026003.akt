							<kuvatavNr><![CDATA[§ 120<sup>3</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri>Rahvusvahelise bussiveo muu dokumendi väljastamine</paragrahvPealkiri>
							<loige id="para120b3lg1">
								<loigeNr/>
								<kuvatavNr/>
								<sisuTekst>
									<tavatekst>Juhuveo kontrolldokumendi väljastamise eest tasutakse riigilõivu 50 eurot.</tavatekst>
