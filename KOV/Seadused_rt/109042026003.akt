									</avaldamismarge>
									<joustumine>2024-07-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para142b85lg8">
								<loigeNr>8</loigeNr>
								<kuvatavNr><![CDATA[(8)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Tootja rahvusvahelise valmistaja koodi ehk WMI-koodi omistamise eest tasutakse riigilõivu 400 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
