						</paragrahv>
						<paragrahv id="para339">
							<paragrahvNr id="d5411cf5-edb4-4a02-99ef-83730f712f8d">339</paragrahvNr>
							<kuvatavNr id="9e5592cd-342f-458e-ae20-217be0779a94"><![CDATA[§ 339. ]]></kuvatavNr>
							<paragrahvPealkiri id="33ffd53c-1c9e-43a7-a26e-8cbbfcbb509a">Abielulahutuse kande tegemine</paragrahvPealkiri>
							<loige id="para339lg1">
								<sisuTekst id="95d24222-ac44-49fe-8486-de6dd6682a82">
									<tavatekst id="182360d9-c2bb-484b-81e9-40e46847f387">Abielulahutuse kande tegemise eest tasutakse riigilõivu 90 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
						<paragrahv id="para340">
							<paragrahvNr id="8e5969de-bc1a-4349-b3df-ea43dc7cf089">340</paragrahvNr>
							<kuvatavNr id="f4859a83-d595-40d4-b80a-3542e1838c26"><![CDATA[§ 340. ]]></kuvatavNr>
							<paragrahvPealkiri id="2a42df5f-76ef-448d-8a2a-38b17c83fbc2">Tõendi väljastamine</paragrahvPealkiri>
							<loige id="para340lg1">
								<loigeNr id="6c8fa63a-9adc-40d9-b675-9454f1651052">1</loigeNr>
								<kuvatavNr id="738eae4c-5066-4744-a1bb-21eea9061332"><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst id="b75f79ee-811e-493a-ba6f-23f3ba8db68f">
									<tavatekst id="111bf106-1972-42f3-8e94-9300816dd0e9">Abieluvõimetõendi ning korduva sünnitõendi, surmatõendi, abielutõendi, abielulahutuse tõendi, nimemuutmise tõendi ja soo muutmise tõendi väljastamise eest tasutakse riigilõivu 20 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para340lg1b1">
								<loigeNr id="045a33ca-8b33-4b24-ad4d-f574a9db5347" ylaIndeks="1">1</loigeNr>
								<kuvatavNr id="9cc1e5da-87f5-4f9c-9cbb-ad25f5f6e1c4"><![CDATA[(1<sup>1</sup>)]]></kuvatavNr>
								<muutmismarge>
									<tavatekst>Kehtetu - </tavatekst>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2022-03-12</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>112032022001</aktViide>
									</avaldamismarge>
									<joustumine>2023-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para340lg1b2">
								<loigeNr ylaIndeks="2">1</loigeNr>
								<kuvatavNr><![CDATA[(1<sup>2</sup>)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Kui käesoleva paragrahvi lõikes 1 nimetatud tõend väljastatakse turvalises veebikeskkonnas ametniku vahetu sekkumiseta, tasutakse riigilõivu 5 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para340lg2">
								<loigeNr id="b96374ba-9a05-41e5-ad96-e74117e3558d">2</loigeNr>
								<kuvatavNr id="c17b9dfa-e451-4bd5-b192-168592dac1d2"><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst id="41923557-99e6-444c-b97a-2f3521944cbf">
									<tavatekst id="aee1df9b-69c4-4443-858f-02b0137dcf39">Perekonnaseisuasutuses säilitatavalt dokumendilt andmete teatisena või kinnitatud koopiana väljastamise eest tasutakse riigilõivu 20 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para340lg2b1">
								<loigeNr id="4a08efb2-5efe-41ed-a799-e0c56c8a1699" ylaIndeks="1">2</loigeNr>
								<kuvatavNr id="40f584b6-6093-463e-9ac2-a047d5d04b22"><![CDATA[(2<sup>1</sup>)]]></kuvatavNr>
								<muutmismarge>
									<tavatekst>Kehtetu - </tavatekst>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2022-03-12</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>112032022001</aktViide>
									</avaldamismarge>
									<joustumine>2023-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para340lg3">
								<loigeNr id="859aba97-3b4a-454e-8c34-cd2390e980b0">3</loigeNr>
								<kuvatavNr id="93d4770f-34e7-4d7e-bd48-7d1dc738daab"><![CDATA[(3)]]></kuvatavNr>
								<sisuTekst id="c302befa-ac61-4e49-9572-966b258faa1e">
									<tavatekst id="bc011f81-efff-4bf0-94d3-591914b09b9b">Nõukogu määruse (EL) 2019/1111, mis käsitleb kohtualluvust, abieluasjade ja vanemliku vastutusega seotud kohtuasjades tehtud lahendite tunnustamist ja täitmist ning rahvusvahelisi lapserööve (uuesti sõnastatud) (ELT L 178, 02.07.2019, lk 1–115), alusel tõendi väljastamise eest tasutakse riigilõivu 20 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para340lg3b1">
								<loigeNr ylaIndeks="1">3</loigeNr>
								<kuvatavNr><![CDATA[(3<sup>1</sup>)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Nõukogu määruse (EÜ) nr 2201/2003, mis käsitleb kohtualluvust ning kohtuotsuste tunnustamist ja täitmist kohtuasjades, mis on seotud abieluasjade ja vanemliku vastutusega, ning millega tunnistatakse kehtetuks määrus (EÜ) nr 1347/2000 (ELT L 338, 23.12.2003, lk 1–29), alusel tõendi väljastamise eest tasutakse riigilõivu 20 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para340lg4">
								<loigeNr id="7dc4e5aa-dd36-4e3e-ba17-fcdace787eb9">4</loigeNr>
								<kuvatavNr id="f3dcf1c6-e0fd-43a7-9649-554247067629"><![CDATA[(4)]]></kuvatavNr>
								<sisuTekst id="57801ec7-0785-48ef-8dc1-42ed79c58859">
									<tavatekst id="3fadffc3-08b1-4dfa-a769-93830a0dfdd3">Euroopa Parlamendi ja nõukogu määruse (EL) 2016/1191 alusel mitmekeelse standardvormi ja sellele lisatava perekonnasündmuse korduva tõendi või abieluvõimetõendi väljastamise eest tasutakse riigilõivu 40 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
					</jaotis>
					<jaotis id="jaotis133">
						<jaotisNr>2</jaotisNr>
						<kuvatavNr><![CDATA[2. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Nimeseaduse alusel tehtavad toimingud</jaotisPealkiri>
						<paragrahv id="para341">
							<paragrahvNr id="06ad8625-842b-4593-9dc7-49183cacebdf">341</paragrahvNr>
							<kuvatavNr id="72703645-95c4-4642-a470-f52de6b39af1"><![CDATA[§ 341. ]]></kuvatavNr>
							<paragrahvPealkiri id="9e501b0a-b98c-45e4-adf9-2f8f67c9f97c">Uue isikunime taotluse läbivaatamine</paragrahvPealkiri>
							<loige id="para341lg1">
								<loigeNr id="44af91e2-d98d-4baa-b6b8-3c42ea23bd9f">1</loigeNr>
								<kuvatavNr id="c622e5fd-93ac-4061-8d7e-806d41c74190"><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst id="8ebe2884-bd03-49b5-891c-6d5b1c8379c8">
									<tavatekst id="869dd3d8-3fe5-41a1-9ddb-cb86c3fff41a">Uue eesnime, perekonnanime või isikunime andmise või eesnime, perekonnanime või isikunime taastamise taotluse läbivaatamise eest tasutakse riigilõivu käesoleva seaduse §-s 262 sätestatud määras.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para341lg2">
								<loigeNr id="1f6f80ed-1b1b-4714-afe4-32d5c6ead9b5">2</loigeNr>
								<kuvatavNr id="25d4f298-70e8-4eb6-b5b8-fa12500fa4f2"><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst id="9f3b8030-a739-4bde-b9b7-e382d738850f">
									<tavatekst id="39d9e914-2474-43fa-b11c-b5578f0b5fcc">Uue eesnime, perekonnanime või isikunime andmise haldusakti ärakirja või väljavõtte korduva väljastamise eest tasutakse riigilõivu 20 eurot.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para341lg3">
								<loigeNr id="716f7eb7-20cc-4514-b098-d306e6b589ab">3</loigeNr>
								<kuvatavNr id="a7bd9ad9-641e-43dc-8595-6af0b816eff5"><![CDATA[(3)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Kui käesoleva paragrahvi lõikes 2 nimetatud haldusakti ärakiri või väljavõte väljastatakse turvalises veebikeskkonnas ametniku vahetu sekkumiseta, tasutakse riigilõivu 5 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2025-12-18</avaldamineKuupaev>
										<RTartikkel>4</RTartikkel>
										<aktViide>118122025004</aktViide>
									</avaldamismarge>
									<joustumine>2025-12-29</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
					</jaotis>
					<jaotis id="jaotis134">
						<jaotisNr>3</jaotisNr>
						<kuvatavNr><![CDATA[3. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Rahvastikuregistri seaduse alusel tehtavad toimingud</jaotisPealkiri>
						<muutmismarge id="20636ec4-ef86-4a3d-a012-86f88afa1e14">
							<avaldamismarge id="fe58e05a-b847-4f79-8533-95129d150170">
								<RTosa id="e747d948-96a9-4639-8555-d489f6ee2ce0">RT I</RTosa>
								<avaldamineKuupaev id="ebc2fadf-8123-4726-b445-c90cc933f131">2015-12-31</avaldamineKuupaev>
								<RTartikkel id="f40fa304-d206-4a9e-8aa5-f01921396637">31</RTartikkel>
								<aktViide id="089037f8-ea8f-409a-a6ac-13ac008d2e74">131122015031</aktViide>
							</avaldamismarge>
							<joustumine id="525570d1-2cbe-4205-931e-8915d83cb58a">2016-01-01</joustumine>
						</muutmismarge>
						<paragrahv id="para341b1">
							<paragrahvNr ylaIndeks="1">341</paragrahvNr>
							<kuvatavNr><![CDATA[§ 341<sup>1</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri>Rahvastikuregistri andmete väljastamise taotluse läbivaatamine isiku õigustatud huvi korral</paragrahvPealkiri>
							<muutmismarge>
								<avaldamismarge>
									<RTosa>RT I</RTosa>
									<avaldamineKuupaev>2022-03-12</avaldamineKuupaev>
									<RTartikkel>1</RTartikkel>
									<aktViide>112032022001</aktViide>
								</avaldamismarge>
								<joustumine>2023-01-01</joustumine>
							</muutmismarge>
							<loige id="para341b1lg1">
								<loigeNr/>
								<kuvatavNr/>
								<sisuTekst>
									<tavatekst>Isiku õigustatud huvi korral rahvastikuregistri andmete väljastamise taotluse läbivaatamise eest perekonnaseisutoimingute seaduse § 3 lõikes 3<sup>2</sup> sätestatud maakonnakeskuse kohaliku omavalitsuse üksuses tasutakse riigilõivu ühe isiku andmete kohta 20 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
						<paragrahv id="para341b2">
							<paragrahvNr ylaIndeks="2">341</paragrahvNr>
							<kuvatavNr><![CDATA[§ 341<sup>2</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri>Rahvastikuregistri väljavõtte väljastamine Euroopa Parlamendi ja nõukogu määruse (EL) 2016/1191 alusel</paragrahvPealkiri>
							<loige id="para341b2lg1">
								<loigeNr/>
								<kuvatavNr/>
								<sisuTekst>
									<tavatekst>Euroopa Parlamendi ja nõukogu määruse (EL) 2016/1191 alusel mitmekeelse standardvormi ja sellele lisatava rahvastikuregistri väljavõtte väljastamise eest tasutakse riigilõivu 40 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
						<paragrahv id="para341b3">
							<paragrahvNr ylaIndeks="3">341</paragrahvNr>
							<kuvatavNr><![CDATA[§ 341<sup>3</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri>Rahvastikuregistri andmete väljastamine isikule tema, tema alaealise lapse, eestkostetava, surnud abikaasa või surnud registreeritud elukaaslase kohta</paragrahvPealkiri>
							<muutmismarge>
								<avaldamismarge>
									<RTosa>RT I</RTosa>
									<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
									<RTartikkel>3</RTartikkel>
									<aktViide>129062024003</aktViide>
								</avaldamismarge>
								<joustumine>2025-01-01</joustumine>
							</muutmismarge>
							<loige id="para341b3lg1">
								<loigeNr>1</loigeNr>
								<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Isikule rahvastikuregistri seaduse § 45 lõikes 1 nimetatud rahvastikuregistri andmete väljastamise eest tasutakse riigilõivu 20 eurot ja notari poolt väljastamisel 5 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para341b3lg2">
								<loigeNr>2</loigeNr>
								<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Kui käesoleva paragrahvi lõikes 1 nimetatud andmed väljastatakse turvalises veebikeskkonnas ametniku vahetu sekkumiseta, tasutakse riigilõivu 5 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
						<paragrahv id="para341b4">
							<paragrahvNr ylaIndeks="4">341</paragrahvNr>
							<kuvatavNr><![CDATA[§ 341<sup>4</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri>Ruumi omanikule isiku kohta, kelle elukoha aadress rahvastikuregistris on temale kuuluva ruumi aadress, rahvastikuregistrist andmete väljastamise taotluse läbivaatamine</paragrahvPealkiri>
							<loige id="para341b4lg1">
								<loigeNr/>
								<kuvatavNr/>
								<sisuTekst>
									<tavatekst>Ruumi omanikule isiku kohta, kelle elukoha aadress rahvastikuregistris on temale kuuluva ruumi aadress, rahvastikuregistrist andmete väljastamise taotluse läbivaatamise eest perekonnaseisutoimingute seaduse § 3 lõikes 3<sup>2</sup> sätestatud maakonnakeskuse kohaliku omavalitsuse üksuse poolt, mis ei ole ruumi asukohajärgne kohaliku omavalitsuse üksus, tasutakse riigilõivu 20 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
					</jaotis>
				</jagu>
				<jagu id="jg55">
					<jaguNr>2</jaguNr>
					<kuvatavNr><![CDATA[2. jagu]]></kuvatavNr>
					<jaguPealkiri>Kutsekvalifikatsiooni tunnustamine</jaguPealkiri>
					<paragrahv id="para342">
						<paragrahvNr>342</paragrahvNr>
						<kuvatavNr><![CDATA[§ 342. ]]></kuvatavNr>
						<paragrahvPealkiri>Kutsekvalifikatsiooni tunnustamise taotluse läbivaatamine</paragrahvPealkiri>
						<loige id="para342lg1">
							<sisuTekst>
								<tavatekst>Kutsekvalifikatsiooni tunnustamise taotluse, sealhulgas Euroopa kutsekaardi taotluse läbivaatamise eest tasutakse riigilõivu 130 eurot.</tavatekst>
							</sisuTekst>
							<muutmismarge>
								<avaldamismarge>
									<RTosa>RT I</RTosa>
									<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
									<RTartikkel>1</RTartikkel>
									<aktViide>130122023001</aktViide>
								</avaldamismarge>
								<joustumine>2024-01-01</joustumine>
							</muutmismarge>
						</loige>
					</paragrahv>
				</jagu>
				<jagu id="jg56">
					<jaguNr>3</jaguNr>
					<kuvatavNr><![CDATA[3. jagu]]></kuvatavNr>
					<jaguPealkiri>Registerpandiga seotud toimingud</jaguPealkiri>
					<paragrahv id="para343">
						<paragrahvNr id="c182cca2-55e1-437c-8826-0b5d55881c71">343</paragrahvNr>
						<kuvatavNr id="ae7ea75d-736e-4d38-8850-3ecc5647b34f"><![CDATA[§ 343. ]]></kuvatavNr>
						<paragrahvPealkiri id="c34ba809-b83e-45c9-913b-5ee0483a5594">Kanded registerpandi kohta</paragrahvPealkiri>
						<loige id="para343lg1">
							<loigeNr id="c61bb3f6-2e6d-4f41-9ecb-340cf9316523">1</loigeNr>
							<kuvatavNr id="91bd33d3-9d3b-4e5d-a8b5-db47bbbd6b31"><![CDATA[(1)]]></kuvatavNr>
							<sisuTekst id="d824b7f7-f0e9-44d7-8f3f-b9a093fb4830">
								<tavatekst id="86714399-c38f-4447-8167-ed058e9535f1">Pandilepingu registreerimise eest tasutakse käesoleva seaduse lisas 2 sätestatud riigilõivu täismäär olenevalt tehinguväärtusest.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para343lg2">
							<loigeNr id="588e880d-713d-483a-a8c6-53d81d0f201a">2</loigeNr>
							<kuvatavNr id="80316cb6-5096-4567-8128-ebb6c52f993b"><![CDATA[(2)]]></kuvatavNr>
							<sisuTekst id="9c63381e-13c2-4708-9093-12a0869c1a6c">
								<tavatekst id="be4053a3-b3a4-4904-9585-02d8adb321cb">Registerpandi järjekoha muutmise eest tasutakse 75 protsenti käesoleva seaduse lisas 2 sätestatud riigilõivu täismäärast olenevalt tehinguväärtusest.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para343lg3">
							<loigeNr id="2066b8ba-0b6d-4ed1-b2e3-42288a131c70">3</loigeNr>
							<kuvatavNr id="72d917c4-9ba3-4899-93ad-d400cf6ed71e"><![CDATA[(3)]]></kuvatavNr>
							<sisuTekst id="e5dde07a-9190-4873-ba2a-526b812aadbc">
								<tavatekst id="92ef4af6-e16c-4ffe-8c26-8625e9c645e7">Pandilepingu lisa registreerimise eest tasutakse riigilõivu 7 eurot.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para343lg4">
							<loigeNr id="d38aa450-53d1-446c-b147-56e4107fe02a">4</loigeNr>
							<kuvatavNr id="a792e452-e6be-4b08-b2af-769c08077c9b"><![CDATA[(4)]]></kuvatavNr>
							<sisuTekst id="1a42da9e-c69a-417c-a90b-dd328ccc3fc4">
								<tavatekst id="ef65c82b-8e60-4a4e-96b0-e7187e3f0726">Pandisummat suurendava pandilepingu lisa registreerimise eest tasutakse riigilõivu käesoleva seaduse lisas 2 sätestatud riigilõivu täismääras, kusjuures tehinguväärtuseks on pandisumma, mille registrisse kandmist taotletakse, ning registrisse kantud pandisumma vahe.</tavatekst>
							</sisuTekst>
						</loige>
					</paragrahv>
				</jagu>
				<jagu id="jg57">
					<jaguNr>4</jaguNr>
					<kuvatavNr><![CDATA[4. jagu]]></kuvatavNr>
					<jaguPealkiri>Majandustegevuse seadustiku üldosa seaduse alusel tehtavad toimingud</jaguPealkiri>
					<paragrahv id="para344">
						<paragrahvNr id="e8257a95-8e31-4f7c-b0f9-b102995a77ee">344</paragrahvNr>
						<kuvatavNr id="f49a17b0-c235-455a-ba9d-4261517446d6"><![CDATA[§ 344. ]]></kuvatavNr>
						<paragrahvPealkiri id="a5a1abcf-8763-4080-88c0-1268cc3cc173">Tegevusloa taotluse läbivaatamine tegevusloa registrisse kandmiseks</paragrahvPealkiri>
						<loige id="para344lg1">
							<sisuTekst id="b373f207-51b8-4f92-b0f5-5a45aedb64f0">
								<tavatekst id="a575d615-bcc4-436d-9a53-2f4d2a7ab426">Tegevusloa taotluse läbivaatamise eest tegevusloa registrisse kandmiseks, kui eriseaduses ei ole sätestatud riigilõivu tegevusloa taotluse läbivaatamise eest või kui ei ole kehtestatud riigilõivuvabastust tegevusloa taotluse läbivaatamise eest, tasutakse riigilõivu 20 eurot.</tavatekst>
							</sisuTekst>
						</loige>
					</paragrahv>
					<paragrahv id="para345">
						<paragrahvNr id="d9b28722-8c6c-42cd-9666-e796d87fa760">345</paragrahvNr>
						<kuvatavNr id="4a4868f4-2ee2-450d-b99c-42f5c7482bc5"><![CDATA[§ 345. ]]></kuvatavNr>
						<paragrahvPealkiri id="9cc0d858-c1ed-4ab1-87f0-354dcd309ef2">Teate esitamine muul viisil kui ühtse kontaktpunkti kaudu</paragrahvPealkiri>
						<loige id="para345lg1">
							<sisuTekst id="2ec978a1-041f-4268-bd48-58630de1e89f">
								<tavatekst>Majandustegevuse seadustiku üldosa seaduse § 58 lõike 1 punktides 1, 2 ja 5 nimetatud teate muul viisil kui ühtse kontaktpunkti kaudu esitamise eest tasutakse riigilõivu 10 eurot.</tavatekst>
							</sisuTekst>
						</loige>
					</paragrahv>
				</jagu>
				<jagu id="jg58">
					<jaguNr>5</jaguNr>
					<kuvatavNr><![CDATA[5. jagu]]></kuvatavNr>
					<jaguPealkiri>Arhiiviseaduse alusel tehtavad toimingud</jaguPealkiri>
					<paragrahv id="para346">
						<paragrahvNr>346</paragrahvNr>
						<kuvatavNr><![CDATA[§ 346. ]]></kuvatavNr>
						<paragrahvPealkiri>Arhiiviteatise väljastamine</paragrahvPealkiri>
						<loige id="para346lg1">
							<sisuTekst>
								<tavatekst>Arhiiviteatise väljastamise eest tasutakse riigilõivu 25 eurot ja välisesinduses 40 eurot.</tavatekst>
							</sisuTekst>
							<muutmismarge>
								<avaldamismarge>
									<RTosa>RT I</RTosa>
									<avaldamineKuupaev>2025-01-09</avaldamineKuupaev>
									<RTartikkel>1</RTartikkel>
									<aktViide>109012025001</aktViide>
								</avaldamismarge>
								<joustumine>2025-09-01</joustumine>
							</muutmismarge>
						</loige>
					</paragrahv>
				</jagu>
				<jagu id="jg59">
					<jaguNr>6</jaguNr>
					<kuvatavNr><![CDATA[6. jagu]]></kuvatavNr>
					<jaguPealkiri>Maareformi seaduse alusel kasutusvaldusesse antud maa omandamise seaduse alusel tehtavad toimingud</jaguPealkiri>
					<muutmismarge id="9b93df03-cdec-4c6c-ba77-e8a462bda453">
						<avaldamismarge id="5d434eae-3df1-4399-9c8c-829c1a4c8434">
							<RTosa id="1b9af4e8-2a6f-4ce6-9494-7c4450bce62c">RT I</RTosa>
							<avaldamineKuupaev id="777d0c14-fe7b-4dc8-a2be-d67b3a778a61">2017-07-04</avaldamineKuupaev>
							<RTartikkel id="3a449fc5-9d9c-41b8-b92a-5b2920f1bf9d">1</RTartikkel>
							<aktViide id="594a3015-a5e9-49d5-a6f8-aed966f94704">104072017001</aktViide>
						</avaldamismarge>
						<joustumine id="5dc4c09f-bc96-43f2-af2c-287ecaff89fd">2018-01-01</joustumine>
					</muutmismarge>
					<paragrahv id="para346b1">
						<paragrahvNr id="01052467-eec2-4035-82b8-69302d33114e" ylaIndeks="1">346</paragrahvNr>
						<kuvatavNr id="e311fb3f-d5f5-4c9e-ae12-66d6881a1802"><![CDATA[§ 346<sup>1</sup>. ]]></kuvatavNr>
						<paragrahvPealkiri id="19bcc994-a6e3-44d2-8b04-ce57aded49f3">Maareformi seaduse alusel kasutusvaldusesse antud maa omandamise taotluse läbivaatamine</paragrahvPealkiri>
						<loige id="para346b1lg1">
							<sisuTekst id="94f05c25-3f5d-4792-a73a-9830712ab52d">
								<tavatekst id="df7af748-4d39-4341-bad3-c44a1770a05b">Maareformi seaduse alusel kasutusvaldusesse antud maa omandamise taotluse läbivaatamise eest tasutakse riigilõivu 32 eurot.</tavatekst>
							</sisuTekst>
							<muutmismarge id="6df5c60a-fab9-46ce-88d2-35e562210fd5">
								<avaldamismarge id="9b4568a3-1253-4238-8019-c6622aac23e2">
									<RTosa id="2b7748a0-9acc-4f32-af26-f91621cb25da">RT I</RTosa>
									<avaldamineKuupaev id="1e8e8673-8901-4b1a-9a32-1a6ce304875d">2017-07-04</avaldamineKuupaev>
									<RTartikkel id="042250b2-ce24-473c-8163-0439e688f945">1</RTartikkel>
									<aktViide id="a60a5cd3-0319-44f9-a221-f5507bc9e851">104072017001</aktViide>
								</avaldamismarge>
								<joustumine id="9632f14a-a77d-4b32-ba93-5aa2496d3284">2018-01-01</joustumine>
							</muutmismarge>
						</loige>
					</paragrahv>
				</jagu>
			</peatykk>
		</osa>
		<osa id="o4">
			<osaNr>4</osaNr>
			<kuvatavNr><![CDATA[4. osa]]></kuvatavNr>
			<osaPealkiri>TEHINGUVÄÄRTUSED</osaPealkiri>
			<peatykk id="ptk18">
				<peatykkNr>18</peatykkNr>
				<kuvatavNr><![CDATA[18. peatükk]]></kuvatavNr>
				<peatykkPealkiri>Tehinguväärtuse määramine</peatykkPealkiri>
				<paragrahv id="para347">
					<paragrahvNr id="a2b872af-7759-4575-a7d5-4a418f506e4d">347</paragrahvNr>
					<kuvatavNr id="1cf50f4f-9ddb-4c88-bf9a-279220e07e6e"><![CDATA[§ 347. ]]></kuvatavNr>
					<paragrahvPealkiri id="6cc3425d-41e2-4d25-bbe6-c8200443768d">Tehinguväärtus kande tegemisel kinnistusraamatusse</paragrahvPealkiri>
					<loige id="para347lg1">
						<loigeNr id="17df8b91-2249-4d28-8fff-bd8decac1a96">1</loigeNr>
						<kuvatavNr id="710cbce9-283c-4e5e-aeb5-1512a17d8cd8"><![CDATA[(1)]]></kuvatavNr>
						<sisuTekst id="8ca1373b-f801-4866-bc83-2b28912db2ed">
							<tavatekst id="716dc186-a6f5-477e-b730-d24df3795a94">Tehinguväärtus määratakse kinnistamise alusdokumendi järgi.</tavatekst>
						</sisuTekst>
					</loige>
					<loige id="para347lg2">
						<loigeNr id="d5320b04-3a3b-4150-8766-0a5ed435ac57">2</loigeNr>
						<kuvatavNr id="179ecf29-d39f-40d3-8fae-b46190565c8b"><![CDATA[(2)]]></kuvatavNr>
						<sisuTekst id="5d953e60-f1f3-4787-9779-d012770bb5dc">
							<tavatekst id="6c9bb61b-7c78-444a-bc93-122283a88f99">Tehingu objektil lasuvaid kohustusi ega objekti võõrandamishinnale lisanduvat käibemaksu summat tehinguväärtuse määramisel maha ei arvata.</tavatekst>
						</sisuTekst>
					</loige>
					<loige id="para347lg3">
						<loigeNr id="049a9381-aae1-4fd9-982b-cdf4aea2abf8">3</loigeNr>
						<kuvatavNr id="78f86b87-e723-47e8-98a3-789dbfa1a51e"><![CDATA[(3)]]></kuvatavNr>
						<sisuTekst id="f03b7251-35e7-4f86-a4fd-ebdf8ad623f0">
							<tavatekst id="0fd9c7d5-976c-407d-9989-7ae916cf2785">Kui kinnistamise alusdokument ei sisalda tehinguväärtust, määratakse tehinguväärtus käesoleva seaduse §-de 348–362 kohaselt.</tavatekst>
						</sisuTekst>
					</loige>
				</paragrahv>
				<paragrahv id="para348">
					<paragrahvNr id="169a97cf-5745-4a43-927b-c6abfb559e67">348</paragrahvNr>
					<kuvatavNr id="c3080328-4d86-439f-84af-286266354dce"><![CDATA[§ 348. ]]></kuvatavNr>
					<paragrahvPealkiri id="b24d74c7-05b2-4c94-bc4b-a79e8fd0e7c0">Kinnisasja kinnistamine</paragrahvPealkiri>
					<loige id="para348lg1">
						<loigeNr id="73c25257-7505-4e31-99f8-ae0b1cd4c3c9">1</loigeNr>
						<kuvatavNr id="4707fc7d-95c8-4962-a0bc-f3da50de647c"><![CDATA[(1)]]></kuvatavNr>
						<sisuTekst id="19c6fb94-8ed5-4ddb-8070-7d4233d20549">
							<tavatekst id="c729c071-960b-45f9-b908-cf26e4f89267">Hoonestamata kinnisasja kinnistamisel on tehinguväärtuseks maa maksustamishind.</tavatekst>
						</sisuTekst>
					</loige>
					<loige id="para348lg2">
						<loigeNr id="cc648d28-f58d-4777-9ff9-7fa37b250a2d">2</loigeNr>
						<kuvatavNr id="e7ba8371-e400-4ffc-ac09-0f5244579aee"><![CDATA[(2)]]></kuvatavNr>
						<sisuTekst id="d0be3b1f-4e5d-4238-b37a-d9269a8be878">
							<tavatekst id="afa60674-5351-41d4-a740-47f01c3f7f22">Hoonestatud kinnisasja kinnistamisel on tehinguväärtuseks maa maksustamishind ja hoone hind.</tavatekst>
						</sisuTekst>
					</loige>
					<loige id="para348lg3">
						<loigeNr id="363a1d1b-be6d-41ec-9336-33b0bae45ad7">3</loigeNr>
						<kuvatavNr id="29dc6803-03a9-41c6-84d9-45fb717a53f0"><![CDATA[(3)]]></kuvatavNr>
						<sisuTekst id="4338161d-17bb-464e-8e56-7ee118dc1d6e">
							<tavatekst id="e9951c8c-33a4-4578-936a-7c77c6d7ffdd">Kui kohtule ei esitata dokumenti hoone hinna kohta, loetakse hoone hinnaks 3200 eurot.</tavatekst>
						</sisuTekst>
					</loige>
					<loige id="para348lg4">
						<loigeNr id="e0150d8e-4d2f-4565-a8bb-05aa6d465e4f">4</loigeNr>
						<kuvatavNr id="41ebea63-d7b9-48d0-b972-da5de4d29b7f"><![CDATA[(4)]]></kuvatavNr>
						<sisuTekst id="a053228f-c134-4bd1-9478-d197404c7902">
							<tavatekst id="8659e6f4-4ee2-4334-b15e-20b155e1bb73">Kinnisasjal asuva hoone omaniku ostueesõigusega erastatud maa kinnistamisel on tehinguväärtuseks maa maksustamishind.</tavatekst>
						</sisuTekst>
					</loige>
					<loige id="para348lg5">
						<loigeNr id="16ffd1b6-4f87-4ab3-bae6-45cbbe01e596">5</loigeNr>
						<kuvatavNr id="6c2ba34a-8241-40ad-a613-d2a0a210a446"><![CDATA[(5)]]></kuvatavNr>
						<sisuTekst id="ca67e6fc-8fea-4f69-b1a8-af4504260925">
							<tavatekst id="b1508b39-bb29-4e0b-afda-20a79ef8e54e">Kui maa maksustamishind ja hoonete hind on kokku väiksem kui kinnisasja koormav hüpoteek, on omandiõiguse kinnistamisel tehinguväärtuseks kinnistusraamatusse kantud hüpoteegi summa.</tavatekst>
						</sisuTekst>
					</loige>
				</paragrahv>
				<paragrahv id="para349">
					<paragrahvNr id="33b52561-18f0-4761-bebd-ae57489279a5">349</paragrahvNr>
					<kuvatavNr id="506f7939-3f05-45b7-b699-25f2d788a78b"><![CDATA[§ 349. ]]></kuvatavNr>
					<paragrahvPealkiri id="38c0c765-f0a1-4b48-a2ff-5cf970c7baf3">Kinnistu jagamine</paragrahvPealkiri>
					<loige id="para349lg1">
						<sisuTekst id="e2468a28-f08f-4249-b351-ac7d3af0eb6a">
							<tavatekst id="ac4f4b52-4837-4376-90da-7860da9f93c2">Kinnistu jagamisel mitmeks kinnistuks määratakse tehinguväärtus lähtuvalt jagamise tulemusel moodustatavast uuest kinnistust käesoleva seaduse § 348 kohaselt.</tavatekst>
						</sisuTekst>
					</loige>
				</paragrahv>
				<paragrahv id="para350">
					<paragrahvNr id="5c4e531b-868f-499e-bb06-56e204ed0dd1">350</paragrahvNr>
					<kuvatavNr id="6422e79f-af4a-42da-8155-f90deb9ac2c9"><![CDATA[§ 350. ]]></kuvatavNr>
					<paragrahvPealkiri id="dd06f3b7-818d-45db-b243-aca5d99af020">Kinnistute ühendamine</paragrahvPealkiri>
					<loige id="para350lg1">
						<sisuTekst id="bd3fefc5-edca-4a87-85e4-82d0df93998b">
							<tavatekst id="39192fdb-a7cf-447a-ac37-a0be6881ae5d">Kinnistute ühendamisel määratakse tehinguväärtus lähtuvalt ühendatavatest kinnisasjadest käesoleva seaduse § 348 kohaselt.</tavatekst>
						</sisuTekst>
					</loige>
				</paragrahv>
				<paragrahv id="para351">
					<paragrahvNr id="a39db6fd-a0ce-4f65-9f9b-1ab161bca44c">351</paragrahvNr>
					<kuvatavNr id="ce51f5fa-11eb-47a1-bc12-494108057e18"><![CDATA[§ 351. ]]></kuvatavNr>
					<paragrahvPealkiri id="8d7f2a3e-8c4f-499c-8bd6-623b2837a093">Kinnistu osa liitmine teise kinnistuga</paragrahvPealkiri>
					<loige id="para351lg1">
						<sisuTekst id="032d5e6c-fc45-4f8a-8b50-e1c93dc5e45b">
							<tavatekst id="8246f017-e037-49dd-b2a5-46188d846b8f">Kinnistu osa liitmisel teise kinnistuga määratakse tehinguväärtus liidetava osa järgi käesoleva seaduse § 348 kohaselt.</tavatekst>
						</sisuTekst>
					</loige>
				</paragrahv>
				<paragrahv id="para352">
					<paragrahvNr id="4513130e-4c65-4537-9404-2a0f4caf1bb3">352</paragrahvNr>
					<kuvatavNr id="7f5eca98-db69-48ab-acf0-ad99b7713475"><![CDATA[§ 352. ]]></kuvatavNr>
					<paragrahvPealkiri id="938767cd-d6f2-44de-b9eb-67d560963403">Korteriomandi kinnistamine</paragrahvPealkiri>
					<loige id="para352lg1">
						<sisuTekst id="0b2826a0-4c58-45a4-985f-722052547b0a">
							<tavatekst id="ee7c5fe5-c7dc-4db9-aec6-020f93436ba9">Korteriomandi kinnistamisel on tehinguväärtuseks 50 protsenti kaasomandi osa suurusele vastavast korteriomandite esemeks oleva kinnisasja maksustamishinnast.</tavatekst>
						</sisuTekst>
					</loige>
				</paragrahv>
				<paragrahv id="para353">
					<paragrahvNr id="a4cdf33b-6318-498a-bbc1-3925ed0f1908">353</paragrahvNr>
					<kuvatavNr id="caaaa85b-412d-4d58-a326-51de67223139"><![CDATA[§ 353. ]]></kuvatavNr>
					<paragrahvPealkiri id="3a4d1df9-43bf-48d1-81a1-3017f2fe8b4b">Hoonestusõigus ja korterihoonestusõigus</paragrahvPealkiri>
					<loige id="para353lg1">
						<loigeNr id="f021b653-922f-4895-811d-3e4a12a80294">1</loigeNr>
						<kuvatavNr id="218e4b59-0541-44f7-bfdd-654a16595973"><![CDATA[(1)]]></kuvatavNr>
						<sisuTekst id="cbee23bb-05a1-48ba-a6e2-32f3504bfb97">
							<tavatekst id="78dcbbb9-091e-4605-81f5-6dcdb8c726d5">Hoonestamata kinnisasja koormamisel hoonestusõigusega on tehinguväärtuseks 80 protsenti koormatava kinnisasja maksustamishinnast.</tavatekst>
						</sisuTekst>
					</loige>
					<loige id="para353lg2">
						<loigeNr id="48a9558b-dd91-4a36-966e-8b21bd076ef2">2</loigeNr>
						<kuvatavNr id="39390e87-9425-46f5-8c21-ef1ea7b3845a"><![CDATA[(2)]]></kuvatavNr>
						<sisuTekst id="e16554e2-2e47-4ac9-ba7f-c36341710725">
							<tavatekst id="e7d20adb-743f-4dfa-8f11-aba7944ca6ea">Hoonestatud kinnisasja koormamisel hoonestusõigusega on tehinguväärtuseks 80 protsenti maa maksustamishinna ja hoone hinna summast.</tavatekst>
						</sisuTekst>
					</loige>
					<loige id="para353lg3">
						<loigeNr id="4c3535e9-7f68-4115-9334-1ab6cf6e90b0">3</loigeNr>
						<kuvatavNr id="d6c9c45c-f0d2-4184-9124-2b5ff0ceeeb1"><![CDATA[(3)]]></kuvatavNr>
						<sisuTekst id="400e8ac3-d0b1-4127-99fa-501eb95fb9b3">
							<tavatekst id="a65a2d10-a9b4-45fd-84ff-cf96a002e13e">Kui hoonestusõiguse eest makstakse tasu, on hoonestusõigusega koormamisel tehinguväärtuseks hoonestusõiguse tasu kogusumma, kuid mitte rohkem kui 25 aasta eest.</tavatekst>
						</sisuTekst>
					</loige>
					<loige id="para353lg4">
						<loigeNr id="3ded6c35-e33f-4597-94f6-fcaf7a8a0a45">4</loigeNr>
						<kuvatavNr id="c97b7d78-ed62-4458-9e48-2f97a6b58e41"><![CDATA[(4)]]></kuvatavNr>
						<sisuTekst id="a5754455-dd91-43a3-bafa-a5ff7049caa9">
							<tavatekst id="063ee78a-7e19-4a87-9b7f-e5de245eb1b7">Korterihoonestusõiguse kinnistamisel on tehinguväärtuseks 50 protsenti kaasomandi osa suurusele vastavast hoonestusõiguse tehinguväärtusest, määratuna käesoleva paragrahvi lõike 1 alusel.</tavatekst>
						</sisuTekst>
					</loige>
				</paragrahv>
				<paragrahv id="para354">
					<paragrahvNr id="4e9b0797-ee7f-48df-9de0-baf4da169622">354</paragrahvNr>
					<kuvatavNr id="46bf6bcf-5341-42db-b48c-c325903faa65"><![CDATA[§ 354. ]]></kuvatavNr>
					<paragrahvPealkiri id="f9bffa7c-27d8-4852-94d2-1697365aacd8">Reaalservituut</paragrahvPealkiri>
					<loige id="para354lg1">
						<loigeNr id="82c5acc7-abd6-4781-a6e4-ce72d14dfe62">1</loigeNr>
						<kuvatavNr id="c3214296-b3cf-49e0-bf61-18502f2b62f1"><![CDATA[(1)]]></kuvatavNr>
						<sisuTekst id="9dad0e9d-8cd0-48b2-a3f1-010978ef7105">
							<tavatekst id="3047c50e-ce88-4538-a782-b2c9d7c44881">Reaalservituudi seadmisel on tehinguväärtuseks väärtus, mida reaalservituut valitseva kinnisasja suhtes omab, kuid mitte vähem kui 130 eurot.</tavatekst>
						</sisuTekst>
					</loige>
					<loige id="para354lg2">
						<loigeNr id="b107a8e3-616b-4889-bfc9-be1bac016e86">2</loigeNr>
						<kuvatavNr id="412d02f0-8f2c-49f0-bcda-0a93e27189d8"><![CDATA[(2)]]></kuvatavNr>
						<sisuTekst id="d7aa0365-623f-41a3-854a-c259900149d9">
							<tavatekst id="67685a15-6bd1-4941-9066-32d6b785bd3b">Kui kohtule ei esitata andmeid reaalservituudi väärtuse suuruse kohta, loetakse tehinguväärtuseks 130 eurot.</tavatekst>
						</sisuTekst>
					</loige>
				</paragrahv>
				<paragrahv id="para355">
					<paragrahvNr id="f563b2e9-5a81-4b2e-a839-58bcd7c4f658">355</paragrahvNr>
					<kuvatavNr id="a4c5897b-3013-4557-bc37-3494cef87deb"><![CDATA[§ 355. ]]></kuvatavNr>
					<paragrahvPealkiri id="9f95b05b-3b17-419c-95ad-148d67ce9d2b">Kasutusvaldus</paragrahvPealkiri>
					<loige id="para355lg1">
						<loigeNr id="1e7836ab-67c6-43a3-b3be-021315d1cd45">1</loigeNr>
						<kuvatavNr id="b5bb1c13-3479-454d-9611-8e5ab68cf2d0"><![CDATA[(1)]]></kuvatavNr>
						<sisuTekst id="343ac138-27be-4ee8-ba07-52b552bc5008">
							<tavatekst id="2f7af705-2ada-4b30-9294-47ceb51bc946">Kasutusvalduse aastaväärtuseks on 4 protsenti koormatava kinnisasja maksustamishinnast.</tavatekst>
						</sisuTekst>
					</loige>
					<loige id="para355lg2">
						<loigeNr id="493fd7d2-444b-4284-8049-adf06242c3b3">2</loigeNr>
						<kuvatavNr id="bca1ce76-e0e5-4456-a0d5-892edb266a15"><![CDATA[(2)]]></kuvatavNr>
						<sisuTekst id="bc0db3ec-fbd8-49fc-956d-90de35125fb0">
							<tavatekst id="9d101029-3577-4e35-8adb-4e801ed976c2">Tähtajalise kasutusvalduse seadmisel on tehinguväärtuseks üksikute aastaväärtuste summa, kuid mitte rohkem kui 25 aasta eest.</tavatekst>
						</sisuTekst>
					</loige>
					<loige id="para355lg3">
						<loigeNr id="3970ae11-5202-4570-9c72-f60b8a0b8333">3</loigeNr>
						<kuvatavNr id="5cce5a73-4367-4398-b3f6-c75557680106"><![CDATA[(3)]]></kuvatavNr>
						<sisuTekst id="7c5ae1af-336c-4fa0-bd8d-49650249eafe">
							<tavatekst id="2df008a3-9029-4ad5-87de-07a552a1e022">Tähtajatu kasutusvalduse seadmisel on tehinguväärtuseks kasutusvalduse aastaväärtuse kordne sõltuvalt kasutusvaldaja vanusest:</tavatekst>
						</sisuTekst>
						<alampunkt id="para355lg3p1">
							<alampunktNr id="b4c5da71-edc2-4041-9226-e8b3810f69ec">1</alampunktNr>
							<kuvatavNr id="9717f5e4-9fbb-4814-a21d-3fc7f41f12a6"><![CDATA[1) ]]></kuvatavNr>
							<sisuTekst id="49fb5df5-01e4-4196-bdf7-578eedfb8a47">
								<tavatekst id="794dc3e7-0bbf-4cb0-b7c4-a183aab8749f">alla 36-aastase isiku puhul 20-kordne aastaväärtus;</tavatekst>
							</sisuTekst>
						</alampunkt>
						<alampunkt id="para355lg3p2">
							<alampunktNr id="24cc168f-3fb5-4f2e-867a-ccaf74da17f6">2</alampunktNr>
							<kuvatavNr id="fb8477c1-ac96-45fa-a822-46f039265024"><![CDATA[2) ]]></kuvatavNr>
							<sisuTekst id="25304cf6-14f7-4e7e-93b1-cd25a356270d">
								<tavatekst id="f5efbe4a-a214-499e-b1df-952cf7744a93">36–50-aastase isiku puhul 15-kordne aastaväärtus;</tavatekst>
							</sisuTekst>
						</alampunkt>
						<alampunkt id="para355lg3p3">
							<alampunktNr id="35fe9af4-fcc8-4e93-b88d-71c3e159a1ec">3</alampunktNr>
							<kuvatavNr id="329908b1-e6fc-438e-ae65-c3ba8c6b3921"><![CDATA[3) ]]></kuvatavNr>
							<sisuTekst id="08458ffa-b034-42d5-88b2-63720316ba09">
								<tavatekst id="a6fbba85-53f1-4a55-8be7-2277ee8c5b27">51–65-aastase isiku puhul 10-kordne aastaväärtus;</tavatekst>
							</sisuTekst>
						</alampunkt>
						<alampunkt id="para355lg3p4">
							<alampunktNr id="142a045b-7267-401f-b31c-4d40c2fe5786">4</alampunktNr>
							<kuvatavNr id="5fa677f5-df8d-4dc9-af86-79cf4fe2bf98"><![CDATA[4) ]]></kuvatavNr>
							<sisuTekst id="207112d2-9a93-4e18-8441-f2d91050be44">
								<tavatekst id="14765135-8084-4781-8181-6a37e802c9bc">66–75-aastase isiku puhul 5-kordne aastaväärtus;</tavatekst>
							</sisuTekst>
						</alampunkt>
						<alampunkt id="para355lg3p5">
							<alampunktNr id="5f3f7875-24e5-47e3-8602-3474c1062fa0">5</alampunktNr>
							<kuvatavNr id="86192281-103a-431a-9c6e-d58d0d25be09"><![CDATA[5) ]]></kuvatavNr>
							<sisuTekst id="604dcc0f-cb45-4d2b-ab3a-c6524990726b">
								<tavatekst id="0cc79fbb-7b5a-4e9f-a704-e3e53a201560">76-aastase ja vanema isiku puhul 3-kordne aastaväärtus.</tavatekst>
							</sisuTekst>
						</alampunkt>
					</loige>
					<loige id="para355lg4">
						<loigeNr id="7e4f2166-c15a-45e7-be50-295afe439bee">4</loigeNr>
						<kuvatavNr id="aaf386db-25df-4692-8aec-d4af99c09801"><![CDATA[(4)]]></kuvatavNr>
						<sisuTekst id="6093658b-2575-46b5-a9fd-cefc5a13ae6d">
							<tavatekst id="f147a272-4f33-4463-926a-2a71b51fea4f">Tähtajatu kasutusvalduse seadmisel ühiselt mitme isiku kasuks võetakse tehinguväärtuse arvutamisel aluseks noorima kasutusvaldust teostava isiku vanus.</tavatekst>
						</sisuTekst>
					</loige>
					<loige id="para355lg5">
						<loigeNr id="d67552a8-3a16-48e7-a7d1-72d1eb6a19b1">5</loigeNr>
						<kuvatavNr id="28e31dac-4ace-4a7a-9fe0-5562068fd695"><![CDATA[(5)]]></kuvatavNr>
						<sisuTekst id="8f890503-ad9e-4925-bf0f-e10eda83cd7a">
							<tavatekst id="a0d9c6fc-2146-4a1b-b3e4-37ae70101e84">Juriidilise isiku kasuks tähtajatu kasutusvalduse seadmisel on tehinguväärtuseks 25-kordne kasutusõiguse aastaväärtus.</tavatekst>
						</sisuTekst>
					</loige>
				</paragrahv>
				<paragrahv id="para356">
					<paragrahvNr id="6cf888cf-3309-4d0e-b3a7-67ddab0a1747">356</paragrahvNr>
					<kuvatavNr id="b4ccf288-4a54-45db-b7a6-67d2f89ff7f6"><![CDATA[§ 356. ]]></kuvatavNr>
					<paragrahvPealkiri id="c52cd877-dfe3-4b23-8668-62ca2f993764">Isiklik kasutusõigus</paragrahvPealkiri>
					<loige id="para356lg1">
						<loigeNr id="e5ce16d4-5445-44d3-83e6-47cb8bf59f1a">1</loigeNr>
						<kuvatavNr id="4df1b527-4e04-4252-9777-44323d418c64"><![CDATA[(1)]]></kuvatavNr>
						<sisuTekst id="70e5fe9d-bd6c-4dde-bf20-0d0cdc95ccdd">
							<tavatekst id="fc35cbc6-34a3-48f7-a47d-8ac9ff700ee9">Isikliku kasutusõiguse seadmisel elamule või muule ehitisele on aastaväärtuseks 4 protsenti koormataval kinnisasjal asuva elamu või muu ehitise väärtusest.</tavatekst>
						</sisuTekst>
					</loige>
					<loige id="para356lg2">
						<loigeNr id="5a926e44-dc30-4159-9330-ec0e654a988e">2</loigeNr>
						<kuvatavNr id="86703af5-339a-40c3-9c95-32cd0f3d83bf"><![CDATA[(2)]]></kuvatavNr>
						<sisuTekst id="f86b7185-ec44-4a9e-a698-ddb4936bd981">
							<tavatekst id="b06aabcd-4b9f-4652-916d-fb5c90ab642b">Tähtajalise isikliku kasutusõiguse seadmisel elamule või muule ehitisele on tehinguväärtuseks isikliku kasutusõiguse aastaväärtuste summa, kuid mitte rohkem kui 25 aasta eest.</tavatekst>
						</sisuTekst>
					</loige>
					<loige id="para356lg3">
						<loigeNr id="6b04d13c-b84b-4ea4-9ef5-b91e999cdf53">3</loigeNr>
						<kuvatavNr id="0a6c116f-32f5-41db-8cb5-afb362bc7519"><![CDATA[(3)]]></kuvatavNr>
						<sisuTekst id="0a2efd7e-c5c7-4c17-bc61-a94baf48f966">
							<tavatekst id="ed36cd49-6fd2-407b-8a07-ef5dd1f3a511">Tähtajatu isikliku kasutusõiguse seadmisel elamule on tehinguväärtuseks isikliku kasutusõiguse aastaväärtuse kordne sõltuvalt kasutaja vanusest:</tavatekst>
						</sisuTekst>
						<alampunkt id="para356lg3p1">
							<alampunktNr id="70783cad-b901-4b3b-a59e-c77f37543f79">1</alampunktNr>
							<kuvatavNr id="7287ebc2-9991-46da-88d8-87c09c1fe072"><![CDATA[1) ]]></kuvatavNr>
							<sisuTekst id="e833e184-70f7-4939-b749-86f0e9c9e879">
								<tavatekst id="5320db0d-5b17-4a2d-b5c5-4022a8a31bb1">alla 36-aastase isiku puhul 20-kordne aastaväärtus;</tavatekst>
							</sisuTekst>
						</alampunkt>
						<alampunkt id="para356lg3p2">
							<alampunktNr id="05ea23da-6b60-4dc5-95a5-3850ed8613f8">2</alampunktNr>
							<kuvatavNr id="c3b179a6-a94b-4ffb-8a9a-d3cad5a8b709"><![CDATA[2) ]]></kuvatavNr>
							<sisuTekst id="459ba3d3-6229-41f5-8a9a-d1250eab55ef">
								<tavatekst id="9ee8f3cf-9ed2-431c-854e-25054c8602f1">36–50-aastase isiku puhul 15-kordne aastaväärtus;</tavatekst>
							</sisuTekst>
						</alampunkt>
						<alampunkt id="para356lg3p3">
							<alampunktNr id="80fac15e-4dc7-454a-9c03-9b72209caaab">3</alampunktNr>
							<kuvatavNr id="c34e1060-bea4-4a02-862b-3a631156208a"><![CDATA[3) ]]></kuvatavNr>
							<sisuTekst id="6ae71959-5142-4539-99a8-4aaf35024c88">
								<tavatekst id="fbdb0f3b-74e2-4ef6-9a82-6f8d06a278b5">51–65-aastase isiku puhul 10-kordne aastaväärtus;</tavatekst>
							</sisuTekst>
						</alampunkt>
						<alampunkt id="para356lg3p4">
							<alampunktNr id="859c4945-0c70-415c-af8f-1b08ae778e3c">4</alampunktNr>
							<kuvatavNr id="7c31e4d3-059c-40ba-b7b5-a906d8c76e51"><![CDATA[4) ]]></kuvatavNr>
							<sisuTekst id="ee0a1c74-ad89-42f1-8195-051e007e0d3c">
								<tavatekst id="0ab95f10-59d6-489c-a717-46149659a3a7">66–75-aastase isiku puhul 5-kordne aastaväärtus;</tavatekst>
							</sisuTekst>
						</alampunkt>
						<alampunkt id="para356lg3p5">
							<alampunktNr id="1d39644a-7a9a-40c4-91d7-7ac00958106a">5</alampunktNr>
							<kuvatavNr id="7fcee620-3226-4b5f-8ca2-4dfa1e23daaf"><![CDATA[5) ]]></kuvatavNr>
							<sisuTekst id="cfc64cc7-d12e-4253-be6d-02f86361b605">
								<tavatekst id="80360560-6dc0-4f8d-a88e-08ec3cb928ed">76-aastase ja vanema isiku puhul 3-kordne aastaväärtus.</tavatekst>
							</sisuTekst>
						</alampunkt>
					</loige>
					<loige id="para356lg4">
						<loigeNr id="06ea369a-2c55-469f-a652-5d7166b3adee">4</loigeNr>
						<kuvatavNr id="e8e13a04-7dfd-49b6-961f-68db7ec1eaee"><![CDATA[(4)]]></kuvatavNr>
						<sisuTekst id="5bcd7626-3ba9-4fd8-974e-1ac02ffaac9b">
							<tavatekst id="b3f2eceb-19f8-4e32-a522-67262a7a5da7">Juriidilise isiku kasuks tähtajatu isikliku kasutusõiguse seadmisel ehitisele on tehinguväärtuseks 25-kordne kasutusõiguse aastaväärtus.</tavatekst>
						</sisuTekst>
					</loige>
					<loige id="para356lg5">
						<loigeNr id="bd7ff589-5475-4bfb-bf85-fd4c1fb55fb8">5</loigeNr>
						<kuvatavNr id="ca415f92-efb4-47e9-adc1-f65ae71b9094"><![CDATA[(5)]]></kuvatavNr>
						<sisuTekst id="808059c0-0161-4ca6-bd3b-3cd2d8a2d5ba">
							<tavatekst id="5c1dd2cf-70d5-4ff0-9c99-dbca7e356b80">Tähtajatu isikliku kasutusõiguse seadmisel elamule ühiselt mitme isiku kasuks võetakse tehinguväärtuse arvutamisel aluseks noorima isiklikku kasutusõigust teostava isiku vanus.</tavatekst>
						</sisuTekst>
					</loige>
					<loige id="para356lg6">
						<loigeNr id="c1e76db6-6ff0-4a3a-9dc2-0aabfbb62e30">6</loigeNr>
						<kuvatavNr id="ab9faa08-c6e6-40d7-a48f-c8a4e3ca30f9"><![CDATA[(6)]]></kuvatavNr>
						<sisuTekst id="4f07cdba-a71d-418e-b049-5483d9ca8ca2">
							<tavatekst id="04787739-1caa-4891-b679-0a32d085e74c">Isikliku kasutusõiguse seadmisel elamu või muu ehitise osale määratakse kasutusõiguse aastaväärtus võrdeliselt selle osa suurusega kogu elamust või muust ehitisest.</tavatekst>
						</sisuTekst>
					</loige>
					<loige id="para356lg7">
						<loigeNr id="c94ac9e5-eabf-40be-b747-51d6928b3807">7</loigeNr>
						<kuvatavNr id="61f4a43c-cd12-432c-b960-295d831866b8"><![CDATA[(7)]]></kuvatavNr>
						<sisuTekst id="39c0b227-bccb-4c2f-bc21-29b8067b97d7">
							<tavatekst id="e5fb2c0f-f503-44bf-8109-914f52a4492a">Kui isikliku kasutusõiguse sisuks on reaalservituudi teostamine, kohaldatakse tehinguväärtuse määramisel käesoleva seaduse § 354.</tavatekst>
						</sisuTekst>
					</loige>
					<loige id="para356lg8">
						<loigeNr id="3568c91e-fd00-498d-8429-f5d4609f74fd">8</loigeNr>
						<kuvatavNr id="84499f76-8c68-44b1-a2ea-e7fd7b750bfc"><![CDATA[(8)]]></kuvatavNr>
						<sisuTekst id="70151795-9c32-49f9-aabb-d0705d731f85">
							<tavatekst id="adedcb70-306e-4f89-8c6c-733c00c9b907">Muude isiklike kasutusõiguste seadmisel on tehinguväärtuseks 64 eurot.</tavatekst>
						</sisuTekst>
					</loige>
				</paragrahv>
				<paragrahv id="para357">
					<paragrahvNr id="8fc1d719-7e65-4a37-abb8-76b207b35371">357</paragrahvNr>
					<kuvatavNr id="680b56f4-a118-4a54-8ad0-9414b774fa9f"><![CDATA[§ 357. ]]></kuvatavNr>
					<paragrahvPealkiri id="f03606bc-6505-40f6-b45e-c4b851b0e0fa">Reaalkoormatis</paragrahvPealkiri>
					<loige id="para357lg1">
						<loigeNr id="0d4d2b1f-b549-4715-9764-9bcd23a6b811">1</loigeNr>
						<kuvatavNr id="f5b9a8c6-a2c2-4826-9c27-19257e2b826d"><![CDATA[(1)]]></kuvatavNr>
						<sisuTekst id="85bf13d5-3b76-471f-84a7-e47e6614ca77">
							<tavatekst id="e6aad8b4-d2b1-486f-b290-d8d3997ff4d0">Reaalkoormatise seadmisel on tehinguväärtuseks reaalkoormatise rahalise väärtuse kogusumma, kuid mitte rohkem kui 25 aasta eest.</tavatekst>
						</sisuTekst>
					</loige>
					<loige id="para357lg2">
						<loigeNr id="f22a9be9-f38f-4ce1-ba3b-50fbc5fa554a">2</loigeNr>
						<kuvatavNr id="8403a104-0509-465f-aa1f-3db37607d8ad"><![CDATA[(2)]]></kuvatavNr>
						<sisuTekst id="a0fa7d27-bc6e-4a4a-9a6f-b5da342feab8">
							<tavatekst id="4315c7f0-cddc-4d49-8e4b-f8b76c2be32b">Kui reaalkoormatise rahaline väärtus pole määratud, on selle tehinguväärtuseks 64 eurot.</tavatekst>
						</sisuTekst>
					</loige>
				</paragrahv>
				<paragrahv id="para358">
					<paragrahvNr id="42bfaf31-33f4-4e69-be85-7b2d15e544c8">358</paragrahvNr>
					<kuvatavNr id="559b60a9-1059-4b62-8955-7da94a5eca94"><![CDATA[§ 358. ]]></kuvatavNr>
					<paragrahvPealkiri id="ba65bf6f-bced-480a-993c-f8b74c00fa75">Ostueesõigus</paragrahvPealkiri>
					<loige id="para358lg1">
						<sisuTekst id="ebec2933-6e43-4c84-aace-a437cc66c862">
							<tavatekst id="a0d61dd3-e26f-4f95-be27-b18d485b9655">Ostueesõiguse seadmisel on tehinguväärtuseks pool koormatava kinnisasja omandiõiguse kinnistamise tehinguväärtusest.</tavatekst>
						</sisuTekst>
					</loige>
				</paragrahv>
				<paragrahv id="para359">
					<paragrahvNr id="7cf79306-7573-4881-8f94-86ec55176a68">359</paragrahvNr>
					<kuvatavNr id="f16814e9-aad8-4154-bdf4-a648084be450"><![CDATA[§ 359. ]]></kuvatavNr>
					<paragrahvPealkiri id="31c53716-7251-4758-b79a-f3ba31bd8d5a">Hüpoteek</paragrahvPealkiri>
					<loige id="para359lg1">
						<loigeNr id="d4f664b3-5b05-4f58-94f5-3af8a56a8c80">1</loigeNr>
						<kuvatavNr id="02cf42c4-8dcf-4dea-8ace-b163ce317208"><![CDATA[(1)]]></kuvatavNr>
						<sisuTekst id="276ea5d9-12c2-48f2-aed3-3f028359e0f5">
							<tavatekst id="0b6c483c-37bb-4517-a0db-03be8a369678">Hüpoteegi seadmisel on tehinguväärtuseks 2/3 hüpoteegisummast.</tavatekst>
						</sisuTekst>
					</loige>
					<loige id="para359lg2">
						<loigeNr id="e99c4ad9-e5da-4175-92ac-a6c0821e2d9f">2</loigeNr>
						<kuvatavNr id="e1f339d3-af83-41ed-995d-f6fe539976bc"><![CDATA[(2)]]></kuvatavNr>
						<sisuTekst id="1f1f764d-86fd-4a9d-a388-d7ef2053c397">
							<tavatekst id="c753c89b-328b-4dfc-816e-602cc138db60">Kui riiklikus ehitisregistris registreeritud pandi ümberregistreerimisel hüpoteegiks pandisumma suureneb, on tehinguväärtuseks 2/3 pandisumma ja hüpoteegisumma vahest.</tavatekst>
						</sisuTekst>
					</loige>
				</paragrahv>
				<paragrahv id="para360">
					<paragrahvNr id="c59b8466-123b-4949-b068-26b384a643bb">360</paragrahvNr>
					<kuvatavNr id="5b95c524-2cac-44e7-9fd3-5f4ef8e55211"><![CDATA[§ 360. ]]></kuvatavNr>
					<paragrahvPealkiri id="1f07f80d-80b7-4c4f-8fa0-2da2984f97c8">Järjekoha muutmine</paragrahvPealkiri>
					<loige id="para360lg1">
						<sisuTekst id="8372c6a1-c0ab-4564-ac78-4dfc7f4825c5">
							<tavatekst id="5d8d58bc-6671-4d32-9855-15b2b2df2be3">Piiratud asjaõiguse järjekoha muutmisel on tehinguväärtuseks etteastuva piiratud asjaõiguse seadmise tehinguväärtus.</tavatekst>
						</sisuTekst>
					</loige>
				</paragrahv>
				<paragrahv id="para361">
					<paragrahvNr id="548d590f-6187-46f6-beb6-0ba1ec307a1f">361</paragrahvNr>
					<kuvatavNr id="17231b7b-694b-4d14-a3fa-f8d9a58b0958"><![CDATA[§ 361. ]]></kuvatavNr>
					<paragrahvPealkiri id="e6dae5a2-bdba-4cbd-a0a4-64bdcc8d5db2">Märge</paragrahvPealkiri>
					<loige id="para361lg1">
						<sisuTekst id="b57c783d-4d51-4a77-86cb-3c03ac9d808e">
							<tavatekst id="7f2ec3d9-f82a-463c-b3a3-e17510bd6346">Märke kinnistamisel on tehinguväärtuseks selle asjaõiguse kinnistamise tehinguväärtus, mille tagamiseks märge kinnistusraamatusse kantakse.</tavatekst>
						</sisuTekst>
					</loige>
				</paragrahv>
				<paragrahv id="para362">
					<paragrahvNr id="565e678f-ccef-41be-91eb-02e51bae2cd9">362</paragrahvNr>
					<kuvatavNr id="17617cdc-ff2f-44fd-8e55-1a4b6c6b6659"><![CDATA[§ 362. ]]></kuvatavNr>
					<paragrahvPealkiri id="341f9676-8ebc-4806-8fa9-d22a9083e8b1">Kannete muutmine ja kustutamine</paragrahvPealkiri>
					<loige id="para362lg1">
						<loigeNr id="0805fd87-afdf-4af9-9b88-8fd0e0d4061a">1</loigeNr>
						<kuvatavNr id="b5792a90-21a2-4ac9-aa11-639358fda38a"><![CDATA[(1)]]></kuvatavNr>
						<sisuTekst id="05b03d32-fd9d-4210-aae2-e85acb11ba1e">
							<tavatekst id="a23eb196-d017-4637-83eb-9ae90d1bea45">Kinnistusraamatu kande muutmisel on tehinguväärtuseks sissekantud asjaõiguse muudetud sisuga kinnistamise tehinguväärtus.</tavatekst>
						</sisuTekst>
					</loige>
					<loige id="para362lg2">
						<loigeNr id="2a017719-176b-40d7-bbcb-85a45b4475da">2</loigeNr>
						<kuvatavNr id="b7fecc82-a5d4-43cf-aad7-5099ade35d86"><![CDATA[(2)]]></kuvatavNr>
						<sisuTekst id="b6429551-979e-4b2a-8a09-248a982468df">
							<tavatekst id="4d738d90-036c-4d30-a2eb-2d4783e53cdc">Kinnistusraamatu kande kustutamisel on tehinguväärtuseks märke või vastava asjaõiguse kinnistamise tehinguväärtus.</tavatekst>
						</sisuTekst>
					</loige>
				</paragrahv>
				<paragrahv id="para363">
					<paragrahvNr id="0b183099-8a1b-4480-8db8-0d50528026c3">363</paragrahvNr>
					<kuvatavNr id="0f453f45-7568-4a9a-9c6f-006530443234"><![CDATA[§ 363. ]]></kuvatavNr>
					<paragrahvPealkiri id="2ae1f124-c9d0-4561-8bd8-d1671f3d5cc8">Pandilepingu registreerimine</paragrahvPealkiri>
					<loige id="para363lg1">
						<sisuTekst id="e5826aa1-0253-4cd3-b7e3-6fc392c5637c">
							<tavatekst id="5ebd263c-cdae-40d9-b094-569e8b02955c">Pandilepingu registreerimisel on tehinguväärtuseks pandisumma.</tavatekst>
						</sisuTekst>
					</loige>
				</paragrahv>
				<paragrahv id="para364">
					<paragrahvNr id="f9b67a4e-1057-43e2-b207-ba44d65c1107">364</paragrahvNr>
					<kuvatavNr id="f444275e-06b2-47a1-b72d-978eeba14590"><![CDATA[§ 364. ]]></kuvatavNr>
					<paragrahvPealkiri id="5e10650d-90e0-4712-a96e-a6f678980759">Registerpandi järjekoha muutmine</paragrahvPealkiri>
					<loige id="para364lg1">
						<sisuTekst id="706441ab-9310-41fe-8ca4-e44a16329a99">
							<tavatekst id="b1272780-031c-44f0-9e01-cf19f4771546">Registerpandi järjekoha muutmise kinnistamisel on tehinguväärtuseks etteastuva registerpandi summa.</tavatekst>
						</sisuTekst>
					</loige>
				</paragrahv>
			</peatykk>
		</osa>
		<osa id="o5">
			<osaNr>5</osaNr>
			<kuvatavNr><![CDATA[5. osa]]></kuvatavNr>
			<osaPealkiri>RAKENDUSSÄTTED</osaPealkiri>
			<peatykk id="ptk19">
				<peatykkNr>19</peatykkNr>
				<kuvatavNr><![CDATA[19. peatükk]]></kuvatavNr>
				<peatykkPealkiri>Rakendussätted</peatykkPealkiri>
				<jagu id="jg60">
					<jaguNr>1</jaguNr>
					<kuvatavNr><![CDATA[1. jagu]]></kuvatavNr>
					<jaguPealkiri>Üleminekusätted</jaguPealkiri>
					<paragrahv id="para365">
						<paragrahvNr>365</paragrahvNr>
						<kuvatavNr><![CDATA[§ 365. ]]></kuvatavNr>
						<paragrahvPealkiri>Seaduse rakendamine</paragrahvPealkiri>
						<loige id="para365lg1">
							<sisuTekst>
								<tavatekst>Seadustes toodud viited riigilõivuseadusele (RT I 2010, 21, 107) loetakse viideteks käesolevale seadusele.</tavatekst>
							</sisuTekst>
						</loige>
					</paragrahv>
					<paragrahv id="para365b1">
						<paragrahvNr ylaIndeks="1">365</paragrahvNr>
						<kuvatavNr><![CDATA[§ 365<sup>1</sup>. ]]></kuvatavNr>
						<paragrahvPealkiri>Paragrahvi 15 lõike 4 ja § 252 kohaldamise lõpptähtpäev</paragrahvPealkiri>
						<loige id="para365b1lg1">
							<sisuTekst>
								<tavatekst>Käesoleva seaduse § 15 lõiget 4 ja § 252 kohaldatakse kuni 2020. aasta 31. märtsini §-s 252 nimetatud tegevuste suhtes, mida tehakse sööda käitleja ettevõttes 2019. aasta viimases kvartalis.</tavatekst>
							</sisuTekst>
							<muutmismarge>
								<avaldamismarge>
									<RTosa>RT I</RTosa>
									<avaldamineKuupaev>2019-12-04</avaldamineKuupaev>
									<RTartikkel>2</RTartikkel>
									<aktViide>104122019002</aktViide>
								</avaldamismarge>
								<joustumine>2019-12-14</joustumine>
							</muutmismarge>
						</loige>
					</paragrahv>
					<paragrahv id="para365b2">
						<paragrahvNr ylaIndeks="2">365</paragrahvNr>
						<kuvatavNr><![CDATA[§ 365<sup>2</sup>. ]]></kuvatavNr>
						<paragrahvPealkiri>Paragrahvi 51<sup>3</sup> rakendamine</paragrahvPealkiri>
						<loige id="para365b2lg1">
							<sisuTekst>
								<tavatekst>Käesoleva seaduse § 51<sup>3</sup> rakendatakse tagasiulatuvalt 2022. aasta 24. veebruarist.</tavatekst>
							</sisuTekst>
							<muutmismarge>
								<avaldamismarge>
									<RTosa>RT I</RTosa>
									<avaldamineKuupaev>2022-10-01</avaldamineKuupaev>
									<RTartikkel>1</RTartikkel>
									<aktViide>101102022001</aktViide>
								</avaldamismarge>
								<joustumine>2022-10-11</joustumine>
							</muutmismarge>
						</loige>
					</paragrahv>
				</jagu>
				<jagu id="jg61">
					<jaguNr>2</jaguNr>
					<kuvatavNr><![CDATA[2. jagu]]></kuvatavNr>
					<jaguPealkiri>Seaduste muutmine ja kehtetuks tunnistamine</jaguPealkiri>
					<paragrahv id="para366">
						<paragrahvNr kehtiv="0">366</paragrahvNr>
						<kuvatavNr>§ 366. </kuvatavNr>
						<sisuTekst>
							<tavatekst> – </tavatekst>
						</sisuTekst>
					</paragrahv>
					<paragrahv id="para371">
						<paragrahvNr kehtiv="0">371</paragrahvNr>
						<kuvatavNr>§ 371. </kuvatavNr>
						<sisuTekst>
							<tavatekst>[Käesolevast tekstist välja jäetud.]</tavatekst>
						</sisuTekst>
					</paragrahv>
				</jagu>
				<jagu id="jg62">
					<jaguNr>3</jaguNr>
					<kuvatavNr><![CDATA[3. jagu]]></kuvatavNr>
					<jaguPealkiri>Seaduse jõustumine</jaguPealkiri>
					<paragrahv id="para372">
						<paragrahvNr>372</paragrahvNr>
						<kuvatavNr><![CDATA[§ 372. ]]></kuvatavNr>
						<paragrahvPealkiri>Seaduse jõustumine</paragrahvPealkiri>
						<loige id="para372lg1">
							<loigeNr>1</loigeNr>
							<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
							<sisuTekst>
								<tavatekst>Käesolev seadus jõustub 2015. aasta 1. jaanuaril.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para372lg2">
							<loigeNr>2</loigeNr>
							<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
							<sisuTekst>
								<tavatekst>Käesoleva seaduse § 68 jõustub 2018. aasta 1. jaanuaril.</tavatekst>
							</sisuTekst>
						</loige>
					</paragrahv>
				</jagu>
			</peatykk>
		</osa>
	</sisu>
	<normtehnmarkus>
		<normtehnmarkusNr>1</normtehnmarkusNr>
		<normtehnmarkusTekst> Euroopa Parlamendi ja nõukogu direktiiv (EL) 2020/1828, mis käsitleb tarbijate kollektiivsete huvide kaitsmise esindushagisid ja millega tunnistatakse kehtetuks direktiiv 2009/22/EÜ (ELT L 409, 04.12.2020, lk 1–27).</normtehnmarkusTekst>
		<muutmismarge>
			<avaldamismarge>
				<RTosa>RT I</RTosa>
				<avaldamineKuupaev>2024-12-31</avaldamineKuupaev>
				<RTartikkel>5</RTartikkel>
				<aktViide>131122024005</aktViide>
			</avaldamismarge>
			<joustumine>2025-01-01</joustumine>
		</muutmismarge>
	</normtehnmarkus>
