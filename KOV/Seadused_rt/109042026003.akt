							<paragrahv id="para142b14">
								<paragrahvNr ylaIndeks="14">142</paragrahvNr>
								<kuvatavNr><![CDATA[§ 142<sup>14</sup>. ]]></kuvatavNr>
								<paragrahvPealkiri>Jätkuvat lennukõlblikkust tagava organisatsiooni sertifikaadi väljaandmise ja muutmise taotluse läbivaatamine ning sertifikaadi hoidmine</paragrahvPealkiri>
								<loige id="para142b14lg1">
									<loigeNr>1</loigeNr>
									<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Jätkuvat lennukõlblikkust tagava organisatsiooni sertifikaadi esmase taotluse läbivaatamise eest tasutakse riigilõivu 2560 eurot.</tavatekst>
									</sisuTekst>
								</loige>
								<loige id="para142b14lg2">
									<loigeNr>2</loigeNr>
									<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Jätkuvat lennukõlblikkust tagava organisatsiooni sertifikaadi muutmise taotluse läbivaatamise eest tasutakse riigilõivu 990 eurot.</tavatekst>
									</sisuTekst>
								</loige>
								<loige id="para142b14lg3">
									<loigeNr>3</loigeNr>
									<kuvatavNr><![CDATA[(3)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Jätkuvat lennukõlblikkust tagava organisatsiooni sertifikaadi hoidmise eest tasutakse iga aasta kohta riigilõivu 1625 eurot.</tavatekst>
									</sisuTekst>
								</loige>
								<loige id="para142b14lg4">
									<loigeNr>4</loigeNr>
									<kuvatavNr><![CDATA[(4)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Euroopa Parlamendi ja nõukogu määruse (EL) 2018/1139, mis käsitleb tsiviillennunduse valdkonna ühisnorme ja millega luuakse Euroopa Liidu Lennundusohutusamet ning millega muudetakse Euroopa Parlamendi ja nõukogu määrusi (EÜ) nr 2111/2005, (EÜ) nr 1008/2008, (EL) nr 996/2010, (EL) nr 376/2014 ja Euroopa Parlamendi ja nõukogu direktiive 2014/30/EL ning 2014/53/EL ning tunnistatakse kehtetuks Euroopa Parlamendi ja nõukogu määrused (EÜ) nr 552/2004 ja (EÜ) nr 216/2008 ning nõukogu määrus (EMÜ) nr 3922/91 (ELT L 212, 22.08.2018, lk 1–122), artikli 2 lõike 3 punktis d nimetatud õhusõiduki jätkuvat lennukõlblikkust korraldava organisatsiooni sertifikaadi väljaandmise eest tasutakse riigilõivu 100 eurot.</tavatekst>
									</sisuTekst>
								</loige>
								<loige id="para142b14lg5">
									<loigeNr>5</loigeNr>
									<kuvatavNr><![CDATA[(5)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Käesoleva paragrahvi lõikes 4 nimetatud organisatsiooni sertifikaadi hoidmise eest tasutakse iga aasta kohta riigilõivu 100 eurot.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130062023001</aktViide>
										</avaldamismarge>
										<joustumine>2023-07-01</joustumine>
									</muutmismarge>
								</loige>
							</paragrahv>
							<paragrahv id="para142b15">
								<paragrahvNr ylaIndeks="15">142</paragrahvNr>
								<kuvatavNr><![CDATA[§ 142<sup>15</sup>. ]]></kuvatavNr>
								<paragrahvPealkiri>Koolitusorganisatsiooni sertifikaadi väljaandmise ja muutmise taotluse läbivaatamine ning sertifikaadi hoidmine</paragrahvPealkiri>
								<loige id="para142b15lg1">
									<loigeNr>1</loigeNr>
									<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Koolitusorganisatsiooni sertifikaadi esmase taotluse läbivaatamise eest tasutakse riigilõivu 1190 eurot.</tavatekst>
									</sisuTekst>
								</loige>
								<loige id="para142b15lg2">
									<loigeNr>2</loigeNr>
									<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Koolitusorganisatsiooni sertifikaadi muutmise taotluse läbivaatamise eest tasutakse riigilõivu 320 eurot.</tavatekst>
									</sisuTekst>
								</loige>
								<loige id="para142b15lg3">
									<loigeNr>3</loigeNr>
									<kuvatavNr><![CDATA[(3)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Koolitusorganisatsiooni sertifikaadi hoidmise eest tasutakse sertifikaadi iga kehtivusaasta kohta riigilõivu 485 eurot.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130062023001</aktViide>
										</avaldamismarge>
										<joustumine>2023-07-01</joustumine>
									</muutmismarge>
								</loige>
							</paragrahv>
							<paragrahv id="para142b16">
								<paragrahvNr ylaIndeks="16">142</paragrahvNr>
								<kuvatavNr><![CDATA[§ 142<sup>16</sup>. ]]></kuvatavNr>
								<paragrahvPealkiri>Õhusõiduki tootjaorganisatsiooni sertifikaadi väljaandmise ja muutmise taotluse läbivaatamine ning sertifikaadi hoidmine</paragrahvPealkiri>
								<loige id="para142b16lg1">
									<loigeNr>1</loigeNr>
									<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Õhusõiduki tootjaorganisatsiooni sertifikaadi esmase taotluse läbivaatamise eest tasutakse riigilõivu 900 eurot.</tavatekst>
									</sisuTekst>
								</loige>
								<loige id="para142b16lg2">
									<loigeNr>2</loigeNr>
									<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Õhusõiduki tootjaorganisatsiooni sertifikaadi muutmise taotluse läbivaatamise eest tasutakse riigilõivu 185 eurot.</tavatekst>
									</sisuTekst>
								</loige>
								<loige id="para142b16lg3">
									<loigeNr>3</loigeNr>
									<kuvatavNr><![CDATA[(3)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Õhusõiduki tootjaorganisatsiooni sertifikaadi hoidmise eest tasutakse iga aasta kohta riigilõivu 185 eurot.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130062023001</aktViide>
										</avaldamismarge>
										<joustumine>2023-07-01</joustumine>
									</muutmismarge>
								</loige>
							</paragrahv>
							<paragrahv id="para142b17">
								<paragrahvNr ylaIndeks="17">142</paragrahvNr>
								<kuvatavNr><![CDATA[§ 142<sup>17</sup>. ]]></kuvatavNr>
								<paragrahvPealkiri>Õhusõiduki hooldusorganisatsiooni sertifikaadi väljaandmise ja muutmise taotluse läbivaatamine ning sertifikaadi hoidmine</paragrahvPealkiri>
								<loige id="para142b17lg1">
									<loigeNr>1</loigeNr>
									<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Õhusõiduki hooldusorganisatsiooni sertifikaadi esmase taotluse või muutmise taotluse läbivaatamise eest tasutakse riigilõivu, lähtudes taotletavast pädevusest:</tavatekst>
									</sisuTekst>
									<alampunkt id="para142b17lg1p1">
										<alampunktNr>1</alampunktNr>
										<kuvatavNr><![CDATA[1)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>õhusõiduki hoolduse A1 või A3 pädevuse taotluse puhul 1790 eurot;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b17lg1p2">
										<alampunktNr>2</alampunktNr>
										<kuvatavNr><![CDATA[2)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>õhusõiduki hoolduse A2 või A4 pädevuse taotluse puhul 895 eurot;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b17lg1p3">
										<alampunktNr>3</alampunktNr>
										<kuvatavNr><![CDATA[3)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>õhusõiduki mootori või abijõuseadme hoolduse B1 kuni B3 pädevuse taotluse puhul 895 eurot iga pädevuse kohta;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b17lg1p4">
										<alampunktNr>4</alampunktNr>
										<kuvatavNr><![CDATA[4)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>õhusõiduki komponendi hoolduse C1 kuni C20 iga pädevuse taotluse puhul 185 eurot iga pädevuse kohta;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b17lg1p5">
										<alampunktNr>5</alampunktNr>
										<kuvatavNr><![CDATA[5)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>eritööde D1 pädevuse taotluse puhul 365 eurot.</tavatekst>
										</sisuTekst>
									</alampunkt>
								</loige>
								<loige id="para142b17lg2">
									<loigeNr>2</loigeNr>
									<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Õhusõiduki hooldusorganisatsiooni sertifikaadi hoidmise eest tasutakse iga aasta kohta riigilõivu 25 protsenti käesoleva paragrahvi lõikes 1 sätestatud pädevuste eest tasutavast riigilõivumäärast.</tavatekst>
									</sisuTekst>
								</loige>
								<loige id="para142b17lg3">
									<loigeNr>3</loigeNr>
									<kuvatavNr><![CDATA[(3)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Euroopa Parlamendi ja nõukogu määruse (EL) 2018/1139 artikli 2 lõike 3 punktis d nimetatud õhusõiduki hooldusorganisatsiooni sertifikaadi väljaandmise eest tasutakse riigilõivu 100 eurot.</tavatekst>
									</sisuTekst>
								</loige>
								<loige id="para142b17lg4">
									<loigeNr>4</loigeNr>
									<kuvatavNr><![CDATA[(4)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Käesoleva paragrahvi lõikes 3 nimetatud organisatsiooni sertifikaadi hoidmise eest tasutakse iga aasta kohta riigilõivu 100 eurot.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130062023001</aktViide>
										</avaldamismarge>
										<joustumine>2023-07-01</joustumine>
									</muutmismarge>
								</loige>
							</paragrahv>
							<paragrahv id="para142b18">
								<paragrahvNr ylaIndeks="18">142</paragrahvNr>
								<kuvatavNr><![CDATA[§ 142<sup>18</sup>. ]]></kuvatavNr>
								<paragrahvPealkiri>Kombineeritud lennukõlblikkust korraldava organisatsiooni sertifikaadi väljaandmise ja muutmise taotluse läbivaatamine ning sertifikaadi hoidmine</paragrahvPealkiri>
								<loige id="para142b18lg1">
									<loigeNr>1</loigeNr>
									<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Kombineeritud lennukõlblikkust korraldava organisatsiooni sertifikaadi esmase taotluse läbivaatamise eest tasutakse riigilõivu 1190 eurot.</tavatekst>
									</sisuTekst>
								</loige>
								<loige id="para142b18lg2">
									<loigeNr>2</loigeNr>
									<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Kombineeritud lennukõlblikkust korraldava organisatsiooni sertifikaadi muutmise taotluse läbivaatamise eest tasutakse riigilõivu 850 eurot.</tavatekst>
									</sisuTekst>
								</loige>
								<loige id="para142b18lg3">
									<loigeNr>3</loigeNr>
									<kuvatavNr><![CDATA[(3)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Kombineeritud lennukõlblikkust korraldava organisatsiooni sertifikaadi hoidmise eest tasutakse iga aasta kohta riigilõivu 1190 eurot.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130062023001</aktViide>
										</avaldamismarge>
										<joustumine>2023-07-01</joustumine>
									</muutmismarge>
								</loige>
