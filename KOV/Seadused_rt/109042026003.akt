								<kuvatavNr/>
								<sisuTekst>
									<tavatekst>Ühenduse tegevusloa tõestatud koopia taotluse läbivaatamise eest tasutakse riigilõivu 18 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
