							<kuvatavNr><![CDATA[§ 143. ]]></kuvatavNr>
							<paragrahvPealkiri>Muinsuskaitseseaduses sätestatud pädevustunnistuse andmise ja pikendamise taotluse läbivaatamine</paragrahvPealkiri>
							<muutmismarge id="730c662a-77c8-4d8d-b5eb-153bda3014f3">
								<avaldamismarge id="23018205-6864-416a-b05e-a00e0acb7600">
									<RTosa id="c65d9774-6f04-49b2-b357-d9728efbc94c">RT I</RTosa>
