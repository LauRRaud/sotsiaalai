						<kuvatavNr><![CDATA[1<sup>1</sup>. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Relvaseaduse alusel tehtavad toimingud</jaotisPealkiri>
						<muutmismarge id="222c75ec-12ec-4f59-b2ec-9b269f018311">
							<avaldamismarge id="77c0c396-780c-4995-8f05-b60d7d8ed1a0">
								<RTosa id="37480ab6-52b2-480c-85ad-aad23e8018bf">RT I</RTosa>
								<avaldamineKuupaev id="62f302e0-995a-46cc-82fb-825527b3d76e">2018-06-29</avaldamineKuupaev>
								<RTartikkel id="8b4707b6-516a-46b9-933f-651da8a2e2c2">3</RTartikkel>
								<aktViide id="c05f67bc-6609-4731-9b50-f6d4249f8069">129062018003</aktViide>
							</avaldamismarge>
							<joustumine id="260eb082-d277-4aba-8720-bca3fe03a135">2018-07-01</joustumine>
						</muutmismarge>
						<paragrahv id="para202b1">
							<paragrahvNr id="0dd4ff84-eeb5-404f-9c4d-e179651bc5a0" ylaIndeks="1">202</paragrahvNr>
							<kuvatavNr id="32dd7079-6c99-4d46-8a52-77b2c078d092"><![CDATA[§ 202<sup>1</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri id="9ae41467-7e37-485c-a77c-1e3217500d79">Sõjalise otstarbega laskemoona või lahingumoona käitlemisega seotud toimingud</paragrahvPealkiri>
							<loige id="para202b1lg1">
								<loigeNr id="caf368c1-7c89-4463-a323-817a8e5f58ff">1</loigeNr>
								<kuvatavNr id="8efbd20b-94eb-4ea1-b77e-35c48feb277d"><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst id="4387ddd7-cc05-43fb-a8d8-58a59bd3c0aa">
									<tavatekst id="0afe1264-8fbc-4b45-bba4-70ce120e8ee0">Sõjalise otstarbega laskemoona või lahingumoona käitlemiseks tegevusloa taotluse läbivaatamise eest tasutakse riigilõivu 950 eurot.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para202b1lg2">
								<loigeNr id="c62d22b2-9197-44f4-a418-17cdee824683">2</loigeNr>
								<kuvatavNr id="379428ce-8434-46f9-8447-efdc134d193a"><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst id="f9446682-c4f0-4c76-bb9a-669d53bf40d3">
									<tavatekst id="163760f2-ac9f-4acd-b93d-3efdfddd5637">Sõjalise otstarbega laskemoona või lahingumoona käitlemiskoha käitamisloa taotluse läbivaatamise eest tasutakse riigilõivu 1150 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge id="9ca69536-55d3-4b9b-a794-44228ffd095a">
									<avaldamismarge id="85b36953-5c85-4af2-8c47-5b343d0390a3">
										<RTosa id="999b9e38-3bbc-401c-b1b6-38ab4e20e7d9">RT I</RTosa>
										<avaldamineKuupaev id="fe8d07b2-ef27-4041-95ed-c7daeff673fa">2018-06-29</avaldamineKuupaev>
										<RTartikkel id="25d13d55-4229-4cb9-b08c-a52e441244f4">3</RTartikkel>
										<aktViide id="c34b0cb0-f021-45d1-ae05-431d9fa6c04e">129062018003</aktViide>
									</avaldamismarge>
									<joustumine id="99220a96-044c-4a51-a258-811d5ad5c075">2018-07-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
					</jaotis>
					<jaotis id="jaotis64">
						<jaotisNr>2</jaotisNr>
						<kuvatavNr><![CDATA[2. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Kaevandamisseaduse alusel tehtavad toimingud</jaotisPealkiri>
						<muutmismarge id="b38d9ac9-08f2-4d11-b225-77f7da6c03fe">
							<tavatekst id="14e41732-24b4-4573-ab97-02b55f3bd495">Kehtetu - </tavatekst>
							<avaldamismarge id="25a335ac-55ab-40da-8776-f71abb8a2f53">
								<RTosa id="d5095de2-9dad-4794-86bd-be267acbec30">RT I</RTosa>
								<avaldamineKuupaev id="3436859a-0211-44e6-a7f9-b6ee5f55bfff">2016-11-10</avaldamineKuupaev>
								<RTartikkel id="99b06a55-f9cb-4b26-be2a-c08e57df759a">1</RTartikkel>
								<aktViide id="bb4f57f6-011a-49ac-b173-f9d35f94e7ac">110112016001</aktViide>
							</avaldamismarge>
							<joustumine id="af4796bf-48c9-4496-823d-a91d343060b6">2017-01-01</joustumine>
						</muutmismarge>
						<paragrahv id="para203">
							<paragrahvNr id="939a4d23-d7c4-4437-b986-713a9bee3e24">203</paragrahvNr>
							<kuvatavNr id="8d9cf67a-c43e-4d14-9542-5b940d014db6"><![CDATA[§ 203. ]]></kuvatavNr>
							<paragrahvPealkiri id="9fc05753-a82c-4c99-9340-866f99be0b59">Vastutava spetsialisti pädevustunnistuse andmise ja kehtivusaja pikendamise taotluse läbivaatamine</paragrahvPealkiri>
							<muutmismarge id="beaac9ae-6f1a-48d6-a5b5-761b323ffca9">
								<tavatekst id="fcf21a6a-baac-46be-9a26-a0939a6cca62">Kehtetu - </tavatekst>
								<avaldamismarge id="bd0f5694-7cfa-40c7-94d4-655921034513">
									<RTosa id="63fb6736-cdc6-4144-bb16-9a2ba49ba54c">RT I</RTosa>
									<avaldamineKuupaev id="4854f249-77d2-4034-a261-f39b1ff4bddf">2016-11-10</avaldamineKuupaev>
									<RTartikkel id="44a2435c-f637-4d92-9f6a-629fdc3a2693">1</RTartikkel>
									<aktViide id="3d9fec8d-9223-4d45-9d54-7cb73d32c2cd">110112016001</aktViide>
								</avaldamismarge>
								<joustumine id="3a8448af-dae5-426c-8cb5-cbd840b81e1a">2017-01-01</joustumine>
							</muutmismarge>
						</paragrahv>
					</jaotis>
					<jaotis id="jaotis65">
						<jaotisNr>3</jaotisNr>
						<kuvatavNr><![CDATA[3. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Mõõteseaduse alusel tehtavad toimingud</jaotisPealkiri>
						<paragrahv id="para204">
							<paragrahvNr id="5706e0b2-331c-4da8-8d23-0ae06e225726">204</paragrahvNr>
							<kuvatavNr id="b1cf1571-27ed-42a7-8b49-712bb1c6efb7"><![CDATA[§ 204. ]]></kuvatavNr>
							<paragrahvPealkiri id="22adf05f-204c-485f-b298-bbd701e8da25">Mõõtevahendi riigisisese tüübikinnitustunnistuse taotluse läbivaatamine</paragrahvPealkiri>
							<muutmismarge id="c5517adc-447b-4230-8074-87384542b201">
								<avaldamismarge id="db11447d-9543-495d-b733-0e15960b8799">
									<RTosa id="e3569da1-5a34-4abf-b972-a590881ebba7">RT I</RTosa>
									<avaldamineKuupaev id="7a26f213-50de-49cb-88e5-15081e3ae44c">2018-05-25</avaldamineKuupaev>
									<RTartikkel id="02f9df10-81d0-4204-8923-b2faed588561">1</RTartikkel>
									<aktViide id="2d25e2ee-8aa6-480a-b01a-bc4e04fa4636">125052018001</aktViide>
								</avaldamismarge>
								<joustumine id="0bc44fa0-2761-4b3d-b84e-bfdb4c3f07ee">2019-01-01</joustumine>
							</muutmismarge>
							<loige id="para204lg1">
								<sisuTekst id="f42ad698-b21d-4e1c-8ae1-48016b3da746">
									<tavatekst id="8cc1456a-9515-4708-9b82-3700ca423316">Riigisisese tüübikinnitustunnistuse andmise, selle muutmise või kehtivusaja pikendamise taotluse läbivaatamise eest tasutakse riigilõivu 240 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge id="2157d09c-ee0a-4b81-86e1-36a3637a433e">
									<avaldamismarge id="b3d3e3b4-eaa2-44db-8710-310cdb118e56">
										<RTosa id="b884e107-fd75-4151-a598-ac98b7f8b4fc">RT I</RTosa>
										<avaldamineKuupaev id="f9de1031-3ba7-425b-a67a-e0e58d2f16c3">2018-05-25</avaldamineKuupaev>
										<RTartikkel id="538a8338-af8c-4b7a-8f6a-280a9af489b9">1</RTartikkel>
										<aktViide id="d86cece8-cf9b-4237-a6a6-d8ffd835572a">125052018001</aktViide>
									</avaldamismarge>
									<joustumine id="fad1763c-19fe-4933-846e-9a9e727d6031">2019-01-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
					</jaotis>
					<jaotis id="jaotis66">
						<jaotisNr>4</jaotisNr>
						<kuvatavNr><![CDATA[4. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Elektroonilise side seaduse alusel tehtavad toimingud</jaotisPealkiri>
						<paragrahv id="para205">
							<paragrahvNr id="41f4d9fc-1c2a-466f-acb3-a6884b181fb8">205</paragrahvNr>
							<kuvatavNr id="2e47a1e7-606d-4064-8711-d44e407e9e86"><![CDATA[§ 205. ]]></kuvatavNr>
							<paragrahvPealkiri id="72c8779b-d25f-443d-b452-ff99f7b8734e">Dokumendi ärakirja väljastamine</paragrahvPealkiri>
							<loige id="para205lg1">
								<sisuTekst id="3a15c14d-ba7b-41f4-80e3-8882f570fc75">
									<tavatekst id="aa8595c9-bade-4b0e-a2a8-b7209cd20b02">Tarbijakaitse ja Tehnilise Järelevalve Ameti väljastatava dokumendi kinnitatud ärakirja eest tasutakse riigilõivu 4 eurot iga dokumendi eest.</tavatekst>
								</sisuTekst>
								<muutmismarge id="1baa4768-703b-447d-8559-fd9d8f619e99">
									<avaldamismarge id="79d5140c-4604-4730-b4f1-9b3f07e135b0">
										<RTosa id="9ee51d1f-559d-43bf-8865-ac0b4c9b1547">RT I</RTosa>
										<avaldamineKuupaev id="715d9cb8-b50f-4341-9971-2f5510972446">2018-12-12</avaldamineKuupaev>
										<RTartikkel id="ec87e8fd-d3da-48db-b7d6-1d6a673cc878">3</RTartikkel>
										<aktViide id="03dab41c-fe9f-449e-99ac-fce7a62c70f2">112122018003</aktViide>
									</avaldamismarge>
									<joustumine id="e383c409-e9b2-4c5b-8c47-c925cf32c4ee">2019-01-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
						<paragrahv id="para206">
							<paragrahvNr id="ef6795c5-0e8a-4ec9-87be-21f8d70a2707">206</paragrahvNr>
							<kuvatavNr id="aaa4b7fd-8e43-447f-94b4-0fef3c58ae08"><![CDATA[§ 206. ]]></kuvatavNr>
							<paragrahvPealkiri id="6bdf0f6f-f1d8-4bf7-8fe1-2feaf8972375">Sagedusloa andmine, muutmine ja kehtivusaja pikendamine</paragrahvPealkiri>
							<loige id="para206lg1">
								<loigeNr id="3152d691-d87b-4567-bde0-7c535200e3fd">1</loigeNr>
								<kuvatavNr id="ab561ecf-edc2-48ef-a9a9-0866da982bd3"><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst id="9712ab5f-8eee-474b-acb9-aa2fa05b7ba5">
									<tavatekst id="965581cf-99db-45c6-a3bc-aff7e1df8e3b">Amatöörraadiojaama tööloa taotluse või tööloa kehtivusaja pikendamise taotluse läbivaatamise eest tasutakse riigilõivu 10 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge id="6a59ce32-6333-4c59-aff8-5b244958f7eb">
									<avaldamismarge id="dc6538bc-5447-41a5-bf39-a3414176c7a8">
										<RTosa id="800c2ede-c36f-492f-8e93-22b92530b83b">RT I</RTosa>
										<avaldamineKuupaev id="5d3ae19f-f191-42a9-8ac3-da261e9f6bf2">2015-12-15</avaldamineKuupaev>
										<RTartikkel id="145e46d6-ff6a-4e45-9408-0283f74386c4">1</RTartikkel>
										<aktViide id="e080e14a-fbb2-43ab-aff3-17f73c7bd9c9">115122015001</aktViide>
									</avaldamismarge>
									<joustumine id="f22e5b41-6b01-4f8b-8b07-4d1774276be4">2016-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para206lg2">
								<loigeNr id="d0eef522-c731-4b0e-8574-d08b685ec33b">2</loigeNr>
								<kuvatavNr id="e3ecc3dd-af21-491a-b471-39fc0bd9784d"><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst id="b9bd4060-9b75-43ff-8f24-e5e43d8b8575">
									<tavatekst id="13035a7b-7c5f-417b-b5a8-982ab53d783b">Sagedusloa andmise või kehtivusaja pikendamise eest ühe simplekssideks kasutatava raadiosageduskanali kohta tasutakse riigilõivu:</tavatekst>
								</sisuTekst>
								<alampunkt id="para206lg2p1">
									<alampunktNr id="6bd126bf-6c99-4073-9209-7f5e9102d123">1</alampunktNr>
									<kuvatavNr id="e847708d-c113-4eed-86b8-948c8029f8b9"><![CDATA[1) ]]></kuvatavNr>
									<sisuTekst id="3bdf3f19-1d47-498b-b9a3-555fe28f1642">
										<tavatekst id="65c1ad53-4ed4-4057-9815-caf333c78fd0">ühes maakonnas paikneva raadiovõrgu eest käesoleva seaduse lisas 3 (edaspidi <i>lisa 3</i>) sätestatud määras;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para206lg2p2">
									<alampunktNr id="61b21608-cede-46ef-9f6e-2270d5bed711">2</alampunktNr>
									<kuvatavNr id="f7559915-908f-4336-9b8f-69be9bdd7861"><![CDATA[2) ]]></kuvatavNr>
									<sisuTekst id="e5a7d4c5-6d05-440d-815a-01d3bcbdffea">
										<tavatekst id="55a717c1-88fb-47db-a12f-123efb60a02b">kahes kuni viies maakonnas paikneva raadiovõrgu eest lisas 3 sätestatud määra kahekordses suuruses;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para206lg2p3">
									<alampunktNr id="430d5bdc-9c23-40e8-9e95-8cdd989f0e7b">3</alampunktNr>
									<kuvatavNr id="835015a0-0115-4278-900f-58c119e8a5a5"><![CDATA[3) ]]></kuvatavNr>
									<sisuTekst id="adc360db-07e5-4c03-b55f-3cea1811afc5">
										<tavatekst id="7a267126-52f9-430f-862b-6d3a73a40243">kuues kuni kümnes maakonnas paikneva raadiovõrgu eest lisas 3 sätestatud määra kolmekordses suuruses;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para206lg2p4">
									<alampunktNr id="b1929e3c-c738-48ce-8bcd-28787a9f9ac0">4</alampunktNr>
									<kuvatavNr id="b7b5cbd9-5e99-4236-b55d-dda81708da11"><![CDATA[4) ]]></kuvatavNr>
									<sisuTekst id="166b8bf3-332d-44a2-b91d-7e537fea3aa8">
										<tavatekst id="5ad868e9-ad12-4cb0-8068-b7bf5be21447">üheteistkümnes ja enamas maakonnas paikneva raadiovõrgu eest lisas 3 sätestatud määra viiekordses suuruses;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para206lg2p5">
									<alampunktNr id="27675c2f-00b8-4991-8cdd-9bab53001418">5</alampunktNr>
									<kuvatavNr id="58f112e0-eb67-44bf-88c7-5fa333c8bef3"><![CDATA[5) ]]></kuvatavNr>
									<sisuTekst id="9cc70b2c-2cb7-458e-8071-f454fd114fb1">
										<tavatekst id="1573850b-8cf5-439d-baab-b03ebb1bf135">ühe raadiosideliini raadiosaatja eest lisas 3 sätestatud määras;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para206lg2p6">
									<alampunktNr id="cff8e7eb-c856-4944-ab51-261775b388dc">6</alampunktNr>
									<kuvatavNr id="0c549372-037f-459a-b9c3-4a3e316ad416"><![CDATA[6) ]]></kuvatavNr>
									<sisuTekst id="fc523459-d47b-4ddf-b5c3-9c3edc60f56b">
										<tavatekst id="6fce511e-36e7-4cfb-9770-1909edfeecba">vee- või õhusõidukiga side pidamiseks kasutatava paikse või liikuva maapealse raadiosaatja, sealhulgas navigatsioonisaatja eest lisas 3 sätestatud määras.</tavatekst>
									</sisuTekst>
								</alampunkt>
							</loige>
							<loige id="para206lg3">
								<loigeNr id="c0239b80-2a13-4d6d-b263-2004e19cbafe">3</loigeNr>
								<kuvatavNr id="4cefd92a-4ad0-4797-ba9b-3a4d4dc136ec"><![CDATA[(3)]]></kuvatavNr>
								<sisuTekst id="8975fd55-f5ed-4c0d-afd8-025489a3a1e0">
									<tavatekst id="056d6115-7391-4e96-a197-4a8032a07909">Lähitoimeseadmetele üheks aastaks sagedusloa andmise või kehtivusaja pikendamise eest tasutakse riigilõivu 16 eurot.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para206lg4">
								<loigeNr id="ee607c32-6d84-428e-a123-d134ced1f3fc">4</loigeNr>
								<kuvatavNr id="75846c0f-3162-4109-9339-987deab0f56a"><![CDATA[(4)]]></kuvatavNr>
								<sisuTekst id="fe77a565-f877-4896-9e86-b9063ef6bd34">
									<tavatekst id="62c25ca4-3064-45b8-a274-553a228323a7">Sagedusloa andmise või kehtivusaja pikendamise eest ühe dupleks- või semiduplekssideks kasutatava raadiosageduskanali kohta tasutakse riigilõivu:</tavatekst>
								</sisuTekst>
								<alampunkt id="para206lg4p1">
									<alampunktNr id="5b9a0af2-b575-4b47-940b-f59872ad4aaf">1</alampunktNr>
									<kuvatavNr id="fc11cf66-19d2-4b1a-990b-f0faf96d229d"><![CDATA[1) ]]></kuvatavNr>
									<sisuTekst id="6995fa23-b456-4131-ac35-00d2c5b63d36">
										<tavatekst id="024a7d6f-0e66-446e-8235-2832191fb575">ühes maakonnas paikneva raadiovõrgu eest lisa 3 punktides 1 ja 6 sätestatud määra pooleteisekordses suuruses;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para206lg4p2">
									<alampunktNr id="534ffdfd-b972-42ec-96fc-38b39d826d20">2</alampunktNr>
									<kuvatavNr id="900f8791-ba0f-45b2-b645-7b307c1e990e"><![CDATA[2) ]]></kuvatavNr>
									<sisuTekst id="6a4010ed-9133-4f2d-8e4a-8b52d46f510f">
										<tavatekst id="5193da8a-b7e2-4f54-b0ef-0aceda48a8e0">kahes kuni viies maakonnas paikneva raadiovõrgu eest lisa 3 punktides 1 ja 6 sätestatud määra kolmekordses suuruses;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para206lg4p3">
									<alampunktNr id="142b788e-efd7-4eec-aca5-57ab9d5d968b">3</alampunktNr>
									<kuvatavNr id="1b9d5604-ef4b-45d4-aed6-1885c34ad489"><![CDATA[3) ]]></kuvatavNr>
									<sisuTekst id="97b9b940-8d51-4496-a88a-5cc64bfa7089">
										<tavatekst id="a2a66b7d-ec31-47d0-b775-d4f614c3f2d6">kuues kuni kümnes maakonnas paikneva raadiovõrgu eest lisa 3 punktides 1 ja 6 sätestatud määra neljakordses suuruses;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para206lg4p4">
									<alampunktNr id="78797a0e-3f15-4c82-a633-32a6fc0bb177">4</alampunktNr>
									<kuvatavNr id="473c948b-370c-4a03-bd71-2f82df416caa"><![CDATA[4) ]]></kuvatavNr>
									<sisuTekst id="e768f52b-a1ae-428f-9e7a-66df20cdea2d">
										<tavatekst id="5e3a4281-30e2-4dc6-8b63-6af1689916b5">üheteistkümnes ja enamas maakonnas paikneva raadiovõrgu eest lisa 3 punktides 1 ja 6 sätestatud määra seitsmekordses suuruses;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para206lg4p5">
									<alampunktNr id="ad51d285-b1a4-447b-8b5c-bfcd12309095">5</alampunktNr>
									<kuvatavNr id="6dced384-cb6d-449b-9fae-bff24a781c66"><![CDATA[5) ]]></kuvatavNr>
									<sisuTekst id="dbf6dc6d-d167-481e-9ec0-5a6b588f04c5">
										<tavatekst id="8a5d8893-850e-40ee-9171-64379ce4ab81">ühe raadiosideliini raadiosaatja eest lisa 3 punktis 4 sätestatud määra pooleteisekordses suuruses.</tavatekst>
									</sisuTekst>
								</alampunkt>
							</loige>
							<loige id="para206lg5">
								<loigeNr id="a84aae40-bdb5-4fb1-95cd-d616084ae6c5">5</loigeNr>
								<kuvatavNr id="6ce878f5-fb86-47e2-aab9-35c9c051d11d"><![CDATA[(5)]]></kuvatavNr>
								<sisuTekst id="f5027e21-ab05-4f82-ab1a-87903f2b50fe">
									<tavatekst id="35598a09-1319-4e26-a0c1-640fbbe18080">Sagedusloa andmise või kehtivusaja pikendamise eest ühe mobiiltelefonivõrgu, juurdepääsu raadiovõrgu või liikuva maaside lairiba raadiovõrgu kohta tasutakse riigilõivu:</tavatekst>
								</sisuTekst>
								<alampunkt id="para206lg5p1">
									<alampunktNr id="841cde50-0510-4abd-8274-b751608c9cf5">1</alampunktNr>
									<kuvatavNr id="1e26a9c3-feb9-4fd3-be1d-9230b58a06af"><![CDATA[1) ]]></kuvatavNr>
									<sisuTekst id="09c84a64-d372-4b0f-bdbf-96fc46d9d89c">
										<tavatekst id="1e8ce0bb-50ff-4d75-9c5f-a71e1259e5bb">ühes maakonnas paikneva raadiovõrgu eest lisa 3 punktis 2 sätestatud määra pooleteisekordses suuruses;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para206lg5p2">
									<alampunktNr id="67856117-ea5d-4f26-bd4e-692b3517f6a1">2</alampunktNr>
									<kuvatavNr id="ec497966-8c2b-4a48-9771-560a40cdb7c5"><![CDATA[2) ]]></kuvatavNr>
									<sisuTekst id="8d5c5ca3-df2e-41e8-aa3f-7f098673f703">
										<tavatekst id="dd3233b4-b625-40ed-a2a5-f78ec9166f5d">kahes kuni viies maakonnas paikneva raadiovõrgu eest lisa 3 punktis 2 sätestatud määra kolmekordses suuruses;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para206lg5p3">
									<alampunktNr id="a6458148-fbcf-4bc0-b34f-0bce9bba74f0">3</alampunktNr>
									<kuvatavNr id="4fdac891-03bc-4827-99d1-c248ed28894f"><![CDATA[3) ]]></kuvatavNr>
									<sisuTekst id="388417a7-178f-49f1-aa4a-5dc88e84a5e5">
										<tavatekst id="b261c568-947e-49e4-bdb1-27626ea4b60a">kuues kuni kümnes maakonnas paikneva raadiovõrgu eest lisa 3 punktis 2 sätestatud määra neljakordses suuruses;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para206lg5p4">
									<alampunktNr id="d70adde2-0892-4aa6-a415-c6b6fc58d89c">4</alampunktNr>
									<kuvatavNr id="3f0b7121-0e6f-4f0a-9224-734fa5d4763b"><![CDATA[4) ]]></kuvatavNr>
									<sisuTekst id="ea7f1007-9673-473c-8e77-63b4e42668d8">
										<tavatekst id="cbdd7756-6e2f-45e8-914f-d0ac9cb6c384">üheteistkümnes ja enamas maakonnas paikneva raadiovõrgu eest lisa 3 punktis 2 sätestatud määra seitsmekordses suuruses.</tavatekst>
									</sisuTekst>
								</alampunkt>
							</loige>
							<loige id="para206lg5b1">
								<loigeNr ylaIndeks="1">5</loigeNr>
								<kuvatavNr><![CDATA[(5<sup>1</sup>)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Sagedusloa andmise või kehtivusaja pikendamise eest ühe privaatse liikuva maaside lairiba raadiovõrgu kohta tasutakse riigilõivu 800 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2021-12-15</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>115122021001</aktViide>
									</avaldamismarge>
									<joustumine>2022-02-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para206lg6">
								<loigeNr id="b69f2614-46e7-49ef-b8ed-c9e8bf95112b">6</loigeNr>
								<kuvatavNr id="b2185220-832e-43fe-82ce-2225ef3081c4"><![CDATA[(6)]]></kuvatavNr>
								<sisuTekst id="4da0b24e-658e-4708-88f8-436aa9d3cbaa">
									<tavatekst id="a7092137-99f4-43d4-a4f1-75e7448191b9">Vee- või õhusõiduki raadioloa kuni kolmeks aastaks andmise või kehtivusaja pikendamise eest tasutakse riigilõivu 1/3 osa lisas 3 sätestatud määrast iga aasta kohta.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para206lg7">
								<loigeNr id="e3af8f0e-4cdd-4b5c-a813-4f346d7108c2">7</loigeNr>
								<kuvatavNr id="b9f8239b-220f-4ba3-a219-8923874e6cd5"><![CDATA[(7)]]></kuvatavNr>
								<sisuTekst id="6b3a8e1a-2db6-42f8-9372-d5b68692f63c">
									<tavatekst id="234fc8f0-2bfb-4323-b776-112455f81e63">Sagedusloa andmise või kehtivusaja pikendamise eest 12,5 kHz või väiksema kanalisammu puhul tasutakse riigilõivu 50 protsenti käesoleva paragrahvi lõigete 2 ja 4 ning lisa 3 punkti 1 alusel arvutatud riigilõivumäärast.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para206lg7b1">
								<loigeNr ylaIndeks="1">7</loigeNr>
								<kuvatavNr><![CDATA[(7<sup>1</sup>)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Sagedusloa, välja arvatud vee- ja õhusõiduki raadioluba, amatöörraadiojaama tööluba ning käesoleva paragrahvi lõigetes 5 ja 5<sup>1</sup> sätestatud võrkude sagedusload, kuni seitsmeks kalendripäevaks andmise eest tasutakse riigilõivu 20 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2021-12-15</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>115122021001</aktViide>
									</avaldamismarge>
									<joustumine>2022-02-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para206lg8">
								<loigeNr id="30f8a852-2414-4c8f-b4a0-a7663354d02f">8</loigeNr>
								<kuvatavNr id="9632cde5-ea74-4ba0-940d-64bf7d4ac5ab"><![CDATA[(8)]]></kuvatavNr>
								<sisuTekst id="09a658bb-3447-4240-a524-33bec6afa8fa">
									<tavatekst id="8d6d9953-9330-4ba9-bfc3-48f498dc0818">Sagedusloa, välja arvatud vee- ja õhusõiduki raadioluba ning amatöörraadiojaama tööluba, 8–31 kalendripäevaks andmise või kehtivusaja pikendamise eest tasutakse riigilõivu 1/6 osa lisas 3 sätestatud määrast.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2021-12-15</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>115122021001</aktViide>
									</avaldamismarge>
									<joustumine>2022-02-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para206lg9">
								<loigeNr id="f7e4a38f-7602-4d6e-ab0a-e5f81e25711f">9</loigeNr>
								<kuvatavNr id="ee04fef2-e40e-418c-91e5-c5cad9ac6d6e"><![CDATA[(9)]]></kuvatavNr>
								<sisuTekst id="98ab4108-7947-4023-acb4-4d9a3bb4889f">
									<tavatekst id="92c18cad-e4ae-4a96-bd94-bf5cf4fdf973">Vee- või õhusõiduki raadioloa kuni 31 kalendripäevaks andmise või kehtivusaja pikendamise eest tasutakse riigilõivu 1/12 osa lisas 3 sätestatud määrast.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para206lg10">
								<loigeNr id="31e5f8a5-d54f-4b84-9b3f-cc9cecbfbed2">10</loigeNr>
								<kuvatavNr id="54369276-a015-4dc1-9d98-45b3bb1eedca"><![CDATA[(10)]]></kuvatavNr>
								<sisuTekst id="11dc4a97-5e12-4afa-96b1-473fba5280cb">
									<tavatekst id="5e21c0ee-921e-4230-9664-35e35210a3c8">Sagedusloa, välja arvatud vee- ja õhusõiduki raadioluba ning amatöörraadiojaama tööluba, 32 kalendripäevast kuni 11 kuuks andmise või kehtivusaja pikendamise eest tasutakse riigilõivu 1/12 osa lisas 3 sätestatud määrast iga kuu kohta.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2021-12-15</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>115122021001</aktViide>
									</avaldamismarge>
									<joustumine>2022-02-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para206lg11">
								<loigeNr id="4fc8c219-e08d-4a83-b6cb-8367b5e99f9d">11</loigeNr>
								<kuvatavNr id="aef67184-2266-4505-8a0c-b97415b39ee1"><![CDATA[(11)]]></kuvatavNr>
								<sisuTekst id="650e7b86-a179-4bc6-80f5-b12a1a109b20">
									<tavatekst id="01e6c7fd-9068-4216-a806-e211937aa1cf">Vee- või õhusõiduki raadioloa 32 kalendripäevaks kuni 11 kuuks andmise või kehtivusaja pikendamise eest tasutakse riigilõivu 1/24 osa lisas 3 sätestatud määrast iga kuu kohta.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para206lg12">
								<loigeNr id="fbc0e71d-ac53-4139-ad10-f5b4218d5f54">12</loigeNr>
								<kuvatavNr id="6a5def24-abc1-4292-bab6-8f6655c3f38c"><![CDATA[(12)]]></kuvatavNr>
								<sisuTekst id="4fe06644-e8ae-4650-b083-7c0562d5c6de">
									<tavatekst id="72bb0440-91a3-4654-801b-bee96c15d8fa">Sagedusloa omaniku soovil sagedusloal märgitud andmete või tingimuste muutmise eest tasutakse riigilõivu 16 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge id="8633c8b1-84ae-48b0-97b2-abe4adab24ec">
									<avaldamismarge id="1e767c79-185b-435e-9652-11556b89c378">
										<RTosa id="078c0199-c6f1-4515-a94d-b26cb31228dd">RT I</RTosa>
										<avaldamineKuupaev id="91362e97-ce37-46cb-a71d-07f042fba112">2015-12-15</avaldamineKuupaev>
										<RTartikkel id="23afcade-b809-4668-9965-ba6735df3158">1</RTartikkel>
										<aktViide id="6bf37324-a10d-4e99-bb31-1eaee7142d56">115122015001</aktViide>
									</avaldamismarge>
									<joustumine id="a11241a8-b537-47f2-8b78-fb7a0fa9a680">2016-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para206lg13">
								<loigeNr id="59737e90-9e6e-4c4d-83fb-b25ba0c618e1">13</loigeNr>
								<kuvatavNr id="9791021b-ea96-4d90-ab7f-616147fd929b"><![CDATA[(13)]]></kuvatavNr>
								<sisuTekst id="bbb63035-91cd-4147-bcd3-28fe99662353">
									<tavatekst id="8f8ae983-f3cc-4541-bec3-905c211e00cf">Sagedusloa omaniku soovil sagedusloal lisas 3 nimetatud tingimuste muutmise eest tasutakse riigilõivu lisaks käesoleva paragrahvi lõikes 12 sätestatud riigilõivumäärale 1/12 osa lisas 3 sätestatud esialgse riigilõivumäära ja muudetud tingimuste esialgsest suurema riigilõivumäära erinevusest iga kuu kohta, mis on jäänud sagedusloa kehtivusaja lõppemiseni.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para206lg14">
								<loigeNr id="ae007c0a-2024-4efb-b0e9-7bd04c45a169">14</loigeNr>
								<kuvatavNr id="f9a43e6f-f298-4776-b615-e7b6026e909c"><![CDATA[(14)]]></kuvatavNr>
								<sisuTekst id="c3cf99c1-b602-40a9-87b0-1fde1a5977fa">
									<tavatekst id="ad22b915-1d71-477b-a77c-429bf6b8b6f9">Sagedusloa omaniku soovil sagedusloal maakondade arvu suurendamise eest tasutakse riigilõivu lisaks käesoleva paragrahvi lõikes 12 sätestatud riigilõivumäärale 1/12 osa käesoleva paragrahvi lõigetes 2 ja 4 nimetatud esialgse ja suurendatud maakondade arvu riigilõivumäärade erinevusest iga kuu kohta, mis on jäänud sagedusloa kehtivusaja lõppemiseni.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para206lg15">
								<loigeNr id="9ccc6356-8380-4594-bef4-b3bb427cb312">15</loigeNr>
								<kuvatavNr id="39813e0c-f5ef-40d9-9352-00677a0b06e7"><![CDATA[(15)]]></kuvatavNr>
								<sisuTekst id="7003df27-9193-4213-b732-13adf4c506ef">
									<tavatekst>Numeratsiooniplaanis elektroonilise side otstarbeks määratud numbriloa andmise või kehtivusaja pikendamise eest tasutakse riigilõivu lisas 3 sätestatud määras.</tavatekst>
								</sisuTekst>
							</loige>
						</paragrahv>
						<paragrahv id="para207">
							<paragrahvNr id="c4f3a25d-5c01-4daf-9d63-388005f15e0b">207</paragrahvNr>
							<kuvatavNr id="ee82aecb-78c3-4e23-91a8-297b58c1579f"><![CDATA[§ 207. ]]></kuvatavNr>
							<paragrahvPealkiri id="30eaf4f8-58eb-41da-80bf-b577909ae360">Raadioamatööri harmoneeritud kvalifikatsioonitunnistuse andmine</paragrahvPealkiri>
							<loige id="para207lg1">
								<sisuTekst id="90e0e458-cac9-4fa2-ab4b-96f8ec7a97c7">
									<tavatekst>Raadioamatööri harmoneeritud kvalifikatsioonitunnistuse (<i>Harmonised Amateur Radio Examination Certificate</i> – HAREC) andmise eest tasutakse riigilõivu 16 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge id="2722c1f5-7cca-4dd2-bbef-5bf165ef3f2b">
									<avaldamismarge id="a92d6653-310c-40eb-9912-41a3ec2ac56b">
										<RTosa id="341f5e54-e503-41ae-a39d-bdaa71db71d3">RT I</RTosa>
										<avaldamineKuupaev id="2b486cb6-4704-4f4c-be27-c225d6e4e731">2015-12-15</avaldamineKuupaev>
										<RTartikkel id="90d211e1-f08c-40da-87d1-c6439b8a6f72">1</RTartikkel>
										<aktViide id="1e41b73b-f37c-4a3d-a837-f2d016c4508b">115122015001</aktViide>
									</avaldamismarge>
									<joustumine id="cb40c5c4-5de6-421e-95fa-c81cd929d596">2016-01-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
					</jaotis>
					<jaotis id="jaotis67">
						<jaotisNr>5</jaotisNr>
						<kuvatavNr><![CDATA[5. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Digitaalallkirja seaduse alusel tehtavad toimingud</jaotisPealkiri>
						<muutmismarge id="8e0b1228-27b5-4d91-934c-d1aa16a24d40">
							<tavatekst id="8859cc90-178f-4d46-af46-533a683e82dc">Kehtetu - </tavatekst>
							<avaldamismarge id="3e7db941-55b7-4fec-8d75-ecf4a8d4c18e">
								<RTosa id="106ac67f-7296-44c3-9f31-da11b1d8f503">RT I</RTosa>
								<avaldamineKuupaev id="81cf8c87-7cfa-4ac8-af48-f3b36f7753cb">2016-10-25</avaldamineKuupaev>
								<RTartikkel id="ece81a49-47d7-4917-8ea1-47eb3abc02b9">1</RTartikkel>
								<aktViide id="6438f9c8-ec59-44e6-bbf5-071e86196598">125102016001</aktViide>
							</avaldamismarge>
							<joustumine id="486549c3-45bc-482d-99e3-23dc7c5195d1">2016-10-26</joustumine>
						</muutmismarge>
						<paragrahv id="para208">
							<paragrahvNr id="6f74763b-bbc0-4a05-9975-6bde59db0c08">208</paragrahvNr>
