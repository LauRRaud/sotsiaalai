							<paragrahvPealkiri id="4c96ce3d-1320-4994-b773-f378b96463ff">Biotsiidi toimeaine biotsiididirektiivi I, I A ja I B lisasse kandmine</paragrahvPealkiri>
							<muutmismarge id="79d1ac79-e41c-4da1-ac6b-385d741f3462">
								<tavatekst id="859cd214-96d4-4024-a799-9f88ba4861d9">Kehtetu - </tavatekst>
								<avaldamismarge id="df273ecf-47f9-42bd-821f-0fc470e2801e">
									<RTosa id="dbfc2476-42a3-409e-8471-6e554af36614">RT I</RTosa>
									<avaldamineKuupaev id="635b6428-f707-4dae-b00b-493e23e81410">2015-03-10</avaldamineKuupaev>
									<RTartikkel id="9ba5b4cc-1f3e-4b52-b77b-797097eecf7b">1</RTartikkel>
