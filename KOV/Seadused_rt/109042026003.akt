									<aktViide>130062023001</aktViide>
								</avaldamismarge>
								<joustumine>2023-07-01</joustumine>
							</muutmismarge>
							<paragrahv id="para142b63">
								<paragrahvNr ylaIndeks="63">142</paragrahvNr>
								<kuvatavNr><![CDATA[§ 142<sup>63</sup>. ]]></kuvatavNr>
								<paragrahvPealkiri>Sadamarajatise esmase, korralise ja täisülevaatuse tegemine</paragrahvPealkiri>
								<loige id="para142b63lg1">
									<loigeNr/>
									<kuvatavNr/>
									<sisuTekst>
										<tavatekst>Sadamarajatise esmase, korralise ja täisülevaatuse tegemise eest tasutakse riigilõivu 150 eurot.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130122023001</aktViide>
										</avaldamismarge>
										<joustumine>2024-07-01</joustumine>
									</muutmismarge>
								</loige>
							</paragrahv>
							<paragrahv id="para142b64">
								<paragrahvNr ylaIndeks="64">142</paragrahvNr>
								<kuvatavNr><![CDATA[§ 142<sup>64</sup>. ]]></kuvatavNr>
								<paragrahvPealkiri>Sadama ja sadamarajatise turvalisuse riskianalüüs ning turvaplaan</paragrahvPealkiri>
								<loige id="para142b64lg1">
									<loigeNr>1</loigeNr>
									<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Sadama ja sadamarajatise turvalisuse riskianalüüsi läbiviimise ja selle aruandesse muudatuste tegemise eest tasutakse riigilõivu 200 eurot iga sadama või sadamarajatise kohta, kuid kokku mitte üle 1000 euro.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130122023001</aktViide>
										</avaldamismarge>
										<joustumine>2024-07-01</joustumine>
									</muutmismarge>
								</loige>
								<loige id="para142b64lg2">
									<loigeNr>2</loigeNr>
									<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Sadama ja sadamarajatise turvaplaanide ja nende muudatuste läbivaatamise eest tasutakse riigilõivu 200 eurot iga sadama või sadamarajatise kohta, kuid kokku mitte üle 1000 euro.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130122023001</aktViide>
										</avaldamismarge>
										<joustumine>2024-07-01</joustumine>
									</muutmismarge>
								</loige>
								<loige id="para142b64lg3">
									<loigeNr>3</loigeNr>
									<kuvatavNr><![CDATA[(3)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Kui sadama või sadamarajatise turvaplaani või selle muudatuste läbivaatamisel selgub, et sadam või sadamarajatis ei ole nõuetekohane, tasutakse uue turvaplaani või selle muudatuste läbivaatamise eest riigilõivu käesoleva paragrahvi lõikes 2 sätestatud määras.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130062023001</aktViide>
										</avaldamismarge>
										<joustumine>2023-07-01</joustumine>
									</muutmismarge>
								</loige>
							</paragrahv>
							<paragrahv id="para142b65">
								<paragrahvNr ylaIndeks="65">142</paragrahvNr>
								<kuvatavNr><![CDATA[§ 142<sup>65</sup>. ]]></kuvatavNr>
								<paragrahvPealkiri>Isiku sadamakapteniks atesteerimiseks esitamine</paragrahvPealkiri>
								<loige id="para142b65lg1">
									<loigeNr/>
									<kuvatavNr/>
									<sisuTekst>
										<tavatekst>Isiku sadamakapteniks atesteerimiseks esitamisel tasutakse riigilõivu 75 eurot.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130062023001</aktViide>
										</avaldamismarge>
										<joustumine>2023-07-01</joustumine>
									</muutmismarge>
								</loige>
							</paragrahv>
							<paragrahv id="para142b66">
								<paragrahvNr ylaIndeks="66">142</paragrahvNr>
								<kuvatavNr><![CDATA[§ 142<sup>66</sup>. ]]></kuvatavNr>
								<paragrahvPealkiri>Sadama ja sadamarajatise turvaülema väljaõppe korraldamise tegevusloa taotluse läbivaatamine</paragrahvPealkiri>
								<loige id="para142b66lg1">
									<loigeNr/>
									<kuvatavNr/>
									<sisuTekst>
										<tavatekst>Sadama ja sadamarajatise turvaülema väljaõppe korraldamise tegevusloa taotluse läbivaatamise eest tasutakse riigilõivu 300 eurot.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130062023001</aktViide>
										</avaldamismarge>
										<joustumine>2023-07-01</joustumine>
									</muutmismarge>
								</loige>
							</paragrahv>
							<paragrahv id="para142b67">
								<paragrahvNr ylaIndeks="67">142</paragrahvNr>
								<kuvatavNr><![CDATA[§ 142<sup>67</sup>. ]]></kuvatavNr>
								<paragrahvPealkiri>Turvaettevõtja tegevusloa taotluse läbivaatamine</paragrahvPealkiri>
								<loige id="para142b67lg1">
									<loigeNr>1</loigeNr>
									<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Turvaettevõtja tegevusloa taotluse läbivaatamise eest tasutakse riigilõivu 150 eurot.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130122023001</aktViide>
										</avaldamismarge>
										<joustumine>2024-07-01</joustumine>
									</muutmismarge>
								</loige>
								<loige id="para142b67lg2">
									<loigeNr>2</loigeNr>
									<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Kui tegevusloa taotluse läbivaatamisel selgub, et turvaettevõtja ei ole nõuetekohane, tasutakse uue taotluse läbivaatamise eest riigilõivu käesoleva paragrahvi lõikes 1 sätestatud määras.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130062023001</aktViide>
										</avaldamismarge>
										<joustumine>2023-07-01</joustumine>
									</muutmismarge>
								</loige>
							</paragrahv>
							<paragrahv id="para142b68">
								<paragrahvNr ylaIndeks="68">142</paragrahvNr>
								<kuvatavNr><![CDATA[§ 142<sup>68</sup>. ]]></kuvatavNr>
								<paragrahvPealkiri>Sadama sadamaregistrisse kandmine ja sadamaregistri kande muutmine</paragrahvPealkiri>
								<loige id="para142b68lg1">
									<loigeNr>1</loigeNr>
									<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Sadama sadamaregistrisse kandmise eest tasutakse riigilõivu 200 eurot.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130122023001</aktViide>
										</avaldamismarge>
										<joustumine>2024-07-01</joustumine>
									</muutmismarge>
								</loige>
								<loige id="para142b68lg2">
									<loigeNr>2</loigeNr>
									<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Sadamaregistri kande muutmise eest tasutakse riigilõivu 20 eurot.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130122023001</aktViide>
										</avaldamismarge>
										<joustumine>2024-07-01</joustumine>
									</muutmismarge>
								</loige>
							</paragrahv>
							<paragrahv id="para142b69">
								<paragrahvNr ylaIndeks="69">142</paragrahvNr>
								<kuvatavNr><![CDATA[§ 142<sup>69</sup>. ]]></kuvatavNr>
								<paragrahvPealkiri>Laevajäätmete eelteatise esitamisest ja nende üleandmise kohustusest ning jäätmetasu maksmisest vabastuse saamise taotluse läbivaatamine</paragrahvPealkiri>
								<loige id="para142b69lg1">
									<loigeNr/>
									<kuvatavNr/>
									<sisuTekst>
										<tavatekst>Laevajäätmete eelteatise sadamas üleantavate ning laevale jäävate laevajäätmete liigi ja koguse kohta esitamisest, laevajäätmete üleandmisest ja laevajäätmete vastuvõtmise tasu maksmisest vabastuse saamise taotluse läbivaatamise eest tasutakse riigilõivu 40 eurot.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130062023001</aktViide>
										</avaldamismarge>
										<joustumine>2023-07-01</joustumine>
									</muutmismarge>
								</loige>
							</paragrahv>
						</alljaotis>
						<alljaotis id="alljaotis5">
							<alljaotisNr>4</alljaotisNr>
							<kuvatavNr><![CDATA[4. alljaotis]]></kuvatavNr>
							<alljaotisPealkiri>Kaubandusliku meresõidu seaduse alusel tehtavad toimingud</alljaotisPealkiri>
							<muutmismarge>
								<avaldamismarge>
									<RTosa>RT I</RTosa>
									<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
									<RTartikkel>1</RTartikkel>
									<aktViide>130062023001</aktViide>
								</avaldamismarge>
								<joustumine>2023-07-01</joustumine>
							</muutmismarge>
							<paragrahv id="para142b70">
								<paragrahvNr ylaIndeks="70">142</paragrahvNr>
								<kuvatavNr><![CDATA[§ 142<sup>70</sup>. ]]></kuvatavNr>
								<paragrahvPealkiri>Vastutuskindlustuse ja muu rahalise tagatise tõendi või tunnistuse taotluse läbivaatamine</paragrahvPealkiri>
								<loige id="para142b70lg1">
									<loigeNr/>
									<kuvatavNr/>
									<sisuTekst>
										<tavatekst>Vastutuskindlustuse või muu rahalise tagatise tõendi või tunnistuse taotluse läbivaatamise eest tasutakse riigilõivu 40 eurot.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130062023001</aktViide>
										</avaldamismarge>
										<joustumine>2023-07-01</joustumine>
									</muutmismarge>
								</loige>
							</paragrahv>
						</alljaotis>
						<alljaotis id="alljaotis6">
							<alljaotisNr>5</alljaotisNr>
							<kuvatavNr><![CDATA[5. alljaotis]]></kuvatavNr>
							<alljaotisPealkiri>Liiklusseaduse alusel tehtavad toimingud</alljaotisPealkiri>
							<muutmismarge>
								<avaldamismarge>
									<RTosa>RT I</RTosa>
									<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
									<RTartikkel>1</RTartikkel>
									<aktViide>130062023001</aktViide>
								</avaldamismarge>
								<joustumine>2023-07-01</joustumine>
							</muutmismarge>
							<paragrahv id="para142b71">
								<paragrahvNr ylaIndeks="71">142</paragrahvNr>
								<kuvatavNr><![CDATA[§ 142<sup>71</sup>. ]]></kuvatavNr>
								<paragrahvPealkiri>Liiklusregistri andmete väljastamine</paragrahvPealkiri>
								<loige id="para142b71lg1">
									<loigeNr>1</loigeNr>
									<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Ühekordse taotluse alusel liiklusregistri andmete ja andmete väljavõtte või muu dokumendi väljastamise eest tasutakse riigilõivu 10 eurot iga töötunni eest.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130122023001</aktViide>
										</avaldamismarge>
										<joustumine>2024-07-01</joustumine>
									</muutmismarge>
								</loige>
								<loige id="para142b71lg2">
									<loigeNr>2</loigeNr>
									<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Andmete liiklusregistrisse kandmise aluseks oleva dokumendi kinnitatud ärakirja väljastamise eest tasutakse riigilõivu 3 eurot iga lehekülje eest.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130122023001</aktViide>
										</avaldamismarge>
										<joustumine>2024-07-01</joustumine>
									</muutmismarge>
								</loige>
							</paragrahv>
						</alljaotis>
					</jaotis>
					<jaotis id="jaotis41">
						<jaotisNr>3</jaotisNr>
						<kuvatavNr><![CDATA[3. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Transpordiameti toimingud maismaatranspordi valdkonnas</jaotisPealkiri>
						<muutmismarge>
							<avaldamismarge>
								<RTosa>RT I</RTosa>
								<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
								<RTartikkel>1</RTartikkel>
								<aktViide>130062023001</aktViide>
							</avaldamismarge>
							<joustumine>2023-07-01</joustumine>
						</muutmismarge>
						<paragrahv id="para142b72">
							<paragrahvNr ylaIndeks="72">142</paragrahvNr>
							<kuvatavNr><![CDATA[§ 142<sup>72</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri>Sõiduki registreerimine</paragrahvPealkiri>
							<loige id="para142b72lg1">
								<loigeNr>1</loigeNr>
								<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Sõiduki, välja arvatud mopeed ning kuni 3500-kilogrammine täismassiga haagis ja liiklusseaduse §-s 190<sup>17</sup> nimetatud sõiduk, registreerimise eest tasutakse riigilõivu 150 eurot. Kui nimetatud toimingut taotletakse elektrooniliselt e-teenuste infosüsteemi kaudu, tasutakse riigilõivu 120 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-08-17</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>117082024001</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para142b72lg2">
								<loigeNr>2</loigeNr>
								<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Maastikusõiduki registreerimise eest tasutakse riigilõivu 77 eurot. Kui nimetatud toimingut taotletakse elektrooniliselt e-teenuste infosüsteemi kaudu, tasutakse riigilõivu 61 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130122023001</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para142b72lg3">
								<loigeNr>3</loigeNr>
								<kuvatavNr><![CDATA[(3)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Ajutiselt Eestisse imporditud sõiduki registreerimise eest tasutakse riigilõivu 350 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130122023001</aktViide>
									</avaldamismarge>
									<joustumine>2024-07-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para142b72lg4">
								<loigeNr>4</loigeNr>
								<kuvatavNr><![CDATA[(4)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Mopeedi registreerimise eest tasutakse riigilõivu 25 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130122023001</aktViide>
									</avaldamismarge>
									<joustumine>2024-07-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para142b72lg5">
								<loigeNr>5</loigeNr>
								<kuvatavNr><![CDATA[(5)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Kuni 3500-kilogrammise täismassiga haagise registreerimise eest tasutakse riigilõivu 72 eurot. Kui nimetatud toimingut taotletakse elektrooniliselt e-teenuste infosüsteemi kaudu, tasutakse riigilõivu 58 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130122023001</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
						<paragrahv id="para142b73">
							<paragrahvNr ylaIndeks="73">142</paragrahvNr>
							<kuvatavNr><![CDATA[§ 142<sup>73</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri>Registreerimismärgi väljastamine</paragrahvPealkiri>
							<loige id="para142b73lg1">
								<loigeNr>1</loigeNr>
								<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Auto üldkasutatava, vähendatud mõõtmetega, vanasõiduki või võistlusauto registreerimismärgi väljastamise eest tasutakse riigilõivu 65 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130122023001</aktViide>
									</avaldamismarge>
									<joustumine>2024-07-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para142b73lg2">
								<loigeNr>2</loigeNr>
								<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Mootorratta, traktori, traktori baasil ehitatud masina, liikurmasina ja haagise registreerimismärgi või nende vanasõidukina registreerimisel vanasõiduki registreerimismärgi või maastikusõiduki registreerimismärgi väljastamise eest tasutakse riigilõivu 35 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130122023001</aktViide>
									</avaldamismarge>
									<joustumine>2024-07-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para142b73lg3">
								<loigeNr>3</loigeNr>
								<kuvatavNr><![CDATA[(3)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Eritellimuse järgi valmistatud registreerimismärgi väljastamise eest tasutakse riigilõivu 1560 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130122023001</aktViide>
									</avaldamismarge>
									<joustumine>2024-07-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para142b73lg4">
								<loigeNr>4</loigeNr>
								<kuvatavNr><![CDATA[(4)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Transiitmärgi väljastamise eest tasutakse riigilõivu 70 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130122023001</aktViide>
									</avaldamismarge>
									<joustumine>2024-07-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para142b73lg5">
								<loigeNr>5</loigeNr>
								<kuvatavNr><![CDATA[(5)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Mootorsõiduki, välja arvatud mootorratas, ja selle haagise teisaldatava registreerimismärgi kirjega „PROOV” väljastamise eest tasutakse riigilõivu 235 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130122023001</aktViide>
									</avaldamismarge>
									<joustumine>2024-07-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para142b73lg6">
								<loigeNr>6</loigeNr>
								<kuvatavNr><![CDATA[(6)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Kui käesoleva paragrahvi lõikes 1 nimetatud registreerimismärgid või haagise registreerimismärk on valmistatud üksikkorras omaniku avalduse alusel, tasutakse nende esmaväljastamise eest riigilõivu 540 eurot. Omaniku avalduse alusel samast seeriast järjestikuste registreerimismärkide tellimise korral korraga rohkem kui kümnele autole tasutakse riigilõivu 155 eurot iga registreerimismärgi väljastamise eest.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130122023001</aktViide>
									</avaldamismarge>
									<joustumine>2024-07-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para142b73lg7">
								<loigeNr>7</loigeNr>
								<kuvatavNr><![CDATA[(7)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Kui käesoleva paragrahvi lõikes 2 nimetatud registreerimismärgid, välja arvatud haagise registreerimismärk, on valmistatud üksikkorras omaniku avalduse alusel, tasutakse nende esmaväljastamise eest riigilõivu 270 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130122023001</aktViide>
									</avaldamismarge>
									<joustumine>2024-07-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para142b73lg8">
								<loigeNr>8</loigeNr>
								<kuvatavNr><![CDATA[(8)]]></kuvatavNr>
								<muutmismarge>
									<tavatekst>Kehtetu - </tavatekst>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130122023001</aktViide>
									</avaldamismarge>
									<joustumine>2024-07-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para142b73lg9">
								<loigeNr>9</loigeNr>
								<kuvatavNr><![CDATA[(9)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Käesoleva paragrahvi lõigetes 1–3 nimetatud registreerimismärgi ühe duplikaadi väljastamise eest tasutakse riigilõivu 15 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130122023001</aktViide>
									</avaldamismarge>
									<joustumine>2024-07-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para142b73lg10">
								<loigeNr>10</loigeNr>
								<kuvatavNr><![CDATA[(10)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Mopeedi registreerimismärgi väljastamise eest tasutakse riigilõivu 15 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130122023001</aktViide>
									</avaldamismarge>
									<joustumine>2024-07-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para142b73lg11">
								<loigeNr>11</loigeNr>
								<kuvatavNr><![CDATA[(11)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Transpordiameti e-teenuste infosüsteemis olemasolevate registreerimismärkide seast valitava auto üldkasutatava või vähendatud mõõtmetega või haagise, mootorratta või maastikusõiduki registreerimismärgi väljastamise eest tasutakse riigilõivu 300 eurot ja mopeedi registreerimismärgi väljastamise eest 150 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130122023001</aktViide>
									</avaldamismarge>
									<joustumine>2024-07-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
						<paragrahv id="para142b74">
							<paragrahvNr ylaIndeks="74">142</paragrahvNr>
							<kuvatavNr><![CDATA[§ 142<sup>74</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri>Registriandmete muutmine ja registrist kustutamine</paragrahvPealkiri>
							<muutmismarge>
								<avaldamismarge>
									<RTosa>RT I</RTosa>
									<avaldamineKuupaev>2024-12-31</avaldamineKuupaev>
									<RTartikkel>1</RTartikkel>
									<aktViide>131122024001</aktViide>
								</avaldamismarge>
								<joustumine>2026-01-01</joustumine>
							</muutmismarge>
							<loige id="para142b74lg1">
								<loigeNr>1</loigeNr>
								<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Registrisse kantud andmete muutmise eest seoses sõiduki omaniku vahetumisega tasutakse riigilõivu 71 eurot. Kui nimetatud toimingut taotletakse elektrooniliselt e-teenuste infosüsteemi kaudu, tasutakse riigilõivu 55 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130122023001</aktViide>
									</avaldamismarge>
									<joustumine>2024-07-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para142b74lg1b1">
								<loigeNr ylaIndeks="1">1</loigeNr>
								<kuvatavNr><![CDATA[(1<sup>1</sup>)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Käesoleva paragrahvi lõikes 1 nimetatud lõivu ei tasuta, kui seoses sõiduki omaniku vahetumisega kuulub tasumisele liiklusseaduse § 190<sup>18</sup> lõike 2 punktis 2 ettenähtud registreerimistasu.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-08-17</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>117082024001</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para142b74lg2">
								<loigeNr>2</loigeNr>
								<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Mopeedi registriandmete muudatuste vormistamise eest tasutakse riigilõivu 15 eurot. Kui nimetatud toimingut taotletakse elektrooniliselt e-teenuste infosüsteemi kaudu, tasutakse riigilõivu 10 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130122023001</aktViide>
									</avaldamismarge>
									<joustumine>2024-07-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para142b74lg3">
								<loigeNr>3</loigeNr>
								<kuvatavNr><![CDATA[(3)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Käesoleva paragrahvi lõigetes 1 ja 2 nimetamata registriandmete muudatuste vormistamise eest tasutakse riigilõivu 25 eurot. Kui nimetatud toimingut taotletakse elektrooniliselt e-teenuste infosüsteemi kaudu, tasutakse riigilõivu 18 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130122023001</aktViide>
									</avaldamismarge>
									<joustumine>2024-07-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para142b74lg4">
								<loigeNr>4</loigeNr>
								<kuvatavNr><![CDATA[(4)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Registreerimistunnistuse väljastamise eest, kui selle on tinginud kõikide lahtrite täitumine tehnonõuetele vastavuse kontrolli kohta tehtavate märgete tõttu, samuti varastatud või tulekahju tagajärjel hävinud registreerimistunnistuse asendamise eest pädeva riigiasutuse tõendi esitamisel koos käesolevas lõikes nimetatud toimingutest tuleneva registrikande muudatusega tasutakse riigilõivu 12 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130122023001</aktViide>
									</avaldamismarge>
									<joustumine>2024-07-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para142b74lg5">
								<loigeNr>5</loigeNr>
								<kuvatavNr><![CDATA[(5)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Sõiduki ajutiselt registrist kustutamise eest liiklusseaduse § 77 lõikes 7<sup>1</sup> ja § 264<sup>4</sup> lõikes 3 nimetatud juhul tasutakse riigilõivu 15 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-12-31</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>131122024001</aktViide>
									</avaldamismarge>
									<joustumine>2026-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para142b74lg6">
								<loigeNr>6</loigeNr>
								<kuvatavNr><![CDATA[(6)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Sõiduki registrist kustutamise eest liiklusseaduse § 77 lõikes 6<sup>1</sup> sätestatud juhul tasutakse riigilõivu 15 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-12-31</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>131122024001</aktViide>
									</avaldamismarge>
									<joustumine>2026-01-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
						<paragrahv id="para142b75">
							<paragrahvNr ylaIndeks="75">142</paragrahvNr>
							<kuvatavNr><![CDATA[§ 142<sup>75</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri>Liiklusregistri andmete väljastamine</paragrahvPealkiri>
							<loige id="para142b75lg1">
								<loigeNr>1</loigeNr>
								<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Ühekordse taotluse alusel liiklusregistri andmete ja andmetest väljavõtte või muu dokumendi väljastamise eest tasutakse riigilõivu 10 eurot iga töötunni eest.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130122023001</aktViide>
									</avaldamismarge>
									<joustumine>2024-07-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para142b75lg2">
								<loigeNr>2</loigeNr>
								<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Andmete liiklusregistrisse kandmise aluseks oleva dokumendi kinnitatud ärakirja väljastamise eest tasutakse riigilõivu 3 eurot iga lehekülje eest.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130122023001</aktViide>
									</avaldamismarge>
									<joustumine>2024-07-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
						<paragrahv id="para142b76">
							<paragrahvNr ylaIndeks="76">142</paragrahvNr>
							<kuvatavNr><![CDATA[§ 142<sup>76</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri>Juhtimisõigust tõendava dokumendi väljastamine</paragrahvPealkiri>
							<loige id="para142b76lg1">
								<loigeNr>1</loigeNr>
								<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Mootorsõiduki esmase juhiloa, juhiloa või rahvusvahelise juhiloa väljastamise või vahetamise eest tasutakse riigilõivu 33 eurot. Kui nimetatud toimingut taotletakse elektrooniliselt e-teenuste infosüsteemi kaudu, tasutakse riigilõivu 23 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130122023001</aktViide>
									</avaldamismarge>
									<joustumine>2024-07-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para142b76lg2">
								<loigeNr>2</loigeNr>
								<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Mootorsõiduki esmase juhiloa või juhiloa väljastamise eest kiirtellimuse korras järgmiseks tööpäevaks tasutakse riigilõivu 63 eurot. Kui nimetatud toimingut taotletakse elektrooniliselt e-teenuste infosüsteemi kaudu, tasutakse riigilõivu 50 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130122023001</aktViide>
									</avaldamismarge>
									<joustumine>2024-07-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para142b76lg3">
								<loigeNr>3</loigeNr>
								<kuvatavNr><![CDATA[(3)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Mootorsõiduki esmase juhiloa või juhiloa taotlemisel käesoleva seaduse § 20 lõikes 2 sätestatud juhul tasutakse riigilõivu 16 eurot. Kui nimetatud juhiluba taotletakse elektrooniliselt e-teenuste infosüsteemi kaudu, tasutakse riigilõivu 12 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130122023001</aktViide>
									</avaldamismarge>
									<joustumine>2024-07-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para142b76lg4">
								<loigeNr>4</loigeNr>
								<kuvatavNr><![CDATA[(4)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Mootorsõiduki piiratud õigusega juhiloa või ajutise juhiloa väljastamise eest tasutakse riigilõivu 20 eurot. Kui nimetatud toimingut taotletakse elektrooniliselt e-teenuste infosüsteemi kaudu, tasutakse riigilõivu 14 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130122023001</aktViide>
									</avaldamismarge>
									<joustumine>2024-07-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para142b76lg5">
								<loigeNr>5</loigeNr>
								<kuvatavNr><![CDATA[(5)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Varastatud või tulekahju tagajärjel hävinud käesoleva paragrahvi lõigetes 1 ja 4 nimetatud dokumendi väljastamise eest tasutakse pädeva riigiasutuse tõendi esitamisel riigilõivu 7 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130122023001</aktViide>
									</avaldamismarge>
									<joustumine>2024-07-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
						<paragrahv id="para142b77">
							<paragrahvNr ylaIndeks="77">142</paragrahvNr>
							<kuvatavNr><![CDATA[§ 142<sup>77</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri>Mootorsõidukijuhi eksamile registreerimine ja eksami vastuvõtmine</paragrahvPealkiri>
							<loige id="para142b77lg1">
								<loigeNr>1</loigeNr>
								<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Mootorsõidukijuhi teooriaeksamile registreerimise ja eksami vastuvõtmise eest tasutakse riigilõivu 30 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130122023001</aktViide>
									</avaldamismarge>
									<joustumine>2024-07-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para142b77lg2">
								<loigeNr>2</loigeNr>
								<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Mootorsõidukijuhi sõidueksamile registreerimise ja eksami vastuvõtmise eest Transpordiameti valduses oleva B-kategooria auto kasutamise korral või muu eksamisõidukile kehtestatud nõuetele vastava sõiduki või mopeedi kasutamise korral tasutakse riigilõivu 50 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130122023001</aktViide>
									</avaldamismarge>
									<joustumine>2024-07-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para142b77lg3">
								<loigeNr>3</loigeNr>
								<kuvatavNr><![CDATA[(3)]]></kuvatavNr>
								<muutmismarge>
									<tavatekst>Kehtetu - </tavatekst>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130122023001</aktViide>
									</avaldamismarge>
									<joustumine>2024-07-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para142b77lg4">
								<loigeNr>4</loigeNr>
								<kuvatavNr><![CDATA[(4)]]></kuvatavNr>
								<muutmismarge>
									<tavatekst>Kehtetu - </tavatekst>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
