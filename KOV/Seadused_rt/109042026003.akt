					<jaotis id="jaotis72">
						<jaotisNr>9</jaotisNr>
						<kuvatavNr><![CDATA[9. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Kemikaaliseaduse alusel tehtavad toimingud</jaotisPealkiri>
						<paragrahv id="para217">
