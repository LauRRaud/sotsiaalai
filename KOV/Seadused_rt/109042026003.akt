						<paragrahv id="para133">
							<paragrahvNr>133</paragrahvNr>
							<kuvatavNr><![CDATA[§ 133. ]]></kuvatavNr>
							<paragrahvPealkiri>Kaaviari pakendite märgiste väljastamine</paragrahvPealkiri>
							<loige id="para133lg1">
								<sisuTekst>
									<tavatekst>(Taas)pakendatud ja töödeldud kaaviari pakendite märgiste väljastamise eest tasutakse riigilõivu:</tavatekst>
								</sisuTekst>
								<alampunkt id="para133lg1p1">
									<alampunktNr>1</alampunktNr>
									<kuvatavNr><![CDATA[1) ]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>esimese 500 märgise eest 320 eurot;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para133lg1p2">
									<alampunktNr>2</alampunktNr>
									<kuvatavNr><![CDATA[2) ]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>iga järgmise 500 märgise eest 130 eurot.</tavatekst>
									</sisuTekst>
								</alampunkt>
							</loige>
						</paragrahv>
					</jaotis>
					<jaotis id="jaotis26">
						<jaotisNr>6</jaotisNr>
						<kuvatavNr><![CDATA[6. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Taimede paljundamise ja sordikaitse seaduse alusel tehtavad toimingud</jaotisPealkiri>
