						<paragrahv id="para136">
							<paragrahvNr>136</paragrahvNr>
							<kuvatavNr><![CDATA[§ 136. ]]></kuvatavNr>
							<paragrahvPealkiri>Fluoritud kasvuhoonegaase sisaldava toote, seadme ja süsteemi käitlemise luba</paragrahvPealkiri>
							<loige id="para136lg1">
								<loigeNr>1</loigeNr>
								<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Fluoritud kasvuhoonegaase sisaldava toote, seadme ja süsteemi käitlemise loa taotluse läbivaatamise eest tasutakse riigilõivu 270 eurot.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para136lg2">
								<loigeNr>2</loigeNr>
								<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Fluoritud kasvuhoonegaase sisaldava toote, seadme ja süsteemi käitlemise loa muutmise taotluse läbivaatamise eest tasutakse riigilõivu 48 eurot.</tavatekst>
								</sisuTekst>
							</loige>
						</paragrahv>
					</jaotis>
