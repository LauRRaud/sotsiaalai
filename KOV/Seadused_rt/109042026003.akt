						<paragrahv id="para258">
							<paragrahvNr>258</paragrahvNr>
							<kuvatavNr><![CDATA[§ 258. ]]></kuvatavNr>
							<paragrahvPealkiri>Vaidlustuse läbivaatamine</paragrahvPealkiri>
							<loige id="para258lg1">
								<loigeNr id="d8eba33f-9420-433e-99a7-244be792ce89">1</loigeNr>
								<kuvatavNr id="8c9d159d-0254-4ded-af2b-8b5257da4f50"><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst id="f0c6fb1b-7139-465a-91f3-42bd4793e405">
									<tavatekst id="b47c71ae-7a84-42f7-941f-37e1af618472">Riigihanke vaidlustuse esitamisel tasutakse riigilõivu:</tavatekst>
								</sisuTekst>
								<alampunkt id="para258lg1p1">
									<alampunktNr id="232ef54c-bcd6-4ec6-ae82-22a843a7284b">1</alampunktNr>
									<kuvatavNr id="646470ae-3890-458b-9de7-3497886811bf"><![CDATA[1) ]]></kuvatavNr>
									<sisuTekst id="e87f85d9-07bd-4826-96c1-460e2632232f">
										<tavatekst id="3f8047d9-afe7-4e23-b90d-bf63392ff578">1280 eurot, kui riigihanke eeldatav maksumus on rahvusvahelisest piirmäärast väiksem;</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2025-12-18</avaldamineKuupaev>
											<RTartikkel>2</RTartikkel>
											<aktViide>118122025002</aktViide>
										</avaldamismarge>
										<joustumine>2026-01-01</joustumine>
									</muutmismarge>
								</alampunkt>
								<alampunkt id="para258lg1p2">
									<alampunktNr id="87a5c365-fb13-480c-acbf-c9dc5ecdae67">2</alampunktNr>
									<kuvatavNr id="6efce2f6-e025-420a-a7ca-944f3d6da922"><![CDATA[2) ]]></kuvatavNr>
									<sisuTekst id="427cb850-7fcb-4de9-90ce-c12e2bcfae83">
										<tavatekst id="cbbe432f-d4ad-4b35-bcba-2dab388bf877">2560 eurot, kui riigihanke eeldatav maksumus on võrdne rahvusvahelise piirmääraga või ületab seda.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2025-12-18</avaldamineKuupaev>
											<RTartikkel>2</RTartikkel>
											<aktViide>118122025002</aktViide>
										</avaldamismarge>
										<joustumine>2026-01-01</joustumine>
									</muutmismarge>
								</alampunkt>
							</loige>
							<loige id="para258lg2">
								<loigeNr id="651a984a-5c8e-4e27-8d67-a62fea60d4e6">2</loigeNr>
								<kuvatavNr id="18c42fe2-19ac-473d-b0e6-0645a909be20"><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst id="66a77e3b-afc0-499c-9170-87f8da5d4313">
									<tavatekst id="ca1eeb02-c9ec-4b8f-94a8-dfb3edd91e30">Ühispakkujad ja ühistaotlejad tasuvad riigilõivu käesoleva paragrahvi lõikes 1 nimetatud riigilõivumääras.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para258lg3">
								<loigeNr id="bc88dbe4-0f54-4ee2-a45c-62fc420b8e62">3</loigeNr>
								<kuvatavNr id="fb03909e-9ebd-4ee4-9dbb-b8cd5a68b87a"><![CDATA[(3)]]></kuvatavNr>
								<sisuTekst id="bf715367-747b-47e6-9359-4ee53fc47a71">
									<tavatekst id="26388532-8750-4615-8455-6208a7bb0cc9">Kahju hüvitamise taotluse esitamisel tasutakse riigilõivu käesoleva seaduse § 60 lõikes 2 sätestatud määras.</tavatekst>
								</sisuTekst>
							</loige>
						</paragrahv>
