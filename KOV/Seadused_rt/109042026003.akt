	<muutmismarge id="6adac707-c003-4d88-8735-938da30fe854">
		<aktikuupaev id="4d4ea651-5b00-484b-856f-12cadebe6d66">2015-05-26</aktikuupaev>
		<avaldamismarge id="78ac755d-0c7d-4e05-b0c7-963a5e14f0f6">
			<RTosa id="3577dd5e-54df-4b79-9df4-592815ef2b99">RT I</RTosa>
			<avaldamineKuupaev id="6a385e83-9027-4588-b107-9650d35df1fa">2015-05-26</avaldamineKuupaev>
			<RTartikkel id="14d1bc04-fe33-4214-adf0-339a9111936e">13</RTartikkel>
			<aktViide id="0fdff931-48b0-4d04-b51c-b121944c24e7">126052015013</aktViide>
		</avaldamismarge>
		<joustumine>2015-05-26</joustumine>
		<tavatekst> - 1. Rahuldada osaliselt õiguskantsleri 22. detsembri 2014. a taotlus. 2. Tunnistada riigilõivuseaduse (RT I, 29.06.2014, 66; RT I, 30.12.2014, 12) § 57 lg-d 1 ja 15 koostoimes lisaga 1 (1. juulist 2014 kuni 31. detsembrini 2014 kehtinud redaktsioonis) ning riigilõivuseaduse (RT I, 30.12.2014, 1) § 59 lg-d 1 ja 15 koostoimes lisaga 1 põhiseadusega vastuolus olevaks ning kehtetuks osas, milles tsiviilasja hinna puhul üle 500 000 euro tasutakse riigilõivu kuni 10 500 eurot. 3. Tsiviilasja hinna puhul üle 500 000 euro tasutakse riigilõivu 3400 eurot.</tavatekst>
	</muutmismarge>
