									<tavatekst id="19ebfb30-cfda-4c7e-b6f5-73a18efa0688">ühe klassi kohta 145 eurot;</tavatekst>
								</sisuTekst>
							</alampunkt>
							<alampunkt id="para94lg1p2">
								<alampunktNr id="e95fa6b0-06a6-4fbd-b948-e46c7d972611">2</alampunktNr>
