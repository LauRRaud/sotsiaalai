							<kuvatavNr><![CDATA[§ 129. ]]></kuvatavNr>
							<paragrahvPealkiri>Jahitunnistuse, jahipiirkonna kasutusõiguse loa ja jahipiirkonna piiride muutmise taotluse läbivaatamine</paragrahvPealkiri>
							<loige id="para129lg1">
								<loigeNr>1</loigeNr>
								<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Jahitunnistuse andmise taotluse läbivaatamise eest tasutakse riigilõivu 40 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130122023001</aktViide>
									</avaldamismarge>
									<joustumine>2024-07-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para129lg2">
								<loigeNr>2</loigeNr>
								<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
