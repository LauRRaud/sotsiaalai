							<loige id="para134lg1">
								<sisuTekst>
									<tavatekst>Sertifitseerimiseks võetava metsapuu seemne proovi võtmise ja laboratoorsete analüüside eest tasutakse riigilõivu 100 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2019-03-19</avaldamineKuupaev>
										<RTartikkel>7</RTartikkel>
										<aktViide>119032019007</aktViide>
									</avaldamismarge>
									<joustumine>2020-01-01</joustumine>
								</muutmismarge>
