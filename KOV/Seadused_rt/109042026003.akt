								<aktViide>130062023001</aktViide>
							</avaldamismarge>
							<joustumine>2023-07-01</joustumine>
						</muutmismarge>
						<alljaotis id="alljaotis1">
							<alljaotisNr>1</alljaotisNr>
							<kuvatavNr><![CDATA[1. alljaotis]]></kuvatavNr>
							<alljaotisPealkiri>Lennundusseaduse alusel tehtavad toimingud</alljaotisPealkiri>
							<muutmismarge>
								<avaldamismarge>
									<RTosa>RT I</RTosa>
									<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
									<RTartikkel>1</RTartikkel>
									<aktViide>130062023001</aktViide>
								</avaldamismarge>
								<joustumine>2023-07-01</joustumine>
							</muutmismarge>
							<paragrahv id="para142b1">
								<paragrahvNr ylaIndeks="1">142</paragrahvNr>
								<kuvatavNr><![CDATA[§ 142<sup>1</sup>. ]]></kuvatavNr>
								<paragrahvPealkiri>Õhusõiduki registreerimise taotluse läbivaatamine ning registreerimissertifikaadis muudatuste tegemine</paragrahvPealkiri>
								<loige id="para142b1lg1">
									<loigeNr>1</loigeNr>
									<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Õhusõiduki registreerimise taotluse läbivaatamise eest tasutakse riigilõivu maksimaalsest lubatud stardimassist (MTOW) lähtuvalt järgmiselt:</tavatekst>
									</sisuTekst>
									<alampunkt id="para142b1lg1p1">
										<alampunktNr>1</alampunktNr>
										<kuvatavNr><![CDATA[1)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>MTOW õhusõidukil kuni 750 kg – 45 eurot;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b1lg1p2">
										<alampunktNr>2</alampunktNr>
										<kuvatavNr><![CDATA[2)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>MTOW õhusõidukil 751–5700 kg – 130 eurot;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b1lg1p3">
										<alampunktNr>3</alampunktNr>
										<kuvatavNr><![CDATA[3)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>MTOW õhusõidukil üle 5700 kg – 255 eurot.</tavatekst>
										</sisuTekst>
									</alampunkt>
								</loige>
								<loige id="para142b1lg2">
									<loigeNr>2</loigeNr>
									<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Õhusõiduki registreerimissertifikaadis muudatuste tegemise eest tasutakse riigilõivu 45 eurot iga sissekande kohta.</tavatekst>
									</sisuTekst>
								</loige>
								<loige id="para142b1lg3">
									<loigeNr>3</loigeNr>
									<kuvatavNr><![CDATA[(3)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Õhusõiduki registreerimise eest omaniku soovile vastava registreerimistunnusega tasutakse täiendavalt riigilõivu 835 eurot.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130062023001</aktViide>
										</avaldamismarge>
										<joustumine>2023-07-01</joustumine>
									</muutmismarge>
								</loige>
							</paragrahv>
							<paragrahv id="para142b2">
								<paragrahvNr ylaIndeks="2">142</paragrahvNr>
								<kuvatavNr><![CDATA[§ 142<sup>2</sup>. ]]></kuvatavNr>
								<paragrahvPealkiri>Õhusõiduki lennukõlblikkussertifikaadi ja lennuloa väljaandmise taotluse läbivaatamine</paragrahvPealkiri>
								<loige id="para142b2lg1">
									<loigeNr>1</loigeNr>
									<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Õhusõiduki lennukõlblikkussertifikaadi taotluse läbivaatamise eest tasutakse riigilõivu maksimaalsest lubatud stardimassist (MTOW) lähtuvalt järgmiselt:</tavatekst>
									</sisuTekst>
									<alampunkt id="para142b2lg1p1">
										<alampunktNr>1</alampunktNr>
										<kuvatavNr><![CDATA[1)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>MTOW õhusõidukil kuni 750 kg – 45 eurot;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b2lg1p2">
										<alampunktNr>2</alampunktNr>
										<kuvatavNr><![CDATA[2)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>MTOW õhusõidukil 751–5700 kg – 180 eurot;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b2lg1p3">
										<alampunktNr>3</alampunktNr>
										<kuvatavNr><![CDATA[3)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>MTOW õhusõidukil üle 5700 kg – 410 eurot.</tavatekst>
										</sisuTekst>
									</alampunkt>
								</loige>
								<loige id="para142b2lg2">
									<loigeNr>2</loigeNr>
									<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Õhusõiduki lennuloa taotluse läbivaatamise eest tasutakse riigilõivu 90 eurot.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130062023001</aktViide>
										</avaldamismarge>
										<joustumine>2023-07-01</joustumine>
									</muutmismarge>
								</loige>
							</paragrahv>
							<paragrahv id="para142b3">
								<paragrahvNr ylaIndeks="3">142</paragrahvNr>
								<kuvatavNr><![CDATA[§ 142<sup>3</sup>. ]]></kuvatavNr>
								<paragrahvPealkiri>Õhusõiduki lennukõlblikkuse kontroll</paragrahvPealkiri>
								<loige id="para142b3lg1">
									<loigeNr/>
									<kuvatavNr/>
									<sisuTekst>
										<tavatekst>Õhusõiduki lennukõlblikkuse kontrolli eest tasutakse riigilõivu maksimaalsest lubatud stardimassist (MTOW) lähtuvalt järgmiselt:</tavatekst>
									</sisuTekst>
									<alampunkt id="para142b3lg1p1">
										<alampunktNr>1</alampunktNr>
										<kuvatavNr><![CDATA[1)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>MTOW õhusõidukil kuni 750 kg – 45 eurot;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b3lg1p2">
										<alampunktNr>2</alampunktNr>
										<kuvatavNr><![CDATA[2)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>MTOW õhusõidukil 751–5700 kg – 180 eurot;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b3lg1p3">
										<alampunktNr>3</alampunktNr>
										<kuvatavNr><![CDATA[3)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>MTOW õhusõidukil üle 5700 kg – 23 × kaalukoefitsient „K” (kus K = MTOW (kilogrammides): 1000) + 130 eurot.</tavatekst>
										</sisuTekst>
										<muutmismarge>
											<avaldamismarge>
												<RTosa>RT I</RTosa>
												<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
												<RTartikkel>1</RTartikkel>
												<aktViide>130062023001</aktViide>
											</avaldamismarge>
											<joustumine>2023-07-01</joustumine>
										</muutmismarge>
									</alampunkt>
								</loige>
							</paragrahv>
							<paragrahv id="para142b4">
								<paragrahvNr ylaIndeks="4">142</paragrahvNr>
								<kuvatavNr><![CDATA[§ 142<sup>4</sup>. ]]></kuvatavNr>
								<paragrahvPealkiri>Lennuettevõtja sertifikaadi väljaandmise taotluse läbivaatamine, käitamistingimuste muutmine ja sertifikaadi hoidmine</paragrahvPealkiri>
								<loige id="para142b4lg1">
									<loigeNr>1</loigeNr>
									<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Ärilise lennutranspordiga tegeleva lennuettevõtja sertifikaadi taotluse läbivaatamise eest tasutakse riigilõivu lennuettevõtja poolt käitatava suurima maksimaalse lubatud stardimassiga (MTOW) õhusõidukist lähtuvalt järgmiselt:</tavatekst>
									</sisuTekst>
									<alampunkt id="para142b4lg1p1">
										<alampunktNr>1</alampunktNr>
										<kuvatavNr><![CDATA[1)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>MTOW lennukil kuni 2800 kg ja helikopteril kuni 1000 kg – 2970 eurot;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b4lg1p2">
										<alampunktNr>2</alampunktNr>
										<kuvatavNr><![CDATA[2)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>MTOW lennukil 2801–5700 kg ja helikopteril 1001–3175 kg – 4160 eurot;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b4lg1p3">
										<alampunktNr>3</alampunktNr>
										<kuvatavNr><![CDATA[3)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>MTOW lennukil 5701–25 000 kg ja helikopteril üle 3175 kg – 7670 eurot;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b4lg1p4">
										<alampunktNr>4</alampunktNr>
										<kuvatavNr><![CDATA[4)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>MTOW lennukil üle 25 000 kg – 11 510 eurot.</tavatekst>
										</sisuTekst>
									</alampunkt>
								</loige>
								<loige id="para142b4lg2">
									<loigeNr>2</loigeNr>
									<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Uue õhusõiduki tüübi sisseviimise eest lennuettevõtja sertifikaadi käitamistingimustesse tasutakse riigilõivu õhusõiduki maksimaalsest lubatud stardimassist (MTOW) lähtuvalt järgmiselt:</tavatekst>
									</sisuTekst>
									<alampunkt id="para142b4lg2p1">
										<alampunktNr>1</alampunktNr>
										<kuvatavNr><![CDATA[1)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>MTOW lennukil kuni 2800 kg ja helikopteril kuni 1000 kg – 275 eurot;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b4lg2p2">
										<alampunktNr>2</alampunktNr>
										<kuvatavNr><![CDATA[2)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>MTOW lennukil 2801–5700 kg ja helikopteril 1001–3175 kg – 450 eurot;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b4lg2p3">
										<alampunktNr>3</alampunktNr>
										<kuvatavNr><![CDATA[3)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>MTOW lennukil 5701–25 000 kg ja helikopteril üle 3175 kg – 680 eurot;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b4lg2p4">
										<alampunktNr>4</alampunktNr>
										<kuvatavNr><![CDATA[4)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>MTOW lennukil üle 25 000 kg – 730 eurot.</tavatekst>
										</sisuTekst>
									</alampunkt>
								</loige>
								<loige id="para142b4lg3">
									<loigeNr>3</loigeNr>
									<kuvatavNr><![CDATA[(3)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Lennuettevõtja sertifikaadi käitamistingimuste muutmise taotluse läbivaatamise eest, välja arvatud käitamistingimustest õhusõiduki kustutamise ja lennuettevõtja kontaktandmete muutmise taotluse korral, tasutakse riigilõivu 185 eurot.</tavatekst>
									</sisuTekst>
								</loige>
								<loige id="para142b4lg4">
									<loigeNr>4</loigeNr>
									<kuvatavNr><![CDATA[(4)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Käesoleva paragrahvi lõikes 1 nimetatud lennuettevõtja sertifikaadi hoidmise eest tasutakse iga aasta kohta riigilõivu õhusõiduki maksimaalsest lubatud stardimassist (MTOW) lähtuvalt järgmiselt:</tavatekst>
									</sisuTekst>
									<alampunkt id="para142b4lg4p1">
										<alampunktNr>1</alampunktNr>
										<kuvatavNr><![CDATA[1)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>MTOW lennukil kuni 2800 kg ja helikopteril kuni 1000 kg – 1460 eurot;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b4lg4p2">
										<alampunktNr>2</alampunktNr>
										<kuvatavNr><![CDATA[2)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>MTOW lennukil 2801–5700 kg ja helikopteril 1001–3175 kg – 2060 eurot;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b4lg4p3">
										<alampunktNr>3</alampunktNr>
										<kuvatavNr><![CDATA[3)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>MTOW lennukil 5701–25 000 kg ja helikopteril üle 3175 kg – 2680 eurot;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b4lg4p4">
										<alampunktNr>4</alampunktNr>
										<kuvatavNr><![CDATA[4)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>MTOW lennukil üle 25 000 kg – 3180 eurot.</tavatekst>
										</sisuTekst>
										<muutmismarge>
											<avaldamismarge>
												<RTosa>RT I</RTosa>
												<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
												<RTartikkel>1</RTartikkel>
												<aktViide>130062023001</aktViide>
											</avaldamismarge>
											<joustumine>2023-07-01</joustumine>
										</muutmismarge>
									</alampunkt>
								</loige>
							</paragrahv>
							<paragrahv id="para142b5">
								<paragrahvNr ylaIndeks="5">142</paragrahvNr>
								<kuvatavNr><![CDATA[§ 142<sup>5</sup>. ]]></kuvatavNr>
								<paragrahvPealkiri>Lennuliikluse korraldamise teenuse osutaja, aeronavigatsiooniteenuse osutaja ja lennuprotseduuride väljatöötaja sertifikaadi väljaandmise ja muutmise taotluse läbivaatamine ning sertifikaadi hoidmine</paragrahvPealkiri>
								<loige id="para142b5lg1">
									<loigeNr>1</loigeNr>
									<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Lennuliikluse korraldamise teenuse osutaja, aeronavigatsiooniteenuse osutaja ja lennuprotseduuride väljatöötaja esmase sertifikaadi taotluse läbivaatamise eest tasutakse riigilõivu 2800 eurot.</tavatekst>
									</sisuTekst>
								</loige>
								<loige id="para142b5lg2">
									<loigeNr>2</loigeNr>
									<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Lennuliikluse korraldamise teenuse osutaja, aeronavigatsiooniteenuse osutaja ja lennuprotseduuride väljatöötaja sertifikaadi muutmise taotluse läbivaatamise eest tasutakse riigilõivu 185 eurot.</tavatekst>
									</sisuTekst>
								</loige>
								<loige id="para142b5lg3">
									<loigeNr>3</loigeNr>
									<kuvatavNr><![CDATA[(3)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Lennuliikluse korraldamise teenuse osutaja, aeronavigatsiooniteenuse osutaja ja lennuprotseduuride väljatöötaja sertifikaadi hoidmise eest tasutakse sertifikaadi iga aasta kohta riigilõivu:</tavatekst>
									</sisuTekst>
									<alampunkt id="para142b5lg3p1">
										<alampunktNr>1</alampunktNr>
										<kuvatavNr><![CDATA[1)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>piirkondliku lennujuhtimisteenuse osutamise puhul 800 eurot;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b5lg3p2">
										<alampunktNr>2</alampunktNr>
										<kuvatavNr><![CDATA[2)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>lähenemislennujuhtimisteenuse osutamise puhul 800 eurot;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b5lg3p3">
										<alampunktNr>3</alampunktNr>
										<kuvatavNr><![CDATA[3)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>lähilennujuhtimisteenuse osutamise puhul 800 eurot;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b5lg3p4">
										<alampunktNr>4</alampunktNr>
										<kuvatavNr><![CDATA[4)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>lähi- ja lähenemislennujuhtimisteenuse osutamise puhul 800 eurot;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b5lg3p5">
										<alampunktNr>5</alampunktNr>
										<kuvatavNr><![CDATA[5)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>lennuvälja lennuinfoteenuse osutamise puhul 800 eurot;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b5lg3p6">
										<alampunktNr>6</alampunktNr>
										<kuvatavNr><![CDATA[6)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>lennumeteoroloogiateenuse osutamise puhul 450 eurot;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b5lg3p7">
										<alampunktNr>7</alampunktNr>
										<kuvatavNr><![CDATA[7)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>aeronavigatsiooniteabe teenuse osutamise puhul 800 eurot;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b5lg3p8">
										<alampunktNr>8</alampunktNr>
										<kuvatavNr><![CDATA[8)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>sideteenuse osutamise puhul 400 eurot;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b5lg3p9">
										<alampunktNr>9</alampunktNr>
										<kuvatavNr><![CDATA[9)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>navigatsiooniteenuse osutamise puhul 400 eurot;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b5lg3p10">
										<alampunktNr>10</alampunktNr>
										<kuvatavNr><![CDATA[10)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>seireteenuse osutamise puhul 400 eurot;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b5lg3p11">
										<alampunktNr>11</alampunktNr>
										<kuvatavNr><![CDATA[11)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>õhuruumi korraldamise teenuse osutaja (ASM) puhul 400 eurot;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b5lg3p12">
										<alampunktNr>12</alampunktNr>
										<kuvatavNr><![CDATA[12)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>lennuliiklusvoo juhtimisteenuse osutaja (ATFM) puhul 400 eurot;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b5lg3p13">
										<alampunktNr>13</alampunktNr>
										<kuvatavNr><![CDATA[13)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>lennuprotseduuride väljatöötaja (ASD) puhul 400 eurot.</tavatekst>
										</sisuTekst>
										<muutmismarge>
											<avaldamismarge>
												<RTosa>RT I</RTosa>
												<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
												<RTartikkel>1</RTartikkel>
												<aktViide>130062023001</aktViide>
											</avaldamismarge>
											<joustumine>2023-07-01</joustumine>
										</muutmismarge>
									</alampunkt>
								</loige>
							</paragrahv>
							<paragrahv id="para142b6">
								<paragrahvNr ylaIndeks="6">142</paragrahvNr>
								<kuvatavNr><![CDATA[§ 142<sup>6</sup>. ]]></kuvatavNr>
								<paragrahvPealkiri>Aeronavigatsiooniseadme sertifikaadi taotluse läbivaatamine</paragrahvPealkiri>
								<muutmismarge>
									<tavatekst>Kehtetu - </tavatekst>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2026-04-09</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>109042026001</aktViide>
									</avaldamismarge>
									<joustumine>2026-04-10</joustumine>
								</muutmismarge>
							</paragrahv>
							<paragrahv id="para142b7">
								<paragrahvNr ylaIndeks="7">142</paragrahvNr>
								<kuvatavNr><![CDATA[§ 142<sup>7</sup>. ]]></kuvatavNr>
								<paragrahvPealkiri>Lennuvälja ning kopteriväljaku sertifikaadi väljaandmise, kehtivusaja pikendamise ja käitamistingimuste muutmise taotluse läbivaatamine</paragrahvPealkiri>
								<loige id="para142b7lg1">
									<loigeNr>1</loigeNr>
									<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Lennuvälja või kopteriväljaku esmase sertifikaadi taotluse läbivaatamise eest tasutakse riigilõivu:</tavatekst>
									</sisuTekst>
									<alampunkt id="para142b7lg1p1">
										<alampunktNr>1</alampunktNr>
										<kuvatavNr><![CDATA[1)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>CAT III, CAT II ja CAT I lennuvälja puhul 5100 eurot;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b7lg1p2">
										<alampunktNr>2</alampunktNr>
										<kuvatavNr><![CDATA[2)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>mittetäppislähenemisega lennuvälja või kopteriväljaku puhul 1000 eurot;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b7lg1p3">
										<alampunktNr>3</alampunktNr>
										<kuvatavNr><![CDATA[3)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>ainult visuaaltingimustes käitatava lennuvälja või kopteriväljaku (<i>visual flight rules</i> – VFR) puhul 275 eurot.</tavatekst>
										</sisuTekst>
									</alampunkt>
								</loige>
								<loige id="para142b7lg2">
									<loigeNr>2</loigeNr>
									<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Lennuvälja või kopteriväljaku sertifikaadi või selle juurde kuuluvate käitamistingimuste muutmise taotluse läbivaatamise eest tasutakse riigilõivu 185 eurot.</tavatekst>
									</sisuTekst>
								</loige>
								<loige id="para142b7lg3">
									<loigeNr>3</loigeNr>
									<kuvatavNr><![CDATA[(3)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Lennuvälja või kopteriväljaku sertifikaadi kehtivuse lõppemisel uue sertifikaadi väljaandmise eest tasutakse uue sertifikaadi iga kehtivusaasta kohta riigilõivu:</tavatekst>
									</sisuTekst>
									<alampunkt id="para142b7lg3p1">
										<alampunktNr>1</alampunktNr>
										<kuvatavNr><![CDATA[1)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>CAT III, CAT II ja CAT I lennuvälja puhul 1920 eurot;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b7lg3p2">
										<alampunktNr>2</alampunktNr>
										<kuvatavNr><![CDATA[2)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>mittetäppislähenemisega lennuvälja või kopteriväljaku puhul 450 eurot;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b7lg3p3">
										<alampunktNr>3</alampunktNr>
										<kuvatavNr><![CDATA[3)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>ainult visuaaltingimustes käitatava lennuvälja või kopteriväljaku puhul 90 eurot.</tavatekst>
										</sisuTekst>
									</alampunkt>
								</loige>
								<loige id="para142b7lg4">
									<loigeNr>4</loigeNr>
									<kuvatavNr><![CDATA[(4)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Käesoleva paragrahvi lõikes 3 nimetatud riigilõivu võib tasuda aasta kaupa. Sellisel juhul tasutakse riigilõiv iga aasta kohta jooksva aasta 31. märtsiks olenevalt sellest, mitmeks aastaks sertifikaat välja on antud.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130062023001</aktViide>
										</avaldamismarge>
										<joustumine>2023-07-01</joustumine>
									</muutmismarge>
								</loige>
							</paragrahv>
							<paragrahv id="para142b8">
								<paragrahvNr ylaIndeks="8">142</paragrahvNr>
								<kuvatavNr><![CDATA[§ 142<sup>8</sup>. ]]></kuvatavNr>
								<paragrahvPealkiri>Komisjoni määruse (EL) nr 139/2014 kohase lennuvälja sertifikaadi väljaandmise taotluse läbivaatamine, käitamistingimuste muutmine ja sertifikaadi hoidmine</paragrahvPealkiri>
								<loige id="para142b8lg1">
									<loigeNr>1</loigeNr>
									<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Komisjoni määruse (EL) nr 139/2014, millega kehtestatakse lennuväljadega seotud nõuded ja haldusmenetlused vastavalt Euroopa Parlamendi ja nõukogu määrusele (EÜ) nr 216/2008 (ELT L 44, 14.02.2014, lk 1–34), kohase lennuvälja esmase sertifikaadi taotluse läbivaatamise eest tasutakse riigilõivu CAT III, CAT II ja CAT I lennuvälja puhul 6620 eurot.</tavatekst>
									</sisuTekst>
								</loige>
								<loige id="para142b8lg2">
									<loigeNr>2</loigeNr>
									<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Komisjoni määruse (EL) nr 139/2014 kohase lennuvälja esmase sertifikaadi taotluse läbivaatamise eest tasutakse riigilõivu mittetäppislähenemisega lennuvälja puhul 1000 eurot.</tavatekst>
									</sisuTekst>
								</loige>
								<loige id="para142b8lg3">
									<loigeNr>3</loigeNr>
									<kuvatavNr><![CDATA[(3)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Komisjoni määruse (EL) nr 139/2014 kohase lennuvälja sertifikaadi või selle juurde kuuluvate käitamistingimuste muutmise taotluse läbivaatamise eest tasutakse riigilõivu 135 eurot.</tavatekst>
									</sisuTekst>
								</loige>
								<loige id="para142b8lg4">
									<loigeNr>4</loigeNr>
									<kuvatavNr><![CDATA[(4)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Komisjoni määruse (EL) nr 139/2014 kohase lennuvälja sertifikaadi hoidmise eest tasutakse sertifikaadi iga kehtivusaasta kohta riigilõivu CAT III, CAT II ja CAT I lennuvälja puhul 1920 eurot.</tavatekst>
									</sisuTekst>
								</loige>
								<loige id="para142b8lg5">
									<loigeNr>5</loigeNr>
									<kuvatavNr><![CDATA[(5)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Komisjoni määruse (EL) nr 139/2014 kohase lennuvälja sertifikaadi hoidmise eest tasutakse sertifikaadi iga kehtivusaasta kohta riigilõivu mittetäppislähenemisega lennuvälja puhul 480 eurot.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130062023001</aktViide>
										</avaldamismarge>
										<joustumine>2023-07-01</joustumine>
									</muutmismarge>
								</loige>
							</paragrahv>
							<paragrahv id="para142b9">
								<paragrahvNr ylaIndeks="9">142</paragrahvNr>
								<kuvatavNr><![CDATA[§ 142<sup>9</sup>. ]]></kuvatavNr>
								<paragrahvPealkiri>Mittesertifitseeritava tsiviillennuvälja ja kopteriväljaku käitamistingimuste väljaandmise ja muutmise taotluse läbivaatamine ning käitamistingimuste hoidmine</paragrahvPealkiri>
								<loige id="para142b9lg1">
									<loigeNr>1</loigeNr>
									<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Mittesertifitseeritava tsiviillennuvälja ja kopteriväljaku käitamistingimuste esmase taotluse läbivaatamise eest tasutakse riigilõivu:</tavatekst>
									</sisuTekst>
									<alampunkt id="para142b9lg1p1">
										<alampunktNr>1</alampunktNr>
										<kuvatavNr><![CDATA[1)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>visuaallennu tingimustes käitatava lennuvälja või kopteriväljaku puhul 130 eurot;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b9lg1p2">
										<alampunktNr>2</alampunktNr>
										<kuvatavNr><![CDATA[2)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>öisteks lendudeks avatud visuaallennuvälja või -kopteriväljaku puhul 195 eurot.</tavatekst>
										</sisuTekst>
									</alampunkt>
								</loige>
								<loige id="para142b9lg2">
									<loigeNr>2</loigeNr>
									<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Käitamistingimuste muutmise taotluse läbivaatamise eest tasutakse riigilõivu 75 eurot.</tavatekst>
									</sisuTekst>
								</loige>
								<loige id="para142b9lg3">
									<loigeNr>3</loigeNr>
									<kuvatavNr><![CDATA[(3)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Käitamistingimuste hoidmise eest tasutakse riigilõivu:</tavatekst>
									</sisuTekst>
									<alampunkt id="para142b9lg3p1">
										<alampunktNr>1</alampunktNr>
										<kuvatavNr><![CDATA[1)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>visuaallennu tingimustes käitatava lennuvälja või kopteriväljaku puhul 40 eurot aastas;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b9lg3p2">
										<alampunktNr>2</alampunktNr>
										<kuvatavNr><![CDATA[2)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>öisteks lendudeks avatud visuaallennuvälja või -kopteriväljaku puhul 60 eurot aastas.</tavatekst>
										</sisuTekst>
										<muutmismarge>
											<avaldamismarge>
												<RTosa>RT I</RTosa>
												<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
												<RTartikkel>1</RTartikkel>
												<aktViide>130062023001</aktViide>
											</avaldamismarge>
											<joustumine>2023-07-01</joustumine>
										</muutmismarge>
									</alampunkt>
								</loige>
							</paragrahv>
							<paragrahv id="para142b10">
								<paragrahvNr ylaIndeks="10">142</paragrahvNr>
								<kuvatavNr><![CDATA[§ 142<sup>10</sup>. ]]></kuvatavNr>
								<paragrahvPealkiri>Lennundusloaga seotud toimingute tegemine</paragrahvPealkiri>
								<loige id="para142b10lg1">
									<loigeNr>1</loigeNr>
									<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Lennundusloa taotluse läbivaatamise eest tasutakse riigilõivu:</tavatekst>
									</sisuTekst>
									<alampunkt id="para142b10lg1p1">
										<alampunktNr>1</alampunktNr>
										<kuvatavNr><![CDATA[1)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>lennujuhiõpilase, erapiloodi, purilennuki, õhupalli, ülikerglennuki ja kergõhusõiduki piloodi ning lennundustehnilise töötaja taotluse puhul 40 eurot;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b10lg1p2">
										<alampunktNr>2</alampunktNr>
										<kuvatavNr><![CDATA[2)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>ameti- ja liinipiloodi, teise piloodi, lennujuhi, lennuinformaatori või lendude korraldaja taotluse puhul 80 eurot.</tavatekst>
										</sisuTekst>
									</alampunkt>
								</loige>
								<loige id="para142b10lg2">
									<loigeNr>2</loigeNr>
									<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Lennundusloa uuendamise või duplikaadi väljaandmise eest tasutakse riigilõivu:</tavatekst>
									</sisuTekst>
									<alampunkt id="para142b10lg2p1">
										<alampunktNr>1</alampunktNr>
										<kuvatavNr><![CDATA[1)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>erapiloodi, purilennuki, õhupalli, ülikerglennuki ja kergõhusõiduki piloodi ning lennundustehnilise töötaja taotluse puhul 20 eurot;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b10lg2p2">
										<alampunktNr>2</alampunktNr>
										<kuvatavNr><![CDATA[2)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>ameti- ja liinipiloodi, lennujuhi, lennuinformaatori või lendude korraldaja taotluse puhul 50 eurot.</tavatekst>
										</sisuTekst>
									</alampunkt>
								</loige>
								<loige id="para142b10lg3">
									<loigeNr>3</loigeNr>
									<kuvatavNr><![CDATA[(3)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Rahvusliku lennundusloa vahetamise eest komisjoni määrusega (EL) nr 1321/2014 õhusõidukite ja lennundustoodete ning nende osade ja seadmete jätkuva lennukõlblikkuse ning sellega tegelevate organisatsioonide ja isikute sertifitseerimise kohta (ELT L 362, 17.12.2014, lk 1–194) kehtestatud vormi 26 ja komisjoni määruse (EL) nr 1178/2011, millega kehtestatakse tsiviillennunduses kasutatavate õhusõidukite meeskonnaga seotud tehnilised nõuded ja haldusmenetlused vastavalt Euroopa Parlamendi ja nõukogu määrusele (EÜ) nr 216/2008 (ELT L 311, 25.11.2011, lk 1−193), nõuetele vastavaks lennundusloaks tasutakse riigilõivu:</tavatekst>
									</sisuTekst>
									<alampunkt id="para142b10lg3p1">
										<alampunktNr>1</alampunktNr>
										<kuvatavNr><![CDATA[1)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>erapiloodi, purilennuki ja õhupalli piloodi ning lennundustehnilise töötaja taotluse puhul 35 eurot;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b10lg3p2">
										<alampunktNr>2</alampunktNr>
										<kuvatavNr><![CDATA[2)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>ameti- ja liinipiloodi taotluse puhul 85 eurot.</tavatekst>
										</sisuTekst>
									</alampunkt>
								</loige>
								<loige id="para142b10lg4">
									<loigeNr>4</loigeNr>
									<kuvatavNr><![CDATA[(4)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Lennundusloale iga uue kande tegemise või iga varasema kande kehtivusaja uue tähtajani pikendamise eest tasutakse riigilõivu 15 eurot. Kui lennundusloa uuendamisel tehakse ühe menetluse käigus lennundusloale mitu kannet, siis tasutakse lõivu ühe kande eest.</tavatekst>
									</sisuTekst>
								</loige>
								<loige id="para142b10lg5">
									<loigeNr>5</loigeNr>
									<kuvatavNr><![CDATA[(5)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Välisriigi lennundusloa tunnustamise kehtivustõendi taotluse läbivaatamise eest tasutakse riigilõivu 85 eurot.</tavatekst>
									</sisuTekst>
								</loige>
								<loige id="para142b10lg6">
									<loigeNr>6</loigeNr>
									<kuvatavNr><![CDATA[(6)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Lennundusloa saamiseks vajaliku teooriaeksami sooritamise eest tasutakse riigilõivu 4 eurot eksamiteema sooritamiseks ette nähtud ühe tunni kohta.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130062023001</aktViide>
										</avaldamismarge>
										<joustumine>2023-07-01</joustumine>
									</muutmismarge>
								</loige>
							</paragrahv>
							<paragrahv id="para142b11">
								<paragrahvNr ylaIndeks="11">142</paragrahvNr>
								<kuvatavNr><![CDATA[§ 142<sup>11</sup>. ]]></kuvatavNr>
								<paragrahvPealkiri>Raadioside pidamise õiguse kande tegemine lennundusloale või lennunduse raadioside loale ja lennunduse raadioside loa väljaandmise taotluse läbivaatamine</paragrahvPealkiri>
								<loige id="para142b11lg1">
									<loigeNr/>
									<kuvatavNr/>
									<sisuTekst>
										<tavatekst>Raadioside pidamise õiguse kande tegemise eest lennundusloale või lennunduse raadioside loale ja lennunduse raadioside loa taotluse läbivaatamise eest tasutakse riigilõivu 15 eurot.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
