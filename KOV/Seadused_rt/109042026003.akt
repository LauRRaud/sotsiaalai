									</alampunkt>
									<alampunkt id="para142b60lg2p6">
										<alampunktNr>6</alampunktNr>
										<kuvatavNr><![CDATA[6)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>laevaelektriku, vanemmadruse, vahimadruse, madruse, siseveelaeva madruse, laevamotoristi, vanemmotoristi, laeva külmutusseadmete masinisti, kiirvalvepaadi vanema, päästevahendite ja valvepaadi vanema, päästeparve vanema või laevakoka tunnistuse puhul – 30 eurot;</tavatekst>
										</sisuTekst>
