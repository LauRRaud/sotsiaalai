								<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Maavara geoloogilise uuringu loa ümberregistreerimise või loal geoloogilise uuringu tegija või loa omaja andmete muutmise taotluse läbivaatamise eest tasutakse riigilõivu 30 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2019-12-21</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>121122019001</aktViide>
									</avaldamismarge>
									<joustumine>2020-07-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
					</jaotis>
					<jaotis id="jaotis29">
						<jaotisNr>9</jaotisNr>
						<kuvatavNr><![CDATA[9. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Keskkonnaseadustiku üldosa seaduse alusel tehtavad toimingud</jaotisPealkiri>
						<muutmismarge>
							<avaldamismarge>
								<RTosa>RT I</RTosa>
								<avaldamineKuupaev>2019-12-21</avaldamineKuupaev>
								<RTartikkel>1</RTartikkel>
								<aktViide>121122019001</aktViide>
							</avaldamismarge>
							<joustumine>2020-07-01</joustumine>
						</muutmismarge>
						<paragrahv id="para136b2">
							<paragrahvNr ylaIndeks="2">136</paragrahvNr>
							<kuvatavNr><![CDATA[§ 136<sup>2</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri>Keskkonnaloa andmise ja muutmise taotluse läbivaatamine</paragrahvPealkiri>
							<loige id="para136b2lg1">
								<loigeNr>1</loigeNr>
								<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Keskkonnaloa taotluse läbivaatamise eest tasutakse riigilõivu lähtuvalt taotletavast tegevusest järgmiselt:</tavatekst>
								</sisuTekst>
								<alampunkt id="para136b2lg1p1">
									<alampunktNr>1</alampunktNr>
									<kuvatavNr><![CDATA[1) ]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>vee erikasutus – 1990 eurot;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para136b2lg1p2">
									<alampunktNr>2</alampunktNr>
									<kuvatavNr><![CDATA[2) ]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>saasteainete viimine paiksest heiteallikast välisõhku – 1990 eurot;</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2025-07-08</avaldamineKuupaev>
											<RTartikkel>55</RTartikkel>
											<aktViide>108072025055</aktViide>
										</avaldamismarge>
										<joustumine>2025-09-01</joustumine>
									</muutmismarge>
								</alampunkt>
								<alampunkt id="para136b2lg1p3">
									<alampunktNr>3</alampunktNr>
									<kuvatavNr><![CDATA[3) ]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>jäätmete käitlemine – 1990 eurot, sealjuures ohtlike jäätmete käitlemine – 2980 eurot;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para136b2lg1p4">
									<alampunktNr>4</alampunktNr>
									<kuvatavNr><![CDATA[4) ]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>maavara kaevandamine – 1990 eurot.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130122023001</aktViide>
										</avaldamismarge>
										<joustumine>2024-07-01</joustumine>
									</muutmismarge>
								</alampunkt>
							</loige>
							<loige id="para136b2lg1b1">
								<loigeNr ylaIndeks="1">1</loigeNr>
								<kuvatavNr><![CDATA[(1<sup>1</sup>)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Kui keskkonnaloa taotluse läbivaatamine otsustatakse atmosfääriõhu kaitse seaduse § 79 lõikes 7 või veeseaduse § 191 lõikes 4 sätestatud juhul avatud menetluseta, tasutakse riigilõivu 660 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130122023001</aktViide>
									</avaldamismarge>
									<joustumine>2024-07-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para136b2lg2">
								<loigeNr>2</loigeNr>
								<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Keskkonnaloa muutmise taotluse läbivaatamise eest tasutakse riigilõivu 50 protsenti käesoleva paragrahvi lõikes 1 sätestatud riigilõivumäärast.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para136b2lg3">
								<loigeNr>3</loigeNr>
								<kuvatavNr><![CDATA[(3)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Kui keskkonnaloa muutmisel taotletakse käesoleva paragrahvi lõikes 1 nimetatud tegevuse lisamist keskkonnaloale, tasutakse riigilõivu käesoleva paragrahvi lõikes 1 sätestatud riigilõivumääras ja ei rakendu käesoleva paragrahvi lõige 2.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para136b2lg4">
								<loigeNr>4</loigeNr>
								<kuvatavNr><![CDATA[(4)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Riigiasutus, kohaliku omavalitsuse üksus, avalik-õiguslik juriidiline isik, mittetulundusühing ja raamatupidamise seaduse § 3 punktis 14 nimetatud mikroettevõtja tasub keskkonnaloa andmise või muutmise taotluse läbivaatamise eest riigilõivu 50 protsenti käesoleva paragrahvi lõigetes 1 ja 1<sup>1</sup> sätestatud või lõike 2 alusel arvutatud riigilõivumäärast.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130122023001</aktViide>
									</avaldamismarge>
									<joustumine>2024-07-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para136b2lg5">
								<loigeNr>5</loigeNr>
								<kuvatavNr><![CDATA[(5)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Raamatupidamise seaduse § 3 punktis 17 nimetatud suurettevõtja tasub keskkonnaloa andmise või muutmise taotluse läbivaatamise eest riigilõivu 125 protsenti käesoleva paragrahvi lõigetes 1 ja 1<sup>1</sup> sätestatud või lõike 2 alusel arvutatud riigilõivumäärast.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130122023001</aktViide>
									</avaldamismarge>
									<joustumine>2024-07-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para136b2lg6">
								<loigeNr>6</loigeNr>
								<kuvatavNr><![CDATA[(6)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Kui keskkonnaloa andmise või muutmise taotlus hõlmab vähemalt kahte käesoleva paragrahvi lõikes 1 nimetatud tegevust, tasutakse riigilõivu 80 protsenti käesoleva paragrahvi lõikes 1 nimetatud tegevuste riigilõivumäärade summast, arvestades käesoleva paragrahvi lõigetes 2–5 sätestatut.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2019-12-21</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>121122019001</aktViide>
									</avaldamismarge>
									<joustumine>2020-07-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
					</jaotis>
				</jagu>
				<jagu id="jg15">
					<jaguNr ylaIndeks="1">3</jaguNr>
					<kuvatavNr><![CDATA[3<sup>1</sup>. jagu]]></kuvatavNr>
					<jaguPealkiri>Konkurentsiameti toimingud</jaguPealkiri>
					<muutmismarge>
						<avaldamismarge>
							<RTosa>RT I</RTosa>
							<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
							<RTartikkel>1</RTartikkel>
							<aktViide>130062023001</aktViide>
						</avaldamismarge>
						<joustumine>2023-07-01</joustumine>
					</muutmismarge>
					<jaotis id="jaotis30">
						<jaotisNr>1</jaotisNr>
						<kuvatavNr><![CDATA[1. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Elektrituruseaduse alusel tehtavad toimingud</jaotisPealkiri>
						<muutmismarge>
							<avaldamismarge>
								<RTosa>RT I</RTosa>
								<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
								<RTartikkel>1</RTartikkel>
								<aktViide>130062023001</aktViide>
							</avaldamismarge>
							<joustumine>2023-07-01</joustumine>
						</muutmismarge>
						<paragrahv id="para136b3">
							<paragrahvNr ylaIndeks="3">136</paragrahvNr>
							<kuvatavNr><![CDATA[§ 136<sup>3</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri>Tegevusloa andmine ja muutmine</paragrahvPealkiri>
							<loige id="para136b3lg1">
								<loigeNr>1</loigeNr>
								<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Tegevusloa eest tasutakse riigilõivu lähtuvalt tegevusloa liigist:</tavatekst>
								</sisuTekst>
								<alampunkt id="para136b3lg1p1">
									<alampunktNr>1</alampunktNr>
									<kuvatavNr><![CDATA[1)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>suurema kui 1 MW netovõimsusega tootmisseadme käitamise lõpetamiseks – 640 eurot;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para136b3lg1p2">
									<alampunktNr>2</alampunktNr>
									<kuvatavNr><![CDATA[2)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>elektrienergia tootmiseks – 160 eurot iga kehtivusaasta eest;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para136b3lg1p3">
									<alampunktNr>3</alampunktNr>
									<kuvatavNr><![CDATA[3)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>jaotusvõrgu kaudu võrguteenuse osutamiseks aastase teenustemahuga kuni 5 GWh – 960 eurot iga kehtivusaasta eest;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para136b3lg1p4">
									<alampunktNr>4</alampunktNr>
									<kuvatavNr><![CDATA[4)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>jaotusvõrgu kaudu võrguteenuse osutamiseks aastase teenustemahuga üle 5 GWh kuni 20 GWh – 1920 eurot iga kehtivusaasta eest;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para136b3lg1p5">
									<alampunktNr>5</alampunktNr>
									<kuvatavNr><![CDATA[5)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>jaotusvõrgu kaudu võrguteenuse osutamiseks aastase teenustemahuga üle 20 GWh kuni 50 GWh – 4480 eurot iga kehtivusaasta eest;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para136b3lg1p6">
									<alampunktNr>6</alampunktNr>
									<kuvatavNr><![CDATA[6)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>jaotusvõrgu kaudu võrguteenuse osutamiseks aastase teenustemahuga üle 50 GWh kuni 100 GWh – 6400 eurot iga kehtivusaasta eest;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para136b3lg1p7">
									<alampunktNr>7</alampunktNr>
									<kuvatavNr><![CDATA[7)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>jaotusvõrgu kaudu võrguteenuse osutamiseks aastase teenustemahuga üle 100 GWh kuni 500 GWh – 12 790 eurot iga kehtivusaasta eest;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para136b3lg1p8">
									<alampunktNr>8</alampunktNr>
									<kuvatavNr><![CDATA[8)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>jaotusvõrgu kaudu võrguteenuse osutamiseks aastase teenustemahuga üle 500 GWh – 19 180 eurot iga kehtivusaasta eest;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para136b3lg1p9">
									<alampunktNr>9</alampunktNr>
									<kuvatavNr><![CDATA[9)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>põhivõrgu kaudu võrguteenuse osutamiseks – 2560 eurot iga kehtivusaasta eest;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para136b3lg1p10">
									<alampunktNr>10</alampunktNr>
									<kuvatavNr><![CDATA[10)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>riigipiiri ületava alalisvooluliini kaudu elektrienergia edastamiseks – 2560 eurot iga kehtivusaasta eest;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para136b3lg1p11">
									<alampunktNr>11</alampunktNr>
									<kuvatavNr><![CDATA[11)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>otseliini kaudu elektrienergia edastamiseks – 1280 eurot iga kehtivusaasta eest;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para136b3lg1p12">
									<alampunktNr>12</alampunktNr>
									<kuvatavNr><![CDATA[12)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>elektrienergia müügiks – 640 eurot iga kehtivusaasta eest.</tavatekst>
									</sisuTekst>
								</alampunkt>
							</loige>
							<loige id="para136b3lg2">
								<loigeNr>2</loigeNr>
								<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Käesoleva paragrahvi lõike 1 punktides 3–8 nimetatud teenustemahuks loetakse eelmisel kalendriaastal tarbijatele edastatud elektrienergia koguse ja võrgukadude summa. Tegevust alustav võrguettevõtja tasub riigilõivu järgmiseks kalendriaastaks kavandatava teenustemahu alusel.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para136b3lg3">
								<loigeNr>3</loigeNr>
								<kuvatavNr><![CDATA[(3)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Tegevusloa tingimuste muutmise taotluse läbivaatamise eest tasutakse riigilõivu 50 protsenti käesoleva paragrahvi lõikes 1 sätestatud riigilõivumäärast.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130062023001</aktViide>
									</avaldamismarge>
									<joustumine>2023-07-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
					</jaotis>
					<jaotis id="jaotis31">
						<jaotisNr>2</jaotisNr>
						<kuvatavNr><![CDATA[2. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Maagaasiseaduse alusel tehtavad toimingud</jaotisPealkiri>
						<muutmismarge>
							<avaldamismarge>
								<RTosa>RT I</RTosa>
								<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
								<RTartikkel>1</RTartikkel>
								<aktViide>130062023001</aktViide>
							</avaldamismarge>
							<joustumine>2023-07-01</joustumine>
						</muutmismarge>
						<paragrahv id="para136b4">
							<paragrahvNr ylaIndeks="4">136</paragrahvNr>
							<kuvatavNr><![CDATA[§ 136<sup>4</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri>Tegevusloa andmine ja muutmine</paragrahvPealkiri>
							<loige id="para136b4lg1">
								<loigeNr>1</loigeNr>
								<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Tegevusloa eest tasutakse riigilõivu lähtuvalt tegevusloa liigist:</tavatekst>
								</sisuTekst>
								<alampunkt id="para136b4lg1p1">
									<alampunktNr>1</alampunktNr>
									<kuvatavNr><![CDATA[1)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>gaasi importimiseks – 640 eurot iga kehtivusaasta eest;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para136b4lg1p2">
									<alampunktNr>2</alampunktNr>
									<kuvatavNr><![CDATA[2)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>gaasi müügiks – 260 eurot iga kehtivusaasta eest;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para136b4lg1p3">
									<alampunktNr>3</alampunktNr>
									<kuvatavNr><![CDATA[3)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>gaasi ülekande teenuse osutamiseks – 260 eurot iga kehtivusaasta eest;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para136b4lg1p4">
									<alampunktNr>4</alampunktNr>
									<kuvatavNr><![CDATA[4)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>gaasi jaotamise teenuse osutamiseks – 260 eurot iga kehtivusaasta eest.</tavatekst>
									</sisuTekst>
								</alampunkt>
							</loige>
							<loige id="para136b4lg2">
								<loigeNr>2</loigeNr>
								<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Tegevusloa tingimuste muutmise taotluse läbivaatamise eest tasutakse riigilõivu 50 protsenti käesoleva paragrahvi lõikes 1 sätestatud riigilõivumäärast.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130062023001</aktViide>
									</avaldamismarge>
									<joustumine>2023-07-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
					</jaotis>
					<jaotis id="jaotis32">
						<jaotisNr>3</jaotisNr>
						<kuvatavNr><![CDATA[3. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Kaugkütteseaduse alusel tehtavad toimingud</jaotisPealkiri>
						<muutmismarge>
							<avaldamismarge>
								<RTosa>RT I</RTosa>
								<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
								<RTartikkel>1</RTartikkel>
								<aktViide>130062023001</aktViide>
							</avaldamismarge>
							<joustumine>2023-07-01</joustumine>
						</muutmismarge>
						<paragrahv id="para136b5">
							<paragrahvNr ylaIndeks="5">136</paragrahvNr>
							<kuvatavNr><![CDATA[§ 136<sup>5</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri>Kaugkütteseaduse kohaselt tegevusloa andmise ja muutmise taotluse läbivaatamine</paragrahvPealkiri>
							<loige id="para136b5lg1">
								<loigeNr>1</loigeNr>
								<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Tegevusloa eest tasutakse riigilõivu lähtuvalt tegevusloa liigist:</tavatekst>
								</sisuTekst>
								<alampunkt id="para136b5lg1p1">
									<alampunktNr>1</alampunktNr>
									<kuvatavNr><![CDATA[1)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>soojuse tootmiseks üle 50 000 MWh aastas – 260 eurot iga kehtivusaasta eest ettevõtja kohta;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para136b5lg1p2">
									<alampunktNr>2</alampunktNr>
									<kuvatavNr><![CDATA[2)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>soojuse jaotamiseks üle 50 000 MWh aastas – 260 eurot iga kehtivusaasta eest ettevõtja kohta;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para136b5lg1p3">
									<alampunktNr>3</alampunktNr>
									<kuvatavNr><![CDATA[3)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>soojuse müügiks üle 50 000 MWh aastas – 260 eurot iga kehtivusaasta eest ettevõtja kohta või kontserni kuuluva ettevõtja kohta, kui kontserni kuuluvate soojusettevõtjate soojuse summaarne müük ületab 50 000 MWh aastas.</tavatekst>
									</sisuTekst>
								</alampunkt>
							</loige>
							<loige id="para136b5lg2">
								<loigeNr>2</loigeNr>
								<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Tegevusloa tingimuste muutmise taotluse läbivaatamise eest tasutakse riigilõivu 50 protsenti käesoleva paragrahvi lõikes 1 sätestatud riigilõivumäärast.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130062023001</aktViide>
									</avaldamismarge>
									<joustumine>2023-07-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
					</jaotis>
					<jaotis id="jaotis33">
						<jaotisNr>4</jaotisNr>
						<kuvatavNr><![CDATA[4. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Raudteeseaduse alusel tehtavad toimingud</jaotisPealkiri>
						<muutmismarge>
							<avaldamismarge>
								<RTosa>RT I</RTosa>
								<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
								<RTartikkel>1</RTartikkel>
								<aktViide>130062023001</aktViide>
							</avaldamismarge>
							<joustumine>2023-07-01</joustumine>
						</muutmismarge>
						<paragrahv id="para136b6">
							<paragrahvNr ylaIndeks="6">136</paragrahvNr>
							<kuvatavNr><![CDATA[§ 136<sup>6</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri>Tegevusloa taotluse läbivaatamine</paragrahvPealkiri>
							<loige id="para136b6lg1">
								<loigeNr/>
								<kuvatavNr/>
								<sisuTekst>
									<tavatekst>Tegevusloa taotluse läbivaatamise eest tasutakse riigilõivu lähtuvalt tegevusloa liigist:</tavatekst>
								</sisuTekst>
								<alampunkt id="para136b6lg1p1">
									<alampunktNr>1</alampunktNr>
									<kuvatavNr><![CDATA[1)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>avaliku raudteeinfrastruktuuri majandamiseks 1920 eurot;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para136b6lg1p2">
									<alampunktNr>2</alampunktNr>
									<kuvatavNr><![CDATA[2)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>reisijateveoga avalikul raudteel tegelemiseks 1920 eurot;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para136b6lg1p3">
									<alampunktNr>3</alampunktNr>
									<kuvatavNr><![CDATA[3)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>kaubaveoga avalikul raudteel tegelemiseks 3840 eurot.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130062023001</aktViide>
										</avaldamismarge>
										<joustumine>2023-07-01</joustumine>
									</muutmismarge>
								</alampunkt>
							</loige>
						</paragrahv>
					</jaotis>
					<jaotis id="jaotis34">
						<jaotisNr>5</jaotisNr>
						<kuvatavNr><![CDATA[5. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Riigilõivu tasumine</jaotisPealkiri>
						<muutmismarge>
							<avaldamismarge>
								<RTosa>RT I</RTosa>
