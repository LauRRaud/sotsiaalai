					<jaotis id="jaotis18">
						<jaotisNr>5</jaotisNr>
						<kuvatavNr><![CDATA[5. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Autoveoseaduse alusel tehtavad toimingud</jaotisPealkiri>
						<muutmismarge>
							<avaldamismarge>
								<RTosa>RT I</RTosa>
								<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
