							<loigeNr id="a75cf7a1-a613-4dbc-98ae-0a5219dcb092">1</loigeNr>
							<kuvatavNr id="c7319e09-1f7f-4ba5-a834-4ca1cb1a2789"><![CDATA[(1)]]></kuvatavNr>
							<sisuTekst id="c09fda5b-e661-4e9f-a067-57f260baf114">
								<tavatekst id="1791d697-f574-443f-a169-b815e06d1333">Kaubamärgi registreerimise taotluse puuduste kõrvaldamise või selgituste andmise tähtaja pikendamise eest tasutakse riigilõivu 32 eurot.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para95lg2">
							<loigeNr id="5dd090fd-4e76-41c4-9463-c9b54e8906c2">2</loigeNr>
							<kuvatavNr id="b5c82a84-f7d8-4abd-92e3-b1855b2b5f8b"><![CDATA[(2)]]></kuvatavNr>
							<sisuTekst id="36a6a54d-dcb1-4548-a6ed-3814946bb3ad">
								<tavatekst id="c934aa47-2528-468b-9731-1da7af7e6b24">Tööstusdisainilahenduse registreerimise taotluse puuduste kõrvaldamise või selgituste andmise tähtaja pikendamise eest tasutakse riigilõivu 32 eurot.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para95lg3">
							<loigeNr id="b155beb9-a17e-45f2-904d-f10c92597b77">3</loigeNr>
							<kuvatavNr id="aae56111-4174-4d78-9c89-a84b61f0063d"><![CDATA[(3)]]></kuvatavNr>
							<sisuTekst id="f28d0e3a-59ca-4c2d-ba10-570a7b3cbf40">
								<tavatekst id="72deea76-d586-475b-b189-c3c8aa5ca533">Geograafilise tähise registreerimise taotluse puuduste kõrvaldamise või selgituste andmise tähtaja pikendamise eest tasutakse riigilõivu 32 eurot.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para95lg4">
							<loigeNr id="65c17ac6-f7d6-43ed-8f87-32a3bc40b78d">4</loigeNr>
							<kuvatavNr id="964516c4-7d26-4dc3-9156-2ffa726193a4"><![CDATA[(4)]]></kuvatavNr>
							<sisuTekst id="ba8ccf6a-39a2-489e-9075-0f0c264a25f5">
								<tavatekst id="4239d93d-ef40-44d4-a9ef-753430774a24">Mikrolülituse topoloogia registreerimise taotluse puuduste kõrvaldamise või selgituste andmise tähtaja pikendamise eest tasutakse riigilõivu 32 eurot.</tavatekst>
							</sisuTekst>
						</loige>
					</paragrahv>
					<paragrahv id="para96">
						<paragrahvNr id="ba773bf0-a637-4ca5-8643-117e1a84614f">96</paragrahvNr>
						<kuvatavNr id="3abdb2c8-21ac-4d29-9211-4b8cd426f4f4"><![CDATA[§ 96. ]]></kuvatavNr>
						<paragrahvPealkiri id="60db9eba-618c-4374-ba26-9c38898fc507">Patenditaotluse parandamine ja täiendamine</paragrahvPealkiri>
						<loige id="para96lg1">
							<sisuTekst id="88127d10-d8fd-4b29-a44b-338f6d74bba7">
								<tavatekst id="19028354-b829-40e0-892a-186f99b4cd09">Pärast patendi väljaandmise või patenditaotluse tagasilükkamise otsuse tegemist tasutakse patenditaotluses paranduste ja täienduste tegemise eest riigilõivu 96 eurot.</tavatekst>
							</sisuTekst>
						</loige>
					</paragrahv>
					<paragrahv id="para97">
						<paragrahvNr id="33aec79d-e940-4521-8ecf-f4a77728721e">97</paragrahvNr>
						<kuvatavNr id="3b4e62b8-0a5f-4586-b3ed-680305823631"><![CDATA[§ 97. ]]></kuvatavNr>
						<paragrahvPealkiri id="2b04c955-9cc5-4067-a352-e3d6216151d1">Taotluse jagamine</paragrahvPealkiri>
						<loige id="para97lg1">
							<loigeNr id="eae45615-2b6f-4ae9-adf1-1dd03c41e56e">1</loigeNr>
							<kuvatavNr id="aa9ff358-8bc2-4e41-8d03-7686c42ceccf"><![CDATA[(1)]]></kuvatavNr>
							<sisuTekst id="4cfceb0f-375c-4482-9bef-8b12b8752c37">
								<tavatekst id="acf0e476-f72d-4dca-a509-872c92922334">Kaubamärgi registreerimise taotluse jagamise eest tasutakse riigilõivu samas määras, kui tasutaks eraldatava taotluse esitamise eest.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para97lg2">
							<loigeNr id="2fddfe1f-9b93-4fb2-a0a5-564472557803">2</loigeNr>
							<kuvatavNr id="db297043-7559-4715-8cd7-7fcece0cf1d1"><![CDATA[(2)]]></kuvatavNr>
							<sisuTekst id="cc38bc92-af25-4d0d-84cc-631975b087cf">
								<tavatekst id="3178182d-73dd-4ee9-95ff-b4931854f5d9">Tööstusdisainilahenduse registreerimise taotluse jagamise eest tasutakse riigilõivu samas määras, kui tasutaks eraldatava taotluse esitamise eest.</tavatekst>
							</sisuTekst>
						</loige>
					</paragrahv>
					<paragrahv id="para98">
						<paragrahvNr id="1ccb2d4f-c8b8-4ae7-87e5-d48e1a00e989">98</paragrahvNr>
						<kuvatavNr id="032cb788-51f4-495b-baed-0da890935c67"><![CDATA[§ 98. ]]></kuvatavNr>
						<paragrahvPealkiri id="68c571fa-1f76-42ba-8fbd-e564d3ffa890">Taotluse võõrandamine ja üleminek</paragrahvPealkiri>
						<loige id="para98lg1">
							<loigeNr id="c08d1dfa-41b6-4683-a509-dd37d1034227">1</loigeNr>
							<kuvatavNr id="2ec92494-d1dd-4739-8b10-a01544f7f912"><![CDATA[(1)]]></kuvatavNr>
							<sisuTekst id="c655883b-5701-4aec-b91a-194c8731c77f">
								<tavatekst id="5bc37380-375c-4724-93da-85e1a627aea1">Kaubamärgi registreerimise taotluse võõrandamisel või üleminekul tasutakse taotluse andmete muutmise kande tegemise avalduse esitamise eest riigilõivu 32 eurot.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para98lg2">
							<loigeNr id="e16e0b9d-5156-48fc-b76e-47168586d66c">2</loigeNr>
							<kuvatavNr id="778b0fd2-c2b4-47ac-99eb-116dd3dac1f7"><![CDATA[(2)]]></kuvatavNr>
							<sisuTekst id="57677133-0db7-4176-9d64-621486bd4b81">
								<tavatekst id="db1810a4-fd61-45ee-8f2d-35b6f0ff13bd">Patenditaotluse üleminekul tasutakse taotleja andmete muutmise avalduse esitamise eest riigilõivu 32 eurot.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para98lg3">
							<loigeNr id="336ae039-6f30-40d6-b82a-cf489d580484">3</loigeNr>
							<kuvatavNr id="113331da-eaed-4af0-956b-021d99d542b3"><![CDATA[(3)]]></kuvatavNr>
							<sisuTekst id="123563d6-ba16-458f-8556-c1da1c003ca3">
								<tavatekst id="00f8656a-7008-4e1d-b574-e6056655a3a7">Kasuliku mudeli registreerimise taotluse üleminekul tasutakse taotleja andmete muutmise avalduse esitamise eest riigilõivu 32 eurot.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para98lg4">
							<loigeNr id="2654f120-4978-4efe-b6e2-195d724adeca">4</loigeNr>
							<kuvatavNr id="3722452f-1580-467e-894b-6818494b63f8"><![CDATA[(4)]]></kuvatavNr>
							<sisuTekst id="a1471cc9-822d-4175-b1e6-ff7d34a3915e">
								<tavatekst id="f5029019-17a1-4b84-933e-d32d05d81dc7">Tööstusdisainilahenduse registreerimise taotluse üleminekul tasutakse taotluse andmete muutmise kande tegemise avalduse esitamise eest riigilõivu 32 eurot.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para98lg5">
							<loigeNr id="4db212b6-c1c5-4eae-ac04-737ad8a4f87d">5</loigeNr>
							<kuvatavNr id="744cfbb5-df91-4c78-86bd-58340c4d66ba"><![CDATA[(5)]]></kuvatavNr>
							<sisuTekst id="ee7fc30d-f353-4757-9a81-a85a5330bafe">
								<tavatekst id="4281b4fe-20b0-4b5d-8ab0-8118694dc487">Mikrolülituse topoloogia registreerimise taotluse üleminekul tasutakse taotleja andmete muutmise avalduse esitamise eest riigilõivu 32 eurot.</tavatekst>
							</sisuTekst>
						</loige>
					</paragrahv>
					<paragrahv id="para99">
						<paragrahvNr id="f7587b25-1d6a-4f3c-aeb2-46d68a44289a">99</paragrahvNr>
						<kuvatavNr id="0f2d3319-b38a-44f1-bd33-2c9539db0aa2"><![CDATA[§ 99. ]]></kuvatavNr>
						<paragrahvPealkiri id="51f843a5-f0bc-49a4-96e0-04cd2ab6827f">Euroopa patenditaotluse siseriiklikku menetlusse võtmine</paragrahvPealkiri>
						<loige id="para99lg1">
							<sisuTekst id="cb87f70c-0a11-44a9-8b34-6df51f33520e">
								<tavatekst id="7b0b91bf-1f0e-4395-b3db-d5776d1b94e7">Euroopa patenditaotluse siseriiklikku menetlusse võtmise eest tasutakse riigilõivu:</tavatekst>
							</sisuTekst>
							<alampunkt id="para99lg1p1">
								<alampunktNr id="a11b946c-039b-4ded-94d0-07032731e036">1</alampunktNr>
								<kuvatavNr id="5753e4df-1f28-431e-9505-10e4dd867177"><![CDATA[1) ]]></kuvatavNr>
								<sisuTekst id="eae18b96-d20a-4ccf-88fd-d2e2501fe53c">
									<tavatekst id="fad77a8b-d80f-4039-850e-98e50d5ff119">patenditaotlusena 225 eurot;</tavatekst>
								</sisuTekst>
							</alampunkt>
							<alampunkt id="para99lg1p2">
								<alampunktNr id="aaa89204-cfdd-42d3-9c8e-b283d181766a">2</alampunktNr>
								<kuvatavNr id="abf4ba1b-face-435f-826c-1cb42a1b5e1c"><![CDATA[2) ]]></kuvatavNr>
								<sisuTekst id="b67474d0-c1c7-4357-ac50-660addbb7120">
									<tavatekst id="e4f27b63-affc-497f-8f34-847d9b40c9b1">kasuliku mudeli registreerimise taotlusena 105 eurot.</tavatekst>
								</sisuTekst>
							</alampunkt>
						</loige>
					</paragrahv>
