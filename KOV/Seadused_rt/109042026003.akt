									<RTosa>RT I</RTosa>
									<avaldamineKuupaev>2020-10-30</avaldamineKuupaev>
									<RTartikkel>1</RTartikkel>
									<aktViide>130102020001</aktViide>
								</avaldamismarge>
								<joustumine>2020-10-31</joustumine>
							</muutmismarge>
							<loige id="para211lg1">
								<loigeNr>1</loigeNr>
								<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Allsüsteemi kasutuselevõtmise loa taotluse läbivaatamise eest tasutakse riigilõivu 4160 eurot.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para211lg2">
								<loigeNr>2</loigeNr>
								<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Raudteeveeremi turule laskmise loa või raudteeveeremi tüübiloa taotluse läbivaatamise eest tasutakse riigilõivu 6240 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130122023001</aktViide>
									</avaldamismarge>
									<joustumine>2024-01-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
						<paragrahv id="para212">
							<paragrahvNr>212</paragrahvNr>
							<kuvatavNr><![CDATA[§ 212. ]]></kuvatavNr>
							<paragrahvPealkiri>Ohutusloa, ühtse ohutustunnistuse ja tegutsemise ohutustunnistuse taotluse läbivaatamine</paragrahvPealkiri>
							<muutmismarge>
								<avaldamismarge>
									<RTosa>RT I</RTosa>
									<avaldamineKuupaev>2020-10-30</avaldamineKuupaev>
									<RTartikkel>1</RTartikkel>
									<aktViide>130102020001</aktViide>
								</avaldamismarge>
								<joustumine>2020-10-31</joustumine>
							</muutmismarge>
							<loige id="para212lg1">
								<loigeNr>1</loigeNr>
								<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Ohutusloa väljaandmise taotluse läbivaatamise eest tasutakse riigilõivu 3120 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130122023001</aktViide>
									</avaldamismarge>
									<joustumine>2024-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para212lg2">
								<loigeNr>2</loigeNr>
								<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Ohutusloa muutmise või uuendamise taotluse läbivaatamise eest tasutakse riigilõivu 1560 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130122023001</aktViide>
									</avaldamismarge>
									<joustumine>2024-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para212lg3">
								<loigeNr>3</loigeNr>
								<kuvatavNr><![CDATA[(3)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Ühtse ohutustunnistuse taotluse läbivaatamise eest tasutakse riigilõivu 4000 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130122023001</aktViide>
									</avaldamismarge>
									<joustumine>2024-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para212lg4">
								<loigeNr>4</loigeNr>
								<kuvatavNr><![CDATA[(4)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Ühtse ohutustunnistuse muutmise või uuendamise taotluse läbivaatamise eest tasutakse riigilõivu 1600 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130122023001</aktViide>
									</avaldamismarge>
									<joustumine>2024-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para212lg5">
								<loigeNr>5</loigeNr>
								<kuvatavNr><![CDATA[(5)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Tegutsemise ohutustunnistuse taotluse läbivaatamise eest tasutakse riigilõivu lähtuvalt tunnistuse liigist järgmiselt:</tavatekst>
								</sisuTekst>
								<alampunkt id="para212lg5p1">
									<alampunktNr>1</alampunktNr>
									<kuvatavNr><![CDATA[1) ]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>mitteavalikul raudteel kogupikkusega kuni 5000 meetrit raudteeliikluse korraldamiseks 1240 eurot;</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130122023001</aktViide>
										</avaldamismarge>
										<joustumine>2024-01-01</joustumine>
									</muutmismarge>
								</alampunkt>
								<alampunkt id="para212lg5p2">
									<alampunktNr>2</alampunktNr>
									<kuvatavNr><![CDATA[2) ]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>mitteavalikul raudteel kogupikkusega 5001–15 000 meetrit raudteeliikluse korraldamiseks 1560 eurot;</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130122023001</aktViide>
										</avaldamismarge>
										<joustumine>2024-01-01</joustumine>
									</muutmismarge>
								</alampunkt>
								<alampunkt id="para212lg5p3">
									<alampunktNr>3</alampunktNr>
									<kuvatavNr><![CDATA[3) ]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>mitteavalikul raudteel kogupikkusega alates 15 001 meetrist raudteeliikluse korraldamiseks 2430 eurot;</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130122023001</aktViide>
										</avaldamismarge>
										<joustumine>2024-01-01</joustumine>
									</muutmismarge>
								</alampunkt>
								<alampunkt id="para212lg5p4">
									<alampunktNr>4</alampunktNr>
									<kuvatavNr><![CDATA[4) ]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>mitteavalikul raudteel reisijateveo korraldamiseks 2340 eurot;</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130122023001</aktViide>
										</avaldamismarge>
										<joustumine>2024-01-01</joustumine>
									</muutmismarge>
								</alampunkt>
								<alampunkt id="para212lg5p5">
									<alampunktNr>5</alampunktNr>
									<kuvatavNr><![CDATA[5) ]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>mitteavalikul raudteel kaubaveo korraldamiseks 2340 eurot.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130122023001</aktViide>
										</avaldamismarge>
										<joustumine>2024-01-01</joustumine>
									</muutmismarge>
								</alampunkt>
							</loige>
							<loige id="para212lg6">
								<loigeNr>6</loigeNr>
								<kuvatavNr><![CDATA[(6)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Tegutsemise ohutustunnistuse muutmise või uuendamise taotluse läbivaatamise eest tasutakse riigilõivu 1200 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130122023001</aktViide>
									</avaldamismarge>
									<joustumine>2024-01-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
						<paragrahv id="para213">
							<paragrahvNr>213</paragrahvNr>
							<kuvatavNr><![CDATA[§ 213. ]]></kuvatavNr>
							<paragrahvPealkiri>Läbilaskevõime taotluse esitamine</paragrahvPealkiri>
							<loige id="para213lg1">
								<sisuTekst>
									<tavatekst>Läbilaskevõime taotluse esitamise korral Tarbijakaitse ja Tehnilise Järelevalve Ametile kui läbilaskevõime jaotusorganile raudteeseaduse § 107 tähenduses tasutakse igaks liiklusgraafikuperioodiks taotletava läbilaskevõimeosa eest riigilõivu 180 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130122023001</aktViide>
									</avaldamismarge>
									<joustumine>2024-01-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
						<paragrahv id="para213b1">
							<paragrahvNr ylaIndeks="1">213</paragrahvNr>
							<kuvatavNr><![CDATA[§ 213<sup>1</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri>Tegevusloa taotluse läbivaatamine</paragrahvPealkiri>
							<loige id="para213b1lg1">
								<loigeNr/>
								<kuvatavNr/>
								<sisuTekst>
									<tavatekst>Tegevusloa taotluse läbivaatamise eest tasutakse riigilõivu lähtuvalt tegevusloa liigist järgmiselt:</tavatekst>
								</sisuTekst>
								<alampunkt id="para213b1lg1p1">
									<alampunktNr>1</alampunktNr>
									<kuvatavNr><![CDATA[1) ]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>avalikul raudteel kasutatava või raudteeveoks kasutatava raudteeveeremi tehnohooldeks ja remondiks 1240 eurot;</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130122023001</aktViide>
										</avaldamismarge>
										<joustumine>2024-01-01</joustumine>
									</muutmismarge>
								</alampunkt>
								<alampunkt id="para213b1lg1p2">
									<alampunktNr>2</alampunktNr>
									<kuvatavNr><![CDATA[2) ]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>raudteeveeremi ehituseks 2340 eurot;</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
