							</paragrahv>
							<paragrahv id="para142b28">
								<paragrahvNr ylaIndeks="28">142</paragrahvNr>
								<kuvatavNr><![CDATA[§ 142<sup>28</sup>. ]]></kuvatavNr>
								<paragrahvPealkiri>Lennutegevuse eriloa taotluse läbivaatamine</paragrahvPealkiri>
								<loige id="para142b28lg1">
									<loigeNr>1</loigeNr>
									<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Lennutegevuse eriloa taotluse, välja arvatud ohtliku kauba veo eriloa taotluse läbivaatamise eest tasutakse riigilõivu õhusõiduki maksimaalsest lubatud stardimassist (MTOW) lähtuvalt järgmiselt:</tavatekst>
									</sisuTekst>
									<alampunkt id="para142b28lg1p1">
										<alampunktNr>1</alampunktNr>
										<kuvatavNr><![CDATA[1)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>MTOW lennukil kuni 2800 kg ja kopteril kuni 1000 kg – 730 eurot;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b28lg1p2">
										<alampunktNr>2</alampunktNr>
										<kuvatavNr><![CDATA[2)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>MTOW lennukil 2801–5700 kg ja kopteril 1001–3175 kg – 1170 eurot;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b28lg1p3">
										<alampunktNr>3</alampunktNr>
										<kuvatavNr><![CDATA[3)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>MTOW lennukil 5701–25 000 kg ja kopteril üle 3175 kg – 1870 eurot;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b28lg1p4">
										<alampunktNr>4</alampunktNr>
										<kuvatavNr><![CDATA[4)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>MTOW lennukil üle 25 000 kg – 2920 eurot.</tavatekst>
										</sisuTekst>
									</alampunkt>
								</loige>
								<loige id="para142b28lg2">
									<loigeNr>2</loigeNr>
									<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Ohtliku kauba veo eriloa taotluse läbivaatamise eest tasutakse riigilõivu õhusõiduki maksimaalsest lubatud stardimassist (MTOW) lähtuvalt järgmiselt:</tavatekst>
									</sisuTekst>
									<alampunkt id="para142b28lg2p1">
										<alampunktNr>1</alampunktNr>
										<kuvatavNr><![CDATA[1)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>MTOW lennukil kuni 2800 kg ja kopteril kuni 1000 kg – 270 eurot;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b28lg2p2">
										<alampunktNr>2</alampunktNr>
										<kuvatavNr><![CDATA[2)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>MTOW lennukil 2801–5700 kg ja kopteril 1001–3175 kg – 360 eurot;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b28lg2p3">
										<alampunktNr>3</alampunktNr>
										<kuvatavNr><![CDATA[3)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>MTOW lennukil 5701–25 000 kg ja kopteril üle 3175 kg – 430 eurot;</tavatekst>
										</sisuTekst>
									</alampunkt>
									<alampunkt id="para142b28lg2p4">
										<alampunktNr>4</alampunktNr>
										<kuvatavNr><![CDATA[4)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>MTOW lennukil üle 25 000 kg – 580 eurot.</tavatekst>
										</sisuTekst>
										<muutmismarge>
											<avaldamismarge>
												<RTosa>RT I</RTosa>
												<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
												<RTartikkel>1</RTartikkel>
												<aktViide>130062023001</aktViide>
											</avaldamismarge>
											<joustumine>2023-07-01</joustumine>
										</muutmismarge>
									</alampunkt>
								</loige>
							</paragrahv>
							<paragrahv id="para142b29">
								<paragrahvNr ylaIndeks="29">142</paragrahvNr>
								<kuvatavNr><![CDATA[§ 142<sup>29</sup>. ]]></kuvatavNr>
								<paragrahvPealkiri>Kõrge riskitasemega ärilise erilennu loa taotluse ja loa muutmise taotluse läbivaatamine ning loa hoidmine</paragrahvPealkiri>
								<loige id="para142b29lg1">
									<loigeNr>1</loigeNr>
									<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Kõrge riskitasemega ärilise erilennu loa taotluse läbivaatamise eest tasutakse riigilõivu 745 eurot.</tavatekst>
									</sisuTekst>
								</loige>
								<loige id="para142b29lg2">
									<loigeNr>2</loigeNr>
									<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Kõrge riskitasemega ärilise erilennu loa muutmise taotluse läbivaatamise eest tasutakse riigilõivu 110 eurot.</tavatekst>
									</sisuTekst>
								</loige>
								<loige id="para142b29lg3">
									<loigeNr>3</loigeNr>
									<kuvatavNr><![CDATA[(3)]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>Kõrge riskitasemega ärilise erilennu loa hoidmise eest tasutakse iga aasta kohta riigilõivu 380 eurot.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130062023001</aktViide>
										</avaldamismarge>
										<joustumine>2023-07-01</joustumine>
									</muutmismarge>
								</loige>
							</paragrahv>
							<paragrahv id="para142b30">
								<paragrahvNr ylaIndeks="30">142</paragrahvNr>
								<kuvatavNr><![CDATA[§ 142<sup>30</sup>. ]]></kuvatavNr>
								<paragrahvPealkiri>Maandumiseks sobimatu ala kohal kopteri ärilisel eesmärgil käitamise loa taotluse läbivaatamine</paragrahvPealkiri>
