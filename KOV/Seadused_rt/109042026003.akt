						<paragrahv id="para297b1">
							<paragrahvNr id="b0f38d65-41d1-4d7c-b5c3-1683b7bd3e47" ylaIndeks="1">297</paragrahvNr>
							<kuvatavNr id="6f2d8147-9dd5-4f6e-89bc-9bcd2ab9d7f0"><![CDATA[§ 297<sup>1</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri id="7a2cad55-f1d0-4c58-aef6-c5eb7499d3b7">Biotsiidi toimeaine heakskiitmine</paragrahvPealkiri>
							<loige id="para297b1lg1">
								<loigeNr id="257a74f2-b11e-4739-9f59-316da4cad5c9"/>
								<kuvatavNr id="a34d32f4-d4ef-4975-b65e-28bbd52932d5"/>
								<sisuTekst id="f887f4a4-9d6b-4e4d-8a8f-2b5faf63f65e">
									<tavatekst id="e1f5b686-fa90-496d-a95a-b8f66392602a">Biotsiidi toimeaine heakskiitmisega seotud taotluse menetlemise eest hindava liikmesriigina tasutakse riigilõivu 3300 eurot.</tavatekst>
								</sisuTekst>
