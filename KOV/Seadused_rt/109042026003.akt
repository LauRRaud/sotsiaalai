					<jaotis id="jaotis44">
						<jaotisNr>2</jaotisNr>
						<kuvatavNr><![CDATA[2. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Kultuuriväärtuste väljaveo, ekspordi ja sisseveo seaduse alusel tehtavad toimingud</jaotisPealkiri>
						<paragrahv id="para144">
							<paragrahvNr>144</paragrahvNr>
							<kuvatavNr><![CDATA[§ 144. ]]></kuvatavNr>
							<paragrahvPealkiri>Kultuuriväärtuse väljaveoloa taotluse läbivaatamine ning väljaveoloa andmine ja sellest keeldumine</paragrahvPealkiri>
							<loige id="para144lg1">
								<sisuTekst>
									<tavatekst>Kultuuriväärtuse väljaveo loa taotluse läbivaatamise eest, samuti väljaveoloa andmise või sellest keeldumise eest kultuuriväärtuste väljaveo, ekspordi ja sisseveo seaduse § 16 lõikes 4 ja § 17 lõikes 3 sätestatud alustel tasutakse riigilõivu 20 eurot kultuuriväärtuse kohta, kuid kokku mitte rohkem kui 200 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge id="17f93dd0-f20f-4749-8375-1e1a406dc3a5">
									<avaldamismarge id="45a82390-61c4-46db-903f-f88117231358">
										<RTosa id="1aadf086-d7e9-4e7b-833b-87cfa62a5297">RT I</RTosa>
