							</muutmismarge>
							<loige id="para143lg1">
								<sisuTekst>
									<tavatekst>Muinsuskaitseseaduses sätestatud pädevustunnistuse andmise ja pikendamise taotluse läbivaatamise eest tasutakse riigilõivu 50 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge id="1cb41df2-21ae-46e1-99d6-e977e4f98aae">
									<avaldamismarge id="60c82a01-fe1b-491a-8dfd-78155d101742">
										<RTosa id="777598c3-0b91-4879-b92a-113b7a43945c">RT I</RTosa>
										<avaldamineKuupaev id="60f9163c-0d2f-4272-8679-1e7992187059">2019-03-19</avaldamineKuupaev>
										<RTartikkel id="3fb2178b-e762-42c3-88de-9abbd55386a8">13</RTartikkel>
