							<kuvatavNr id="551cc0f4-32a0-4334-bd7f-97ee066a8692"><![CDATA[§ 325. ]]></kuvatavNr>
							<paragrahvPealkiri id="26fb99a5-5431-41fa-83e6-579859b92926">Lapsehoiuteenuse osutamise tegevusloa taotluse läbivaatamine</paragrahvPealkiri>
							<muutmismarge id="63f2a8a2-f9e3-4eda-a451-cacb05b3e602">
								<tavatekst id="c1777d3a-3a4a-4aaf-91a0-d4a0c2704122">Kehtetu - </tavatekst>
								<avaldamismarge id="2c30af2d-777e-4cfd-8f69-162064cb7b3d">
