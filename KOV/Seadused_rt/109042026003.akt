										<kuvatavNr><![CDATA[3)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>väiksema kui 200-se kogumahutavusega laeva vahitüürimehe tunnistuse puhul – 30 eurot;</tavatekst>
										</sisuTekst>
										<muutmismarge>
											<avaldamismarge>
