							<paragrahv id="para142b27">
								<paragrahvNr ylaIndeks="27">142</paragrahvNr>
								<kuvatavNr><![CDATA[§ 142<sup>27</sup>. ]]></kuvatavNr>
								<paragrahvPealkiri>Langevarjundustegevuse käsiraamatu läbivaatamine</paragrahvPealkiri>
								<loige id="para142b27lg1">
									<loigeNr/>
									<kuvatavNr/>
									<sisuTekst>
										<tavatekst>Langevarjundustegevuse käsiraamatu läbivaatamise eest tasutakse riigilõivu 230 eurot.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130062023001</aktViide>
