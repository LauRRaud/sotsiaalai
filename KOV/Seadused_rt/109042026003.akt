									<joustumine>2024-07-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para142b85lg9">
								<loigeNr>9</loigeNr>
								<kuvatavNr><![CDATA[(9)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Üksiksõiduki kinnituse omistamise eest tasutakse riigilõivu 205 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
