						<paragrahv id="para202">
							<paragrahvNr>202</paragrahvNr>
							<kuvatavNr><![CDATA[§ 202. ]]></kuvatavNr>
							<paragrahvPealkiri>Lõhkematerjaliseaduse alusel toimingute tegemine</paragrahvPealkiri>
							<loige id="para202lg1">
								<loigeNr id="2e061ecc-87b2-4d34-a7fc-3b101f7202b8">1</loigeNr>
								<kuvatavNr id="df9597a0-f61f-4773-8f54-0c6ede916730"><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst id="aacf7591-912a-4d1b-8d0e-bccd2554575f">
									<tavatekst id="5756c24e-5fb5-4d4f-90ac-57b317cad19a">Lõhkematerjali käitlemisloa taotluse läbivaatamise eest tasutakse riigilõivu 290 eurot.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para202lg1b1">
								<loigeNr id="58f98769-aa88-43d6-8501-7fe77de806b1" ylaIndeks="1">1</loigeNr>
								<kuvatavNr id="c202e299-039a-42af-b01b-33b01b9ec005"><![CDATA[(1<sup>1</sup>)]]></kuvatavNr>
								<sisuTekst id="4b2b705a-f458-499e-a837-c90bed7b0338">
									<tavatekst id="6930aac7-b4d0-4cc6-992d-7653d6448db7">Lõhkematerjali ja pürotehnilise toote käitlemiskoha käitamisloa taotluse läbivaatamise eest tasutakse riigilõivu järgmiselt:</tavatekst>
								</sisuTekst>
								<alampunkt id="para202lg1b1p1">
									<alampunktNr id="2b96cff5-23d2-40c4-a6c5-ace593450d14">1</alampunktNr>
									<kuvatavNr id="b6fd646c-93bb-46a7-b011-8ccd6209143d"><![CDATA[1) ]]></kuvatavNr>
									<sisuTekst id="48775330-67b7-4462-a1e9-a69e4a2732c7">
										<tavatekst id="5c0643bd-2e4b-4d2b-8d4f-41cebb60bdc8">1030 eurot, kui käitlemiskoht on samal ajal A-kategooria suurõnnetuse ohuga ettevõte kemikaaliseaduse tähenduses;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para202lg1b1p2">
									<alampunktNr id="72035729-f89e-4a6b-b596-7bbf6e735143">2</alampunktNr>
									<kuvatavNr id="f4bbf0fc-dfba-4c1e-8187-ae3d582fc66d"><![CDATA[2) ]]></kuvatavNr>
									<sisuTekst id="6f71e67c-fcb0-4599-92c1-d9d98618d087">
										<tavatekst id="b0645439-89a8-4959-8313-66baabbf4da3">900 eurot, kui käitlemiskoht on samal ajal B-kategooria suurõnnetuse ohuga ettevõte kemikaaliseaduse tähenduses;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para202lg1b1p3">
									<alampunktNr id="01e6dcb8-6234-484a-a6d5-d0d2ed2570df">3</alampunktNr>
									<kuvatavNr id="83e63474-84dc-442c-853d-c7cfdf84cc18"><![CDATA[3) ]]></kuvatavNr>
									<sisuTekst id="2edb1106-4e47-46f2-92a1-bca4df30c33c">
										<tavatekst id="5f9334c4-1690-4652-b16a-f144522a3e91">640 eurot, kui käitlemiskoht on samal ajal C-kategooria ettevõte kemikaaliseaduse tähenduses;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para202lg1b1p4">
									<alampunktNr id="cd90941e-0fe2-4d46-9b5e-f8187f2602d5">4</alampunktNr>
									<kuvatavNr id="acc1ac65-9f40-45df-8aa7-79e6bc1d5040"><![CDATA[4) ]]></kuvatavNr>
									<sisuTekst id="a5b6676f-cecf-420e-afde-78bfdc1228d1">
										<tavatekst id="3531e719-061f-4d05-8e06-9e72917e473b">käesoleva lõike punktides 1−3 nimetamata juhul 385 eurot.</tavatekst>
									</sisuTekst>
									<muutmismarge id="d4b901c9-b5bc-479c-92fb-5725f4414e2e">
