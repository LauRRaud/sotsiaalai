						<jaotisPealkiri>Välismaalaste seaduse alusel tehtavad toimingud</jaotisPealkiri>
						<paragrahv id="para273">
							<paragrahvNr>273</paragrahvNr>
							<kuvatavNr><![CDATA[§ 273. ]]></kuvatavNr>
							<paragrahvPealkiri>Elamisloa taotluse läbivaatamine</paragrahvPealkiri>
							<loige id="para273lg1">
								<loigeNr>1</loigeNr>
								<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Tähtajalise elamisloa taotluse läbivaatamise eest tasutakse riigilõivu 225 eurot ja välisesinduses 255 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para273lg2">
								<loigeNr>2</loigeNr>
								<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Töötamiseks antava tähtajalise elamisloa taotluse läbivaatamise eest tasutakse riigilõivu 250 eurot ja välisesinduses 280 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para273lg3">
								<loigeNr>3</loigeNr>
								<kuvatavNr><![CDATA[(3)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Ettevõtluseks antava tähtajalise elamisloa taotluse läbivaatamise eest tasutakse riigilõivu 350 eurot ja välisesinduses 380 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para273lg4">
								<loigeNr>4</loigeNr>
								<kuvatavNr><![CDATA[(4)]]></kuvatavNr>
								<muutmismarge>
									<tavatekst>Kehtetu - </tavatekst>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para273lg5">
								<loigeNr>5</loigeNr>
								<kuvatavNr><![CDATA[(5)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Eesti kodanikust abikaasa, registreeritud elukaaslase või Eesti kodanikust lähedase sugulase juurde elama asumiseks tähtajalise elamisloa taotluse läbivaatamise eest tasutakse riigilõivu 115 eurot ja välisesinduses 145 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para273lg6">
								<loigeNr>6</loigeNr>
								<kuvatavNr><![CDATA[(6)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Pikaajalise elaniku elamisloa taotluse ja pikaajalise elaniku elamisloa taastamise taotluse läbivaatamise eest tasutakse riigilõivu 185 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para273lg7">
								<loigeNr>7</loigeNr>
								<kuvatavNr><![CDATA[(7)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Alla 18-aastase välismaalase ja üldtingimustel Eesti vanaduspensioni ikka jõudnud isiku pikaajalise elaniku elamisloa taotluse ning pikaajalise elaniku elamisloa taastamise taotluse läbivaatamise eest tasutakse riigilõivu 93 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
										<aktViide>129062024003</aktViide>
									</avaldamismarge>
									<joustumine>2025-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para273lg8">
								<loigeNr>8</loigeNr>
								<kuvatavNr><![CDATA[(8)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Käesoleva paragrahvi lõigetes 1–7 nimetatud dokumendi väljastamise eest välisesinduses tasutakse riigilõivu 20 eurot, mis tasutakse dokumendi taotlemisel.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2025-06-26</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>126062025001</aktViide>
									</avaldamismarge>
									<joustumine>2025-07-06</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
						<paragrahv id="para274">
							<paragrahvNr>274</paragrahvNr>
							<kuvatavNr><![CDATA[§ 274. ]]></kuvatavNr>
							<paragrahvPealkiri>Tähtajalise elamisloa pikendamise taotluse läbivaatamine</paragrahvPealkiri>
