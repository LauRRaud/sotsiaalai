							<loige id="para67lg1b1">
								<loigeNr ylaIndeks="1">1</loigeNr>
								<kuvatavNr><![CDATA[(1<sup>1</sup>)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Usulise ühenduse registrisse ennistamise eest tegevuse jätkamiseks, kui usuline ühendus on registrist kustutatud äriregistri seaduse § 61 või 62 alusel, tasutakse riigilõivu 200 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2022-05-05</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>105052022001</aktViide>
									</avaldamismarge>
									<joustumine>2023-02-01</joustumine>
									<tavatekst>; osaliselt muudetud [RT I, 23.12.2022, 2]</tavatekst>
								</muutmismarge>
							</loige>
							<loige id="para67lg2">
								<loigeNr>2</loigeNr>
								<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Usulise ühenduse kohta registrisse kantud andmete muutmise või täiendamise eest tasutakse riigilõivu 10 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2021-12-08</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>108122021001</aktViide>
									</avaldamismarge>
									<joustumine>2022-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para67lg3">
								<loigeNr>3</loigeNr>
								<kuvatavNr><![CDATA[(3)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Käesoleva paragrahvi lõikes 2 nimetatud kande kindlal kuupäeval tegemise eest tasutakse riigilõivu kahekordses määras.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2022-05-05</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>105052022001</aktViide>
									</avaldamismarge>
									<joustumine>2024-03-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
						<paragrahv id="para68">
							<paragrahvNr>68</paragrahvNr>
							<kuvatavNr><![CDATA[§ 68. ]]></kuvatavNr>
							<paragrahvPealkiri>Korteriühistu kohta kande tegemine</paragrahvPealkiri>
							<muutmismarge>
								<avaldamismarge>
									<RTosa>RT I</RTosa>
									<avaldamineKuupaev>2022-05-05</avaldamineKuupaev>
									<RTartikkel>1</RTartikkel>
									<aktViide>105052022001</aktViide>
								</avaldamismarge>
								<joustumine>2023-02-01</joustumine>
							</muutmismarge>
							<loige id="para68lg1">
								<loigeNr>1</loigeNr>
								<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Korteriühistu kohta registrisse kantud andmete muutmise või täiendamise eest tasutakse riigilõivu 10 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2021-12-08</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>108122021001</aktViide>
									</avaldamismarge>
									<joustumine>2022-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para68lg2">
								<loigeNr>2</loigeNr>
								<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Käesoleva paragrahvi lõikes 1 nimetatud kande kindlal kuupäeval tegemise eest tasutakse riigilõivu kahekordses määras.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2022-05-05</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>105052022001</aktViide>
									</avaldamismarge>
									<joustumine>2024-03-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
						<paragrahv id="para68b1">
							<paragrahvNr ylaIndeks="1">68</paragrahvNr>
							<kuvatavNr><![CDATA[§ 68<sup>1</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri>Maaparandusühistu kohta kande tegemine</paragrahvPealkiri>
							<muutmismarge>
								<avaldamismarge>
									<RTosa>RT I</RTosa>
									<avaldamineKuupaev>2022-05-05</avaldamineKuupaev>
									<RTartikkel>1</RTartikkel>
									<aktViide>105052022001</aktViide>
								</avaldamismarge>
								<joustumine>2023-02-01</joustumine>
							</muutmismarge>
							<loige id="para68b1lg1">
								<loigeNr>1</loigeNr>
								<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Maaparandusühistu registrisse kandmise eest tasutakse riigilõivu 30 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2021-12-08</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>108122021001</aktViide>
									</avaldamismarge>
									<joustumine>2022-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para68b1lg1b1">
								<loigeNr ylaIndeks="1">1</loigeNr>
								<kuvatavNr><![CDATA[(1<sup>1</sup>)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Maaparandusühistu registrisse ennistamise eest tegevuse jätkamiseks, kui maaparandusühistu on registrist kustutatud äriregistri seaduse § 61 või 62 alusel, tasutakse riigilõivu 200 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2022-05-05</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>105052022001</aktViide>
									</avaldamismarge>
									<joustumine>2023-02-01</joustumine>
									<tavatekst>; osaliselt muudetud [RT I, 23.12.2022, 2]</tavatekst>
								</muutmismarge>
							</loige>
							<loige id="para68b1lg2">
								<loigeNr>2</loigeNr>
								<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Maaparandusühistu kohta registrisse kantud andmete muutmise või täiendamise eest tasutakse riigilõivu 10 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2021-12-08</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>108122021001</aktViide>
									</avaldamismarge>
									<joustumine>2022-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para68b1lg3">
								<loigeNr>3</loigeNr>
								<kuvatavNr><![CDATA[(3)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Käesoleva paragrahvi lõikes 2 nimetatud kande kindlal kuupäeval tegemise eest tasutakse riigilõivu kahekordses määras.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2022-05-05</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>105052022001</aktViide>
									</avaldamismarge>
									<joustumine>2024-03-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
						<paragrahv id="para69">
							<paragrahvNr>69</paragrahvNr>
							<kuvatavNr><![CDATA[§ 69. ]]></kuvatavNr>
							<paragrahvPealkiri>Registri dokumendi väljastamine</paragrahvPealkiri>
							<muutmismarge>
								<tavatekst>Kehtetu - </tavatekst>
								<avaldamismarge>
									<RTosa>RT I</RTosa>
									<avaldamineKuupaev>2017-05-09</avaldamineKuupaev>
									<RTartikkel>1</RTartikkel>
									<aktViide>109052017001</aktViide>
								</avaldamismarge>
								<joustumine>2017-07-01</joustumine>
							</muutmismarge>
						</paragrahv>
					</jaotis>
					<jaotis id="jaotis6">
						<jaotisNr>3</jaotisNr>
						<kuvatavNr><![CDATA[3. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Kommertspandiregistri toimingud</jaotisPealkiri>
						<paragrahv id="para70">
							<paragrahvNr id="d501ca86-a45d-494e-b29e-95885a4d5db3">70</paragrahvNr>
							<kuvatavNr id="2909406c-d7a9-4176-9269-9c7d5278e3e8"><![CDATA[§ 70. ]]></kuvatavNr>
							<paragrahvPealkiri id="c8a12ca8-b515-490e-a316-2720393b0ff7">Kommertspandiregistri kande tegemine</paragrahvPealkiri>
							<loige id="para70lg1">
								<loigeNr id="044bea75-8de1-4e60-ad07-5796342f5a8c">1</loigeNr>
								<kuvatavNr id="7bbd7792-5d91-45df-8cb0-b805d429681d"><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst id="7220e71f-7752-4cf5-a0b7-65850b955849">
									<tavatekst id="bda61bee-d3d4-4c7f-9ddf-edb520958d9b">Kommertspandi kande tegemise eest kommertspandiregistrisse tasutakse riigilõivu 0,2 protsenti pandisummast, kuid mitte alla 32 euro ja mitte üle 2560 euro.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para70lg2">
								<loigeNr id="2f27f8b0-3540-4f12-bc71-32d7a14593a8">2</loigeNr>
								<kuvatavNr id="9adeab3c-e6e5-44f8-99a4-0c5efc383420"><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst id="3152b5cc-2a6c-4da5-a7d2-870d3a6da860">
									<tavatekst>Pandisumma suurendamise registrisse kandmise eest tasutakse riigilõivu 0,2 protsenti taotletava ning registrisse kantud pandisumma vahest, kuid mitte alla 32 euro ja mitte üle 2560 euro.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para70lg3">
								<loigeNr id="40ecd117-509f-4a75-96c0-5d0883d491e5">3</loigeNr>
								<kuvatavNr id="c8176e8b-a53e-4ffb-9f61-7e903f11b98d"><![CDATA[(3)]]></kuvatavNr>
								<sisuTekst id="2c9f10f4-7e18-4368-8e45-09b9a3e8f3e2">
									<tavatekst id="85a80bc1-1af4-45f7-84f6-4a45432a1a3a">Pandisumma vähendamise registrisse kandmise eest tasutakse riigilõivu 0,2 protsenti taotletavast pandisummast, kuid mitte alla 32 euro ja mitte üle 2560 euro.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para70lg4">
								<loigeNr id="a72f1e0a-a233-4dad-8cb2-b15c0895cbd7">4</loigeNr>
								<kuvatavNr id="85bd997f-8f01-4b8e-a856-a06035b4b369"><![CDATA[(4)]]></kuvatavNr>
								<sisuTekst id="925d4993-d0a7-4585-a109-d4c328c98efa">
									<tavatekst id="0176c4de-f0dc-48c9-898a-ed74d787f475">Kommertspandi kustutamise eest tasutakse riigilõivu 10 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2021-12-08</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>108122021001</aktViide>
									</avaldamismarge>
									<joustumine>2022-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para70lg5">
								<loigeNr id="4731885c-8b8a-4b27-97c7-ecc332b164c1">5</loigeNr>
								<kuvatavNr id="0a4e9702-0ebf-4787-adfc-0bc1d4051769"><![CDATA[(5)]]></kuvatavNr>
								<sisuTekst id="797b4581-2fae-4e75-a6b4-045a35a3a03b">
									<tavatekst id="2461e841-54a0-4aa1-8ef0-ad624be005d4">Muude kommertspandi andmete muutmise või täiendamise eest tasutakse riigilõivu 32 eurot.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para70lg6">
								<loigeNr id="eb01e996-85f2-4d36-853b-27d843d3db8d">6</loigeNr>
								<kuvatavNr id="2f217eaa-a4e3-43a1-82d3-50b591e8118c"><![CDATA[(6)]]></kuvatavNr>
								<sisuTekst id="f4c0e958-f64a-4a3e-8b4b-876eab54bacf">
									<tavatekst id="17461036-fbe4-41c0-9619-16a9b67296fd">Üheaegselt mitmesse registrikaardi veergu kande tegemise eest tasutakse riigilõivu lähtuvalt kandest, mille tegemise eest on ette nähtud kõrgeim riigilõivumäär.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para70lg7">
								<loigeNr id="a1f063fb-ec4f-4cbf-9262-213bf57ba547">7</loigeNr>
								<kuvatavNr id="d207f493-7e53-406a-ac85-fd18faaca1b2"><![CDATA[(7)]]></kuvatavNr>
								<sisuTekst id="386f06d4-355e-4d88-9114-e4d8bd49f6f3">
									<tavatekst id="ea741c1d-ce95-4ef7-8f39-db0c354481b0">Üheaegselt mitme kommertspandi registriandmete muutmise, täiendamise või kustutamise eest tasutakse riigilõivu iga kande eest.</tavatekst>
								</sisuTekst>
							</loige>
						</paragrahv>
						<paragrahv id="para71">
							<paragrahvNr id="60cd11bb-2e22-4465-ab3f-dd7493797d35">71</paragrahvNr>
							<kuvatavNr id="f653f5a1-12be-48b2-a710-f341a5859d58"><![CDATA[§ 71. ]]></kuvatavNr>
							<paragrahvPealkiri id="1ab79220-1b9e-4f78-9ac4-de433333b026">Registri dokumendi väljastamine</paragrahvPealkiri>
							<muutmismarge id="2cabb5b5-7133-4048-8b6f-dcb63baddfcd">
								<tavatekst id="29beca96-7c6f-43d9-9cc6-17340a2ba391">Kehtetu - </tavatekst>
								<avaldamismarge id="50843cf2-1d02-4b14-baa7-f31341837aff">
									<RTosa id="a02ed4af-89a5-4133-a902-64a4374ea702">RT I</RTosa>
									<avaldamineKuupaev id="cd6d45d5-8842-410a-ac40-7a1b1dd7981b">2017-05-09</avaldamineKuupaev>
									<RTartikkel id="14e69b9b-89b9-4eaa-9b06-4a7b949e4782">1</RTartikkel>
									<aktViide id="c9028b2a-7922-4387-a5c1-6251fd99ca1d">109052017001</aktViide>
								</avaldamismarge>
								<joustumine id="288065b6-0293-412c-9f31-87d76f8052b6">2017-07-01</joustumine>
							</muutmismarge>
						</paragrahv>
					</jaotis>
					<jaotis id="jaotis7">
						<jaotisNr>4</jaotisNr>
						<kuvatavNr><![CDATA[4. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Laevakinnistusraamatu toimingud</jaotisPealkiri>
						<paragrahv id="para72">
							<paragrahvNr id="91fdec41-ff24-4f0a-aed1-de322e8c2712">72</paragrahvNr>
							<kuvatavNr id="e19cb570-bf8e-4ce5-93c1-15e4ab995feb"><![CDATA[§ 72. ]]></kuvatavNr>
							<paragrahvPealkiri id="e09b4fe1-4e00-4edc-9726-a541f7b6a80d">Laevakinnistusraamatu kande ja märke tegemine</paragrahvPealkiri>
							<loige id="para72lg1">
								<loigeNr id="b207b1f7-5eb4-414b-bfd2-6756c8fdb909">1</loigeNr>
								<kuvatavNr id="30dde3cd-9425-4ceb-be0f-ac86f4a6519d"><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst id="8a61d79e-7b08-4b4d-bdaa-dcb5afa4d9a4">
									<tavatekst id="ac5b9b49-a956-4aa8-a815-c9035cd4cb7a">Esmakordse laevakinnistusraamatusse kandmise eest koos merelaevatunnistuse või siseveelaevatunnistuse väljastamisega tasutakse riigilõivu:</tavatekst>
								</sisuTekst>
								<alampunkt id="para72lg1p1">
									<alampunktNr id="1300d211-62e9-49c7-8a96-a4436341571d">1</alampunktNr>
									<kuvatavNr id="e732ed0d-0696-4a64-9cbb-21126439e22a"><![CDATA[1) ]]></kuvatavNr>
									<sisuTekst id="91e586a9-0c84-4d88-ad19-33271bfb831d">
										<tavatekst id="1044bc2a-4e9e-4a27-a915-086cb66e6489">merelaeva ja teisaldatava ujuvvahendi puhul 130 eurot;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para72lg1p2">
									<alampunktNr id="451af1d5-b49e-4124-bcd4-061e3eea3912">2</alampunktNr>
									<kuvatavNr id="8d5bdb09-44a6-4971-8f92-ff620eebd105"><![CDATA[2) ]]></kuvatavNr>
									<sisuTekst id="0f5e1520-642e-40aa-978f-16d8bab38ba8">
										<tavatekst id="85462649-0538-44e6-8796-2fb8931da829">siseveelaeva puhul 32 eurot.</tavatekst>
									</sisuTekst>
								</alampunkt>
							</loige>
							<loige id="para72lg2">
								<loigeNr id="ead635e4-0216-4d0b-8475-884accee50df">2</loigeNr>
								<kuvatavNr id="19173f17-bb49-4471-a20f-e2e0cbb16370"><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst id="5737d17a-526a-4dda-adfb-45a23e2bca34">
									<tavatekst id="77788155-19f1-48a3-92ae-6caad3f00e3b">Uue omaniku või kaasomaniku laevakinnistusraamatusse kandmise eest tasutakse riigilõivu:</tavatekst>
								</sisuTekst>
								<alampunkt id="para72lg2p1">
									<alampunktNr id="d60c6e14-ed56-436a-89af-f120bcfce079">1</alampunktNr>
									<kuvatavNr id="f9a7e4a0-bed0-4fb7-b3cd-4af5f5b96942"><![CDATA[1) ]]></kuvatavNr>
									<sisuTekst id="2e53f7b1-8f63-45a5-85dc-f5830a02fe5d">
										<tavatekst id="cbb29c2b-abe7-4438-b680-a6d40d5de36e">merelaeva ja teisaldatava ujuvvahendi puhul 130 eurot;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para72lg2p2">
									<alampunktNr id="535cae57-cf28-4ad3-9433-17a921c338f6">2</alampunktNr>
									<kuvatavNr id="61593030-4986-40f4-85a8-2a589b3ddb73"><![CDATA[2) ]]></kuvatavNr>
									<sisuTekst id="21c27017-844a-4383-9e48-4f2b86e1bbec">
										<tavatekst id="22b630dc-08ea-4d8d-9559-9f4208099b90">siseveelaeva puhul 32 eurot.</tavatekst>
									</sisuTekst>
								</alampunkt>
							</loige>
							<loige id="para72lg3">
								<loigeNr id="57ad0bff-95cb-4cdd-99ec-3165b997e398">3</loigeNr>
								<kuvatavNr id="0e39e586-088c-4deb-a593-15390ee7ecb0"><![CDATA[(3)]]></kuvatavNr>
								<sisuTekst id="7bfcba62-1a29-4a74-9ddd-507461f2bd78">
									<tavatekst id="b4779d1f-dac5-4767-9ad5-82e43aefc6b2">Laeva identifitseerivate tunnuste, tehniliste ja päritoluandmete muutmise kannete ning lipuõiguslike märgete tegemise eest tasutakse riigilõivu 16 eurot.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para72lg4">
								<loigeNr id="9da30b05-6dfc-4646-847b-d0f8468d55d4">4</loigeNr>
								<kuvatavNr id="f9173c38-9997-4b06-96b1-cd8955757f88"><![CDATA[(4)]]></kuvatavNr>
								<sisuTekst id="9bf50ca2-b4be-4269-a626-3f1432ed00f5">
									<tavatekst id="18ad4c3e-afa1-49ee-b64e-18f7e292c1a8">Hüpoteegi seadmise kande tegemise eest tasutakse riigilõivu:</tavatekst>
								</sisuTekst>
								<alampunkt id="para72lg4p1">
									<alampunktNr id="335c3bcd-8970-4654-a879-f734c3e213e2">1</alampunktNr>
									<kuvatavNr id="741ab90b-239e-40d1-9540-f3e45a2cbed0"><![CDATA[1) ]]></kuvatavNr>
									<sisuTekst id="3064466c-303a-469e-951a-d4926cdf997a">
										<tavatekst id="4e2a5bae-df3f-45c0-b6e2-57b6a97b8dea">merelaeva ja teisaldatava ujuvvahendi puhul 130 eurot;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para72lg4p2">
									<alampunktNr id="10831e4e-ba51-4beb-bc75-9af602fdcfa1">2</alampunktNr>
									<kuvatavNr id="8a6bf048-3ccc-4d03-a971-0933e151af0f"><![CDATA[2) ]]></kuvatavNr>
									<sisuTekst id="d1910321-be79-482b-90b6-7b8b69aa286d">
										<tavatekst id="c947d55b-ca22-439c-9774-89b4caceb4b1">siseveelaeva puhul 32 eurot.</tavatekst>
									</sisuTekst>
								</alampunkt>
							</loige>
							<loige id="para72lg5">
								<loigeNr id="e777b128-36d1-43d6-960e-33394d93832c">5</loigeNr>
								<kuvatavNr id="b8150c7c-91d4-4db4-b8ce-d3079d5d6991"><![CDATA[(5)]]></kuvatavNr>
								<sisuTekst id="57ef4d1e-76ac-4999-a198-a62048e1ff37">
									<tavatekst id="c6586b6d-02c0-4175-8969-eadd6c34d8e9">Ühishüpoteegi seadmise eest üheaegselt siseveelaevale ja merelaevale või teisaldatavale ujuvvahendile tasutakse riigilõivu 130 eurot.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para72lg6">
								<loigeNr id="1cce74c8-a5ba-4586-88f6-1621edc95790">6</loigeNr>
								<kuvatavNr id="bf4d8b3e-6402-493a-a603-98ede85df85b"><![CDATA[(6)]]></kuvatavNr>
								<sisuTekst id="4cefb923-86c2-4ab4-a25f-63a52dc23337">
									<tavatekst id="9ef39e97-319a-4f07-8257-fd125a558e2f">Ühishüpoteegi seadmist käsitatakse riigilõivu tasumisel ühe kandena.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para72lg7">
								<loigeNr id="96ad031e-141e-48af-9392-9c9f792b04d2">7</loigeNr>
								<kuvatavNr id="e6d4558b-cd15-4ad9-a064-6f43fcd782c4"><![CDATA[(7)]]></kuvatavNr>
								<sisuTekst id="7413aa5f-1f08-4b4a-ad5e-285dbb5ae6b2">
									<tavatekst id="afbf4e26-5142-4359-9639-359b4a85bc84">Kasutusvalduse seadmise kande eest tasutakse riigilõivu:</tavatekst>
								</sisuTekst>
								<alampunkt id="para72lg7p1">
									<alampunktNr id="8a40fc5a-a2bc-45ae-be3e-67ebf20f1456">1</alampunktNr>
									<kuvatavNr id="19b44591-8e75-44f6-9b36-0b6afd1a1301"><![CDATA[1) ]]></kuvatavNr>
									<sisuTekst id="c3b90085-5b7a-4df2-9ce0-c61de0d99c2f">
										<tavatekst id="d2975d9d-5f57-4445-b05e-9e46b8ceb421">merelaeva ja teisaldatava ujuvvahendi puhul 130 eurot;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para72lg7p2">
									<alampunktNr id="c2580d90-ae2e-42f5-aa65-bfd44b71bd3c">2</alampunktNr>
									<kuvatavNr id="e5856888-7b97-4a40-8873-c2d9e3353fb5"><![CDATA[2) ]]></kuvatavNr>
									<sisuTekst id="baa5f73f-be46-430c-98bb-57534c10eed7">
										<tavatekst id="c03c2181-28fe-4f79-8d2c-7703c096235d">siseveelaeva puhul 32 eurot.</tavatekst>
									</sisuTekst>
								</alampunkt>
							</loige>
							<loige id="para72lg8">
								<loigeNr id="58ad7b97-0f1c-448a-bfa7-cf347322752d">8</loigeNr>
								<kuvatavNr id="b6238be5-aca2-4e95-beda-50dfc5c45762"><![CDATA[(8)]]></kuvatavNr>
								<sisuTekst id="11708fad-dae3-4476-a28e-46580adb46fc">
									<tavatekst id="1137c345-23f4-4905-aa35-8b9e59304263">Hüpoteegi ja kasutusvalduse kannete muutmise ja kustutamise eest ning hüpoteegi ja kasutusvaldusega seotud märgete tegemise ja muutmise eest tasutakse riigilõivu:</tavatekst>
								</sisuTekst>
								<alampunkt id="para72lg8p1">
									<alampunktNr id="748aaa60-b803-4ed8-a238-708f148546e9">1</alampunktNr>
									<kuvatavNr id="457a96cb-2f49-4ab6-a49d-5445ecf1aaba"><![CDATA[1) ]]></kuvatavNr>
									<sisuTekst id="29f41a56-6d28-4cbe-8cda-bec0841a11ba">
										<tavatekst id="3e85b002-89ab-4cd6-bb01-b42229329ede">merelaeva ja teisaldatava ujuvvahendi puhul 64 eurot;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para72lg8p2">
									<alampunktNr id="d947ab7d-8856-4c6b-959b-41c793000567">2</alampunktNr>
									<kuvatavNr id="8d74ccd1-6972-4f8e-8535-8348fb206a8d"><![CDATA[2) ]]></kuvatavNr>
									<sisuTekst id="5d831425-f5e9-4297-86b2-b4257fbde6a0">
										<tavatekst id="9c29d6a5-0c0f-4643-b557-6bba0e68857c">siseveelaeva puhul 16 eurot.</tavatekst>
									</sisuTekst>
								</alampunkt>
							</loige>
							<loige id="para72lg9">
								<loigeNr id="3bd034c2-7215-4366-a2c1-8cc202e3836b">9</loigeNr>
								<kuvatavNr id="89a56987-9259-4de4-b0c2-d0ed2054231b"><![CDATA[(9)]]></kuvatavNr>
								<sisuTekst id="40e3caf4-70da-48bf-a592-5c4abf960ead">
									<tavatekst id="c81a53af-b175-4a54-9d98-ab7ddd660176">Üheaegselt siseveelaevale ja merelaevale või teisaldatavale ujuvvahendile seatud ühishüpoteegi muutmise või kustutamise ning ühishüpoteegiga seotud märgete muutmise või kustutamise eest tasutakse riigilõivu 64 eurot.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para72lg10">
								<loigeNr id="5d99081d-04b5-42d7-a187-af580e785bb4">10</loigeNr>
								<kuvatavNr id="c46bb5c9-ac55-4c29-8203-c8983be22194"><![CDATA[(10)]]></kuvatavNr>
								<sisuTekst id="226af594-36d6-4043-83b0-f3b1cc878613">
									<tavatekst>Ühishüpoteegi kannete muutmist või kustutamist või ühishüpoteegiga seotud märgete tegemist või muutmist käsitatakse riigilõivu tasumisel ühe kandena.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para72lg11">
								<loigeNr id="9e607703-2537-44b8-b77c-9b52bf1eff6c">11</loigeNr>
								<kuvatavNr id="de21d802-0391-4138-8d24-a0bf9fa2d75e"><![CDATA[(11)]]></kuvatavNr>
								<sisuTekst id="46b45d75-dd88-461e-9a12-3ac1d3a3de96">
									<tavatekst id="dee2c76f-9454-49d1-b689-c9ed71d504eb">Muude kannete ja märgete tegemise eest tasutakse riigilõivu 16 eurot.</tavatekst>
								</sisuTekst>
							</loige>
						</paragrahv>
						<paragrahv id="para73">
							<paragrahvNr id="76a5e2f7-aafd-4604-bdd1-b7cefc2c7409">73</paragrahvNr>
							<kuvatavNr id="a7d5c532-290c-45d7-9c8a-076593572e19"><![CDATA[§ 73. ]]></kuvatavNr>
							<paragrahvPealkiri id="def4add0-e2ed-400f-af79-57f35d8f2d86">Laevakinnistusraamatu dokumendi väljastamine</paragrahvPealkiri>
							<muutmismarge id="67225567-0df2-448d-b427-6fc13de90465">
								<tavatekst id="027b2bbe-6163-48a4-b1c2-5c4eb47ebfb1">Kehtetu - </tavatekst>
								<avaldamismarge id="7bc33da6-b24a-42f6-93b7-0e69c837e359">
									<RTosa id="2d36599d-221e-4c5f-8c63-c893e7f616b1">RT I</RTosa>
									<avaldamineKuupaev id="0a7bcf47-b5f3-4490-ab6c-690015c1d659">2019-03-04</avaldamineKuupaev>
									<RTartikkel id="5c6774c8-be78-4499-ae30-a3f92a3af178">1</RTartikkel>
									<aktViide id="53f0c776-c6ef-4b7c-a7d3-a065dac51a16">104032019001</aktViide>
								</avaldamismarge>
								<joustumine id="c8fdbae6-aa8c-4bdc-ab4c-32cd76b2b190">2020-07-01</joustumine>
								<tavatekst id="3b6d81f8-c275-4c58-859f-55d4222203ae">, jõustumisaeg muudetud [RT I, 28.02.2020, 2]</tavatekst>
							</muutmismarge>
						</paragrahv>
					</jaotis>
					<jaotis id="jaotis8">
						<jaotisNr>5</jaotisNr>
						<kuvatavNr><![CDATA[5. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Kinnistusraamatu toimingud</jaotisPealkiri>
						<paragrahv id="para74">
							<paragrahvNr>74</paragrahvNr>
							<kuvatavNr><![CDATA[§ 74. ]]></kuvatavNr>
							<paragrahvPealkiri>Riigilõivu suuruse määramine</paragrahvPealkiri>
							<loige id="para74lg1">
								<sisuTekst>
									<tavatekst>Kinnistusraamatu toimingute eest tasutava riigilõivu suurus määratakse lähtuvalt tehinguväärtusest käesoleva seaduse lisa 2 järgi või kindla summana.</tavatekst>
								</sisuTekst>
							</loige>
						</paragrahv>
						<paragrahv id="para75">
							<paragrahvNr>75</paragrahvNr>
							<kuvatavNr><![CDATA[§ 75. ]]></kuvatavNr>
							<paragrahvPealkiri>Kinnistusregistriosa avamine</paragrahvPealkiri>
							<loige id="para75lg1">
								<sisuTekst>
									<tavatekst>Kinnistusregistriosa avamise eest tasutakse riigilõivu täismäär.</tavatekst>
								</sisuTekst>
							</loige>
						</paragrahv>
						<paragrahv id="para76">
							<paragrahvNr>76</paragrahvNr>
							<kuvatavNr><![CDATA[§ 76. ]]></kuvatavNr>
							<paragrahvPealkiri>Omaniku kohta kande tegemine</paragrahvPealkiri>
							<loige id="para76lg1">
								<loigeNr>1</loigeNr>
								<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Kinnistu uue omaniku kohta kande tegemise eest tasutakse riigilõivu täismäär, välja arvatud käesoleva paragrahvi lõigetes 2 ja 3 sätestatud juhul.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para76lg2">
								<loigeNr>2</loigeNr>
								<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Kui kinnistu omandajaks on kinnistusraamatusse kantud omaniku alaneja või üleneja sugulane, abikaasa või registreeritud elukaaslane, tasutakse kinnistu uue omaniku kohta kande tegemise eest riigilõivu 50 protsenti täismäärast.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-07-06</avaldamineKuupaev>
										<RTartikkel>6</RTartikkel>
										<aktViide>106072023006</aktViide>
									</avaldamismarge>
									<joustumine>2024-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para76lg3">
								<loigeNr>3</loigeNr>
								<kuvatavNr><![CDATA[(3)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Kui kinnistu omandajaks on kinnistusraamatusse kantud omaniku õde või vend või nende alaneja sugulane, tasutakse kinnistu uue omaniku kohta kande tegemise eest riigilõivu 75 protsenti täismäärast.</tavatekst>
								</sisuTekst>
							</loige>
						</paragrahv>
						<paragrahv id="para77">
							<paragrahvNr>77</paragrahvNr>
							<kuvatavNr><![CDATA[§ 77. ]]></kuvatavNr>
							<paragrahvPealkiri>Piiratud asjaõiguse kohta kande tegemine</paragrahvPealkiri>
							<loige id="para77lg1">
								<loigeNr>1</loigeNr>
								<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Piiratud asjaõiguse kohta kande tegemise eest tasutakse riigilõivu täismäär.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para77lg2">
								<loigeNr id="af1b8358-36ca-4710-b49f-1b456957de88">2</loigeNr>
								<kuvatavNr id="9d05e77c-c08a-40e1-bc4a-ba5fd31e8d7a"><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst id="dadb3ec9-fa12-4447-845d-ed485e2ff103">
									<tavatekst id="81acce2b-ee5c-4d1b-8184-628e754dc2ea">Piiratud asjaõiguse kohta kande tegemise eest koos registriosa avamise või omandi ülekandmise kandega tasutakse riigilõivu 50 protsenti täismäärast.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para77lg3">
								<loigeNr id="eda58c0a-b12b-40d5-9495-90ea0f19508d">3</loigeNr>
								<kuvatavNr id="401cf383-cd3c-4d55-9595-f1a4f9152329"><![CDATA[(3)]]></kuvatavNr>
								<sisuTekst id="828575b1-a640-4792-a7ac-23f240ee8cdc">
									<tavatekst id="88f46de2-eb50-4712-bc17-8f70b67b7a03">Piiratud asjaõiguse uue omaniku kohta kande tegemise eest tasutakse riigilõivu 50 protsenti täismäärast.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para77lg3b1">
								<loigeNr ylaIndeks="1">3</loigeNr>
								<kuvatavNr><![CDATA[(3<sup>1</sup>)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Piiratud asjaõiguse uue omaniku kande tegemise eest pandikirjade tagatisvara moodustamiseks loovutatud nõude tagatise üleandmisel tasutakse riigilõivu 18 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2021-11-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130112021001</aktViide>
									</avaldamismarge>
									<joustumine>2021-12-10</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para77lg4">
								<loigeNr id="b43ffeae-9c82-4735-af4f-eedc7a64dedd">4</loigeNr>
								<kuvatavNr id="5da04058-c1a4-4957-a5de-2569d5de7541"><![CDATA[(4)]]></kuvatavNr>
								<sisuTekst id="0809ab31-1ee9-4247-b585-d3ad1f09cc09">
									<tavatekst id="ec6add33-b3b1-406f-9392-648f3994fa53">Kinnistusraamatusse kantud piiratud asjaõiguse sisu muutmise eest tasutakse riigilõivu 50 protsenti täismäärast.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para77lg5">
								<loigeNr id="3cef011e-f524-4742-bb07-2516d01de0f8">5</loigeNr>
								<kuvatavNr id="91f68a38-67ad-47c7-9660-0f0689177b35"><![CDATA[(5)]]></kuvatavNr>
								<sisuTekst id="965d8b36-2b70-4bbe-8fff-3a76eda92541">
									<tavatekst id="9b4444d5-af52-4f18-b8ac-7a3aa7961436">Kinnistusraamatusse kantud piiratud asjaõiguse kohta tehtud kande kustutamise eest tasutakse riigilõivu 25 protsenti täismäärast, välja arvatud käesoleva paragrahvi lõikes 6 sätestatud juhul.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para77lg6">
								<loigeNr id="19a3adde-7108-4319-a889-20c93ca26ae9">6</loigeNr>
								<kuvatavNr id="64e6fd7e-ce74-4c67-8c87-59fa57493816"><![CDATA[(6)]]></kuvatavNr>
								<sisuTekst id="f8ac6c84-2bec-4bc0-8dd5-daa37d10d7ee">
									<tavatekst id="8f56b857-5cab-45ba-8bdc-29854690dcf3">Ühishüpoteegi kohta tehtud kande kustutamise eest mõne kaasvastutava kinnistu registriosas ilma hüpoteegisummat muutmata tasutakse riigilõivu 7 eurot.</tavatekst>
								</sisuTekst>
							</loige>
						</paragrahv>
						<paragrahv id="para78">
							<paragrahvNr id="dd2c687e-64ef-4d59-a759-c16250c7a54e">78</paragrahvNr>
							<kuvatavNr id="aef01fb9-8ee7-47c0-a3d7-c132f3e0e6cf"><![CDATA[§ 78. ]]></kuvatavNr>
							<paragrahvPealkiri id="9f3542c5-fbbf-4256-818d-fad0811b7a1b">Märke kandmine kinnistusraamatusse</paragrahvPealkiri>
							<loige id="para78lg1">
								<loigeNr id="bf56d5c7-b293-4fb9-bf5f-04782ad66183">1</loigeNr>
								<kuvatavNr id="5ee8cfd9-8493-43f6-909d-2ee839ba1e5d"><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst id="10bf6104-804b-4d18-bd39-e9843a8f3e8a">
									<tavatekst id="fa670ccd-cd55-47aa-ba02-98ab71929c92">Kinnistusraamatusse märke kandmise eest tasutakse riigilõivu 25 protsenti täismäärast.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para78lg2">
								<loigeNr id="3b1613ff-5f52-43e5-a3f7-5d166d3a1e39">2</loigeNr>
								<kuvatavNr id="dd7c2bc8-e510-486b-a50c-b15b71b56159"><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst id="e8b8aad4-82ce-4573-8fd3-4019e5742001">
									<tavatekst id="b167d552-ab6f-4d63-878e-0e20fff3ff2b">Märke kustutamise eest, kui sellega ei kaasne märkega tagatud õiguse kandmist kinnistusraamatusse, tasutakse riigilõivu 25 protsenti täismäärast.</tavatekst>
								</sisuTekst>
							</loige>
						</paragrahv>
						<paragrahv id="para79">
							<paragrahvNr id="bab5bc88-a26b-4299-a99e-20e02745bcab">79</paragrahvNr>
							<kuvatavNr id="dba70dc4-13b1-4895-b379-cf6618b9cafb"><![CDATA[§ 79. ]]></kuvatavNr>
							<paragrahvPealkiri id="8649afe8-71f3-4377-b9f1-d585b3853ebb">Üüri- ja rendilepingu märke kandmine kinnistusraamatusse</paragrahvPealkiri>
							<loige id="para79lg1">
								<loigeNr id="1a7cbfe1-c3ca-4df6-a4f9-d8b7d3b4ec28">1</loigeNr>
								<kuvatavNr id="a3609f7c-16ef-49c4-b8d9-b8ad5935c1aa"><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst id="72d8502a-5c33-40bd-9128-88586a8c8a65">
									<tavatekst id="54ed66c3-4f43-47d9-bfb2-58af1004b7c5">Üüri- või rendilepingu märke kandmise eest kinnistusraamatusse tasutakse riigilõivu 6 eurot iga üüri- või rendilepingu kehtivusaja aasta kohta, kuid kokku mitte rohkem kui 52 eurot.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para79lg2">
								<loigeNr id="1503cc75-2a49-497f-b4a8-7097ab62d65b">2</loigeNr>
								<kuvatavNr id="082e73ce-670d-41d9-8b4d-2e544458ec17"><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst id="8c6f013e-4d6a-46c4-b85b-634b6c0bb7f3">
									<tavatekst id="bd94b553-89f7-4209-9702-afcb6839fc4c">Tähtajatu üüri- või rendilepingu märke kandmise eest kinnistusraamatusse tasutakse riigilõivu 23 eurot.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para79lg3">
								<loigeNr id="b3a08447-55bb-418c-9298-db1b0db3d4eb">3</loigeNr>
								<kuvatavNr id="69b48fea-aa11-4e4d-a4af-937e874267e1"><![CDATA[(3)]]></kuvatavNr>
								<sisuTekst id="563b399c-e6c5-4b28-91fa-a262812e0c0f">
									<tavatekst id="1c997924-582a-4108-9bbf-8f2f96eed96b">Kinnistusraamatusse kantud üüri- või rendilepingu tähtaja pikendamisel tasutakse pikendamise kande tegemise eest riigilõivu 6 eurot üüri- või rendilepingu täiendava kehtivusaja iga aasta kohta, kuid lepingu kogu kehtivusaja eest kokku mitte rohkem kui 52 eurot.</tavatekst>
								</sisuTekst>
							</loige>
						</paragrahv>
						<paragrahv id="para80">
							<paragrahvNr id="d41712f6-5fc4-4ede-9847-e8b1853dd49b">80</paragrahvNr>
							<kuvatavNr id="18bc1da8-8cff-4f11-b21d-5b931ccf12be"><![CDATA[§ 80. ]]></kuvatavNr>
							<paragrahvPealkiri id="c95f73df-5fe2-4c7a-b675-b6b26452732d">Kinnistu osa liitmine teise kinnistuga, kinnistute jagamine ja ühendamine</paragrahvPealkiri>
							<loige id="para80lg1">
								<loigeNr id="89663041-a9f6-4f5b-a71e-f08673adb211">1</loigeNr>
								<kuvatavNr id="387daa45-bfd6-4725-ba52-b0b09aff8d67"><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst id="616a62dc-938e-485c-8a69-0e20e0ce7290">
									<tavatekst id="aa8d775c-58ea-413d-817c-f45354ca281f">Kinnistu jagamise, kinnistute ühendamise või kinnistu osa teise kinnistuga liitmise kande eest tasutakse riigilõivu 25 protsenti täismäärast.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para80lg2">
								<loigeNr id="1aeb257b-60a1-4de9-8676-3f8f004599fe">2</loigeNr>
								<kuvatavNr id="9a502167-c836-4d92-9291-38d0a3f52b0e"><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst id="163d3013-3d84-417f-9c63-b00fb137cf12">
									<tavatekst id="e657ee7c-0109-472f-b5e2-aa0bc307a0a7">Kui kinnistu jagamisele või kinnistute ühendamisele lisandub omandi üleminek, tasutakse riigilõivu ka uue omaniku kohta kande tegemise eest käesoleva seaduse §-s 76 sätestatud määras.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para80lg3">
								<loigeNr id="046c2f99-d4b5-46d7-8a64-f7f177d6d868">3</loigeNr>
								<kuvatavNr id="bb64dbc8-952b-4de9-a203-3301720bf59f"><![CDATA[(3)]]></kuvatavNr>
								<sisuTekst id="6c3b824f-b3f1-40b9-bb5f-c6c9881f91aa">
									<tavatekst id="e6786cc4-b962-43dc-b137-a092d4f4c07d">Kinnistu jagamisel tasutakse riigilõivu lisaks käesoleva paragrahvi lõikes 1 sätestatud määrale 7 eurot iga jagamisega kaasneva uue registriosa avamise eest alates kolmandast uuest registriosast.</tavatekst>
								</sisuTekst>
							</loige>
						</paragrahv>
						<paragrahv id="para81">
							<paragrahvNr id="8933f2ac-4300-493a-828f-51bfe0fbe500">81</paragrahvNr>
							<kuvatavNr id="ab1361a8-d83d-463a-b1de-819df71499f2"><![CDATA[§ 81. ]]></kuvatavNr>
							<paragrahvPealkiri id="c5ef8c39-38d5-49a5-b6a8-707d033d6249">Muu sissekande tegemine</paragrahvPealkiri>
							<loige id="para81lg1">
								<sisuTekst id="0d2dd02e-1fd2-4062-a496-250e855b9863">
									<tavatekst id="dfd401b6-b56a-49a4-9955-acffbbb07866">Muu sissekande tegemise eest kinnistusraamatusse tasutakse riigilõivu 25 protsenti täismäärast.</tavatekst>
								</sisuTekst>
							</loige>
						</paragrahv>
						<paragrahv id="para82">
							<paragrahvNr id="9f853573-72ef-47c4-81fd-8a24eb7b713b">82</paragrahvNr>
							<kuvatavNr id="85e731c6-b12d-4030-a266-6d88ef0bb4fb"><![CDATA[§ 82. ]]></kuvatavNr>
							<paragrahvPealkiri id="cfd2bcce-d056-41ca-a594-94ed453cee9e">Kinnistusraamatu dokumendi väljastamine</paragrahvPealkiri>
							<muutmismarge id="889fc6f7-b6dc-4544-9f80-d232eab7f417">
								<tavatekst id="7661c23e-6ead-4c71-a86a-84d5895c25ae">Kehtetu - </tavatekst>
								<avaldamismarge id="0ab5ed02-0e5b-4a58-b409-664969e174a6">
									<RTosa id="f8ae16b0-8404-4753-8d9e-0baa6c77abeb">RT I</RTosa>
									<avaldamineKuupaev id="cd783a8f-4496-41af-872a-6c4ae001eedf">2017-05-09</avaldamineKuupaev>
									<RTartikkel id="f3b90d99-5472-49bd-8cf9-dcee5d4cb86d">1</RTartikkel>
									<aktViide id="73efd1f8-e4db-44b8-8e38-0acdfe711e37">109052017001</aktViide>
								</avaldamismarge>
								<joustumine id="d83e4c2d-567a-4f19-91f7-db26ae243a9d">2017-07-01</joustumine>
							</muutmismarge>
						</paragrahv>
					</jaotis>
					<jaotis id="jaotis9">
						<jaotisNr>6</jaotisNr>
						<kuvatavNr><![CDATA[6. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Abieluvararegistri toimingud</jaotisPealkiri>
						<paragrahv id="para83">
							<paragrahvNr id="c864c903-3c40-4edb-a516-ff2dc20bf0b9">83</paragrahvNr>
							<kuvatavNr id="061a68ba-0c77-45eb-8340-f5d35676b378"><![CDATA[§ 83. ]]></kuvatavNr>
							<paragrahvPealkiri id="7cfb73a7-5dae-4058-be1b-a0526e1616a2">Abieluvararegistri kande tegemine</paragrahvPealkiri>
							<muutmismarge id="9a8a3b87-967a-4bf8-b056-eec065a2f1fc">
								<tavatekst id="c7340a5d-1bcb-4be6-b531-d2301dbd52c4">Kehtetu - </tavatekst>
								<avaldamismarge id="f7b1a5b5-1570-4c35-852a-a8227d75f642">
									<RTosa id="8c1b0533-12cc-45ca-a83a-fc8a1ac879ea">RT I</RTosa>
									<avaldamineKuupaev id="d62722c6-7f3f-4fe2-ae26-0e2ca3c67484">2016-12-21</avaldamineKuupaev>
									<RTartikkel id="95bbd348-b9be-48d1-934b-15af1e585ee8">1</RTartikkel>
									<aktViide id="676f94b3-aab2-4449-8c12-cf7803a6fbb6">121122016001</aktViide>
								</avaldamismarge>
								<joustumine id="26552b9b-d28a-4f74-9e42-f97d27be8535">2018-03-01</joustumine>
							</muutmismarge>
						</paragrahv>
						<paragrahv id="para84">
							<paragrahvNr id="cefc84c6-cb8e-4004-aaab-9477ce729262">84</paragrahvNr>
							<kuvatavNr id="1fd2e49b-239e-43c2-ad0a-992fc8496de8"><![CDATA[§ 84. ]]></kuvatavNr>
							<paragrahvPealkiri id="041aabea-e46a-4ce8-8924-289a2f55c74e">Abieluvararegistri dokumendi väljastamine</paragrahvPealkiri>
							<muutmismarge id="c86806de-9173-4094-98db-c144e088c26e">
								<tavatekst id="18746b6b-a61b-4c7e-b3d6-fd159da5879f">Kehtetu - </tavatekst>
								<avaldamismarge id="b760cb9c-e0b4-41fa-9769-5383e35f573f">
									<RTosa id="2bec1b1e-92ef-4364-8f77-0b49a6e989f0">RT I</RTosa>
									<avaldamineKuupaev id="50abff8b-2c52-4526-a37a-b8cf87046dac">2017-05-09</avaldamineKuupaev>
									<RTartikkel id="c7e8f030-3ebe-43b3-8bef-6ffef70c78bd">1</RTartikkel>
									<aktViide id="c20d8403-ff0b-420e-81ba-a8135cb96c72">109052017001</aktViide>
								</avaldamismarge>
