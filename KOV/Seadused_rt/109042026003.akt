						<paragrahv id="para287">
							<paragrahvNr>287</paragrahvNr>
							<kuvatavNr><![CDATA[§ 287. ]]></kuvatavNr>
							<paragrahvPealkiri>Perearsti nimistu alusel perearstiabi, kiirabi, eriarstiabi, iseseisvalt õendusabi ja iseseisvalt ämmaemandusabi osutamise tegevusloa taotluse läbivaatamine</paragrahvPealkiri>
							<muutmismarge>
								<avaldamismarge>
									<RTosa>RT I</RTosa>
									<avaldamineKuupaev>2024-06-21</avaldamineKuupaev>
									<RTartikkel>2</RTartikkel>
									<aktViide>121062024002</aktViide>
								</avaldamismarge>
								<joustumine>2024-07-01</joustumine>
							</muutmismarge>
							<loige id="para287lg1">
								<loigeNr>1</loigeNr>
								<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Perearsti nimistu alusel perearstiabi, kiirabi, eriarstiabi, iseseisvalt õendusabi ja iseseisvalt ämmaemandusabi osutamise tegevusloa taotluse läbivaatamise eest tasutakse riigilõivu:</tavatekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2024-06-21</avaldamineKuupaev>
											<RTartikkel>2</RTartikkel>
											<aktViide>121062024002</aktViide>
										</avaldamismarge>
										<joustumine>2024-07-01</joustumine>
									</muutmismarge>
								</sisuTekst>
								<alampunkt id="para287lg1p1">
									<alampunktNr>1</alampunktNr>
									<kuvatavNr><![CDATA[1) ]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>perearsti nimistu alusel perearstiabi osutamise tegevusloa puhul 290 eurot iga tegevuskoha kohta;</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2024-12-20</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>120122024001</aktViide>
										</avaldamismarge>
										<joustumine>2025-01-01</joustumine>
									</muutmismarge>
								</alampunkt>
								<alampunkt id="para287lg1p2">
									<alampunktNr>2</alampunktNr>
									<kuvatavNr><![CDATA[2) ]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>kiirabi osutamise tegevusloa puhul 290 eurot iga teeninduspiirkonna kohta;</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2024-12-20</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>120122024001</aktViide>
										</avaldamismarge>
										<joustumine>2025-01-01</joustumine>
									</muutmismarge>
								</alampunkt>
								<alampunkt id="para287lg1p3">
									<alampunktNr>3</alampunktNr>
									<kuvatavNr><![CDATA[3) ]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>haiglavälise eriarstiabi osutamise tegevusloa puhul 290 eurot iga tegevuskoha kohta;</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2024-12-20</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>120122024001</aktViide>
										</avaldamismarge>
										<joustumine>2025-01-01</joustumine>
									</muutmismarge>
								</alampunkt>
								<alampunkt id="para287lg1p4">
									<alampunktNr>4</alampunktNr>
									<kuvatavNr><![CDATA[4) ]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>iseseisvalt õendusabi osutamise tegevusloa, välja arvatud iseseisvalt statsionaarse õendusabi osutamise tegevusloa puhul 170 eurot iga tegevuskoha kohta;</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2024-12-20</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>120122024001</aktViide>
										</avaldamismarge>
										<joustumine>2025-01-01</joustumine>
									</muutmismarge>
								</alampunkt>
								<alampunkt id="para287lg1p5">
									<alampunktNr>5</alampunktNr>
									<kuvatavNr><![CDATA[5) ]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>iseseisvalt ämmaemandusabi osutamise tegevusloa puhul 290 eurot iga tegevuskoha kohta.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2024-12-20</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>120122024001</aktViide>
										</avaldamismarge>
										<joustumine>2025-01-01</joustumine>
									</muutmismarge>
								</alampunkt>
							</loige>
