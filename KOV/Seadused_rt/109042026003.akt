					<paragrahv id="para95">
						<paragrahvNr id="3054ce53-8377-4be0-b8d5-0fb08dbefc0c">95</paragrahvNr>
						<kuvatavNr id="09102b03-7450-4ea2-9b97-9d727c504a0f"><![CDATA[§ 95. ]]></kuvatavNr>
						<paragrahvPealkiri id="ba694f1f-78e6-4fae-88ea-35e8a2bd919b">Taotluse puuduste kõrvaldamise ja selgituste andmise tähtaja pikendamine</paragrahvPealkiri>
