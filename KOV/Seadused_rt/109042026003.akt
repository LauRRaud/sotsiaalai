					<jaotis id="jaotis132">
						<jaotisNr>1</jaotisNr>
						<kuvatavNr><![CDATA[1. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Perekonnaseisutoimingute seaduse alusel tehtavad toimingud</jaotisPealkiri>
						<paragrahv id="para338">
							<paragrahvNr id="86b09b34-ce5e-46eb-aa2b-b7f8e67c71fe">338</paragrahvNr>
							<kuvatavNr id="ba96d08a-dc56-4201-8daf-af5e0238e511"><![CDATA[§ 338. ]]></kuvatavNr>
							<paragrahvPealkiri id="8d16abfd-3563-40f6-89b7-33020199152c">Abielukande tegemine</paragrahvPealkiri>
							<loige id="para338lg1">
								<sisuTekst id="f70539a8-e30d-419b-a8b8-9a9608c2e2b5">
									<tavatekst id="831d37e1-351c-4638-8cd1-adaefe69e91e">Abielukande tegemise eest tasutakse riigilõivu 70 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-06-29</avaldamineKuupaev>
										<RTartikkel>3</RTartikkel>
