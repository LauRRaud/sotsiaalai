					</paragrahv>
					<paragrahv id="para334">
						<paragrahvNr id="cf178e1f-b209-42dd-a4fa-730dfeb2dcca">334</paragrahvNr>
						<kuvatavNr id="2a670a22-3394-4b2b-b0b7-a8992bfb259c"><![CDATA[§ 334. ]]></kuvatavNr>
						<paragrahvPealkiri id="ea7cd1ab-1c82-45ff-86e8-9a5338115649">Teenindajakaardi taotluse läbivaatamine</paragrahvPealkiri>
						<muutmismarge id="6a026d60-b728-4390-8e06-ad1af703d94c">
							<avaldamismarge id="bee6d56a-8d7e-4f22-920f-d968ebd358cd">
								<RTosa id="8f5b582a-e07f-4057-b2c0-d1fd89d77dd6">RT I</RTosa>
								<avaldamineKuupaev id="037019e2-869a-41b4-808e-eb09fd0f7864">2015-03-23</avaldamineKuupaev>
								<RTartikkel id="1de4df54-2273-4572-b7e5-05d4156cece6">2</RTartikkel>
								<aktViide id="2076d8b5-2c48-42ca-b319-448d743f0acc">123032015002</aktViide>
							</avaldamismarge>
							<joustumine id="1e293907-d33c-4500-b21a-b106858231a8">2015-10-01</joustumine>
						</muutmismarge>
						<loige id="para334lg1">
							<sisuTekst id="289f9c37-94db-458e-aada-e7bb7a110bcb">
								<tavatekst id="cdd85c95-033b-4c79-88b8-12188a029419">Teenindajakaardi taotluse läbivaatamise eest tasutakse riigilõivu 38 eurot.</tavatekst>
							</sisuTekst>
							<muutmismarge id="fc1afdda-9c05-4815-a852-9dd990695a79">
								<avaldamismarge id="0534142e-148a-47e2-b035-2235a6ca5543">
									<RTosa id="d2b4b0d3-c563-4748-b9f0-c676031de085">RT I</RTosa>
									<avaldamineKuupaev id="f0dfdef8-ac0e-4be2-8ce7-17fa1e4a9d39">2015-03-23</avaldamineKuupaev>
									<RTartikkel id="341f3561-2883-4d7b-9e88-fa673e7b7132">2</RTartikkel>
									<aktViide id="6ab491cd-5424-4599-a07b-884b009c168d">123032015002</aktViide>
