								<alampunktNr id="b2611d10-850f-4a08-a930-50321ce912f9">1</alampunktNr>
								<kuvatavNr id="af7976e6-5607-42cd-b7aa-f82ef1a1a039"><![CDATA[1) ]]></kuvatavNr>
