								<loigeNr>5</loigeNr>
								<kuvatavNr><![CDATA[(5)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Eesti kodanikust abikaasa, registreeritud elukaaslase või Eesti kodanikust lähedase sugulase juurde elama asumiseks tähtajalise elamisloa pikendamise taotluse läbivaatamise eest tasutakse riigilõivu 115 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
