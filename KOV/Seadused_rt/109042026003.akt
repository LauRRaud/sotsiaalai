									<tavatekst>Jahitunnistuse vahetamise, pikendamise või kehtivuse taastamise taotluse läbivaatamise eest tasutakse riigilõivu 20 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130122023001</aktViide>
									</avaldamismarge>
									<joustumine>2024-07-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para129lg3">
								<loigeNr>3</loigeNr>
								<kuvatavNr><![CDATA[(3)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Jahipiirkonna kasutusõiguse loa taotluse läbivaatamise eest tasutakse riigilõivu 100 eurot.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para129lg4">
								<loigeNr>4</loigeNr>
								<kuvatavNr><![CDATA[(4)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Jahipiirkonna piiride muutmise taotluse läbivaatamise eest tasutakse riigilõivu 100 eurot.</tavatekst>
								</sisuTekst>
							</loige>
