									<loigeNr/>
									<kuvatavNr/>
									<sisuTekst>
										<tavatekst>Tuntud saatja tunnustamise taotluse ja tunnustuse kehtivuse pikendamise taotluse läbivaatamise eest tasutakse riigilõivu 235 eurot.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
