											<avaldamismarge>
												<RTosa>RT I</RTosa>
												<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
												<RTartikkel>1</RTartikkel>
												<aktViide>130122023001</aktViide>
											</avaldamismarge>
											<joustumine>2024-07-01</joustumine>
										</muutmismarge>
									</alampunkt>
									<alampunkt id="para142b60lg2p7">
										<alampunktNr>7</alampunktNr>
										<kuvatavNr><![CDATA[7)]]></kuvatavNr>
										<sisuTekst>
											<tavatekst>laeva turvaülema tunnistuse puhul – 30 eurot.</tavatekst>
										</sisuTekst>
										<muutmismarge>
											<avaldamismarge>
												<RTosa>RT I</RTosa>
												<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
												<RTartikkel>1</RTartikkel>
