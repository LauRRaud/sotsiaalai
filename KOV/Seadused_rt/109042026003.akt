									<tavatekst id="99be52bd-dca8-471e-84c4-5690906effa2">Koondumise menetlemise eest tasutakse riigilõivu 1920 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge id="280cb373-7078-4057-81b9-58b51ef418c5">
