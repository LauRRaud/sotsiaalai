								<sisuTekst id="675dfa04-3146-4092-91b0-c888698f359f">
									<tavatekst id="87461fea-f812-40de-9d12-07f46ec6f98d">Tegevusloa taotluse läbivaatamise eest tasutakse riigilõivu:</tavatekst>
								</sisuTekst>
								<alampunkt id="para260lg1p1">
									<alampunktNr id="29a329f0-2f1b-4423-bdcf-367b32255aca">1</alampunktNr>
									<kuvatavNr id="e38cf3cf-bb94-4da9-9821-8a741f41314b"><![CDATA[1) ]]></kuvatavNr>
									<sisuTekst id="d9f6261e-f383-4f03-8ef0-1b4ad8fcf925">
										<tavatekst id="084ab59b-8ca8-4bf5-8eab-614e25ab41ea">õnnemängu korraldamiseks 47 940 eurot;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para260lg1p2">
									<alampunktNr id="01b339e0-2f93-49b0-a00f-747e121386c4">2</alampunktNr>
									<kuvatavNr id="eb7e1178-fd24-4d56-ba27-56aa14a516a2"><![CDATA[2) ]]></kuvatavNr>
									<sisuTekst id="f249bf02-0bab-4a8a-89c2-10f192baf037">
										<tavatekst id="ea626ba9-2c43-4a86-bdcd-a605bc2d9395">osavusmängu korraldamiseks 3200 eurot;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para260lg1p3">
									<alampunktNr id="308bfff1-6326-44cc-98e2-b96f86d41751">3</alampunktNr>
									<kuvatavNr id="41ae0804-e016-4807-80b1-a5912199d77d"><![CDATA[3) ]]></kuvatavNr>
									<sisuTekst id="6943cd5b-60e6-432c-8f07-1eb3d5bfea91">
										<tavatekst id="832cafce-c3e1-46dd-a132-c19413d9ecfa">toto korraldamiseks 31 960 eurot.</tavatekst>
									</sisuTekst>
								</alampunkt>
							</loige>
						</paragrahv>
						<paragrahv id="para261">
							<paragrahvNr id="ca891041-3d33-492e-a325-d419752e0c8c">261</paragrahvNr>
							<kuvatavNr id="3a1c8ea4-050c-4f41-ae5d-9b49a29a8d4a"><![CDATA[§ 261. ]]></kuvatavNr>
							<paragrahvPealkiri id="b2c1e9d0-2626-4246-a48a-0a05fa25bb56">Hasartmängu korraldusloa taotluse läbivaatamine</paragrahvPealkiri>
							<loige id="para261lg1">
								<loigeNr id="a6b121a0-b722-4377-a66a-5322b3c73518">1</loigeNr>
								<kuvatavNr id="d884c6df-6540-4366-a7de-b0b802eccedb"><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst id="24e9d318-6140-49ef-88dd-72c98211177a">
									<tavatekst id="53a94064-e0e4-4589-a3ea-494c0367e89d">Hasartmängu, välja arvatud loterii, korraldusloa taotluse läbivaatamise eest tasutakse riigilõivu 3200 eurot.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para261lg2">
								<loigeNr id="47788c22-c04c-4a55-85a3-5418668a16bd">2</loigeNr>
								<kuvatavNr id="8869c37c-b0f8-4281-a16f-67460eebe22a"><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst id="2491bb67-a09b-4ddd-9ef5-f1d6d502a380">
									<tavatekst id="42c4873a-c320-4499-816e-ad5b283e63f7">Loterii korraldusloa taotluse läbivaatamise eest tasutakse riigilõivu 640 eurot.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para261lg3">
								<loigeNr id="e74202d7-c2b9-458c-ad3d-7abcec595806">3</loigeNr>
								<kuvatavNr id="0637e18e-7dce-4ad5-b430-f2bce6de3897"><![CDATA[(3)]]></kuvatavNr>
								<sisuTekst id="4591f2e1-4e0e-4310-8cc2-538de9637201">
									<tavatekst id="ec97d32e-9d78-4759-a217-10697150a099">Vabariigi Valitsuse määratud mittetulundusühingu või sihtasutuse põhikirjalise eesmärgi toetuseks korraldatava loterii korraldusloa taotluse läbivaatamise eest tasutakse riigilõivu 130 eurot.</tavatekst>
