									</avaldamismarge>
									<joustumine>2022-01-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para63lg2">
								<loigeNr>2</loigeNr>
								<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Osaühingu, aktsiaseltsi, tulundusühistu või välismaa äriühingu filiaali kohta äriregistrisse muudatuse kandmise eest tasutakse riigilõivu 25 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
