								<kuvatavNr><![CDATA[§ 142<sup>26</sup>. ]]></kuvatavNr>
								<paragrahvPealkiri>Kokkuleppelise esindaja tunnustamine</paragrahvPealkiri>
								<loige id="para142b26lg1">
									<loigeNr/>
									<kuvatavNr/>
									<sisuTekst>
										<tavatekst>Kokkuleppelise esindaja tunnustamise taotluse ja tunnustuse kehtivuse pikendamise taotluse läbivaatamise eest tasutakse riigilõivu 245 eurot.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
