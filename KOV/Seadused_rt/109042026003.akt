						<paragrahv id="para128">
							<paragrahvNr>128</paragrahvNr>
							<kuvatavNr><![CDATA[§ 128. ]]></kuvatavNr>
							<paragrahvPealkiri>Jäätmete riikidevahelise veo loa taotluse läbivaatamine</paragrahvPealkiri>
							<loige id="para128lg1">
								<sisuTekst>
									<tavatekst>Jäätmete riikidevahelise veo loa taotluse läbivaatamise eest tasutakse riigilõivu 520 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130122023001</aktViide>
									</avaldamismarge>
									<joustumine>2024-07-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
					</jaotis>
