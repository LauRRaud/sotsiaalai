									<RTosa id="64a79559-f597-44c6-98fd-b973d5ef7d96">RT I</RTosa>
									<avaldamineKuupaev id="ae3aa8ad-98f4-44e2-b5b9-284b885a0322">2019-12-21</avaldamineKuupaev>
									<RTartikkel id="a3c7b6d3-3191-4977-8735-d0fccdd1be0e">1</RTartikkel>
