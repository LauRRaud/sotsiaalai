							<kuvatavNr id="ec189bd4-c70a-4fff-b0c1-d0a020835858"><![CDATA[§ 126. ]]></kuvatavNr>
							<paragrahvPealkiri id="63e91601-3573-4234-b73e-5156e8cc62bf">Jäätmeloa andmise ja muutmise taotluse läbivaatamine</paragrahvPealkiri>
							<muutmismarge id="ed83341a-38f3-42dd-bcfe-93cf5f3f5050">
								<tavatekst id="c502af9a-b2b6-452e-819d-7986122249bb">Kehtetu - </tavatekst>
								<avaldamismarge id="5d241005-929b-490e-bdc8-dc582aa8a11a">
									<RTosa id="aa4e59e1-bbaf-4439-8a80-c6f105c725c8">RT I</RTosa>
									<avaldamineKuupaev id="14d7fbcf-cff4-4845-8dc7-0984b5f59903">2019-12-21</avaldamineKuupaev>
