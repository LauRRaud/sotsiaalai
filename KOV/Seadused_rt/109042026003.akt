						<kuvatavNr id="160202cf-4157-4b72-8168-8777b33e9353"><![CDATA[§ 116. ]]></kuvatavNr>
						<paragrahvPealkiri id="91375115-54b3-4c39-a97d-34eda8817010">Kaebuse ja avalduse esitamine</paragrahvPealkiri>
						<muutmismarge id="faf091f6-5f46-4699-9bcc-e2aac73e2ec7">
							<avaldamismarge id="b9901607-0b51-4d5f-8420-e64f59f8eae4">
								<RTosa id="6983ef64-20f9-418e-933a-166313c54572">RT I</RTosa>
								<avaldamineKuupaev id="08bdb77d-584f-4c59-bb23-2f5de1473dfb">2019-03-19</avaldamineKuupaev>
								<RTartikkel id="56e10560-fed6-4c95-84d1-dd09ed93e849">5</RTartikkel>
								<aktViide id="8ce63dc6-70da-46ad-93e0-ad475c86a8d6">119032019005</aktViide>
							</avaldamismarge>
							<joustumine id="d07be24a-3191-4b15-af9b-0c47426ecbae">2019-04-01</joustumine>
						</muutmismarge>
						<loige id="para116lg1">
							<sisuTekst>
								<tavatekst>Tööstusomandi apellatsioonikomisjonile kaebuse või avalduse esitamise eest tasutakse riigilõivu 160 eurot.</tavatekst>
							</sisuTekst>
							<muutmismarge>
								<avaldamismarge>
									<RTosa>RT I</RTosa>
									<avaldamineKuupaev>2019-03-19</avaldamineKuupaev>
									<RTartikkel>5</RTartikkel>
									<aktViide>119032019005</aktViide>
								</avaldamismarge>
								<joustumine>2019-04-01</joustumine>
							</muutmismarge>
						</loige>
					</paragrahv>
				</jagu>
				<jagu id="jg11">
					<jaguNr>6</jaguNr>
					<kuvatavNr><![CDATA[6. jagu]]></kuvatavNr>
					<jaguPealkiri>Konkurentsiameti toimingud</jaguPealkiri>
					<muutmismarge id="5ba94d72-2daa-40cd-a9a4-58e22e54111e">
						<avaldamismarge id="6a13090d-45b6-4ac3-8c14-73cf55909cc3">
							<RTosa id="dd7da6de-caff-4ef0-a19b-3ed923e4086e">RT I</RTosa>
