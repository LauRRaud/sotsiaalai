				<jagu id="jg14">
					<jaguNr>3</jaguNr>
					<kuvatavNr><![CDATA[3. jagu]]></kuvatavNr>
					<jaguPealkiri>Keskkonnaameti toimingud</jaguPealkiri>
					<jaotis id="jaotis21">
						<jaotisNr>1</jaotisNr>
						<kuvatavNr><![CDATA[1. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Tööstusheite seaduse alusel tehtavad toimingud</jaotisPealkiri>
						<paragrahv id="para124">
							<paragrahvNr>124</paragrahvNr>
							<kuvatavNr><![CDATA[§ 124. ]]></kuvatavNr>
							<paragrahvPealkiri>Keskkonnakompleksloa andmise ja muutmise taotluse läbivaatamine</paragrahvPealkiri>
							<muutmismarge>
								<avaldamismarge>
									<RTosa>RT I</RTosa>
									<avaldamineKuupaev>2019-12-21</avaldamineKuupaev>
									<RTartikkel>1</RTartikkel>
									<aktViide>121122019001</aktViide>
								</avaldamismarge>
								<joustumine>2020-07-01</joustumine>
							</muutmismarge>
							<loige id="para124lg1">
								<loigeNr>1</loigeNr>
								<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Keskkonnakompleksloa (edaspidi <i>kompleksluba</i>) taotluse läbivaatamise eest tasutakse riigilõivu lähtuvalt taotletavast tegevusest ja sellest, mitme järgmise valdkonna andmed loale kantakse:</tavatekst>
								</sisuTekst>
								<alampunkt id="para124lg1p1">
									<alampunktNr>1</alampunktNr>
									<kuvatavNr><![CDATA[1) ]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>tööstusheite seaduse § 41 lõikes 2 sätestatud andmed – 4930 eurot;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para124lg1p2">
									<alampunktNr>2</alampunktNr>
									<kuvatavNr><![CDATA[2) ]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>atmosfääriõhu kaitse seaduse § 98 lõikes 1 sätestatud andmed – 4930 eurot;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para124lg1p3">
									<alampunktNr>3</alampunktNr>
									<kuvatavNr><![CDATA[3) ]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>jäätmeseaduse § 81 lõikes 2 sätestatud andmed – 4930 eurot;</tavatekst>
									</sisuTekst>
								</alampunkt>
								<alampunkt id="para124lg1p4">
									<alampunktNr>4</alampunktNr>
									<kuvatavNr><![CDATA[4) ]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>veeseaduse §-s 193 sätestatud andmed – 4930 eurot.</tavatekst>
									</sisuTekst>
								</alampunkt>
							</loige>
							<loige id="para124lg2">
								<loigeNr>2</loigeNr>
								<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Kui kompleksluba taotletakse sea-, veise- või linnukasvatuseks, tasutakse kompleksloa taotluse läbivaatamise eest riigilõivu 50 protsenti käesoleva paragrahvi lõikes 1 sätestatud riigilõivumäärast.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para124lg3">
								<loigeNr>3</loigeNr>
								<kuvatavNr><![CDATA[(3)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Kompleksloa muutmise taotluse läbivaatamise eest tasutakse riigilõivu 50 protsenti käesoleva paragrahvi lõikes 1 sätestatud riigilõivumäärast, arvestades lõikes 2 sätestatut.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2025-07-08</avaldamineKuupaev>
										<RTartikkel>55</RTartikkel>
										<aktViide>108072025055</aktViide>
									</avaldamismarge>
									<joustumine>2025-09-01</joustumine>
								</muutmismarge>
							</loige>
							<loige id="para124lg4">
								<loigeNr>4</loigeNr>
								<kuvatavNr><![CDATA[(4)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Kui kompleksloa muutmise korral taotletakse käesoleva paragrahvi lõikes 1 nimetatud valdkonna lisamist kompleksloale, tasutakse riigilõivu lõikes 1 sätestatud riigilõivumääras ja lõiget 3 ei rakendata.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para124lg5">
								<loigeNr>5</loigeNr>
								<kuvatavNr><![CDATA[(5)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Kui kompleksloa andmise või muutmise taotlus hõlmab vähemalt kolme käesoleva paragrahvi lõikes 1 nimetatud valdkonda, tasutakse riigilõivu 80 protsenti lõikes 1 nimetatud valdkondade riigilõivumäärade summast, arvestades lõigetes 3 ja 4 sätestatut.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>130122023001</aktViide>
									</avaldamismarge>
									<joustumine>2024-07-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
						<paragrahv id="para125">
							<paragrahvNr id="80840a5d-6de0-4dc5-a9d3-95c1a4a87f66">125</paragrahvNr>
							<kuvatavNr id="e5acca98-d293-4c61-866e-a0263fceb052"><![CDATA[§ 125. ]]></kuvatavNr>
