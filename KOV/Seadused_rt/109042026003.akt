					<jaotis id="jaotis39">
						<jaotisNr>1</jaotisNr>
						<kuvatavNr><![CDATA[1. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Transpordiameti toimingud lennunduse valdkonnas</jaotisPealkiri>
						<muutmismarge>
							<avaldamismarge>
								<RTosa>RT I</RTosa>
								<avaldamineKuupaev>2023-06-30</avaldamineKuupaev>
