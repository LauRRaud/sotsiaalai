					</jaotis>
				</jagu>
				<jagu id="jg8">
					<jaguNr>3</jaguNr>
					<kuvatavNr><![CDATA[3. jagu]]></kuvatavNr>
					<jaguPealkiri>Registrite ja Infosüsteemide Keskuse toimingud</jaguPealkiri>
					<jaotis id="jaotis10">
						<jaotisNr>1</jaotisNr>
						<kuvatavNr><![CDATA[1. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Riigi Teataja seaduse alusel tehtavad toimingud</jaotisPealkiri>
						<paragrahv id="para85">
							<paragrahvNr>85</paragrahvNr>
							<kuvatavNr><![CDATA[§ 85. ]]></kuvatavNr>
							<paragrahvPealkiri>Teadaande avaldamine</paragrahvPealkiri>
							<loige id="para85lg1">
								<sisuTekst>
									<tavatekst>Teadaande avaldamise eest ametlikus väljaandes Ametlikud Teadaanded tasutakse riigilõivu 7 eurot.</tavatekst>
								</sisuTekst>
							</loige>
						</paragrahv>
					</jaotis>
					<jaotis id="jaotis11">
						<jaotisNr>2</jaotisNr>
						<kuvatavNr><![CDATA[2. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Karistusregistri seaduse alusel tehtavad toimingud</jaotisPealkiri>
						<paragrahv id="para86">
							<paragrahvNr id="1054c529-54e2-4ee8-87a0-87c108d69f50">86</paragrahvNr>
							<kuvatavNr id="57fbdfa3-c73a-44d7-b06b-022564abf3c5"><![CDATA[§ 86. ]]></kuvatavNr>
							<paragrahvPealkiri id="329c346c-c3fb-4ef2-a9c5-b85ea0349944">Karistusregistri teate väljastamine</paragrahvPealkiri>
							<loige id="para86lg1">
								<sisuTekst id="55debdc8-4b68-47ab-8393-f774e208cd78">
									<tavatekst>Karistusregistri paberkandjal teate väljastamise eest rohkem kui üks kord aasta jooksul tasutakse riigilõivu 4 eurot ja välisesinduses 10 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge id="6f593776-12cb-4b8d-8a65-8718fef95016">
									<avaldamismarge id="7ce8a317-c7eb-4c2b-8b82-7a1d982100c1">
										<RTosa id="8a035a5c-4d78-4ea0-9e97-d01b036d1107">RT I</RTosa>
										<avaldamineKuupaev id="23f9e41b-2423-4ca5-b8f9-629ffc640936">2015-12-15</avaldamineKuupaev>
										<RTartikkel id="3c6a0e5e-3428-4d6d-adba-57b73afc6965">1</RTartikkel>
										<aktViide id="e6d07915-46bb-405e-b2a8-1732a6687374">115122015001</aktViide>
									</avaldamismarge>
									<joustumine id="873cf646-d1ca-4609-b196-4bc16e5911e6">2016-01-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
					</jaotis>
				</jagu>
				<jagu id="jg9">
					<jaguNr>4</jaguNr>
					<kuvatavNr><![CDATA[4. jagu]]></kuvatavNr>
					<jaguPealkiri>Vangla direktori tõestamistoimingud</jaguPealkiri>
					<jaotis id="jaotis12">
						<jaotisNr>1</jaotisNr>
						<kuvatavNr><![CDATA[1. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Notariaadiseaduse alusel tehtavad toimingud</jaotisPealkiri>
						<paragrahv id="para87">
							<paragrahvNr id="b59ff306-7731-4562-a155-33070e0e640d">87</paragrahvNr>
							<kuvatavNr id="97e0965b-d150-4fd3-aadc-9014167dab37"><![CDATA[§ 87. ]]></kuvatavNr>
							<paragrahvPealkiri id="a7c6c483-9ed4-4d51-a01d-796a07110322">Dokumendi ärakirja ja väljavõtte õigsuse kinnitamine</paragrahvPealkiri>
							<loige id="para87lg1">
								<sisuTekst id="5cd033af-5eae-47dd-b956-be83028a3754">
									<tavatekst id="a1d722fc-d2ce-448c-800e-1d0b79846925">Dokumendi ärakirja või väljavõtte õigsuse kinnitamise eest tasutakse riigilõivu 0,65 eurot iga lehekülje eest.</tavatekst>
								</sisuTekst>
							</loige>
						</paragrahv>
						<paragrahv id="para88">
							<paragrahvNr id="0db88094-9ac7-4430-a768-094d69b835d0">88</paragrahvNr>
							<kuvatavNr id="a4fbb6af-a9c0-42aa-a674-6eb2e151686b"><![CDATA[§ 88. ]]></kuvatavNr>
							<paragrahvPealkiri id="6c035996-6a1d-4d70-9d14-2ee0b1e59d58">Allkirja õigsuse kinnitamine</paragrahvPealkiri>
							<loige id="para88lg1">
								<sisuTekst id="c3db00d3-20a3-4a30-88a8-69d99f613404">
									<tavatekst id="d7938d70-3a11-43b4-8282-d9d14e73b0ad">Dokumendil allkirja õigsuse kinnitamise eest tasutakse riigilõivu 1 euro.</tavatekst>
								</sisuTekst>
							</loige>
						</paragrahv>
					</jaotis>
				</jagu>
				<jagu id="jg10">
					<jaguNr>5</jaguNr>
					<kuvatavNr><![CDATA[5. jagu]]></kuvatavNr>
					<jaguPealkiri>Patendiameti, patendivoliniku kutsekomisjoni ja tööstusomandi apellatsioonikomisjoni toimingud</jaguPealkiri>
					<paragrahv id="para89">
						<paragrahvNr id="d47f7888-dbd7-49a7-89e4-b449df1f8391">89</paragrahvNr>
						<kuvatavNr id="bc92699d-f18b-4e59-8e37-6416dbedbd23"><![CDATA[§ 89. ]]></kuvatavNr>
						<paragrahvPealkiri id="8f153c2d-257f-49a0-ad29-c7ffbd9397dc">Taotluse esitamine</paragrahvPealkiri>
						<loige id="para89lg1">
							<loigeNr id="2103b7f5-1534-439c-9cee-ad154dfeed91">1</loigeNr>
							<kuvatavNr id="dd3fd8dc-9058-4332-b069-8c334714299b"><![CDATA[(1)]]></kuvatavNr>
							<sisuTekst id="54418a64-495d-4146-9173-0df10b36fa4f">
								<tavatekst id="8db64300-227c-4244-bbb8-4da084a0bee1">Kaubamärgi registreerimise taotluse esitamise eest tasutakse riigilõivu rahvusvahelises kaupade ja teenuste klassifikatsioonis toodud kaupade või teenuste klassi järgi:</tavatekst>
							</sisuTekst>
							<alampunkt id="para89lg1p1">
								<alampunktNr id="fefffaa7-42e2-4a14-9289-277f37621237">1</alampunktNr>
								<kuvatavNr id="6c406119-842f-42e0-9be7-ead216888b2d"><![CDATA[1) ]]></kuvatavNr>
								<sisuTekst id="7a609af9-13ba-4dc3-bc25-0cbbfd0c3ff8">
									<tavatekst id="c1ef44ec-77ca-4583-b699-8fe4a634afc7">ühe klassi kohta 145 eurot;</tavatekst>
								</sisuTekst>
							</alampunkt>
							<alampunkt id="para89lg1p2">
								<alampunktNr id="7098c7ea-bc67-4f7d-bb6d-0614ad1922ae">2</alampunktNr>
								<kuvatavNr id="0ec022ff-c2ce-4c62-bf2b-148c3cd673ab"><![CDATA[2) ]]></kuvatavNr>
								<sisuTekst id="9a22c6e9-6810-40e2-8af2-8f5a0fcaebcd">
									<tavatekst id="61297a6c-aea2-426b-adbd-862ea03dca12">iga täiendava klassi kohta 45 eurot.</tavatekst>
								</sisuTekst>
							</alampunkt>
						</loige>
						<loige id="para89lg2">
							<loigeNr id="990baeee-2e73-4a89-915d-c36cc3c51910">2</loigeNr>
							<kuvatavNr id="c817e403-2dfc-408e-95b1-7c4d2e291b79"><![CDATA[(2)]]></kuvatavNr>
							<sisuTekst id="25640ae1-abee-4064-8292-57e8a2b0b7a0">
								<tavatekst id="64632072-047c-404f-b5b9-baacbff47e3f">Kollektiivkaubamärgi ja sertifitseerimismärgi registreerimise taotluse esitamise eest tasutakse riigilõivu rahvusvahelises kaupade ja teenuste klassifikatsioonis toodud kaupade või teenuste klassi järgi:</tavatekst>
							</sisuTekst>
							<muutmismarge id="a8022be7-6ec3-49a9-9be4-f50e0e01f8cb">
								<avaldamismarge id="13d149bc-08e2-465b-a698-e698af9d417f">
									<RTosa id="54816a22-b862-4719-ac10-008e9b5ce7c0">RT I</RTosa>
									<avaldamineKuupaev id="2dc173a9-7cc2-4a3f-8e32-803d20dcc1c7">2019-03-19</avaldamineKuupaev>
									<RTartikkel id="749d48f9-3bd5-4cce-9423-f507458adc33">5</RTartikkel>
									<aktViide id="18f827c1-237a-443d-9a52-6899b3a64c74">119032019005</aktViide>
								</avaldamismarge>
								<joustumine id="a02b1d00-8fe7-4c8f-9e27-a39a6fd7a40d">2019-04-01</joustumine>
							</muutmismarge>
							<alampunkt id="para89lg2p1">
								<alampunktNr id="d7806fad-ca67-40f8-a6ee-722010d885a2">1</alampunktNr>
								<kuvatavNr id="48111ef0-3243-478a-a0b1-61ccebc59ae4"><![CDATA[1) ]]></kuvatavNr>
								<sisuTekst id="5a270c05-df9b-4e43-a408-50830b1f2296">
									<tavatekst id="ca9805d2-e329-48b6-b827-012231b94d41">ühe klassi kohta 195 eurot;</tavatekst>
								</sisuTekst>
							</alampunkt>
							<alampunkt id="para89lg2p2">
								<alampunktNr id="5d426cab-1503-44b4-8289-831b9fb21994">2</alampunktNr>
								<kuvatavNr id="80be4762-efe1-4044-bf61-33629361e01a"><![CDATA[2) ]]></kuvatavNr>
								<sisuTekst id="6ce9fee9-2d4d-4a2d-91e3-4873589b8233">
									<tavatekst id="7deb7fd3-54a3-4597-b1ff-8280a4964993">iga täiendava klassi kohta 45 eurot.</tavatekst>
								</sisuTekst>
							</alampunkt>
						</loige>
						<loige id="para89lg3">
							<loigeNr id="9b9003b0-3fc3-4f79-ad0c-2ab186056041">3</loigeNr>
							<kuvatavNr id="1e529b8e-c4ab-46df-98fd-4ca5098bfa4d"><![CDATA[(3)]]></kuvatavNr>
							<sisuTekst id="1b94884a-f5c1-41c4-ae63-b6e7cbabe30d">
								<tavatekst id="df844fe9-919e-4094-8f0a-255b0c9b3c4b">Patenditaotluse esitamise eest tasutakse riigilõivu 225 eurot.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para89lg4">
							<loigeNr id="a5cfbf45-2b71-4996-ac47-ab06bb4280de">4</loigeNr>
							<kuvatavNr id="6d645695-71a0-41d5-824c-aaa9941a3294"><![CDATA[(4)]]></kuvatavNr>
							<sisuTekst id="af488f1a-521b-4864-a430-1e76ea56194f">
								<tavatekst id="1f3c521e-af45-490f-a659-98f5d06c1ec7">Füüsilise isiku või ainult füüsiliste isikute poolt patenditaotluse esitamise eest tasutakse riigilõivu 56 eurot.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para89lg5">
							<loigeNr id="16fb20db-5921-4511-9c5d-745c224c63cf">5</loigeNr>
							<kuvatavNr id="ccd03c05-418d-488a-a36c-20061dec904f"><![CDATA[(5)]]></kuvatavNr>
							<sisuTekst id="6a096ad6-d6da-4eb4-b1fe-e0fe7572a46f">
								<tavatekst id="a00791e4-a835-490a-9736-22c167cbcd8a">Üle 10-punktilise patendinõudlusega patenditaotluse esitamise eest tasutakse riigilõivu käesoleva paragrahvi lõikes 3 või 4 sätestatud määras ja lisaks 13 eurot iga punkti eest alates 11. punktist.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para89lg6">
							<loigeNr id="3c7f47ec-ff19-490c-bc15-c8a3ec9dc390">6</loigeNr>
							<kuvatavNr id="5318d971-68d4-40ad-893b-c811cc367e1e"><![CDATA[(6)]]></kuvatavNr>
							<sisuTekst id="ed7e833f-5535-4c9b-ada8-9a3a7e6d86ed">
								<tavatekst id="582f3ce7-c193-48bc-938c-8a22e2186d97">Patendiga kaitstud meditsiinitoote või taimekaitsetoote täiendava kaitse taotluse ja patendiga kaitstud meditsiinitoote täiendava kaitse pikendamise taotluse esitamise eest tasutakse riigilõivu 105 eurot.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para89lg7">
							<loigeNr id="8a4e5703-0634-4b0a-922d-7e9561165442">7</loigeNr>
							<kuvatavNr id="30bbd5d7-c689-43ff-9e88-62f026ac633f"><![CDATA[(7)]]></kuvatavNr>
							<sisuTekst id="46489fa5-b5c3-4256-8a25-ffe495c67a0e">
								<tavatekst id="ef5ae6d8-f1a0-4942-a46e-0b6b6a50ab9c">Kasuliku mudeli registreerimise taotluse esitamise eest tasutakse riigilõivu 105 eurot.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para89lg8">
							<loigeNr id="d5dfeb9b-7689-46de-ae03-909ad7a46728">8</loigeNr>
							<kuvatavNr id="3c93c860-4e26-4819-b726-65f3f61c449a"><![CDATA[(8)]]></kuvatavNr>
							<sisuTekst id="2ead2633-45c7-4e02-b7e3-2dfa1a360a97">
								<tavatekst id="5d5c5968-ecd9-4941-882f-41eb65d461bb">Füüsilise isiku või ainult füüsiliste isikute poolt kasuliku mudeli registreerimise taotluse esitamise eest tasutakse riigilõivu 26 eurot.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para89lg9">
							<loigeNr id="2446f692-0077-437b-9e86-90e19407963c">9</loigeNr>
							<kuvatavNr id="4a068eda-6345-4600-adf0-5b7095f00737"><![CDATA[(9)]]></kuvatavNr>
							<sisuTekst id="ce3f6479-99b1-4db9-91a9-3c7bff58a92c">
								<tavatekst id="c6ad0334-4ef1-47f2-a665-4303680f8861">Tööstusdisainilahenduse registreerimise taotluse esitamise eest tasutakse riigilõivu 105 eurot.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para89lg10">
							<loigeNr id="2002e54c-133d-415b-bdc6-28650a73ad40">10</loigeNr>
							<kuvatavNr id="7c1ea6c4-772e-4613-9d02-2a9eee8d9ff4"><![CDATA[(10)]]></kuvatavNr>
							<sisuTekst id="8f008e20-d4ae-4672-a19c-d3ada1d1e11e">
								<tavatekst id="cf3a1bb9-bfac-4e97-9527-cf09b935c5d5">Füüsilise isiku või ainult füüsiliste isikute poolt tööstusdisainilahenduse registreerimise taotluse esitamise eest tasutakse riigilõivu 26 eurot.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para89lg11">
							<loigeNr id="3d3f9e31-8ae1-48e0-93f9-53ff3fab907b">11</loigeNr>
							<kuvatavNr id="4fbdd41e-41c6-4d88-a16e-3ba9b53f0c2e"><![CDATA[(11)]]></kuvatavNr>
							<sisuTekst id="53b769e9-7b83-4c1a-a63a-1b38532f60ae">
								<tavatekst id="cbc88e69-e700-47ff-ae76-1aee7884065b">Tööstusdisainilahenduse variante sisaldava registreerimistaotluse esitamise eest tasutakse riigilõivu käesoleva paragrahvi lõikes 9 või 10 sätestatud määras ja lisaks 26 eurot iga järgmise variandi eest alates kolmandast variandist.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para89lg12">
							<loigeNr id="77a1521a-b635-4b25-99a8-85e6a3bae2cb">12</loigeNr>
							<kuvatavNr id="d9b82ac9-01fb-4cb0-a2fb-7a766a22f063"><![CDATA[(12)]]></kuvatavNr>
							<sisuTekst id="63102a88-13ea-4fb9-81fb-8dfb9eabbe6f">
								<tavatekst id="24ccbd0b-133d-4c8b-83eb-01650bcd214a">Geograafilise tähise registreerimise taotluse esitamise eest tasutakse riigilõivu 105 eurot.</tavatekst>
							</sisuTekst>
						</loige>
						<loige id="para89lg13">
							<loigeNr id="fc1525a5-d5c6-44b0-b19e-34a4a2dc83a5">13</loigeNr>
							<kuvatavNr id="ddbafb38-29ed-4f6c-8e65-94f136683db8"><![CDATA[(13)]]></kuvatavNr>
							<sisuTekst id="d5a4750c-7072-4cca-be4d-86d7ae01b7e6">
								<tavatekst id="121ea71e-6614-4a04-9687-92e6fccbb16f">Mikrolülituse topoloogia registreerimise taotluse esitamise eest tasutakse riigilõivu 105 eurot.</tavatekst>
							</sisuTekst>
						</loige>
					</paragrahv>
