						<paragrahv id="para285b3">
							<paragrahvNr ylaIndeks="3">285</paragrahvNr>
							<kuvatavNr><![CDATA[§ 285<sup>3</sup>. ]]></kuvatavNr>
							<paragrahvPealkiri>Meditsiiniseadme kliinilise uuringu tegemise taotluse ja in vitro diagnostikameditsiiniseadme toimivusuuringu tegemise taotluse läbivaatamine</paragrahvPealkiri>
							<loige id="para285b3lg1">
								<loigeNr>1</loigeNr>
								<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Meditsiiniseadme kliinilise uuringu tegemise taotluse läbivaatamise eest tasutakse riigilõivu 210 eurot.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para285b3lg2">
								<loigeNr>2</loigeNr>
								<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>
										<i>In vitro</i> diagnostikameditsiiniseadme toimivusuuringu tegemise taotluse läbivaatamise eest tasutakse riigilõivu 210 eurot.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2024-11-20</avaldamineKuupaev>
										<RTartikkel>1</RTartikkel>
										<aktViide>120112024001</aktViide>
