					<jaotis id="jaotis14">
						<jaotisNr>1</jaotisNr>
						<kuvatavNr><![CDATA[1. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Keskkonnamõju hindamise ja keskkonnajuhtimissüsteemi seaduse alusel tehtavad toimingud</jaotisPealkiri>
						<paragrahv id="para117">
							<paragrahvNr>117</paragrahvNr>
							<kuvatavNr><![CDATA[§ 117. ]]></kuvatavNr>
							<paragrahvPealkiri>Keskkonnamõju hindamise litsentsi andmise ja kehtivusaja pikendamise taotluse läbivaatamine</paragrahvPealkiri>
							<loige id="para117lg1">
								<sisuTekst>
									<tavatekst>Keskkonnamõju hindamise litsentsi andmise või kehtivusaja pikendamise taotluse läbivaatamise eest tasutakse riigilõivu 260 eurot.</tavatekst>
								</sisuTekst>
							</loige>
						</paragrahv>
						<paragrahv id="para118">
							<paragrahvNr>118</paragrahvNr>
							<kuvatavNr><![CDATA[§ 118. ]]></kuvatavNr>
							<paragrahvPealkiri>Ühenduse ökomärgise kasutamise õiguse andmine</paragrahvPealkiri>
							<loige id="para118lg1">
								<loigeNr>1</loigeNr>
								<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Ühenduse ökomärgise (edaspidi <i>ökomärgis</i>) kasutamise taotluse läbivaatamise eest tasutakse riigilõivu:</tavatekst>
								</sisuTekst>
								<alampunkt id="para118lg1p1">
									<alampunktNr>1</alampunktNr>
									<kuvatavNr><![CDATA[1) ]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>mikroettevõte 240 eurot;</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130122023001</aktViide>
										</avaldamismarge>
										<joustumine>2024-07-01</joustumine>
									</muutmismarge>
								</alampunkt>
								<alampunkt id="para118lg1p2">
									<alampunktNr>2</alampunktNr>
									<kuvatavNr><![CDATA[2) ]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>väike- ja keskmise suurusega ettevõte ning arenguriikidest pärit ettevõte 300 eurot;</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130122023001</aktViide>
										</avaldamismarge>
										<joustumine>2024-07-01</joustumine>
									</muutmismarge>
								</alampunkt>
								<alampunkt id="para118lg1p3">
									<alampunktNr>3</alampunktNr>
									<kuvatavNr><![CDATA[3) ]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>suurettevõte 385 eurot.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130122023001</aktViide>
										</avaldamismarge>
										<joustumine>2024-07-01</joustumine>
									</muutmismarge>
								</alampunkt>
							</loige>
							<loige id="para118lg2">
								<loigeNr>2</loigeNr>
								<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Ökomärgise tootel kasutamise õiguse eest tasutakse aastas riigilõivu:</tavatekst>
								</sisuTekst>
								<alampunkt id="para118lg2p1">
									<alampunktNr>1</alampunktNr>
									<kuvatavNr><![CDATA[1) ]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>mikroettevõte 60 eurot;</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130122023001</aktViide>
										</avaldamismarge>
										<joustumine>2024-07-01</joustumine>
									</muutmismarge>
								</alampunkt>
								<alampunkt id="para118lg2p2">
									<alampunktNr>2</alampunktNr>
									<kuvatavNr><![CDATA[2) ]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>väike- ja keskmise suurusega ettevõte ning arenguriikidest pärit ettevõte 120 eurot;</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130122023001</aktViide>
										</avaldamismarge>
										<joustumine>2024-07-01</joustumine>
									</muutmismarge>
								</alampunkt>
								<alampunkt id="para118lg2p3">
									<alampunktNr>3</alampunktNr>
									<kuvatavNr><![CDATA[3) ]]></kuvatavNr>
									<sisuTekst>
										<tavatekst>suurettevõte 240 eurot.</tavatekst>
									</sisuTekst>
									<muutmismarge>
										<avaldamismarge>
											<RTosa>RT I</RTosa>
											<avaldamineKuupaev>2023-12-30</avaldamineKuupaev>
											<RTartikkel>1</RTartikkel>
											<aktViide>130122023001</aktViide>
										</avaldamismarge>
										<joustumine>2024-07-01</joustumine>
									</muutmismarge>
								</alampunkt>
							</loige>
							<loige id="para118lg3">
								<loigeNr>3</loigeNr>
								<kuvatavNr><![CDATA[(3)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Käesolevas paragrahvis nimetatud ettevõtete klassifitseerimisel lähtutakse komisjoni määruse (EÜ) nr 800/2008 asutamislepingu artiklite 87 ja 88 kohaldamise kohta, millega teatavat liiki abi tunnistatakse ühisturuga kokkusobivaks (üldine grupierandi määrus) (ELT L 214, 09.08.2008, lk 3–47), lisas 1 nimetatud kriteeriumidest.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para118lg4">
								<loigeNr>4</loigeNr>
								<kuvatavNr><![CDATA[(4)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Kui ettevõte klassifitseerub alternatiivsete kriteeriumite tõttu mitme erineva ettevõtte klassi hulka, loetakse ta suurema ettevõtte klassi kuuluvaks.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para118lg5">
								<loigeNr>5</loigeNr>
								<kuvatavNr><![CDATA[(5)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Ühenduse keskkonnajuhtimis- ja keskkonnaauditeerimissüsteemis (EMAS) registreeritud või ISO 14001 standardi alusel sertifitseeritud taotleja taotluse menetlemise tasu vähendatakse Euroopa Parlamendi ja nõukogu määruses (EÜ) nr 66/2010 sätestatud korras ja ulatuses.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2015-03-23</avaldamineKuupaev>
										<RTartikkel>6</RTartikkel>
										<aktViide>123032015006</aktViide>
									</avaldamismarge>
									<joustumine>2015-07-01</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
					</jaotis>
					<jaotis id="jaotis15">
						<jaotisNr>2</jaotisNr>
						<kuvatavNr><![CDATA[2. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Geneetiliselt muundatud organismide keskkonda viimise seaduse alusel tehtavad toimingud</jaotisPealkiri>
						<paragrahv id="para119">
							<paragrahvNr>119</paragrahvNr>
							<kuvatavNr><![CDATA[§ 119. ]]></kuvatavNr>
							<paragrahvPealkiri>Geneetiliselt muundatud organismi keskkonda viimise loa ja turustamise loa taotluse läbivaatamine</paragrahvPealkiri>
							<loige id="para119lg1">
								<loigeNr>1</loigeNr>
								<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Geneetiliselt muundatud organismi keskkonda viimise loa taotluse läbivaatamise eest tasutakse riigilõivu 20 eurot.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para119lg2">
								<loigeNr>2</loigeNr>
								<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Geneetiliselt muundatud organismi või nimetatud organismi sisaldava või sellest koosneva toote turustamise loa taotluse läbivaatamise eest tasutakse riigilõivu 32 eurot.</tavatekst>
								</sisuTekst>
							</loige>
						</paragrahv>
					</jaotis>
					<jaotis id="jaotis16">
						<jaotisNr>3</jaotisNr>
						<kuvatavNr><![CDATA[3. jaotis]]></kuvatavNr>
						<jaotisPealkiri>Atmosfääriõhu kaitse seaduse alusel tehtavad toimingud</jaotisPealkiri>
						<muutmismarge>
							<avaldamismarge>
								<RTosa>RT I</RTosa>
								<avaldamineKuupaev>2016-07-05</avaldamineKuupaev>
								<RTartikkel>1</RTartikkel>
								<aktViide>105072016001</aktViide>
							</avaldamismarge>
							<joustumine>2017-01-01</joustumine>
						</muutmismarge>
						<paragrahv id="para120">
							<paragrahvNr>120</paragrahvNr>
							<kuvatavNr><![CDATA[§ 120. ]]></kuvatavNr>
							<paragrahvPealkiri>Kasvuhoonegaaside heitkoguse ühikutega kauplemise registri toimingud</paragrahvPealkiri>
							<loige id="para120lg1">
								<loigeNr>1</loigeNr>
								<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Kauplemiskonto avamise taotluse läbivaatamise eest tasutakse riigilõivu 300 eurot.</tavatekst>
								</sisuTekst>
							</loige>
							<loige id="para120lg2">
								<loigeNr>2</loigeNr>
								<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
								<sisuTekst>
									<tavatekst>Kauplemiskonto hoolduse eest tasutakse riigilõivu iga aasta kohta 320 eurot jooksva aasta 15. jaanuariks.</tavatekst>
								</sisuTekst>
								<muutmismarge>
									<avaldamismarge>
										<RTosa>RT I</RTosa>
										<avaldamineKuupaev>2021-06-25</avaldamineKuupaev>
										<RTartikkel>2</RTartikkel>
										<aktViide>125062021002</aktViide>
									</avaldamismarge>
									<joustumine>2021-07-05</joustumine>
								</muutmismarge>
							</loige>
						</paragrahv>
					</jaotis>
