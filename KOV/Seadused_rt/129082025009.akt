					<kuvatavNr id="0b593561-25ad-4895-8e4f-b85933f4077e"><![CDATA[11) ]]></kuvatavNr>
					<sisuTekst id="77d14ed7-24cc-4926-ad9e-8a520cb99e01">
						<tavatekst id="192fdf60-8802-4d76-9411-73222a62ddf2">abivahendi näidustus ja kitsendus;</tavatekst>
