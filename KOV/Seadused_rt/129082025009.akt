						<tavatekst id="00f93e75-fb9c-418e-bde2-d1b6b1ad256d">tellimusmeditsiiniseadme identifitseerimisandmed;</tavatekst>
					</sisuTekst>
					<muutmismarge id="1ce3f6c6-59ee-4197-ad62-b3954dd8bb92">
						<avaldamismarge id="400ac585-c3eb-47eb-9051-1e3b0ba9720c">
