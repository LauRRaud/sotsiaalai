	<sisu id="ad22a9d4-e20a-4d47-a3b8-be18a6001fe0">
		<preambul id="d73492ff-7ab9-4634-b82e-bac305f6d6c8">
			<tavatekst id="3cb19343-9a87-496b-8445-32aa6a46adca">Määrus kehtestatakse </tavatekst>
			<viide id="9ad7e267-157f-412e-9796-dee2d1d807a1">
				<kuvatavTekst id="9d85528b-89a8-498d-8806-430c85d35f98"><![CDATA[sotsiaalhoolekande seaduse]]></kuvatavTekst>
				<viideURID id="9a9e8ac6-8640-47ba-9bf2-437bcc60dfc2">
					<viideURI id="4edebfa4-edc4-4010-be00-05047c34c5d0"><![CDATA[./dyn=129082025009&id=113032019154!pr47lg2b1]]></viideURI>
				</viideURID>
			</viide>
			<tavatekst id="b1bdeb27-22f2-42de-997a-ffdd7ad7d0bc"> § 47 lõigete 1<sup>1</sup>, 3<sup>4</sup>, 5 ja 8, § 48 lõike 2, § 51 lõike 2, § 52 lõike 3 ning § 55 lõigete 2<sup>1</sup> ja 3 alusel.</tavatekst>
			<muutmismarge id="cb0dadf6-2dc6-4c4b-99ee-20b62ee85e8d">
				<avaldamismarge id="1a15bdb3-a754-46fa-96bd-a0036ded0bc9">
					<RTosa id="718d942f-eb2a-4159-b2bf-8377548ff65f">RT I</RTosa>
					<avaldamineKuupaev id="3d161eef-e78b-48e4-87db-3deab4ad2c99">2024-12-29</avaldamineKuupaev>
					<RTartikkel id="7e4bf3ac-a7f7-49ed-b154-8b82afaacd1e">22</RTartikkel>
					<aktViide id="5096e001-b0e1-412f-951a-0da615a42b16">129122024022</aktViide>
				</avaldamismarge>
				<joustumine id="ce5709eb-88df-48f1-8e86-f649b51aad05">2025-09-01</joustumine>
			</muutmismarge>
		</preambul>
		<paragrahv id="para1">
			<paragrahvNr id="1c022b2d-82b9-4db5-b16e-1c8e1535978f">1</paragrahvNr>
			<kuvatavNr id="9af4d4ca-d4f1-4fc4-8f47-14c17918ed1d"><![CDATA[§ 1. ]]></kuvatavNr>
			<paragrahvPealkiri id="cb653ca1-ec1a-42f6-a15b-8b0e30f0ed36">Reguleerimisala</paragrahvPealkiri>
			<loige id="para1lg1">
				<loigeNr id="e35983bd-ca6e-40f2-9b8c-392e9df6d560"/>
				<kuvatavNr id="d168a51b-142d-4fae-ae3e-abbe6afb4f1a"/>
				<sisuTekst id="f5587950-113b-4d83-ae91-3d0ae1d11b89">
					<tavatekst id="acd7b40e-202c-4d09-b780-70f412e996a7">Määruses sätestatakse:</tavatekst>
				</sisuTekst>
				<alampunkt id="para1lg1p1">
					<alampunktNr id="6a20a7a6-d2cd-4fb4-b1c8-da01dd92e8a4">1</alampunktNr>
					<kuvatavNr id="4fa43e85-0f5d-48b4-9dfa-1e2158b5fc9a"><![CDATA[1) ]]></kuvatavNr>
					<sisuTekst id="57ad3f9e-0869-4273-afb7-c27d3c4da3ae">
						<tavatekst id="e5acc669-a591-4973-873f-a200c0797e51">abivahendite loetelu, kuhu on kantud sotsiaalhoolekande seaduse § 48 lõikes 3 nimetatud andmed (määruse lisa);</tavatekst>
					</sisuTekst>
				</alampunkt>
				<alampunkt id="para1lg1p2">
					<alampunktNr id="533f45ea-1e26-4843-a4a4-8b98e3c5ed2f">2</alampunktNr>
					<kuvatavNr id="cc3ca55b-6ea8-4c82-af33-676884a6cc3f"><![CDATA[2) ]]></kuvatavNr>
					<sisuTekst id="7a6bf123-c65e-460f-b6b4-86783dcbdfad">
						<tavatekst id="f22789b2-70f5-4b7b-8a40-348961a83e2c">abivahendi kasutamise vajaduse tuvastajad sõltuvalt abivahendi keerukusest;</tavatekst>
					</sisuTekst>
				</alampunkt>
				<alampunkt id="para1lg1p3">
					<alampunktNr id="936d5842-6d49-46d9-a179-f96dcc6c466c">3</alampunktNr>
					<kuvatavNr id="9cff8008-160d-40ae-9c64-6ac415ff3f2c"><![CDATA[3) ]]></kuvatavNr>
					<sisuTekst id="3c753a2f-5106-4bf4-8d0a-f86960aa6620">
						<tavatekst id="6c89354e-4270-48eb-ad76-bbee38339144">tasu maksmise kohustuse ülevõtmise taotlemiseks vajalike andmete ja dokumentide loetelu;</tavatekst>
					</sisuTekst>
					<muutmismarge id="9c640af3-46cf-4aa7-953e-a1db91f41d76">
						<avaldamismarge id="bdae6bab-4d27-4389-be06-27593c16034d">
							<RTosa id="58d7cc57-7e82-4c8a-a0ce-7b2d6399cecb">RT I</RTosa>
							<avaldamineKuupaev id="99f38b53-25bb-42af-b290-12424294d8f4">2024-12-29</avaldamineKuupaev>
							<RTartikkel id="78422346-8fc5-44e9-a144-887f46babe67">22</RTartikkel>
							<aktViide id="b053a7c9-e274-4cb8-9fc4-7ee15bfb2517">129122024022</aktViide>
						</avaldamismarge>
						<joustumine id="d446c437-ebe2-4908-bab9-0ea6764f0eac">2025-09-01</joustumine>
					</muutmismarge>
				</alampunkt>
				<alampunkt id="para1lg1p4">
					<alampunktNr id="31566e73-11e5-40c2-b466-ef181472b206">4</alampunktNr>
					<kuvatavNr id="967a4592-2687-44c7-adcc-70550802d8d9"><![CDATA[4) ]]></kuvatavNr>
					<sisuTekst id="914395d4-4aa7-4ce7-8dbd-b96b67a4d178">
						<tavatekst id="97682ba4-378a-448f-8377-dfbd4495a6f4">abivahendi tõendi ja kaardi andmekoosseis;</tavatekst>
					</sisuTekst>
					<muutmismarge id="ca8cc178-9a0a-4e98-8d7c-d35f2686e616">
						<avaldamismarge id="eb7d819f-d850-437c-8945-7e54ed22123e">
							<RTosa id="82deba00-1d19-4443-b50a-267981b4d3f7">RT I</RTosa>
							<avaldamineKuupaev id="20ea24a9-1739-463a-8929-2332c8576eca">2024-12-29</avaldamineKuupaev>
							<RTartikkel id="0ceb843b-3631-45d8-ae9a-a78695487c80">22</RTartikkel>
							<aktViide id="2aa59ed9-fc63-47ac-a38a-10691b3a1ee3">129122024022</aktViide>
						</avaldamismarge>
						<joustumine id="17790c92-ad98-4f1b-9446-60d51796e817">2025-09-01</joustumine>
					</muutmismarge>
				</alampunkt>
				<alampunkt id="para1lg1p5">
					<alampunktNr id="1922961b-8573-4e08-ba1d-f7e61bb8eaeb">5</alampunktNr>
					<kuvatavNr id="5307cae2-06bc-40e6-b043-578e493ab201"><![CDATA[5) ]]></kuvatavNr>
					<sisuTekst id="d6d6c36d-3ff2-4d04-a27a-46fe25e37e80">
						<tavatekst id="eb80f025-e80b-4887-8fbe-10e2cf0bfe96">abivahendi kasutamise nõustamine;</tavatekst>
					</sisuTekst>
				</alampunkt>
				<alampunkt id="para1lg1p6">
					<alampunktNr id="b0d50506-c1a8-4ecf-9dae-8a0717281465">6</alampunktNr>
					<kuvatavNr id="5cbb9e88-cc90-4b31-a93f-b57910c1cfb2"><![CDATA[6) ]]></kuvatavNr>
					<sisuTekst id="694b9cc5-17a9-4298-99c2-1b267f4d86c3">
						<tavatekst id="741a3d8f-f9f2-4fd9-bdd6-e4937da9d452">abivahendi eest tasu maksmise kohustuse erandkorras ülevõtmise otsustamise (edaspidi <i>erandi otsustamine</i>) täpsemad tingimused;</tavatekst>
					</sisuTekst>
				</alampunkt>
				<alampunkt id="para1lg1p7">
					<alampunktNr id="a966f67f-4eda-4473-8359-cf5acee403ca">7</alampunktNr>
					<kuvatavNr id="1cfad96e-9a13-476e-a34b-c8b895bbf8bc"><![CDATA[7) ]]></kuvatavNr>
					<sisuTekst id="b3cefae7-b826-4f24-b7ae-912afd951100">
						<tavatekst id="0301e088-3e59-49cc-9b29-497baa8fdcec">spetsialistid, kellel on abivahendi müümiseks või üürimiseks sobiv kvalifikatsioon ja ettevalmistus.</tavatekst>
					</sisuTekst>
				</alampunkt>
				<alampunkt id="para1lg1p8">
					<alampunktNr id="c61744fe-c4c7-489e-b55e-4a0330f44aba">8</alampunktNr>
					<kuvatavNr id="6acb41fd-4ba2-4ad2-a96c-0c650eba504b"><![CDATA[8) ]]></kuvatavNr>
					<muutmismarge id="055e1c8a-e4fe-4844-9191-64e4a96bd450">
						<tavatekst id="9802b757-c5b0-40c0-a50d-be74eb511aae">kehtetu -</tavatekst>
						<avaldamismarge id="c6a58ee3-984b-46f4-a2a3-0c7520ffeafe">
							<RTosa id="04d19098-091b-453e-86f6-74bfeb3934c1">RT I</RTosa>
							<avaldamineKuupaev id="5bc1b73b-fc69-4924-ba48-28fd937f08ef">2024-12-29</avaldamineKuupaev>
							<RTartikkel id="f34293d7-dd3a-4177-895e-2fe2948c77e8">22</RTartikkel>
							<aktViide id="4fd8e6ac-97c6-489b-b61c-7cf25f8e0047">129122024022</aktViide>
						</avaldamismarge>
						<joustumine id="a367c3ff-5eba-418f-9bd5-5f06b065e0d3">2025-09-01</joustumine>
					</muutmismarge>
				</alampunkt>
			</loige>
		</paragrahv>
		<paragrahv id="para2">
			<paragrahvNr id="76bd32e5-cfa1-46d4-80e9-7e6de93600df">2</paragrahvNr>
			<kuvatavNr id="a42ed685-9b37-48f8-a34c-259317444cbb"><![CDATA[§ 2. ]]></kuvatavNr>
			<paragrahvPealkiri id="5fe567aa-db3c-4bdb-9c3b-a3d5d10c8c19">Tasu maksmise kohustuse ülevõtmise taotlemiseks vajalikud andmed ja dokumendid</paragrahvPealkiri>
			<muutmismarge id="cc25c82e-7341-4da4-b50d-4edaba617ddd">
				<avaldamismarge id="4404eadb-8581-4c99-8de0-1161f13dafad">
					<RTosa id="98420d9b-ef0c-405a-b4fb-3d97ae3555b7">RT I</RTosa>
					<avaldamineKuupaev id="2b79d53d-d186-4fe1-9258-59b1f1787be6">2024-12-29</avaldamineKuupaev>
					<RTartikkel id="53534ca9-0250-45de-b82a-8aa914f875e3">22</RTartikkel>
					<aktViide id="b88ffed7-e90f-4fc6-85a2-f7a5c505fb39">129122024022</aktViide>
				</avaldamismarge>
				<joustumine id="c19d844c-2750-4d24-9d56-7da5ce76660d">2025-09-01</joustumine>
			</muutmismarge>
			<loige id="para2lg1">
				<loigeNr id="fcc7286d-bd84-4357-9cb5-12c5dfbf917f">1</loigeNr>
				<kuvatavNr id="bff76242-edb4-4c2b-a677-e3f44ad7d05e"><![CDATA[(1)]]></kuvatavNr>
				<sisuTekst id="c6a6f8e6-1106-453b-8d0f-d467b130e794">
					<tavatekst id="e82118b6-6545-4012-8315-735ab631939d">Isik esitab abivahendi eest tasu maksmise kohustuse riigi poolt ülevõtmise taotlemisel järgmised andmed:</tavatekst>
				</sisuTekst>
				<alampunkt id="para2lg1p1">
					<alampunktNr id="0f7cd2c1-7cbd-483e-855f-a7008f70f2b0">1</alampunktNr>
					<kuvatavNr id="58bdf2c2-c222-428f-90af-6fd8f22f35d8"><![CDATA[1) ]]></kuvatavNr>
					<sisuTekst id="e02f7a3a-0716-4050-8d87-e48379a9e829">
						<tavatekst id="b550e7d3-0730-47e7-aefd-76318cf7173a">taotleja ees- ja perekonnanimi, isikukood;</tavatekst>
					</sisuTekst>
				</alampunkt>
				<alampunkt id="para2lg1p2">
					<alampunktNr id="714608dc-65f4-4297-b5f5-1374d28f7445">2</alampunktNr>
					<kuvatavNr id="3c9938f8-60ad-4eca-b4ac-5a9183d56ace"><![CDATA[2) ]]></kuvatavNr>
					<sisuTekst id="f19a0b69-127c-4fd6-9d99-fa14191d3862">
						<tavatekst id="199dbe0a-2924-42a5-9048-79c3a2d4b46f">taotleja kontaktandmed (aadress, telefon, e-posti aadress);</tavatekst>
					</sisuTekst>
				</alampunkt>
				<alampunkt id="para2lg1p3">
					<alampunktNr id="1aa53912-2bac-4df8-8c7e-7296458232b1">3</alampunktNr>
					<kuvatavNr id="eeeffffd-8aba-459f-af52-3e769a94681b"><![CDATA[3) ]]></kuvatavNr>
					<sisuTekst id="fba987e9-31bd-4d34-bfc7-2445146b0e1a">
						<tavatekst id="c093b5b8-3809-40e5-81cd-8d6b10ae64c8">otsuse kättesaamise viis (postiaadress, e-posti aadress).</tavatekst>
					</sisuTekst>
				</alampunkt>
			</loige>
			<loige id="para2lg2">
				<loigeNr id="69db65df-a9d3-44ef-bf92-dcbb61a178f2">2</loigeNr>
				<kuvatavNr id="d042ff16-1828-4314-b623-a4de1564489c"><![CDATA[(2)]]></kuvatavNr>
				<sisuTekst id="f25507b7-aade-43e8-bb23-d7548c2cb5e3">
					<tavatekst id="313d502b-6077-41cc-a253-83bbbb5309cf">Isik, välja arvatud riikliku pensionikindlustuse seaduse §-s 7 sätestatud vanaduspensioniikka jõudnud isik uriini absorbeerivate abivahendite puhul, esitab abivahendi müüja või üürija poole pöördumisel arsti, õe, ämmaemanda, füsioterapeudi, logopeedi või tegevusterapeudi tõendi või rehabilitatsiooniplaani abivahendi vajaduse kohta. Tõendil või rehabilitatsiooniplaanis on märgitud toote ISO-kood, selle puudumise korral nimetus või kirjeldus, mis võimaldab abivahendi ISO-koodi täpsusega kindlaks määrata.</tavatekst>
				</sisuTekst>
				<muutmismarge id="96396b32-389f-4483-8dc3-f8e06a2316e5">
					<avaldamismarge id="4f21b50b-b761-4437-beaf-408a939054bb">
						<RTosa id="0c46e0fc-9e8f-472a-9734-cac9f4e5f0d4">RT I</RTosa>
						<avaldamineKuupaev id="4091ec3e-8380-404b-b9f5-44da675b4f27">2021-12-29</avaldamineKuupaev>
						<RTartikkel id="fd73f6c4-350f-440e-8b4b-a3579bf29874">7</RTartikkel>
						<aktViide id="f052f675-f171-4754-b4c3-742cf57e4e1f">129122021007</aktViide>
					</avaldamismarge>
					<joustumine id="534cdd5d-2df5-4780-b62b-4783c741b6f9">2022-01-01</joustumine>
				</muutmismarge>
			</loige>
			<loige id="para2lg2b1">
				<loigeNr id="a9cb08d1-9a11-4b89-80af-83efc470a8f2" ylaIndeks="1">2</loigeNr>
				<kuvatavNr id="35f21d0a-300d-4f31-ac87-0e678eef5bac"><![CDATA[(2<sup>1</sup>)]]></kuvatavNr>
				<sisuTekst id="5fce8935-ba97-46ac-a05e-f1657d24281d">
					<tavatekst id="f2a640d0-a2f7-44ed-82b3-c0893f353dd9">Abivahendi kasutamise vajaduse võib tuvastada ja sellekohase tõendi väljastada:</tavatekst>
				</sisuTekst>
				<alampunkt id="para2lg2b1p1">
					<alampunktNr id="67bfd7b5-4d6f-474d-b658-e1b0168ccb6d">1</alampunktNr>
					<kuvatavNr id="39055a03-fcbd-4b2a-a058-ed175b50bd56"><![CDATA[1) ]]></kuvatavNr>
					<sisuTekst id="bb976ed0-e7af-4aa2-b9b0-4a6682f891a2">
						<tavatekst id="4a1985a1-3193-430e-8cbc-032c5c206cdf">arst;</tavatekst>
					</sisuTekst>
				</alampunkt>
				<alampunkt id="para2lg2b1p2">
					<alampunktNr id="16ebb860-b6f9-4a83-bd07-684fe12edf14">2</alampunktNr>
					<kuvatavNr id="ecae29b9-76b8-4a72-a4fa-be2f24c47e9c"><![CDATA[2) ]]></kuvatavNr>
					<sisuTekst id="ab862467-a673-4037-8e9a-fbb9b1447654">
						<tavatekst id="8dc22bc5-3aa0-4123-a19c-0cd222d92811">õde;</tavatekst>
					</sisuTekst>
				</alampunkt>
				<alampunkt id="para2lg2b1p3">
					<alampunktNr id="ac7d20dc-a229-45a6-af2f-73d32bed85e6">3</alampunktNr>
					<kuvatavNr id="6c3bd426-53f0-4123-a734-b44e31956e08"><![CDATA[3) ]]></kuvatavNr>
					<sisuTekst id="e2a68d3c-b448-4272-a5ae-d787bfa4f338">
						<tavatekst id="12937110-dc2b-44c6-8abd-36acbd4dcea7">ämmaemand;</tavatekst>
					</sisuTekst>
				</alampunkt>
				<alampunkt id="para2lg2b1p4">
					<alampunktNr id="dd3e4e27-a959-4eea-91b2-63929895a0ca">4</alampunktNr>
					<kuvatavNr id="f4fb77bb-87b8-4c0d-8a11-46da3ef73340"><![CDATA[4) ]]></kuvatavNr>
					<sisuTekst id="f8963a6e-a024-4992-84d9-846150599970">
						<tavatekst id="aade44b2-8bf0-4bca-9524-52041052c3e0">füsioterapeut, kellel on füsioterapeudi kutse või riiklikult tunnustatud kõrgharidus füsioteraapias või sellele vastav kvalifikatsioon ja kes töötab tõendi väljastamise hetkel füsioterapeudina rehabilitatsiooni- või tervishoiuteenuse osutaja juures;</tavatekst>
					</sisuTekst>
				</alampunkt>
				<alampunkt id="para2lg2b1p5">
					<alampunktNr id="ec2e03a2-b978-4f81-91a5-df7379466030">5</alampunktNr>
					<kuvatavNr id="30b3101a-cb50-472d-810c-817f7e357d6c"><![CDATA[5) ]]></kuvatavNr>
					<sisuTekst id="025b0766-6dbe-409e-984b-217e3485494d">
						<tavatekst id="277bd4e7-3fbc-41a9-b476-3d6196849921">tegevusterapeut, kellel on tegevusterapeudi kutse või riiklikult tunnustatud kõrgharidus tegevusteraapias või sellele vastav kvalifikatsioon ja kes töötab tõendi väljastamise hetkel tegevusterapeudina rehabilitatsiooni- või tervishoiuteenuse osutaja juures;</tavatekst>
					</sisuTekst>
				</alampunkt>
				<alampunkt id="para2lg2b1p6">
					<alampunktNr id="2404e41f-d526-4bc3-b229-a716c0b72b15">6</alampunktNr>
					<kuvatavNr id="ef3cb961-e87c-4c3b-abd1-5c352942f8de"><![CDATA[6) ]]></kuvatavNr>
					<sisuTekst id="48a3548e-69ef-4d4b-99e8-7af7d89c527c">
						<tavatekst id="9a75acad-2100-4a2c-8165-8be141648aba">logopeed, kellel on logopeedi 7. või 8. taseme kutse;</tavatekst>
					</sisuTekst>
				</alampunkt>
				<alampunkt id="para2lg2b1p7">
					<alampunktNr id="4bc1f664-adbd-4a74-a55f-ed8e4a41d099">7</alampunktNr>
					<kuvatavNr id="48867d66-506b-45b6-a9e6-e30af73cee05"><![CDATA[7) ]]></kuvatavNr>
					<sisuTekst id="fac550df-9295-46f8-b253-2e918dd0fb0c">
						<tavatekst id="5771d3cb-4fbc-4cd6-9385-3145eec19074">audioloog, kellel on magistrikraad audioloogias;</tavatekst>
					</sisuTekst>
				</alampunkt>
				<alampunkt id="para2lg2b1p8">
					<alampunktNr id="7e9e8f5b-a1f9-4490-9eff-b23ca4a70777">8</alampunktNr>
					<kuvatavNr id="98c2d9e0-d2d0-415d-a4fc-eaaaf4ad52a7"><![CDATA[8) ]]></kuvatavNr>
					<sisuTekst id="5339a277-308c-4f54-b1cb-64227990d448">
						<tavatekst id="481fd8f8-f4c6-4c32-87a7-a68dbad8a0cb">rehabilitatsioonimeeskond rehabilitatsiooniplaanina.</tavatekst>
					</sisuTekst>
					<muutmismarge id="dd562077-94a4-45c3-8c5a-7c4cdea77ed2">
						<avaldamismarge id="572c1ffb-a345-431e-91a7-db392677fb77">
							<RTosa id="07c36d05-9593-4467-9d58-0e100352c302">RT I</RTosa>
							<avaldamineKuupaev id="c4cbb67b-738b-47d1-b598-8f9a870aec80">2024-12-29</avaldamineKuupaev>
							<RTartikkel id="2276b35b-d9b3-4994-9bd5-7c1a79077748">22</RTartikkel>
							<aktViide id="f2e52f25-cff6-41e5-b4ed-35f582f085c9">129122024022</aktViide>
						</avaldamismarge>
						<joustumine id="0c4656a3-ea41-47e3-8b6a-8dee7c546b49">2025-01-01</joustumine>
					</muutmismarge>
				</alampunkt>
			</loige>
			<loige id="para2lg2b2">
				<loigeNr id="e0bea4fe-db84-4f2f-bb0d-7211e5c9eb99" ylaIndeks="2">2</loigeNr>
				<kuvatavNr id="a8d7afc9-2fc4-4384-bd7c-0ca9d56a0d9c"><![CDATA[(2<sup>2</sup>)]]></kuvatavNr>
				<muutmismarge id="95fc3f93-7ac6-45ee-a0a2-638d6045def8">
					<tavatekst id="21ce4881-7a9c-40ab-97b1-99c2616cb1ac">Kehtetu -</tavatekst>
					<avaldamismarge id="68ae9a67-e08f-4dbb-8680-13f7279072d9">
						<RTosa id="8765d15d-648f-4444-b966-ffe0727a987b">RT I</RTosa>
						<avaldamineKuupaev id="2cc474a6-abcd-4deb-904e-f3ccaca4ebdb">2024-12-29</avaldamineKuupaev>
						<RTartikkel id="83c1ff63-adf4-49d9-a08e-a3b335cb2b2e">22</RTartikkel>
						<aktViide id="6b96f41c-4ba5-44c0-9653-33dc12154189">129122024022</aktViide>
					</avaldamismarge>
					<joustumine id="ba15bea5-c325-427d-b8b8-6fac52bdf780">2025-01-01</joustumine>
				</muutmismarge>
			</loige>
			<loige id="para2lg2b3">
				<loigeNr id="ac51a7fa-edaf-4b89-bbf1-e6ca33cf76b2" ylaIndeks="3">2</loigeNr>
				<kuvatavNr id="72e122d4-5b78-4a07-9a98-fb01ba60b6e3"><![CDATA[(2<sup>3</sup>)]]></kuvatavNr>
				<muutmismarge id="33421a24-afe6-4748-be47-eff2c6291e25">
					<tavatekst id="16cf182e-f43e-4c80-a9a8-3ff539a385d4">Kehtetu -</tavatekst>
					<avaldamismarge id="fc675f61-0e17-4448-825e-b0ae585fe1d2">
