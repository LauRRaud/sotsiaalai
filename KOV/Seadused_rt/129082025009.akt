			<paragrahvPealkiri id="b1c05b4f-22d5-4602-9ba3-3d7f708a6099">Abivahendi tõend</paragrahvPealkiri>
			<loige id="para2b1lg1">
				<loigeNr id="6c705c5f-a095-45e9-acb3-a50d8f2f6e51">1</loigeNr>
				<kuvatavNr id="3f3ed5ea-65c3-4928-8cda-ac4d405f6955"><![CDATA[(1)]]></kuvatavNr>
				<sisuTekst id="59bef9f2-100e-43b2-8e18-ad20d9668d27">
					<tavatekst id="43eee98c-8efe-47c0-891f-bbd11756bea6">Abivahendi tõendit on õigus väljastada § 2 lõikes 2<sup>1</sup> nimetatud isikutel.</tavatekst>
				</sisuTekst>
			</loige>
			<loige id="para2b1lg2">
				<loigeNr id="e8335c28-0c88-41fe-bf1a-faafc468e10e">2</loigeNr>
				<kuvatavNr id="32a62f39-f5b5-48e6-84fe-7ec89a9e25e5"><![CDATA[(2)]]></kuvatavNr>
				<sisuTekst id="c8421697-7b6f-44e9-bced-6bf1d7f0dc2a">
					<tavatekst id="2eeb4519-c1c8-4e1a-a4ba-e237fbd3e938">Abivahendi tõendile kantakse järgmised andmed:</tavatekst>
				</sisuTekst>
				<alampunkt id="para2b1lg2p1">
					<alampunktNr id="664ccccc-eef5-455f-b3ca-8c1c213b6d84">1</alampunktNr>
					<kuvatavNr id="8a9d7af5-10bb-4f20-b314-7f7a53192427"><![CDATA[1) ]]></kuvatavNr>
					<sisuTekst id="791c3030-6376-4b07-ae3e-3fe536b898cb">
						<tavatekst id="152c835e-9a51-4f64-8887-9d7320abfd17">isiku üldandmed (ees- ja perekonnanimi, isikukood);</tavatekst>
					</sisuTekst>
				</alampunkt>
				<alampunkt id="para2b1lg2p2">
					<alampunktNr id="761cdd11-9d3d-4cf8-8011-993cef08c379">2</alampunktNr>
					<kuvatavNr id="0a9065b7-6129-44f3-8a36-a8924306bd01"><![CDATA[2) ]]></kuvatavNr>
					<sisuTekst id="d8f052f6-1e50-4bd7-b219-26d3d30e5c89">
						<tavatekst id="0290a653-cd62-4c5d-adcb-5ab06678b076">tõendi väljastaja andmed (asutuse ja abivahendi vajaduse tuvastaja andmed);</tavatekst>
					</sisuTekst>
				</alampunkt>
				<alampunkt id="para2b1lg2p3">
					<alampunktNr id="5dbecdab-d2bb-4595-92a7-c70c3d928ee8">3</alampunktNr>
					<kuvatavNr id="4ac4446a-c829-4c33-a3d4-650b92d38d9f"><![CDATA[3) ]]></kuvatavNr>
					<sisuTekst id="fdcb9a40-3750-4571-ad2d-d2b535e4b8a1">
						<tavatekst id="9cdaa6b8-dc95-4d18-bc2d-d2b16eaedd16">abivahendi andmed (abivahendi ISO-kood, nimetus või kirjeldus);</tavatekst>
					</sisuTekst>
				</alampunkt>
				<alampunkt id="para2b1lg2p4">
					<alampunktNr id="f55dcdc0-58e4-4557-ae63-ff1b4c92a384">4</alampunktNr>
					<kuvatavNr id="fcc863eb-69c5-4e20-a5f6-e335e4334713"><![CDATA[4) ]]></kuvatavNr>
					<sisuTekst id="d2f04cc2-40ef-4a05-9493-41d49f97ef38">
						<tavatekst id="1f10a2b9-8099-4251-8196-d74a4cbe5d84">abivahendi määramise põhjus (diagnoosist või funktsioonihäirest lähtuvalt);</tavatekst>
					</sisuTekst>
				</alampunkt>
				<alampunkt id="para2b1lg2p5">
					<alampunktNr id="b42b667f-d1e9-4b18-a745-0daa6f41a348">5</alampunktNr>
					<kuvatavNr id="6ce84a6e-77c1-4d0f-87df-91b44c416a38"><![CDATA[5) ]]></kuvatavNr>
					<sisuTekst id="82b5eb52-8b3a-4007-9e16-03143a8892dc">
						<tavatekst id="aa35ff00-665e-4b54-b937-2d5c81501efa">tõendi üldandmed (tõendi allkirjastaja ja allkirjastamise aeg).</tavatekst>
					</sisuTekst>
					<muutmismarge id="c68e894d-7c10-4689-83bb-f82815adceff">
						<avaldamismarge id="5e140959-fc14-45e6-ac6c-f812f88c3bb2">
							<RTosa id="fd785d83-c723-4907-81d4-409b5732fd2e">RT I</RTosa>
							<avaldamineKuupaev id="473c426a-991c-437c-a385-20bf9c2d02e7">2024-12-29</avaldamineKuupaev>
