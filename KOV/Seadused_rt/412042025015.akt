			</loige>
		</paragrahv>
		<paragrahv id="para2">
			<paragrahvNr id="075c8549-238f-4aae-a494-08f1599ce25d">2</paragrahvNr>
			<kuvatavNr id="548b6225-6115-4232-9fc3-391283a5a602"><![CDATA[§ 2. ]]></kuvatavNr>
			<paragrahvPealkiri id="6d34a253-c503-4969-886e-a196ffa7db13">Lastekaitseseadusega kohaliku omavalitsuse üksusele pandud ülesannete täitmise delegeerimine</paragrahvPealkiri>
			<loige id="para2lg1">
				<loigeNr id="9597a7f4-18d7-41a7-99d9-ad27c8b59ed7">1</loigeNr>
				<kuvatavNr id="c1af41e9-007b-4bd7-9f13-18825d39395c"><![CDATA[(1)]]></kuvatavNr>
				<sisuTekst id="c30fa7fb-3460-4807-ac64-e18fca514129">
					<tavatekst id="631fd2e6-3d3c-43e9-882e-b1001d8c9302">Linnavalitsusele delegeeritakse järgmised ülesanded:</tavatekst>
				</sisuTekst>
				<alampunkt id="para2lg1p1">
					<alampunktNr id="9374978e-1b4c-47f0-8a13-b758e4bb76fa">1</alampunktNr>
					<kuvatavNr id="c78a6d13-b87e-4630-8958-df58ee1c6359"><![CDATA[1) ]]></kuvatavNr>
					<sisuTekst id="5c770fcf-087d-4851-ba67-66c7cdf5b13f">
						<tavatekst id="c0944e75-1609-49ea-9955-b0dcabe46bb9">lastekaitse korraldamine;</tavatekst>
					</sisuTekst>
				</alampunkt>
				<alampunkt id="para2lg1p2">
					<alampunktNr id="73496596-64a6-4b9b-b478-9a83914b7b74">2</alampunktNr>
					<kuvatavNr id="535e9b9b-d466-4558-8c8f-9d9a8a295911"><![CDATA[2) ]]></kuvatavNr>
					<sisuTekst id="e59cb548-d938-41e1-b438-d77614b18933">
						<tavatekst id="78970548-796c-4fd3-b707-6514f8302c8f">lapse õigusi ja heaolu tagavate programmide ja projektide väljatöötamine ning nende rakendamine Tallinna haldusterritooriumil last ohustavate riskide ennetamiseks ja vähendamiseks;</tavatekst>
					</sisuTekst>
				</alampunkt>
				<alampunkt id="para2lg1p3">
					<alampunktNr id="a1df9b90-234c-4ed8-9757-c50e99c447a9">3</alampunktNr>
					<kuvatavNr id="efe44f60-e4db-46b7-b492-deb582e30fec"><![CDATA[3) ]]></kuvatavNr>
					<sisuTekst id="875c7142-ed5d-4a00-bf35-7e9f0553cdc7">
						<tavatekst id="053a35c7-8150-4377-86cd-3e9c1cc3c2c4">linna ametiasutuste hallatavate lasteasutuste sisehindamise üle teenistusliku järelevalve korraldamine;</tavatekst>
					</sisuTekst>
				</alampunkt>
				<alampunkt id="para2lg1p4">
					<alampunktNr id="126b348b-670d-403c-b1ee-0c4f77b783e0">4</alampunktNr>
					<kuvatavNr id="ffdfc103-9367-474d-b02a-1ca477f64e42"><![CDATA[4) ]]></kuvatavNr>
					<sisuTekst id="84bfa83c-dfb4-4b6e-9a5f-05078c39a02a">
						<tavatekst id="64986dec-b399-41a1-bbb8-90818b9625c7">alaealise öise liikumispiirangu ajutine lühendamine;</tavatekst>
					</sisuTekst>
				</alampunkt>
				<alampunkt id="para2lg1p5">
					<alampunktNr id="729cdd4f-a0c3-4fd8-bc3f-0adef4176e14">5</alampunktNr>
					<kuvatavNr id="e6c2cb04-6d6f-46bb-814d-dbc71fe3f55e"><![CDATA[5) ]]></kuvatavNr>
					<sisuTekst id="dab047cc-bb1d-422b-915d-fd35ae60feaa">
						<tavatekst id="f8e55610-67ca-4acd-862b-102afbd2a9ef">tingimuste loomine lastekaitsetöö tegemiseks eesmärgiga tagada kohaliku omavalitsuse üksuse ülesannete täitmine; laste ja perede komisjoni moodustamine.</tavatekst>
					</sisuTekst>
				</alampunkt>
			</loige>
			<loige id="para2lg2">
				<loigeNr id="0e81c420-d83b-4d4f-a655-73bde1e91c6f">2</loigeNr>
				<kuvatavNr id="2337052d-1048-48b7-b10a-b16f175343c5"><![CDATA[(2)]]></kuvatavNr>
				<sisuTekst id="f50147f8-713b-408d-a297-0ddf461adf13">
					<tavatekst id="7481b8f5-7186-4c24-8636-e74da7884bd3">Tallinna Sotsiaal- ja Tervishoiuametile delegeeritakse järgmised ülesanded:</tavatekst>
				</sisuTekst>
				
				<alampunkt id="para2lg2p1">
					<alampunktNr id="bb8320fb-a685-4b6a-92fc-89ca5cc717c1">1</alampunktNr>
					<kuvatavNr id="08d27964-7f01-4542-a02c-1b9313fda664"><![CDATA[1) ]]></kuvatavNr>
					<sisuTekst id="2e50f5f8-d535-4d1d-bb5f-3816e88d5f78">
						<tavatekst id="6f91f5d7-23c0-47ef-a8ce-6041f8ae0091">lapse arengut toetava keskkonna loomiseks ning laste, lastega perede ja lapsi kasvatavate isikute toimetuleku parandamiseks vajaliku teabe kogumine laste ja perede olukorra ning vajaduste kohta;</tavatekst>
					</sisuTekst>
					
				</alampunkt>
				<alampunkt id="para2lg2p2">
					<alampunktNr id="ec2241e2-aec8-4645-8c72-9ecb2ea2816c">2</alampunktNr>
					<kuvatavNr id="abe79429-428c-4386-a995-1a177a00e45d"><![CDATA[2) ]]></kuvatavNr>
					<sisuTekst id="29baea64-9823-4090-8472-c14d48f18025">
						<tavatekst id="10f13585-2939-4627-ac3b-6d940917344a">abi vajavast lapsest teada saamisel viivitamata lapse abivajaduse hindamine ja lapse abistamiseks meetmete pakkumine;</tavatekst>
					</sisuTekst>
					
				</alampunkt>
				<alampunkt id="para2lg2p3">
					<alampunktNr id="a4a7223f-5262-4e0e-b04e-26c9f56f3d77">3</alampunktNr>
					<kuvatavNr id="24c9d894-323b-4e96-9430-88178918c3ce"><![CDATA[3) ]]></kuvatavNr>
					<sisuTekst id="9b2f4285-4593-48ea-85ee-a822673dd06b">
						<tavatekst id="facdf957-1337-4aba-ad61-0af97d29e661">perekonnast eraldatud lapsele ja tema perekonnale meetmete pakkumine;</tavatekst>
					</sisuTekst>
					
				</alampunkt>
				<alampunkt id="para2lg2p4">
					<alampunktNr id="4afbe239-7c0a-4714-a615-f421e1ab07b8">4</alampunktNr>
					<kuvatavNr id="f982d29a-31d9-4739-9fe8-29dbd7bd0ec4"><![CDATA[4) ]]></kuvatavNr>
					<sisuTekst id="1a11f9d2-79f9-4071-b06a-d06f03cc8ce8">
						<tavatekst id="200949cf-224d-442f-944f-c051810cc158">riikliku järelevalve teostamine lastekaitseseaduses sätestatud alustel.</tavatekst>
					</sisuTekst>
					<muutmismarge id="bd97cb2e-5ad5-4420-92f7-a2b47bc6eb69">
						<avaldamismarge id="479be32a-9fd2-46d2-9013-dc7c9bf34af7">
							<RTosa id="1bcf352d-9032-4bed-96c3-7bc08ed6ad2a">RT IV</RTosa>
							<avaldamineKuupaev id="f0003d11-639e-4a9c-88db-cecb3cb18e47">2025-04-12</avaldamineKuupaev>
							<RTartikkel id="b16c075d-7e69-4549-b5a6-f47647ad54be">1</RTartikkel>
							<aktViide id="c14c2dcd-1a2f-4cd1-ab87-60514f04fed4">412042025001</aktViide>
						</avaldamismarge>
						<joustumine id="0fd3e056-c31d-4e2f-ac28-6063bf4fe79e">2025-05-01</joustumine>
					</muutmismarge>
				</alampunkt>
			</loige>
			<loige id="para2lg3">
				<loigeNr id="b23151f3-e92d-4890-961d-4322d2d62862">3</loigeNr>
				<kuvatavNr id="567fb52a-fdbb-4011-8edc-fad9fd900eb3"><![CDATA[(3)]]></kuvatavNr>
				
				<muutmismarge id="e1cd7203-788f-47b6-aa81-0f21185a94ef">
					<tavatekst id="ace1198b-08e1-49a1-a5a1-0df7a7417604">Kehtetu -</tavatekst>
					<avaldamismarge id="9f3feb5d-4387-4c7e-a3fc-49e37dbf05b4">
						<RTosa id="01b7c9f8-649b-4968-9417-15457e663b7a">RT IV</RTosa>
						<avaldamineKuupaev id="76221b73-a807-4c90-b68c-9b030379dca2">2025-04-12</avaldamineKuupaev>
						<RTartikkel id="6db859a8-309b-4a34-9dac-add8c1345de2">1</RTartikkel>
						<aktViide id="c34bffcc-310c-4b24-825b-a6d4ff444e07">412042025001</aktViide>
					</avaldamismarge>
					<joustumine id="762bec21-3223-45ba-99ed-c943017e98f5">2025-05-01</joustumine>
				</muutmismarge>
			</loige>
		</paragrahv>
		<paragrahv id="para3">
			<paragrahvNr id="7efb6ded-40e6-41f7-a964-50d130369b53">3</paragrahvNr>
			<kuvatavNr id="d237698c-f173-4ac1-88b2-b5fdb6e0ea12"><![CDATA[§ 3. ]]></kuvatavNr>
			<paragrahvPealkiri id="c70e4de9-26e7-46fa-9c2d-5374f3898e61">Sotsiaalseadustiku üldosa seadusega kohaliku omavalitsuse üksusele pandud ülesannete täitmise delegeerimine</paragrahvPealkiri>
			<muutmismarge id="c406cfc7-58e5-4b32-9644-4476e843807c">
				<tavatekst id="96c4792b-c07e-4871-b155-974fc6409848">Kehtetu -</tavatekst>
				<avaldamismarge id="2f749fa5-09a6-428d-9b3e-5daf9f5402f8">
					<RTosa id="5f9d0b45-a05f-4845-8307-9ff9fd7583b4">RT IV</RTosa>
					<avaldamineKuupaev id="8430d779-0099-48b6-94ec-93d9829c6be9">2025-04-12</avaldamineKuupaev>
					<RTartikkel id="e5cfa9b4-fe44-4e99-9222-755d8cc45924">1</RTartikkel>
					<aktViide id="28fcc433-7aca-4180-834a-89d3f74108b5">412042025001</aktViide>
				</avaldamismarge>
				<joustumine id="e63cb328-94bf-42b5-bd46-4b26fff63209">2025-05-01</joustumine>
			</muutmismarge>
		</paragrahv>
		<paragrahv id="para4">
			<paragrahvNr id="b51a2b99-9d99-430e-a24e-dd7574bb4229">4</paragrahvNr>
			<kuvatavNr id="9f6baec1-7391-48b7-9f55-1de4da2836a1"><![CDATA[§ 4. ]]></kuvatavNr>
			<paragrahvPealkiri id="6b0f4481-4c48-4597-bead-62a3919e7292">Riigilõivuseadusega kohaliku omavalitsuse üksusele pandud ülesannete täitmise delegeerimine</paragrahvPealkiri>
			<loige id="para4lg1">
				<sisuTekst id="e02f3146-c763-4f3c-877c-352e8472e65d">
					<tavatekst id="05ac3560-91e7-4f10-8329-55aab5a7ef22">Linnaosade valitsuste sotsiaalhoolekande osakondade juhatajatele delegeeritakse edasivolitamise õigusega ülesanne esitada Politsei- ja Piirivalveametile või konsulaarametnikule taotlusi isikute riigilõivu tasumisest vabastamiseks või tasutava riigilõivu määra vähendamiseks.</tavatekst>
				</sisuTekst>
			</loige>
		</paragrahv>
		<paragrahv id="para5">
			<paragrahvNr id="bc8df501-a902-4270-a83f-506c12b374f4">5</paragrahvNr>
			<kuvatavNr id="783de4dd-7d26-4870-871f-f5a52a7f9816"><![CDATA[§ 5. ]]></kuvatavNr>
			<paragrahvPealkiri id="0aeab691-ee44-406f-9909-c85a6a14f2a4">Määruste kehtetuks tunnistamine</paragrahvPealkiri>
			<loige id="para5lg1">
				<loigeNr id="11016e0b-3a2e-47a8-b510-719680d3e7ae"/>
