				<alampunkt id="para1lg3p7">
					<alampunktNr id="6b853ab0-11c9-4a12-9c13-67b25c15c2e1">7</alampunktNr>
					<kuvatavNr id="38bfd283-0361-4f1a-a7d0-a227e36593e5"><![CDATA[7) ]]></kuvatavNr>
					
					<muutmismarge id="3ae5fd15-b6fa-4082-a358-50e34ec10a83">
						<tavatekst id="947816e6-0609-40b5-8862-2eda664ef1c2">kehtetu -</tavatekst>
						<avaldamismarge id="22986740-87e5-42eb-b60f-d1e6c99fd5f1">
							<RTosa id="4a68e9bd-152b-45f4-bda9-7d9e4b94d7d8">RT IV</RTosa>
							<avaldamineKuupaev id="e98de316-2b71-4ebf-aadd-815afb7b7322">2025-04-12</avaldamineKuupaev>
							<RTartikkel id="d1a7c765-37b9-4884-8fa8-70e7c25203f2">1</RTartikkel>
							<aktViide id="e6ac42d3-d547-4e75-81b3-58a851e4af2c">412042025001</aktViide>
						</avaldamismarge>
						<joustumine id="53b2f179-51c3-4d30-b32d-bde5ee2d5490">2025-05-01</joustumine>
					</muutmismarge>
				</alampunkt>
				<alampunkt id="para1lg3p8">
					<alampunktNr id="7130f4ae-0fe7-4528-baa6-3d6776b1c767">8</alampunktNr>
					<kuvatavNr id="424e675b-6eed-4c5b-a5f6-02bcf9ce70fa"><![CDATA[8) ]]></kuvatavNr>
					<sisuTekst id="2c834ee4-39a6-49db-9694-8e3709f06143">
						<tavatekst id="a9284ee3-675e-46e6-b430-269ac9b4e2be">riigieelarvest makstava täiendava sotsiaaltoetuse määramine ja maksmine.</tavatekst>
					</sisuTekst>
				</alampunkt>
				<alampunkt id="para1lg3p9">
					<alampunktNr id="84bbc373-665b-4033-bc77-bfa2c7878ac3">9</alampunktNr>
					<kuvatavNr id="9f435656-c239-42f7-9861-269de121b966"><![CDATA[9) ]]></kuvatavNr>
					
					<muutmismarge id="eb579e5f-94f4-4c28-b8fa-c008364b0763">
						<tavatekst id="2249026c-f019-45ea-97ed-1fd0cba75b0d">kehtetu -</tavatekst>
						<avaldamismarge id="a0259e1a-3ce7-44ea-8fc6-31171ae2b2e6">
							<RTosa id="6f88c1a4-9597-40d1-96f2-b724f5c263f0">RT IV</RTosa>
							<avaldamineKuupaev id="98b6a0cc-48f7-4244-b832-e7ba6a3c6f4a">2025-04-12</avaldamineKuupaev>
							<RTartikkel id="fabe4668-e4bb-4ca2-bc17-ae8876fac082">1</RTartikkel>
							<aktViide id="4c77cb61-d863-4700-87d8-c1e65d219d00">412042025001</aktViide>
						</avaldamismarge>
