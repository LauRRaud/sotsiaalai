			<paragrahv id="para46">
				<paragrahvNr kehtiv="0">46</paragrahvNr>
				<kuvatavNr><![CDATA[§ 46. ]]></kuvatavNr>
				<sisuTekst>
					<tavatekst>[Käesolevast tekstist välja jäetud.]</tavatekst>
				</sisuTekst>
			</paragrahv>
			<paragrahv id="para47">
				<paragrahvNr>47</paragrahvNr>
				<kuvatavNr><![CDATA[§ 47.]]></kuvatavNr>
				<paragrahvPealkiri>Seaduse jõustumine</paragrahvPealkiri>
				<loige id="para47lg1">
					<loigeNr>1</loigeNr>
					<kuvatavNr><![CDATA[(1)]]></kuvatavNr>
					<sisuTekst>
						<tavatekst>Käesolev seadus jõustub 2016. aasta 1. jaanuaril.</tavatekst>
					</sisuTekst>
				</loige>
				<loige id="para47lg2">
					<loigeNr>2</loigeNr>
					<kuvatavNr><![CDATA[(2)]]></kuvatavNr>
					<sisuTekst>
						<tavatekst>Käesoleva seaduse § 19 jõustub 2020. aasta 1. jaanuaril.</tavatekst>
					</sisuTekst>
				</loige>
			</paragrahv>
