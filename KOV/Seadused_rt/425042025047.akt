		</vastuvoetud>
		<avaldamismarge><RTosa>RT IV</RTosa><avaldamineKuupaev>2025-04-25</avaldamineKuupaev><RTaasta>2025</RTaasta><RTartikkel>47</RTartikkel><aktViide>425042025047</aktViide></avaldamismarge><kehtivus>
			<kehtivuseAlgus>2025-05-01</kehtivuseAlgus>
		</kehtivus>
