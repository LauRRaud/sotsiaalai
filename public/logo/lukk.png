>
  <g
    fill="none"
    stroke="#C9C7C2"
    stroke-width="0.9"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <!-- korpus -->
    <rect x="6.5" y="11" width="15" height="9" rx="2.2" ry="2.2" />

    <!-- sang -->
    <path d="M9.5 11V9a4.5 4.5 0 0 1 9 0v2" />
  </g>

