# Core
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000
APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-random-secret
DATABASE_URL=postgresql://sotsiaal_user:sotsiaalai@localhost:5432/sotsiaal_ai

# AI / RAG
OPENAI_API_KEY=replace-with-openai-key
OPENAI_MODEL=gpt-4.1-mini
RAG_INTERNAL_HOST=127.0.0.1:8000
RAG_API_BASE=http://127.0.0.1:8000
RAG_API_KEY=replace-with-rag-api-key
RAG_SERVICE_API_KEY=replace-with-rag-service-key
RAG_DELETE_ON_DOCUMENT_DELETE=true
RAG_TRACE_V1_ENABLED=true
RAG_ATTRIBUTION_DECISIONS_ENABLED=true
RAG_DISPLAYED_SOURCES_ENFORCED=true
RAG_LEXICAL_SEARCH_ENABLED=true
RAG_LEXICAL_SCAN_LIMIT=2000
RAG_LEXICAL_TOP_K=20

# Storage
DOCS_STORAGE_DIR=tmp/documents
MATERIALS_STORAGE_DIR=tmp/materials
AGENT_STORAGE_DIR=tmp/agent

# Retention policy
DATA_RETENTION_DAYS=90
CONVERSATION_TTL_DAYS=90
PAYMENT_RETENTION_DAYS=2555
PAYMENT_RAW_RETENTION_DAYS=90
LOG_RETENTION_DAYS=90
# Documentation/ops policy only; the app does not enforce backup deletion.
BACKUP_RETENTION_DAYS=30

# Email
EMAIL_FROM=no-reply@example.test
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true

# Payments
MAKSEKESKUS_API_BASE=
MAKSEKESKUS_API_KEY=
MAKSEKESKUS_PUBLIC_KEY=
MAKSEKESKUS_SHOP_ID=
MAKSEKESKUS_RETURN_URL=http://localhost:3000/api/subscription/callback
MAKSEKESKUS_CANCEL_URL=http://localhost:3000/api/subscription/callback
MAKSEKESKUS_WEBHOOK_URL=http://localhost:3000/api/subscription/webhook
