{
  "name": "sotsiaalai",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "SotsiaalAI – kaasaegne AI-platvorm sotsiaalvaldkonna spetsialistidele ja abivajajatele.",
  "author": "SotsiaalAI OÜ",
  "scripts": {
    "dev": "cross-env NODE_ENV=development NEXT_DISABLE_TURBOPACK=1 next dev -p 3000",
    "dev:webpack": "cross-env NODE_ENV=development next dev -p 3000",
    "dev:no-turbo": "cross-env NODE_ENV=development next dev -p 3000",
    "portaal": "npm run dev:webpack",
    "test": "npm run dev",
    "db:push:local": "dotenv -e .env.local -- prisma db push",
    "prisma:generate:local": "dotenv -e .env.local -- prisma generate",
    "dev:create-admin:sotsiaalai": "node scripts/create-admin.mjs --email \"admin@sotsiaal.ai\" --password \"sotsiaalai1\" --role ADMIN --admin",
    "build": "npm run i18n:check && next build",
    "start": "cross-env NODE_ENV=production next start -p 3000",
    "serve": "cross-env NODE_ENV=production pm2 start npm --name \"sotsiaalai\" -- start",
    "analyze": "cross-env BUNDLE_ANALYZE=true next build",
    "analyze:dev": "cross-env BUNDLE_ANALYZE=true next dev --turbopack",
    "clean:next": "node scripts/clean-next.mjs",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "check": "prisma generate && npm run i18n:check && next lint",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "dotenv -e .env.production -- prisma migrate deploy",
    "migrate:prod": "dotenv -e .env.production -- prisma migrate deploy",
    "db:push:prod": "dotenv -e .env.production -- prisma db push",
    "prisma:studio:prod": "dotenv -e .env.production -- prisma studio",
    "postinstall": "prisma generate",
    "dev:create-admin": "node scripts/create-admin.mjs --email admin@localhost --password Parool123 --role ADMIN --admin",
    "uuenda": "git add -A && git commit -m \"uuendus\" || echo \"(pole midagi commitida)\"; git push origin main",
    "i18n:types": "node scripts/generate-message-types.mjs",
    "i18n:check": "node scripts/check-messages.mjs",
    "encoding:check": "node scripts/encoding/check.mjs",
    "encoding:fix": "node scripts/encoding/fix.mjs",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@google-cloud/text-to-speech": "^6.4.0",
    "@next-auth/prisma-adapter": "1.0.7",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "@react-three/fiber": "8.18.0",
    "bcrypt": "6.0.0",
    "framer-motion": "^12.23.24",
    "gsap": "^3.13.0",
    "ioredis": "^5.8.2",
    "motion": "^12.23.24",
    "next": "^15.5.7",
    "next-auth": "^4.24.13",
    "ogl": "1.0.11",
    "openai": "^6.8.1",
    "pg": "^8.16.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-parallax-tilt": "1.7.312",
    "sharp": "0.34.5",
    "styled-components": "6.1.19",
    "three": "^0.167.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@next/bundle-analyzer": "^15.5.9",
    "@playwright/test": "^1.56.1",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^24.10.0",
    "autoprefixer": "^10.4.23",
    "cross-env": "10.1.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "9.39.1",
    "eslint-config-next": "^15.5.6",
    "eslint-plugin-unused-imports": "^4.3.0",
    "globals": "^17.0.0",
    "postcss": "^8.5.6",
    "prettier": "3.6.2",
    "prisma": "^7.0.0",
    "tailwindcss": "^4.1.18"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions",
    "not ie <= 11"
  ],
  "engines": {
    "node": ">=18.18 <25"
  }
}
