[
  {
    "name": "rail-back-resting",
    "route": "/vestlus",
    "auth": true,
    "selectors": ["[data-key=\"back\"] svg"],
    "properties": ["transform"]
  },
  {
    "name": "rail-back-hover",
    "route": "/vestlus",
    "auth": true,
    "steps": [{ "hover": "[data-key=\"back\"]", "force": true }],
    "selectors": ["[data-key=\"back\"] svg"],
    "properties": ["transform"]
  },
  {
    "name": "rail-tooltip-hc",
    "route": "/vestlus",
    "auth": true,
    "themes": ["hc"],
    "selectors": ["[role=\"tooltip\"]"],
    "properties": ["border-top-width", "border-top-style", "border-top-color", "background-clip"]
  },
  {
    "name": "dropdown-trigger",
    "route": "/documents",
    "auth": true,
    "selectors": [".documents-dropdown-trigger", ".documents-dropdown-label"],
    "properties": ["background", "background-color", "border-top-width", "border-top-color", "box-shadow", "color", "opacity"]
  },
  {
    "name": "dropdown-menu-open",
    "route": "/documents",
    "auth": true,
    "steps": [{ "click": ".documents-dropdown-trigger" }],
    "selectors": [".documents-dropdown-menu", ".documents-dropdown-item"],
    "properties": ["background", "background-color", "border-top-width", "border-top-color", "box-shadow", "color", "opacity"]
  }
]
