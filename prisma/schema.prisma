}

model CallParticipant {
  id            String              @id @default(cuid())
  callSessionId String
  userId        String
  role          CallParticipantRole @default(PARTICIPANT)
  joinedAt      DateTime            @default(now())
  leftAt        DateTime?
  micMuted      Boolean             @default(false)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  callSession CallSession @relation(fields: [callSessionId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([callSessionId, leftAt])
  @@index([callSessionId, userId])
  @@index([userId, joinedAt])
}

model CallSpeakRequest {
  id               String                 @id @default(cuid())
  callSessionId    String
  userId           String
  status           CallSpeakRequestStatus @default(ACTIVE)
  requestedAt      DateTime               @default(now())
  resolvedAt       DateTime?
  resolvedByUserId String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  callSession CallSession @relation(fields: [callSessionId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  resolvedBy  User?       @relation("CallSpeakRequestResolvedBy", fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  @@index([callSessionId, status, requestedAt])
  @@index([userId, status])
}

model CallRecordingRequest {
  id                  String                     @id @default(cuid())
  callSessionId       String
  requestedByUserId   String
  purpose             CallRecordingPurpose       @default(GENERAL_SUMMARY)
  purposeText         String?                    @db.Text
  status              CallRecordingRequestStatus @default(REQUESTED)
  consentTextVersion  String
  consentTextSnapshot String                     @db.Text
  requestedAt         DateTime                   @default(now())
  startedAt           DateTime?
  stoppedAt           DateTime?
  completedAt         DateTime?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt

  callSession CallSession            @relation(fields: [callSessionId], references: [id], onDelete: Cascade)
  requestedBy User                   @relation("CallRecordingRequestRequestedBy", fields: [requestedByUserId], references: [id], onDelete: Cascade)
  consents    CallRecordingConsent[]
  files       CallRecordingFile[]

  @@index([callSessionId, status])
  @@index([requestedByUserId, requestedAt])
}

model CallRecordingConsent {
  id                  String                     @id @default(cuid())
  recordingRequestId  String
  callSessionId       String
  userId              String
  status              CallRecordingConsentStatus @default(REQUESTED)
  consentTextVersion  String
  consentTextSnapshot String                     @db.Text
  respondedAt         DateTime?
  withdrawnAt         DateTime?
  ipAddressHash       String?
  userAgentHash       String?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt

  recordingRequest CallRecordingRequest @relation(fields: [recordingRequestId], references: [id], onDelete: Cascade)
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([recordingRequestId, status])
  @@index([callSessionId, userId])
}

model CallRecordingFile {
  id                 String                  @id @default(cuid())
  recordingRequestId String
  callSessionId      String
  egressId           String?
  storageProvider    String?
  filePath           String?
  mimeType           String?
  fileSizeBytes      Int?
  durationSeconds    Int?
  checksum           String?
  status             CallRecordingFileStatus @default(NOT_CREATED)
  createdDocumentId  String?
  retentionUntil     DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  recordingRequest CallRecordingRequest @relation(fields: [recordingRequestId], references: [id], onDelete: Cascade)
  callSession      CallSession          @relation(fields: [callSessionId], references: [id], onDelete: Cascade)
  createdDocument  UserDocument?        @relation(fields: [createdDocumentId], references: [id], onDelete: SetNull)

  @@index([recordingRequestId, status])
  @@index([callSessionId, status])
  @@index([createdDocumentId])
}

model UserDocument {
  id                    String       @id @default(cuid())
  ownerId               String
  title                 String
  originalName          String
  kind                  DocumentKind @default(MATERIAL)
  templateFor           TemplateFor?
  agentAllowed          Boolean      @default(false)
  mime                  String
  size                  Int
  sha256                String
  storagePath           String
  frameworkAcceptanceId String?      @unique
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  owner               User                          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  frameworkAcceptance FrameworkAcceptance?          @relation(fields: [frameworkAcceptanceId], references: [id], onDelete: SetNull)
  templateArtifacts   AgentArtifact[]               @relation("AgentArtifactTemplate")
  sourceArtifactLinks AgentArtifactSourceDocument[]
  audits              DocumentAudit[]
  callRecordingFiles  CallRecordingFile[]

  @@index([ownerId, updatedAt])
  @@index([ownerId, kind, updatedAt])
  @@index([ownerId, agentAllowed, updatedAt])
  @@index([sha256])
}

model FrameworkAcceptance {
  id                         String    @id @default(cuid())
  userId                     String
  frameworkKey               String
  frameworkVersion           String
  acceptanceType             String
  acceptanceSource           String
  roleAtAcceptance           Role
  locale                     String?
  ipAddress                  String?
  userAgent                  String?
  acceptedAt                 DateTime  @default(now())
  reviewDocumentOpenedAt     DateTime?
  signedDocumentDownloadedAt DateTime?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  document UserDocument?

  @@index([userId, acceptedAt])
  @@index([frameworkKey, frameworkVersion, acceptedAt])
  @@index([acceptanceType, acceptedAt])
}

model AgentArtifact {
  id         String              @id @default(cuid())
  ownerId    String
  type       AgentArtifactType
  title      String?
  status     AgentArtifactStatus @default(DRAFT)
  content    String              @db.Text
  approvedAt DateTime?
  templateId String?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  owner           User                          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  template        UserDocument?                 @relation("AgentArtifactTemplate", fields: [templateId], references: [id], onDelete: SetNull)
  sourceDocuments AgentArtifactSourceDocument[]
  audits          DocumentAudit[]

  @@index([ownerId, updatedAt])
  @@index([ownerId, type, updatedAt])
  @@index([ownerId, status, updatedAt])
  @@index([templateId])
}

model AgentArtifactSourceDocument {
  artifactId String
  documentId String
  createdAt  DateTime @default(now())

  artifact AgentArtifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  document UserDocument  @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@id([artifactId, documentId])
  @@index([documentId])
}

model DocumentAudit {
  id         String              @id @default(cuid())
  ownerId    String
  documentId String?
  artifactId String?
  action     DocumentAuditAction
  meta       Json?
  createdAt  DateTime            @default(now())

  owner    User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  document UserDocument?  @relation(fields: [documentId], references: [id], onDelete: SetNull)
  artifact AgentArtifact? @relation(fields: [artifactId], references: [id], onDelete: SetNull)

  @@index([ownerId, createdAt])
  @@index([documentId, createdAt])
  @@index([artifactId, createdAt])
  @@index([action, createdAt])
}

model MaterialSubmission {
  id                String    @id @default(cuid())
  submittedByUserId String
  comment           String    @db.Text
  originalName      String
  mime              String
  size              Int
  sha256            String
  storagePath       String
  status            String    @default("pending")
  reviewedAt        DateTime?
  reviewedBy        String?
  reviewNote        String?   @db.Text
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  submittedByUser User @relation(fields: [submittedByUserId], references: [id], onDelete: Cascade)

  @@index([submittedByUserId, createdAt])
  @@index([createdAt])
  @@index([sha256])
  @@index([status, createdAt])
  @@index([reviewedAt])
}
