/**
 * ---------- Models ----------
 */

model User {
  id                      String    @id @default(cuid())
  email                   String?   @unique
  emailVerified           DateTime?
  emailVerificationSentAt DateTime?
  passwordHash            String?
  role                    Role      @default(CLIENT)
  isAdmin                 Boolean   @default(false)
  sessionVersion          Int       @default(0)
  acceptsPreInquiries     Boolean   @default(false)

  // NextAuth
  accounts Account[]
  sessions Session[]

  // Äri
  profile                Profile?
  subscriptions          Subscription[]
  payments               Payment[]
  billingMethods         BillingMethod[]
  sponsoredSubscriptions Subscription[]        @relation("SubscriptionSponsorUser")
  ragDocuments           RagDocument[]
  documents              UserDocument[]
  agentArtifacts         AgentArtifact[]
  documentAudits         DocumentAudit[]
  frameworkAcceptances   FrameworkAcceptance[]
  materialSubmissions    MaterialSubmission[]

  // Chat / runs
  conversationRuns        ConversationRun[]
  conversationMessages    ConversationMessage[]
  conversations           Conversation[]
  analyzeUsage            AnalyzeUsage[]
  emailOtpCodes           EmailOtpCode[]
  trustedDevices          TrustedDevice[]
  loginTempTokens         LoginTempToken[]
  roomsOwned              Room[]
  roomMemberships         RoomMember[]
  sentInvites             Invite[]                 @relation("InviterUser")
  sponsoredInvites        Invite[]                 @relation("InviteSponsorUser")
  sponsoredMembers        RoomMember[]             @relation("RoomMemberSponsorUser")
  acceptedInvites         Invite[]                 @relation("InviteAcceptedBy")
  roomMessages            RoomMessage[]            @relation("RoomMessageAuthor")
  callSessionsStarted     CallSession[]            @relation("CallSessionStartedBy")
  callParticipants        CallParticipant[]
  callSpeakRequests       CallSpeakRequest[]
  callSpeakRequestsClosed CallSpeakRequest[]        @relation("CallSpeakRequestResolvedBy")
  callRecordingRequests   CallRecordingRequest[]    @relation("CallRecordingRequestRequestedBy")
  callRecordingConsents   CallRecordingConsent[]
  helpRequests            HelpRequest[]
  helpOffers              HelpOffer[]
  requestedHelpMatches    HelpMatch[]              @relation("HelpMatchRequester")
  offeredHelpMatches      HelpMatch[]              @relation("HelpMatchOfferer")
  researchJobs            ResearchJob[]
  serviceProviderProfiles ServiceProviderProfile[]
  authoredPreInquiries    PreInquiry[]             @relation("PreInquiryAuthor")
  receivedPreInquiries    PreInquiry[]             @relation("PreInquiryRecipientOwner")
  covisionCasesOwned      CovisionCase[]           @relation("CovisionCaseOwner")
  covisionParticipants    CovisionParticipant[]    @relation("CovisionParticipantUser")
  covisionMessages        CovisionMessage[]        @relation("CovisionMessageAuthor")
  effectivePractices      EffectivePractice[]      @relation("EffectivePracticeAuthor")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([acceptsPreInquiries])
}

model Profile {
  id        String  @id @default(cuid())
  userId    String  @unique
  firstName String?
  lastName  String?
  phone     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String

  refresh_token String?
  access_token  String?
  expires_at    Int?
  token_type    String?
  scope         String?
  id_token      String?
  session_state String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Subscription {
  id                String             @id @default(cuid())
  userId            String
  status            SubscriptionStatus @default(NONE)
  plan              String             @default("kuutellimus")
  billingMode       BillingMode        @default(ONE_OFF)
  billingInterval   BillingInterval?
  billingMethodId   String?
  billingSource     BillingSource      @default(SELF)
  sponsorUserId     String?
  inviteId          String?
  validUntil        DateTime?
  nextBilling       DateTime?
  lastBilledAt      DateTime?
  pastDueSince      DateTime?
  billingRetryCount Int                @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  canceledAt        DateTime?

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  billingMethod BillingMethod? @relation(fields: [billingMethodId], references: [id], onDelete: SetNull)
  sponsorUser   User?          @relation("SubscriptionSponsorUser", fields: [sponsorUserId], references: [id], onDelete: SetNull)
  invite        Invite?        @relation("InviteGrantedSubscription", fields: [inviteId], references: [id], onDelete: SetNull)
  payments      Payment[]

  @@index([userId])
  @@index([status])
  @@index([validUntil])
  @@index([billingMode])
  @@index([billingMethodId])
  @@index([billingSource])
  @@index([sponsorUserId])
  @@index([inviteId])
}

model Payment {
  id                String          @id @default(cuid())
  subscriptionId    String?
  inviteId          String?
  userId            String
  provider          PaymentProvider @default(MAKSEKESKUS)
  kind              PaymentKind     @default(OTHER)
  billingMethodId   String?
  providerPaymentId String
  amount            Decimal         @db.Decimal(10, 2)
  currency          String          @default("EUR")
  status            PaymentStatus
  paidAt            DateTime?
  failedAt          DateTime?
  refundedAt        DateTime?
  attemptNumber     Int             @default(1)
  raw               Json?
  createdAt         DateTime        @default(now())

  subscription  Subscription?  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  billingMethod BillingMethod? @relation(fields: [billingMethodId], references: [id], onDelete: SetNull)
  invite        Invite?        @relation(fields: [inviteId], references: [id], onDelete: SetNull)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerPaymentId])
  @@index([subscriptionId])
  @@index([billingMethodId])
  @@index([inviteId])
  @@index([userId])
  @@index([kind])
}

model BillingMethod {
  id                 String              @id @default(cuid())
  userId             String
  provider           PaymentProvider     @default(MAKSEKESKUS)
  status             BillingMethodStatus @default(PENDING)
  providerCustomerId String?
  providerToken      String?
  providerMandateId  String?
  label              String?
  expiresAt          DateTime?
  activatedAt        DateTime?
  revokedAt          DateTime?
  lastUsedAt         DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]
  payments      Payment[]

  @@index([userId])
  @@index([status])
  @@index([provider])
  @@index([providerCustomerId])
  @@index([providerMandateId])
}

model RagDocument {
  id      String  @id @default(cuid())
  adminId String?
  admin   User?   @relation(fields: [adminId], references: [id], onDelete: SetNull)

  title       String?
  description String?
  type        RagSourceType
  status      RagStatus     @default(PENDING)
  audience    Audience      @default(BOTH)

  // Päritolu
  sourceUrl String?
  fileName  String?
  mimeType  String?
  fileSize  Int?

  // RAG backendi dokument (stabiilne id) – hoia unikaalsena
  remoteId String? @unique

  // Veahaldus ja toor-meta
  error      String?
  metadata   Json?
  insertedAt DateTime?

  // --- Ajakirja/Artikli meta ---
  authors      String[] @default([]) // Postgres: text[]
  issueId      String?
  issueLabel   String?
  year         Int?
  articleId    String?
  section      String?
  pages        Int[]    @default([]) // Postgres: integer[]
  pageRange    String?
  journalTitle String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // --- Indeksid ---
  @@index([adminId])
  @@index([status])
  @@index([audience])
  @@index([type])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([insertedAt])
  @@index([journalTitle])
  @@index([issueLabel])
  @@index([year])
  @@index([articleId])
  // kiired otsingud/loetelud
  @@index([sourceUrl])
  @@index([fileName])
  @@index([mimeType])
  // kombineeritud sort/filtri muster admin-paneelile
  @@index([status, updatedAt, createdAt])
}

model SourcePackageSnapshot {
  id               String                             @id @default(cuid())
  packageId        String
  canonicalItemId  String
  municipalityId   String?
  packageType      String
  title            String?
  status           String                             @default("active")
  confidence       String?
  missingSections  Json
  packageHash      String
  lastBuiltAt      DateTime                           @default(now())
  lastChecked      DateTime?
  version          Int
  sectionSummary   Json
  sourceMembership Json
  active           Boolean                            @default(true)
  reviewStatus     String                             @default("pending")
  reviewedAt       DateTime?
  reviewedBy       String?
  reviewNote       String?
  createdAt        DateTime                           @default(now())
  updatedAt        DateTime                           @updatedAt
  reviewEvents     SourcePackageSnapshotReviewEvent[]

  @@unique([packageId, packageHash])
  @@unique([packageId, version])
  @@index([packageId, active])
  @@index([municipalityId])
  @@index([packageType])
  @@index([status])
  @@index([reviewStatus])
  @@index([lastBuiltAt])
}

model SourcePackageSnapshotReviewEvent {
  id               String   @id @default(cuid())
  snapshotId       String
  packageId        String
  action           String
  actor            String?
  note             String?
  fromStatus       String?
  toStatus         String?
  fromReviewStatus String?
  toReviewStatus   String?
  fromActive       Boolean?
  toActive         Boolean?
  metadata         Json?
  createdAt        DateTime @default(now())

  snapshot SourcePackageSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([snapshotId, createdAt])
  @@index([packageId, createdAt])
  @@index([action])
}

model ConversationRun {
  /// Frontendi saadetud convId (nt randomUUID). Hoia stabiilsena sama vestluse jooksul.
  id       String    @id
  userId   String
  role     Role
  text     String    @default("") @db.Text
  sources  Json?
  status   RunStatus @default(RUNNING)
  isCrisis Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
  @@index([status])
  @@index([userId, status, updatedAt])
  @@index([isCrisis, updatedAt])
}

model Conversation {
  id             String    @id @default(cuid())
  userId         String
  title          String?
  summary        String?   @db.Text
  metadata       Json?
  role           Role
  lastActivityAt DateTime  @default(now())
  expiresAt      DateTime?
  archivedAt     DateTime?
  isPinned       Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user     User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ConversationMessage[]

  @@index([userId, isPinned, lastActivityAt])
  @@index([userId, archivedAt])
  @@index([expiresAt])
}

model ConversationMessage {
  id             String                  @id @default(cuid())
  conversationId String
  authorId       String?
  role           ConversationMessageRole
  content        String                  @db.Text
  metadata       Json?
  createdAt      DateTime                @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  author       User?        @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([authorId])
}

/// Päevane analüüsi kasutus per kasutaja (püsiv kvoodi arvestus)
model AnalyzeUsage {
  id        String   @id @default(cuid())
  userId    String
  day       DateTime @db.Date
  count     Int      @default(0)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, day], name: "userId_day")
  @@index([userId])
}

model EmailOtpCode {
  id        String    @id @default(cuid())
  userId    String
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model TrustedDevice {
  id                   String    @id @default(cuid())
  userId               String
  deviceTokenHash      String    @unique
  name                 String?
  userAgentFingerprint String?
  ipRange              String?
  expiresAt            DateTime
  lastUsedAt           DateTime?
  createdAt            DateTime  @default(now())

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  loginTokens LoginTempToken[]

  @@index([userId])
  @@index([expiresAt])
}

model LoginTempToken {
  id              String    @id @default(cuid())
  userId          String
  tokenHash       String    @unique
  requiresOtp     Boolean   @default(false)
  otpVerifiedAt   DateTime?
  expiresAt       DateTime
  usedAt          DateTime?
  userAgent       String?
  ipAddress       String?
  trustedDeviceId String?
  createdAt       DateTime  @default(now())

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  trustedDevice TrustedDevice? @relation(fields: [trustedDeviceId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([expiresAt])
}

// Chat / RAG telemetry log
model ChatLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId String?
  role   String?
  event  String
  data   Json

  @@index([createdAt])
  @@index([event, createdAt])
  @@index([role, createdAt])
}

model DataAuditLog {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  actorUserId  String?
  targetUserId String?
  action       String
  resourceType String?
  resourceId   String?
  ipAddress    String?
  userAgent    String?
  meta         Json?

  @@index([createdAt])
  @@index([actorUserId, createdAt])
  @@index([targetUserId, createdAt])
  @@index([action, createdAt])
}

model DataDeletionJob {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  actorUserId  String?
  targetUserId String?
  action       String
  resourceType String
  resourceId   String?
  storagePath  String?
  externalRef  String?
  status       String   @default("pending")
  attempts     Int      @default(0)
  lastError    String?

  @@index([status, createdAt])
  @@index([targetUserId, createdAt])
  @@index([resourceType, resourceId])
}

model ResearchJob {
  id         String    @id
  userId     String
  payload    Json
  status     String    @default("queued")
  error      String?
  result     Json?
  metrics    Json?
  attempts   Int       @default(0)
  workerId   String?
  leaseUntil DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  startedAt  DateTime?
  endedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, updatedAt])
  @@index([status, updatedAt])
  @@index([status, leaseUntil, updatedAt])
  @@index([workerId])
  @@index([endedAt])
}

model Municipality {
  id          String           @id @default(cuid())
  slug        String           @unique
  baseName    String
  type        MunicipalityType
  displayName String           @unique
  county      String?
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  helpRequests      HelpRequest[]
  helpOffers        HelpOffer[]
  kovAdmin          MunicipalityKovAdmin?
  serviceMapEntries ServiceMapEntry[]

  @@index([baseName])
  @@index([type])
  @@index([isActive])
}

model MunicipalityKovAdmin {
  id                      String             @id @default(cuid())
  municipalityId          String             @unique
  officialWebsite         String?
  riigiTeatajaUrl         String?
  status                  KovAdminStatus     @default(NOT_STARTED)
  checkedAt               DateTime?
  notes                   String?            @db.Text
  readyForIngest          Boolean            @default(false)
  ingestStatus            KovIngestStatus    @default(NOT_INGESTED)
  lastIngestedAt          DateTime?
  lastIngestError         String?            @db.Text
  ragDocId                String?
  rtCheckedAt             DateTime?
  rtNotes                 String?            @db.Text
  rtStatus                KovRtStatus        @default(NOT_STARTED)
  rtIngestStatus          KovIngestStatus    @default(NOT_INGESTED)
  rtLastIngestedAt        DateTime?
  rtLastIngestError       String?            @db.Text
  rtRagDocId              String?
  reviewCadence           String             @default("ANNUAL_JAN_PLUS_JULY_CHECK")
  autoCheckStatus         KovAutoCheckStatus @default(IDLE)
  lastFullReviewAt        DateTime?
  nextFullReviewAt        DateTime?
  lastLightCheckAt        DateTime?
  nextLightCheckAt        DateTime?
  lastChangeDetectedAt    DateTime?
  lightCheckSnapshot      Json?
  lastLightCheckSummary   Json?
  rtAutoCheckStatus       KovAutoCheckStatus @default(IDLE)
  rtLastLightCheckAt      DateTime?
  rtNextLightCheckAt      DateTime?
  rtLastChangeDetectedAt  DateTime?
  rtLightCheckSnapshot    Json?
  rtLastLightCheckSummary Json?
