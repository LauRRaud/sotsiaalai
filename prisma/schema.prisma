generator client {
  provider = "prisma-client"
  // Paneme kliendi eraldi kausta, et import oleks selge
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  // Prisma 7: URL, directUrl, shadowDatabaseUrl enam siia ei käi
}
enum Role {
  ADMIN
  SOCIAL_WORKER
  CLIENT
}

enum SubscriptionStatus {
  NONE
  ACTIVE
  CANCELED
  PAST_DUE
}

enum PaymentProvider {
  MAKSEKESKUS
  TEST
}

enum PaymentStatus {
  INITIATED
  PAID
  CANCELED
  FAILED
  REFUNDED
}

enum PaymentKind {
  SUBSCRIPTION_INITIAL
  SUBSCRIPTION_RENEWAL
  INVITE_SPONSORED
  OTHER
}

enum BillingMode {
  ONE_OFF
  RECURRING
}

enum BillingInterval {
  MONTHLY
}

enum BillingMethodStatus {
  PENDING
  ACTIVE
  REVOKED
  FAILED
  EXPIRED
}

enum RagSourceType {
  FILE
  URL
}

enum RagStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum Audience {
  SOCIAL_WORKER
  CLIENT
  BOTH
}

enum RunStatus {
  RUNNING
  COMPLETED
  ERROR
  DELETED
}

enum ConversationMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum RoomRole {
  OWNER
  MODERATOR
  MEMBER
}

enum RoomMessageSenderType {
  USER
  ASSISTANT
}

enum MunicipalityType {
  LINN
  VALD
}

enum KovAdminStatus {
  NOT_STARTED
  DRAFT
  READY_FOR_INGEST
  INGESTED
  NEEDS_REVIEW
}

enum KovAdminFileRole {
  SOURCES_JSON
  DATA_JSON
  META_JSON
  RAG_MD
  RT_JSON
  RT_MD
  RT_XML
}

enum KovFileValidationStatus {
  MISSING
  VALID
  INVALID
}

enum KovRtStatus {
  NOT_STARTED
  DRAFT
  NEEDS_REVIEW
  READY
}

enum KovIngestStatus {
  NOT_INGESTED
  READY
  INGESTING
  INGESTED
  ERROR
}

enum KovAutoCheckStatus {
  IDLE
  DUE
  CHECKING
  CHANGES_DETECTED
  NO_CHANGES
  ERROR
}

enum OrganizationAdminFileRole {
  SOURCES_JSON
  DATA_JSON
  META_JSON
  RAG_MD
  ATTACHMENT
}

enum OrganizationFileValidationStatus {
  MISSING
  VALID
  INVALID
}

enum HelpRecordStatus {
  DRAFT
  OPEN
  MATCHED
  CLOSED
  CANCELLED
  ARCHIVED
}

enum HelpType {
  VOLUNTARY
  PAID
  MIXED
}

enum TimeType {
  ONE_TIME
  RECURRING
  FLEXIBLE
}

enum ClassificationSource {
  AI
  USER
  MANUAL
}

enum HelpMatchStatus {
  PENDING
  CONTACTED
  ACCEPTED
  DECLINED
  CLOSED
}

enum InviteStatus {
  PENDING_PAYMENT
  SENT
  ACCEPTED
  EXPIRED
  REVOKED
}

enum RelationshipType {
  COLLEAGUE
  CLIENT
}

enum InvitePaymentMode {
  SELF_PAID
  SPONSORED_BY_HOST
}

enum BillingSource {
  SELF
  SPONSORED_BY_HOST
}

enum DocumentKind {
  TEMPLATE
  MATERIAL
  OTHER
}

enum TemplateFor {
  REPORT_DRAFT
  CASE_BRIEF
  MEETING_SUMMARY
  CHECKLIST
  LETTER_DRAFT
  OTHER
}

enum AgentArtifactType {
  MEETING_SUMMARY
  CASE_BRIEF
  REPORT_DRAFT
  CHECKLIST
  LETTER_DRAFT
  OTHER
}

enum AgentArtifactStatus {
  DRAFT
  FINAL
}

enum DocumentAuditAction {
  UPLOAD
  DOWNLOAD
  UPDATE
  DELETE
  ARTIFACT_CREATE
  ARTIFACT_UPDATE
  ARTIFACT_REFINE
  ARTIFACT_APPROVE
  ARTIFACT_DOWNLOAD
  ARTIFACT_DELETE
}

/**
 * ---------- Models ----------
 */

model User {
  id                      String    @id @default(cuid())
  email                   String?   @unique
  emailVerified           DateTime?
  emailVerificationSentAt DateTime?
  passwordHash            String?
  role                    Role      @default(CLIENT)
  isAdmin                 Boolean   @default(false)
  sessionVersion          Int       @default(0)

  // NextAuth
  accounts Account[]
  sessions Session[]

  // Äri
  profile        Profile?
  subscriptions  Subscription[]
  payments       Payment[]
  billingMethods BillingMethod[]
  sponsoredSubscriptions Subscription[] @relation("SubscriptionSponsorUser")
  ragDocuments   RagDocument[]
  documents      UserDocument[]
  agentArtifacts AgentArtifact[]
  documentAudits DocumentAudit[]
  frameworkAcceptances FrameworkAcceptance[]
  materialSubmissions MaterialSubmission[]

  // Chat / runs
  conversationRuns     ConversationRun[]
  conversationMessages ConversationMessage[]
  conversations        Conversation[]
  analyzeUsage         AnalyzeUsage[]
  emailOtpCodes        EmailOtpCode[]
  trustedDevices       TrustedDevice[]
  loginTempTokens      LoginTempToken[]
  roomsOwned           Room[]
  roomMemberships      RoomMember[]
  sentInvites          Invite[]            @relation("InviterUser")
  sponsoredInvites     Invite[]            @relation("InviteSponsorUser")
  sponsoredMembers     RoomMember[]        @relation("RoomMemberSponsorUser")
  acceptedInvites      Invite[]            @relation("InviteAcceptedBy")
  roomMessages         RoomMessage[]       @relation("RoomMessageAuthor")
  helpRequests         HelpRequest[]
  helpOffers           HelpOffer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Profile {
  id        String  @id @default(cuid())
  userId    String  @unique
  firstName String?
  lastName  String?
  phone     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String

  refresh_token String?
  access_token  String?
  expires_at    Int?
  token_type    String?
  scope         String?
  id_token      String?
  session_state String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Subscription {
  id          String             @id @default(cuid())
  userId      String
  status      SubscriptionStatus @default(NONE)
  plan        String             @default("kuutellimus")
  billingMode BillingMode        @default(ONE_OFF)
  billingInterval BillingInterval?
  billingMethodId String?
  billingSource BillingSource    @default(SELF)
  sponsorUserId String?
  inviteId      String?
  validUntil  DateTime?
  nextBilling DateTime?
  lastBilledAt DateTime?
  pastDueSince DateTime?
  billingRetryCount Int          @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  canceledAt  DateTime?

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  billingMethod BillingMethod? @relation(fields: [billingMethodId], references: [id], onDelete: SetNull)
  sponsorUser User?     @relation("SubscriptionSponsorUser", fields: [sponsorUserId], references: [id], onDelete: SetNull)
  invite      Invite?   @relation("InviteGrantedSubscription", fields: [inviteId], references: [id], onDelete: SetNull)
  payments    Payment[]

  @@index([userId])
  @@index([status])
  @@index([validUntil])
  @@index([billingMode])
  @@index([billingMethodId])
  @@index([billingSource])
  @@index([sponsorUserId])
  @@index([inviteId])
}

model Payment {
  id                String          @id @default(cuid())
  subscriptionId    String?
  inviteId          String?
  userId            String
  provider          PaymentProvider @default(MAKSEKESKUS)
  kind              PaymentKind     @default(OTHER)
  billingMethodId   String?
  providerPaymentId String
  amount            Decimal         @db.Decimal(10, 2)
  currency          String          @default("EUR")
  status            PaymentStatus
  paidAt            DateTime?
  failedAt          DateTime?
  refundedAt        DateTime?
  attemptNumber     Int             @default(1)
  raw               Json?
  createdAt         DateTime        @default(now())

  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  billingMethod BillingMethod? @relation(fields: [billingMethodId], references: [id], onDelete: SetNull)
  invite       Invite?       @relation(fields: [inviteId], references: [id], onDelete: SetNull)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerPaymentId])
  @@index([subscriptionId])
  @@index([billingMethodId])
  @@index([inviteId])
  @@index([userId])
  @@index([kind])
}

model BillingMethod {
  id                 String              @id @default(cuid())
  userId             String
  provider           PaymentProvider     @default(MAKSEKESKUS)
  status             BillingMethodStatus @default(PENDING)
  providerCustomerId String?
  providerToken      String?
  providerMandateId  String?
  label              String?
  expiresAt          DateTime?
  activatedAt        DateTime?
  revokedAt          DateTime?
  lastUsedAt         DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]
  payments      Payment[]

  @@index([userId])
  @@index([status])
  @@index([provider])
  @@index([providerCustomerId])
  @@index([providerMandateId])
}

model RagDocument {
  id      String  @id @default(cuid())
  adminId String?
  admin   User?   @relation(fields: [adminId], references: [id], onDelete: SetNull)

  title       String?
  description String?
  type        RagSourceType
  status      RagStatus     @default(PENDING)
  audience    Audience      @default(BOTH)

  // Päritolu
  sourceUrl String?
  fileName  String?
  mimeType  String?
  fileSize  Int?

  // RAG backendi dokument (stabiilne id) – hoia unikaalsena
  remoteId String? @unique

  // Veahaldus ja toor-meta
  error      String?
  metadata   Json?
  insertedAt DateTime?

  // --- Ajakirja/Artikli meta ---
  authors      String[] @default([]) // Postgres: text[]
  issueId      String?
  issueLabel   String?
  year         Int?
  articleId    String?
  section      String?
  pages        Int[]    @default([]) // Postgres: integer[]
  pageRange    String?
  journalTitle String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // --- Indeksid ---
  @@index([adminId])
  @@index([status])
  @@index([audience])
  @@index([type])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([insertedAt])
  @@index([journalTitle])
  @@index([issueLabel])
  @@index([year])
  @@index([articleId])
  // kiired otsingud/loetelud
  @@index([sourceUrl])
  @@index([fileName])
  @@index([mimeType])
  // kombineeritud sort/filtri muster admin-paneelile
  @@index([status, updatedAt, createdAt])
}

model ConversationRun {
  /// Frontendi saadetud convId (nt randomUUID). Hoia stabiilsena sama vestluse jooksul.
  id       String    @id
  userId   String
  role     Role
  text     String    @default("") @db.Text
  sources  Json?
  status   RunStatus @default(RUNNING)
  isCrisis Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
  @@index([status])
  @@index([userId, status, updatedAt])
  @@index([isCrisis, updatedAt])
}

model Conversation {
  id             String    @id @default(cuid())
  userId         String
  title          String?
  summary        String?   @db.Text
  metadata       Json?
  role           Role
  lastActivityAt DateTime  @default(now())
  expiresAt      DateTime?
  archivedAt     DateTime?
  isPinned       Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user     User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ConversationMessage[]

  @@index([userId, isPinned, lastActivityAt])
  @@index([userId, archivedAt])
  @@index([expiresAt])
}

model ConversationMessage {
  id             String                  @id @default(cuid())
  conversationId String
  authorId       String?
  role           ConversationMessageRole
  content        String                  @db.Text
  metadata       Json?
  createdAt      DateTime                @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  author       User?        @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([authorId])
}

/// Päevane analüüsi kasutus per kasutaja (püsiv kvoodi arvestus)
model AnalyzeUsage {
  id        String   @id @default(cuid())
  userId    String
  day       DateTime @db.Date
  count     Int      @default(0)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, day], name: "userId_day")
  @@index([userId])
}

model EmailOtpCode {
  id        String   @id @default(cuid())
  userId    String
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model TrustedDevice {
  id                    String   @id @default(cuid())
  userId                String
  deviceTokenHash       String   @unique
  userAgentFingerprint  String?
  ipRange               String?
  expiresAt             DateTime
  lastUsedAt            DateTime?
  createdAt             DateTime @default(now())

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  loginTokens LoginTempToken[]

  @@index([userId])
  @@index([expiresAt])
}

model LoginTempToken {
  id               String    @id @default(cuid())
  userId           String
  tokenHash        String    @unique
  requiresOtp      Boolean   @default(false)
  otpVerifiedAt    DateTime?
  expiresAt        DateTime
  usedAt           DateTime?
  userAgent        String?
  ipAddress        String?
  trustedDeviceId  String?
  createdAt        DateTime  @default(now())

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  trustedDevice TrustedDevice? @relation(fields: [trustedDeviceId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([expiresAt])
}

// Chat / RAG telemetry log
model ChatLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId String?
  role   String?
  event  String
  data   Json

  @@index([createdAt])
  @@index([event, createdAt])
  @@index([role, createdAt])
}

model Municipality {
  id          String           @id @default(cuid())
  slug        String           @unique
  baseName    String
  type        MunicipalityType
  displayName String           @unique
  county      String?
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  helpRequests HelpRequest[]
  helpOffers   HelpOffer[]
  kovAdmin     MunicipalityKovAdmin?
  @@index([baseName])
  @@index([type])
  @@index([isActive])
}

model MunicipalityKovAdmin {
  id               String         @id @default(cuid())
  municipalityId   String         @unique
  officialWebsite  String?
  riigiTeatajaUrl  String?
  status           KovAdminStatus @default(NOT_STARTED)
  checkedAt        DateTime?
  notes            String?        @db.Text
  readyForIngest   Boolean        @default(false)
  ingestStatus     KovIngestStatus   @default(NOT_INGESTED)
  lastIngestedAt   DateTime?
  lastIngestError  String?           @db.Text
  ragDocId         String?
  rtCheckedAt      DateTime?
  rtNotes          String?           @db.Text
  rtStatus         KovRtStatus       @default(NOT_STARTED)
  rtIngestStatus   KovIngestStatus @default(NOT_INGESTED)
  rtLastIngestedAt DateTime?
  rtLastIngestError String?          @db.Text
  rtRagDocId       String?
  reviewCadence    String            @default("ANNUAL_JAN_PLUS_JULY_CHECK")
  autoCheckStatus  KovAutoCheckStatus @default(IDLE)
  lastFullReviewAt DateTime?
  nextFullReviewAt DateTime?
  lastLightCheckAt DateTime?
  nextLightCheckAt DateTime?
  lastChangeDetectedAt DateTime?
  lightCheckSnapshot Json?
  lastLightCheckSummary Json?
  rtAutoCheckStatus KovAutoCheckStatus @default(IDLE)
  rtLastLightCheckAt DateTime?
  rtNextLightCheckAt DateTime?
  rtLastChangeDetectedAt DateTime?
  rtLightCheckSnapshot Json?
  rtLastLightCheckSummary Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  municipality Municipality               @relation(fields: [municipalityId], references: [id], onDelete: Cascade)
  files        MunicipalityKovAdminFile[]

  @@index([status])
  @@index([checkedAt])
  @@index([readyForIngest])
  @@index([ingestStatus])
  @@index([rtCheckedAt])
  @@index([rtStatus])
  @@index([rtIngestStatus])
  @@index([autoCheckStatus])
  @@index([nextFullReviewAt])
  @@index([nextLightCheckAt])
  @@index([rtAutoCheckStatus])
  @@index([rtNextLightCheckAt])
}

model MunicipalityKovAdminFile {
  id                String                  @id @default(cuid())
  kovAdminId        String
  role              KovAdminFileRole
  originalName      String
  mime              String
  size              Int
  sha256            String
  storagePath       String
  version           Int                     @default(1)
  validationStatus  KovFileValidationStatus @default(INVALID)
  validationMessage String?
  validatedAt       DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  kovAdmin MunicipalityKovAdmin @relation(fields: [kovAdminId], references: [id], onDelete: Cascade)

  @@unique([kovAdminId, role])
  @@index([role])
  @@index([storagePath])
  @@index([validationStatus])
}

model OrganizationAdmin {
  id              String   @id @default(cuid())
  slug            String   @unique
  displayName     String   @unique
  type            String
  focus           String?
  county          String?
  isActive        Boolean  @default(true)
  officialWebsite String?
  contactEmail    String?
  contactPhone    String?
  notes           String?  @db.Text
  crawlReadiness  String   @default("PLANNED")
  ingestStatus    String   @default("NOT_INGESTED")
  lastIngestedAt  DateTime?
  lastIngestError String?  @db.Text
  ragDocId        String?
  fileCount       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  files           OrganizationAdminFile[]

  @@index([type])
  @@index([county])
  @@index([isActive])
  @@index([crawlReadiness])
  @@index([ingestStatus])
}

model OrganizationAdminFile {
  id             String   @id @default(cuid())
  organizationId String
  role           OrganizationAdminFileRole @default(ATTACHMENT)
  originalName   String
  mime           String
  size           Int
  sha256         String
  storagePath    String
  validationStatus  OrganizationFileValidationStatus @default(INVALID)
  validationMessage String?
  validatedAt       DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization OrganizationAdmin @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([role])
  @@index([storagePath])
}

model HelpCategory {
  id            String               @id @default(cuid())
  code          String               @unique
  labelEt       String
  labelEn       String
  labelRu       String
  descriptionEt String?
  descriptionEn String?
  descriptionRu String?
  sortOrder     Int                  @default(0)
  isActive      Boolean              @default(true)
  parentId      String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  parent         HelpCategory?         @relation("HelpCategoryTree", fields: [parentId], references: [id])
  children       HelpCategory[]        @relation("HelpCategoryTree")
  requestPrimary HelpRequest[]         @relation("HelpRequestPrimaryCategory")
  offerPrimary   HelpOffer[]           @relation("HelpOfferPrimaryCategory")
  requestLinks   HelpRequestCategory[]
  offerLinks     HelpOfferCategory[]

  @@index([isActive])
  @@index([sortOrder])
  @@index([parentId])
}

model TargetGroup {
  id           String                   @id @default(cuid())
  code         String                   @unique
  labelEt      String
  labelEn      String
  labelRu      String
  isActive     Boolean                  @default(true)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  requestLinks HelpRequestTargetGroup[]
  offerLinks   HelpOfferTargetGroup[]
}

model HelpRequest {
  id                       String                 @id @default(cuid())
  userId                   String
  municipalityId           String?
  primaryCategoryId        String
  title                    String?
  description              String                 @db.Text
  structuredSummary        String?
  roleLabel                String?
  rawPlace                 String?
  helpType                 HelpType?
  timeType                 TimeType?
  status                   HelpRecordStatus       @default(OPEN)
  classificationSource     ClassificationSource   @default(AI)
  classificationConfidence Float?
  userConfirmedAt          DateTime?
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt

  user             User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  municipality     Municipality?            @relation(fields: [municipalityId], references: [id], onDelete: SetNull)
  primaryCategory  HelpCategory             @relation("HelpRequestPrimaryCategory", fields: [primaryCategoryId], references: [id])
  categoryLinks    HelpRequestCategory[]
  targetGroupLinks HelpRequestTargetGroup[]
  matches          HelpMatch[]

  @@index([userId])
  @@index([municipalityId])
  @@index([primaryCategoryId])
  @@index([status])
  @@index([createdAt])
}

model HelpOffer {
  id                       String                 @id @default(cuid())
  userId                   String
  municipalityId           String?
  primaryCategoryId        String
  title                    String?
  description              String                 @db.Text
  structuredSummary        String?
  roleLabel                String?
  rawPlace                 String?
  helpType                 HelpType?
  timeType                 TimeType?
  status                   HelpRecordStatus       @default(OPEN)
  classificationSource     ClassificationSource   @default(AI)
  classificationConfidence Float?
  userConfirmedAt          DateTime?
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt

  user             User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  municipality     Municipality?          @relation(fields: [municipalityId], references: [id], onDelete: SetNull)
  primaryCategory  HelpCategory           @relation("HelpOfferPrimaryCategory", fields: [primaryCategoryId], references: [id])
  categoryLinks    HelpOfferCategory[]
  targetGroupLinks HelpOfferTargetGroup[]
  matches          HelpMatch[]

  @@index([userId])
  @@index([municipalityId])
  @@index([primaryCategoryId])
  @@index([status])
  @@index([createdAt])
}

model HelpRequestCategory {
  requestId  String
  categoryId String

  request  HelpRequest  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  category HelpCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([requestId, categoryId])
  @@index([categoryId])
}

model HelpOfferCategory {
  offerId    String
  categoryId String

  offer    HelpOffer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  category HelpCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([offerId, categoryId])
  @@index([categoryId])
}

model HelpRequestTargetGroup {
  requestId     String
  targetGroupId String

  request     HelpRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  targetGroup TargetGroup @relation(fields: [targetGroupId], references: [id], onDelete: Cascade)

  @@id([requestId, targetGroupId])
  @@index([targetGroupId])
}

model HelpOfferTargetGroup {
  offerId       String
  targetGroupId String

  offer       HelpOffer   @relation(fields: [offerId], references: [id], onDelete: Cascade)
  targetGroup TargetGroup @relation(fields: [targetGroupId], references: [id], onDelete: Cascade)

  @@id([offerId, targetGroupId])
  @@index([targetGroupId])
}

model HelpMatch {
  id            String          @id @default(cuid())
  requestId     String
  offerId       String
  requesterId   String
  offererId     String
  roomId        String?         @unique
  status        HelpMatchStatus @default(PENDING)
  scoreSnapshot Float?
  reasonsJson   Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  request HelpRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  offer   HelpOffer   @relation(fields: [offerId], references: [id], onDelete: Cascade)
  room    Room?       @relation(fields: [roomId], references: [id], onDelete: SetNull)

  @@unique([requestId, offerId])
  @@index([requesterId])
  @@index([offererId])
  @@index([roomId])
  @@index([status])
}

model Room {
  id          String    @id @default(cuid())
  ownerId     String
  title       String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner   User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members RoomMember[]
  invites Invite[]
  messages RoomMessage[]
  helpMatch HelpMatch?

  @@index([ownerId])
}

model RoomMember {
  id              String         @id @default(cuid())
  roomId          String
  userId          String
  role            RoomRole       @default(MEMBER)
  displayName     String?
  billingSource   BillingSource  @default(SELF)
  sponsorUserId   String?
  sponsorOrgId    String?
  joinedAt        DateTime       @default(now())
  leftAt          DateTime?
  lastReadAt      DateTime?

  room         Room    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  sponsorUser  User?   @relation("RoomMemberSponsorUser", fields: [sponsorUserId], references: [id], onDelete: SetNull)

  @@unique([roomId, userId])
  @@index([userId])
}

model Invite {
  id                String             @id @default(cuid())
  roomId            String
  inviterId         String
  inviteeEmail      String
  tokenHash         String             @unique
  status            InviteStatus       @default(SENT)
  relationshipType  RelationshipType   @default(COLLEAGUE)
  paymentMode       InvitePaymentMode  @default(SELF_PAID)
  sponsoredByUserId String?
  sponsoredByOrgId  String?
  sponsoredRole     Role?
  sponsoredPlan     String?
  sponsoredPaidAt   DateTime?
  expiresAt         DateTime
  maxUses           Int                @default(1)
  useCount          Int                @default(0)
  createdAt         DateTime           @default(now())
  acceptedBillingSource BillingSource?
  acceptedByUserId      String?

  room                   Room           @relation(fields: [roomId], references: [id], onDelete: Cascade)
  inviter                User           @relation("InviterUser", fields: [inviterId], references: [id], onDelete: Cascade)
  sponsoredByUser        User?          @relation("InviteSponsorUser", fields: [sponsoredByUserId], references: [id], onDelete: SetNull)
  acceptedByUser         User?          @relation("InviteAcceptedBy", fields: [acceptedByUserId], references: [id], onDelete: SetNull)
  payments               Payment[]
  grantedSubscriptions   Subscription[] @relation("InviteGrantedSubscription")

  @@index([roomId, status])
  @@index([tokenHash])
  @@index([expiresAt])
  @@index([sponsoredRole])
}

model RoomMessage {
  id         String   @id @default(cuid())
  roomId     String
  authorId   String
  senderType RoomMessageSenderType @default(USER)
  content    String   @db.Text
  createdAt  DateTime @default(now())
  deletedAt  DateTime?

  room   Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  author User @relation("RoomMessageAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([roomId, createdAt])
  @@index([roomId, id])
}

model UserDocument {
  id           String       @id @default(cuid())
  ownerId      String
  title        String
  originalName String
  kind         DocumentKind @default(MATERIAL)
  templateFor  TemplateFor?
  agentAllowed Boolean      @default(false)
  mime         String
  size         Int
  sha256       String
  storagePath  String
  frameworkAcceptanceId String? @unique
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  owner               User                          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  frameworkAcceptance FrameworkAcceptance?          @relation(fields: [frameworkAcceptanceId], references: [id], onDelete: SetNull)
  templateArtifacts   AgentArtifact[]               @relation("AgentArtifactTemplate")
  sourceArtifactLinks AgentArtifactSourceDocument[]
  audits              DocumentAudit[]

  @@index([ownerId, updatedAt])
  @@index([ownerId, kind, updatedAt])
  @@index([ownerId, agentAllowed, updatedAt])
  @@index([sha256])
}

model FrameworkAcceptance {
  id                        String   @id @default(cuid())
  userId                    String
  frameworkKey              String
  frameworkVersion          String
  acceptanceType            String
  acceptanceSource          String
  roleAtAcceptance          Role
  locale                    String?
  ipAddress                 String?
  userAgent                 String?
  acceptedAt                DateTime @default(now())
  reviewDocumentOpenedAt    DateTime?
  signedDocumentDownloadedAt DateTime?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  document UserDocument?

  @@index([userId, acceptedAt])
  @@index([frameworkKey, frameworkVersion, acceptedAt])
  @@index([acceptanceType, acceptedAt])
}

model AgentArtifact {
  id         String              @id @default(cuid())
  ownerId    String
  type       AgentArtifactType
  title      String?
  status     AgentArtifactStatus @default(DRAFT)
  content    String              @db.Text
  approvedAt DateTime?
  templateId String?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  owner             User                          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  template          UserDocument?                @relation("AgentArtifactTemplate", fields: [templateId], references: [id], onDelete: SetNull)
  sourceDocuments   AgentArtifactSourceDocument[]
  audits            DocumentAudit[]

  @@index([ownerId, updatedAt])
  @@index([ownerId, type, updatedAt])
  @@index([ownerId, status, updatedAt])
  @@index([templateId])
}

model AgentArtifactSourceDocument {
  artifactId  String
  documentId  String
  createdAt   DateTime      @default(now())

  artifact AgentArtifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  document UserDocument  @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@id([artifactId, documentId])
  @@index([documentId])
}

model DocumentAudit {
  id         String              @id @default(cuid())
  ownerId    String
  documentId String?
  artifactId String?
  action     DocumentAuditAction
  meta       Json?
  createdAt  DateTime            @default(now())

  owner    User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  document UserDocument? @relation(fields: [documentId], references: [id], onDelete: SetNull)
  artifact AgentArtifact? @relation(fields: [artifactId], references: [id], onDelete: SetNull)

  @@index([ownerId, createdAt])
  @@index([documentId, createdAt])
  @@index([artifactId, createdAt])
  @@index([action, createdAt])
}

model MaterialSubmission {
  id                String    @id @default(cuid())
  submittedByUserId String?
  comment           String    @db.Text
  originalName      String
  mime              String
  size              Int
  sha256            String
  storagePath       String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  submittedByUser User? @relation(fields: [submittedByUserId], references: [id], onDelete: SetNull)

  @@index([submittedByUserId, createdAt])
  @@index([createdAt])
  @@index([sha256])
}
